{
  "name": "persona-blog",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "npx tsx scripts/check-token-compliance.ts --guard && npx tsx scripts/check-motion-sanctuary.ts && npx tsx scripts/check-ds-kbd.ts && npx tsx scripts/check-no-chip-lit-in-arrival.ts && npx tsx scripts/check-citation-delegation.ts && npx tsx --test src/lib/client/keep-hotkey.test.ts && npx tsx --test src/lib/client/keep-legend.test.ts && npx tsx --test src/lib/client/ds-kbd-lit.test.ts && npx tsx --test src/lib/client/arrival.test.ts && npx tsx --test src/lib/citation-golden.test.ts && npx tsx --test scripts/check-citation-delegation.test.ts",
    "build": "astro build",
    "preview": "astro preview",
    "whisper": "node cli/whisper.mjs",
    "lint:tokens": "npx tsx scripts/check-token-compliance.ts",
    "lint:motion": "npx tsx scripts/check-motion-sanctuary.ts",
    "check:ds-kbd": "npx tsx scripts/check-ds-kbd.ts",
    "check:no-chip-lit-in-arrival": "npx tsx scripts/check-no-chip-lit-in-arrival.ts",
    "generate:stage-tokens": "npx tsx scripts/generate-stage-tokens.ts",
    "test:ceremony": "node --test --import=tsx/esm src/lib/seal-ceremony.test.ts",
    "test:dates": "npx tsx scripts/test-dates.ts",
    "test:stage-tokens": "npx tsx --test scripts/generate-stage-tokens.test.ts",
    "test:stage-underline": "npx tsx --test src/lib/stage-underline.test.ts",
    "test:cite-legend": "npx tsx --test src/lib/client/cell-cite-legend.test.ts",
    "test:nav-legend": "npx tsx --test src/lib/client/nav-legend.test.ts",
    "test:cell-confirm": "npx tsx --test src/lib/client/cell-confirm.test.ts",
    "test:keep-hotkey": "npx tsx --test src/lib/client/keep-hotkey.test.ts",
    "test:keep-legend": "npx tsx --test src/lib/client/keep-legend.test.ts",
    "test:chip-lit": "npx tsx --test src/lib/client/ds-kbd-lit.test.ts",
    "test:arrival": "npx tsx --test src/lib/client/arrival.test.ts",
    "check:citation-delegation": "npx tsx scripts/check-citation-delegation.ts",
    "test:citation-golden": "npx tsx --test src/lib/citation-golden.test.ts",
    "test:citation-delegation": "npx tsx --test scripts/check-citation-delegation.test.ts"
  },
  "dependencies": {
    "@astrojs/node": "^8.3.4",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^4.16.0",
    "better-sqlite3": "^12.8.0",
    "pkijs": "^3.4.0",
    "satori": "^0.26.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.6.0"
  }
}
