---
// src/components/DecayCard.astro
// The core feature card — blog posts visually age over time.
// Opacity fades, blur increases, saturation drops. Hover revives.
// Uses CSS class .decay-card from decay.css for hover revival.
//
// coverImage: rendered above the title with CSS decay filters.
// Fallback gradient renders when no image is provided.
// DONE: prev/next linking lives in PostNav.astro (blog detail pages)

import PostBadge from './PostBadge.astro';
import RevivalBadge from './RevivalBadge.astro';
import RisenBadge from './RisenBadge.astro';
import KeepButton from './KeepButton.astro';
import BloomParticles from './BloomParticles.astro';
import DecayClock from './DecayClock.astro';
import TensionBadge from './TensionBadge.astro';
import { formatPubDate } from '../lib/dates';
import type { PostDisplayData } from '../lib/postMeta';
import { clockUrgency } from '../lib/death-clock';
import { convictionMultiplier } from '../lib/decay-engine';

// BattingAverageChip removed from card per Tanya §4.2:
//   "Do not show batting average on the card — too much cognitive load per card."
//   Author reputation visible on /author/[slug] and /leaderboard.

interface Props {
  post: PostDisplayData;
}

const { post } = Astro.props;
const href = `/blog/${post.slug}`;
const formattedDate = formatPubDate(post.pubDate);
// endangeredDaysLeft covers all posts (0 = entombed, >0 = days remaining)
const daysRemaining = post.endangeredDaysLeft;
const urgency = clockUrgency(daysRemaining);
// conviction is null when no beliefs declared — maps to transparent tint
const conviction = post.conviction ?? null;
// verdictModifier for per-clock decay delta accuracy (still-true=0.7, wrong=1.4, etc.)
const verdictModifier = convictionMultiplier(conviction);

// Atmosphere stage from decay factor — drives card-scoped color cascade.
// Tanya §2: endangered cards get data-atmosphere scoped to their cell, not page-wide.
function cardAtmosphere(factor: number): string {
  if (factor < 0.25) return 'fresh';
  if (factor < 0.50) return 'fading';
  if (factor < 0.75) return 'endangered';
  if (factor < 0.95) return 'ghost';
  return 'entombed';
}
const atmosphere = cardAtmosphere(post.decay);

// Stage identity attribute — drives [data-decay-stage] CSS selectors in decay-stage-identity.css.
// Thresholds mirror stage-identity.ts stageFor() and heartbeat-orchestrator FOSSIL_THRESHOLD.
// JS (applyStageTokens) updates this dynamically; SSR sets the initial correct value.
function stageAttr(factor: number): string {
  if (factor >= 0.97) return 'fossil';
  if (factor >= 0.75) return 'ghost';
  if (factor >= 0.50) return 'endangered';
  if (factor >= 0.25) return 'fading';
  return 'fresh';
}
const decayStage = stageAttr(post.decay);
---

<article
  class="decay-card post-card choreo-pending"
  style={post.decayStyle}
  data-atmosphere={atmosphere}
  data-decay-stage={decayStage}
  data-slug={post.slug}
  data-pub-date={post.pubDateISO}
  data-decay-factor={post.decay.toFixed(4)}
  data-revival-count={post.revivalCount}
  data-reading-seconds={post.readingSeconds > 0 ? post.readingSeconds : undefined}
  data-revival-warm={post.revivalWarm ? 'true' : undefined}
  data-days-remaining={daysRemaining}
  data-clock-urgency={urgency}
  data-conviction={conviction ?? undefined}
  data-fvh-quiet
  tabindex="0"
  aria-label={`${post.title} — hold Space or Enter to revive`}
>
  <BloomParticles />
  {post.coverImage
    ? <div class="cover-wrap"><img src={post.coverImage} alt="" class="cover-img" aria-hidden="true" loading="lazy" decoding="async" /></div>
    : <div class="cover-gradient" aria-hidden="true" />
  }
  <a href={href} class="post-link">
    <time datetime={post.pubDateISO} class="post-date">{formattedDate}</time>
    <h2 class="post-title">{post.title}</h2>
  </a>
  <PostBadge readingTime={post.readingTime} badge={post.badge} />
  {post.description && <p class="post-excerpt">{post.description}</p>}
  <div class="card-footer">
    <DecayClock variant="ring" daysRemaining={daysRemaining} urgency={urgency} compact={true} conviction={conviction} decayFactor={post.decay} verdictModifier={verdictModifier} />
    {/* Single badge slot — priority: risen > tension > revival > empty.
        Mutually exclusive: only ONE badge renders (Mike Koch arch §2).
        TensionBadge embedded=true suppresses the tension-memory sub-label. */}
    <div class="card-footer-meta">
      {post.recentlyRisen
        ? <RisenBadge visible={true} />
        : (post.tensionResult && post.tensionResult.label !== 'indifferent')
          ? <TensionBadge tensionResult={post.tensionResult} revivalCount={post.revivalCount} slug={post.slug} embedded={true} />
          : post.revivalCount > 0
            ? <RevivalBadge count={post.revivalCount} />
            : null
      }
    </div>
    <KeepButton slug={post.slug} count={post.revivalCount} urgency={urgency} conviction={conviction} />
  </div>
</article>

<style>
  .post-card {
    position: relative;
    overflow: hidden;
    padding: 0;                         /* cover image bleeds edge-to-edge */
    border-radius: var(--radius-card, var(--radius, 12px));
    background: var(--surface-raised);
    border: 1px solid color-mix(in oklch, var(--atm-bloom-color, var(--keep-accent)) 6%, transparent);
    max-width: 40rem;
    margin: 0 auto var(--space-5);
    display: flex;
    flex-direction: column;
  }

  /* ── Cover image: physics layer — decay filters applied from CSS vars ── */
  .cover-wrap {
    position: relative;  /* needed: stage-crossing ::after is positioned within */
    width: 100%;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    /* Concentric with card top corners — must match --radius-card exactly.
       Tanya §1 §13: "A 20px cover inside a 12px card creates a visible gap." */
    border-radius: var(--radius-card, 12px) var(--radius-card, 12px) 0 0;
  }

  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Decay filter cascade: saturation collapses, sepia accumulates, opacity fades, blur ghosts.
       Tanya §5: sepia sits between saturation and opacity (correct position).
       At fossil stage --decay-sepia reaches 0.15 — subtle, not aggressive. */
    filter:
      saturate(calc(1 - var(--decay-factor, 0) * 0.8))
      sepia(calc(var(--decay-factor, 0) * var(--decay-sepia, 0)))
      opacity(calc(1 - var(--decay-factor, 0) * 0.55))
      /* Tanya §5: cap blur at 1.2px — 2px looks broken, not aged */
      blur(calc(var(--decay-factor, 0) * 1.2px));
    transition: filter 600ms ease;
    will-change: filter;
  }

  /* Fallback gradient — same slot, same height, atmosphere-tinted */
  .cover-gradient {
    width: 100%;
    aspect-ratio: 16 / 7;
    /* max(2%, …) preserves ghost of warmth even at fossil (Tanya §7.1).
       Without it: (0.12 - 0.9×0.08)×100% = 4.8% → near-transparent black. */
    background: linear-gradient(
      135deg,
      color-mix(in oklch,
        var(--atm-bloom-color, var(--keep-accent))
        max(2%, calc((0.12 - var(--decay-factor, 0) * 0.08) * 100%)),
        transparent),
      oklch(0% 0 0 / 0.15)
    );
    /* Concentric with card top corners — same token as .cover-wrap */
    border-radius: var(--radius-card, 12px) var(--radius-card, 12px) 0 0;
  }

  /* Body: inner padding lives here now (removed from .post-card) */
  .post-link,
  .post-excerpt,
  .card-footer {
    padding-left: var(--space-7);
    padding-right: var(--space-7);
  }

  .post-link { padding-top: var(--space-5); }

  .post-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-date {
    display: block;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: var(--space-1);
  }

  .post-title {
    margin: 0 0 var(--space-2);
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    color: var(--mood-accent, currentColor);
  }

  .post-link:hover .post-title {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1.5px;
  }

  .post-excerpt {
    margin:      var(--space-1) 0 0;
    font-size:   var(--text-sm);
    line-height: var(--leading-normal);
    opacity:     0.7;
  }

  /* Footer: exactly 3 slots — clock · badge · keep (Tanya §2, Mike §arch) */
  .card-footer {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    height: 52px;
    margin-top: auto;          /* push to bottom of flex column card */
    padding-top: 0;
    padding-bottom: 0;
    border-top: 1px solid var(--border-subtle);
    background: var(--surface-footer);  /* token replaces inline rgba (Tanya §11) */
    backdrop-filter: blur(8px);
    /* Concentric corners: footer bottom matches card bottom (Tanya §1.3) */
    border-radius:
      0 0
      var(--card-computed-radius, var(--radius-card, 12px))
      var(--card-computed-radius, var(--radius-card, 12px));
  }

  /* Center badge slot — natural width, no flex-grow */
  .card-footer-meta {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  /* KeepButton pushed to far right */
  .card-footer :global(.pact-wrapper) {
    margin-left: auto;
  }
</style>

<script>
  // Stage-crossing flash — wire decay:stage-change → card visual flinch.
  // Event bubbles from DecayClock → DecayCard <article> via bubbles:true.
  // Astro deduplicates this module script across all DecayCard instances.
  // Tanya §3.5 (class state machine) · Mike §1 (event path is free).

  const PREFIX = 'decay-card--crossing-';

  /** Matches --flash-duration-* tokens in tokens.css */
  const FLASH_MS: Record<string, number> = {
    fading:     480,
    endangered: 600,
    ghost:      400,
    fossil:     300,
  };

  /**
   * Adobe circuit-breaker: stops infinite border-pulse after 15s on tab restore.
   * Only fires if card is still in endangered stage after 15s (stuck animation edge case).
   * Tanya §12 Rule 4 + Adobe "How Can Web Animations Fail Safely?"
   */
  function armCircuitBreaker(card: HTMLElement): void {
    setTimeout(() => {
      if (!document.contains(card)) return;
      if (card.dataset.decayStage !== 'endangered') return;
      card.style.setProperty('animation', 'none');
    }, 15_000);
  }

  function handleStageChange(e: Event): void {
    const card   = e.currentTarget as HTMLElement;
    const detail = (e as CustomEvent<{ stage: string }>).detail;
    if (!detail?.stage) return;
    if (card.className.includes(PREFIX)) return;  // re-entry: already crossing
    // Sync data-decay-stage on card — activates [data-decay-stage] CSS identity selectors.
    // JS applyStageTokens() also sets this for the blog-detail orchestrator path.
    card.dataset.decayStage = detail.stage;
    if (detail.stage === 'endangered') armCircuitBreaker(card);
    card.classList.add(PREFIX + detail.stage);
    setTimeout(() => card.classList.remove(PREFIX + detail.stage), FLASH_MS[detail.stage] ?? 600);
  }

  function attachListeners(): void {
    document.querySelectorAll<HTMLElement>('.decay-card').forEach(card =>
      card.addEventListener('decay:stage-change', handleStageChange)
    );
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', attachListeners, { once: true });
  } else {
    attachListeners();
  }
</script>
