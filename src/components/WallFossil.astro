---
// src/components/WallFossil.astro
// A fully fossilised wall entry — compressed, muted, embedded flat.
// Fossils are not "very decayed entries" — they are a different thing.
// Minimal chrome, tight spacing, inscription-in-stone aesthetic.
//
// TODO: geology texture tint per mood (v2)

import type { ComputedWallEntry } from '../lib/wall';
import { resolveMood } from '../lib/mood';

interface Props {
  computed: ComputedWallEntry;
}

const { computed } = Astro.props;
const mood = resolveMood(computed.entry.mood);
const fossilStyle = `--entry-accent-rgb: ${mood.accent_rgb};`;
---

<article class="wall-fossil" style={fossilStyle}>
  <p class="fossil-text">{computed.entry.text}</p>
  <span class="fossil-mood">{mood.label}</span>
</article>

<style>
  .wall-fossil {
    padding: 0.5rem 0.75rem;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.025);
    border-left: 2px solid rgba(var(--entry-accent-rgb, 0,0,0), 0.12);
  }

  .fossil-text {
    margin: 0;
    font-size: 0.75rem;
    line-height: 1.3;
    opacity: 0.38;
  }

  .fossil-mood {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.22;
  }
</style>
