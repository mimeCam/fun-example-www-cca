---
/**
 * ConvictionRecord.astro — 3-Zone Layout (P1-A Sprint)
 *
 * Zone A — Author Signal:  WHO staked this? Trust bar, stage pill, decay clock.
 * Zone B — Decay Pressure: WHAT IS AT STAKE? Ghost echoes, dispute tally.
 * Zone C — Verdict Moment: THE DECISION. Hero KeepButton, challenge, audit trail.
 *
 * CSS Grid, named areas. No new tokens. No API changes. No JS hydration.
 * RevivalOrchestrator wiring inherited automatically by .keep-btn in Zone C.
 *
 * Mike §ConvictionRecord 3-zone · Tanya §2 Zone A/B/C spec
 */
import type { DisputeState }  from '../lib/verdict-dispute';
import type { DecayStage }    from '../lib/decay-engine';
import type { ClockUrgency }  from '../lib/decay-engine';
import KeepButton             from './KeepButton.astro';
import GhostEchoes            from './GhostEchoes.astro';
import DisputeTally           from './DisputeTally.astro';
import DisputeChallenge       from './DisputeChallenge.astro';
import ConvictionAuditTrail   from './ConvictionAuditTrail.astro';
import BattingAverageChip     from './BattingAverageChip.astro';
import DecayClock             from './DecayClock.astro';

interface Props {
  slug:            string;
  revivalCount:    number;
  urgency:         string;
  conviction:      string | null;
  decayFactor:     number;
  lifespan:        number;
  verdictSealed:   boolean;
  disputeState:    DisputeState;
  decayStage:      DecayStage;
  // Zone A — author trust bar
  authorSlug:      string;
  totalPublished?: number;
  daysRemaining?:  number;
}

const {
  slug, revivalCount, urgency, conviction,
  decayFactor, lifespan, verdictSealed, disputeState, decayStage,
  authorSlug, totalPublished, daysRemaining = 0,
} = Astro.props;

// Tanya Zone A: clock visible only at endangered/ghost — no crying wolf at fresh.
const showClock = decayStage === 'endangered' || decayStage === 'ghost';
---

<section
  class="conviction-record surface-card"
  data-decay-stage={decayStage}
  aria-label="Conviction record"
  id="conviction-audit"
>
  <!-- ── Zone A: Author Signal — WHO staked this? ─────────────────── -->
  <div class="cr-zone-a">
    <a href={`/author/${authorSlug}`} class="cr-author type-caption">
      {authorSlug}
    </a>

    <BattingAverageChip
      authorSlug={authorSlug}
      size="inline"
      totalPublished={totalPublished}
    />

    <span class="cr-stage-pill" data-stage={decayStage} aria-label={`Post stage: ${decayStage}`}>
      {decayStage}
    </span>

    {showClock && (
      <DecayClock
        variant="ring"
        compact
        daysRemaining={daysRemaining}
        urgency={urgency as ClockUrgency}
        decayFactor={decayFactor}
      />
    )}

    <a
      href={`/audit/${slug}`}
      class="cr-audit-link type-caption"
      aria-label="View conviction receipt"
    >
      view receipt ↗
    </a>
  </div>

  <!-- ── Zone B: Decay Pressure — WHAT IS AT STAKE? ───────────────── -->
  <div class="cr-zone-b">
    <GhostEchoes slug={slug} />
    <DisputeTally slug={slug} disputeState={disputeState} />
  </div>

  <!-- ── Zone C: Verdict Moment — THE DECISION ────────────────────── -->
  <div class="cr-zone-c">
    <KeepButton
      slug={slug}
      count={revivalCount}
      urgency={urgency}
      conviction={conviction}
      decayFactor={decayFactor}
      lifespan={lifespan}
    />

    <DisputeChallenge
      slug={slug}
      verdictSealed={verdictSealed}
      disputeState={disputeState}
    />

    <ConvictionAuditTrail slug={slug} />
  </div>
</section>

<style>
  /**
   * Zone C hero overrides: full-width 52px KeepButton, verdict radius.
   * Tanya Zone C: "52px tall, full-column-width KeepButton with --radius-md".
   * :global needed — KeepButton scoped styles use hash selectors.
   */
  .cr-zone-c :global(.pact-wrapper) {
    width: 100%;
    align-items: stretch;
  }

  .cr-zone-c :global(.keep-btn) {
    width: 100%;
    height: 52px;
    min-width: unset;
    border-radius: var(--radius-md);
    justify-content: center;
    font-size: var(--text-sm);
  }
</style>
