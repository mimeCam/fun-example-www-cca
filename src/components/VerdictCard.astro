---
// src/components/VerdictCard.astro
// Jury card for the Verdict Wall — specimen-cabinet presentation.
// One post on trial: conviction label, stance bar, death clock, CTA.
// SSR-only. No hydration island — all state encoded server-side.
//
// Layout (Tanya §VerdictCard spec):
//   Row 1: DeathClock ring (compact) + title + state badge
//   Row 2: conviction verdict (amber ◈ glyph, large) + label
//   Row 3: stance bar — agree(emerald) | torn(amber) | disagree(red)
//   Row 4: CTA [Take Stance →] + [audited ✓] link
//
// Credits: Tanya Donska (UX spec — VerdictCard layout, colors, hover)

import type { VerdictPost } from '../lib/verdict-wall';
import DecayClock from './DecayClock.astro';

interface Props {
  post: VerdictPost;
}

const { post } = Astro.props;

// ── State badge ───────────────────────────────────────────────────────────────

const STATE_LABELS: Record<string, string> = {
  living:     'LIVING',
  endangered: 'ENDANGERED',
  revived:    'REVIVED',
  fossil:     'FOSSIL',
};

// State colors reference CSS custom properties via the data-state attribute.
// Inline fallback: var() is not valid in JS string context — we use the CSS class approach.
// verdictCard CSS classes (.verdict-card--living etc.) set --state-color via :where() rules.
const STATE_TOKEN_FALLBACK: Record<string, string> = {
  living:     'var(--gold)',
  endangered: 'var(--urgency-critical-color)',
  revived:    'var(--verdict-true)',
  fossil:     'var(--verdict-pending)',
};

const stateColor = STATE_TOKEN_FALLBACK[post.verdictState] ?? 'var(--verdict-pending)';
const stateLabel = STATE_LABELS[post.verdictState] ?? 'UNKNOWN';

// ── Conviction label ──────────────────────────────────────────────────────────

const CONVICTION_LABELS: Record<string, string> = {
  'still-true': 'Still True',
  'evolved':    'Evolved',
  'unaudited':  'Unaudited',
  'wrong':      'Wrong',
  'abandoned':  'Abandoned',
};

const CONVICTION_COLORS: Record<string, string> = {
  'still-true': 'var(--verdict-true)',
  'evolved':    'var(--gold)',
  'unaudited':  'var(--text-tertiary)',
  'wrong':      'var(--verdict-wrong)',
  'abandoned':  'var(--verdict-pending)',
};

const convictionKey   = post.conviction ?? 'unaudited';
const convictionLabel = CONVICTION_LABELS[convictionKey] ?? 'Unaudited';
const convictionColor = CONVICTION_COLORS[convictionKey] ?? 'var(--text-tertiary)';

// ── Stance bar ────────────────────────────────────────────────────────────────

const hasStances = post.stanceTotal > 0;

// ── Inline border-left accent via CSS var ────────────────────────────────────
const cardStyle = `--state-color: ${stateColor};`;
---

<article
  class:list={['card-base', 'card-verdict', 'verdict-card', `verdict-card--${post.verdictState}`]}
  style={cardStyle}
  data-slug={post.slug}
  aria-label={`${post.title} — ${stateLabel}`}
>

  <!-- Row 1: clock + title + badge -->
  <div class="vc-header">
    <DecayClock
      variant="ring"
      daysRemaining={post.daysRemaining}
      urgency={post.clockUrgency}
      compact={true}
      conviction={post.conviction}
    />
    <div class="vc-title-group">
      <h2 class="vc-title">
        <a href={`/blog/${post.slug}/`} class="vc-title-link">{post.title}</a>
      </h2>
      <span
        class="vc-state-badge"
        style={`color: ${stateColor}; border-color: ${stateColor}33;`}
        aria-label={`Status: ${stateLabel}`}
      >{stateLabel}</span>
    </div>
  </div>

  <!-- Row 2: conviction verdict -->
  <div class="vc-conviction" style={`color: ${convictionColor};`}>
    <span class="vc-conviction-glyph" aria-hidden="true">◈</span>
    <span class="vc-conviction-value">{convictionLabel}</span>
    <span class="vc-conviction-label">conviction</span>
  </div>

  <!-- Row 3: stance bar -->
  {hasStances ? (
    <div
      class="vc-stance-bar"
      aria-label={`Stances: ${post.agreePct}% agree, ${post.tornPct}% torn, ${post.disagreePct}% disagree`}
      title={`${post.stanceTotal} total votes`}
    >
      <div class="vc-stance-segments">
        {post.agreeCount > 0 && (
          <div
            class="vc-stance-seg vc-stance-seg--agree"
            style={`width: ${post.agreePct}%`}
            aria-label={`Agree ${post.agreePct}%`}
          />
        )}
        {post.tornCount > 0 && (
          <div
            class="vc-stance-seg vc-stance-seg--torn"
            style={`width: ${post.tornPct}%`}
            aria-label={`Torn ${post.tornPct}%`}
          />
        )}
        {post.disagreeCount > 0 && (
          <div
            class="vc-stance-seg vc-stance-seg--disagree"
            style={`width: ${post.disagreePct}%`}
            aria-label={`Disagree ${post.disagreePct}%`}
          />
        )}
      </div>
      <div class="vc-stance-legend" aria-hidden="true">
        {post.agreeCount > 0    && <span class="vc-leg vc-leg--agree">{post.agreePct}%</span>}
        {post.tornCount > 0     && <span class="vc-leg vc-leg--torn">{post.tornPct}%</span>}
        {post.disagreeCount > 0 && <span class="vc-leg vc-leg--disagree">{post.disagreePct}%</span>}
        <span class="vc-leg-total">{post.stanceTotal} votes</span>
      </div>
    </div>
  ) : (
    <p class="vc-no-stances">No verdicts yet — be first</p>
  )}

  <!-- Row 4: CTA -->
  <div class="vc-actions">
    {!post.entombed && !post.runtimeVerdict && (
      <a href={`/blog/${post.slug}/`} class="vc-cta">Take Stance →</a>
    )}
    {post.runtimeVerdict && (
      <a
        href={`/verdict/${post.slug}/`}
        class="vc-cta vc-cta--verdict"
        aria-label="View verdict ceremony"
      >Verdict sealed ◈</a>
    )}
    {post.entombed && !post.runtimeVerdict && (
      <a href={`/graveyard`} class="vc-cta vc-cta--ghost">View in graveyard →</a>
    )}
    <a
      href={`/audit/${post.slug}/`}
      class="vc-audit-link"
      aria-label="View conviction audit receipt"
    >audited ✓</a>
  </div>

</article>

<style>
  /* ── Card shell — geometry from .card-base + .card-verdict (card-base.css) ── */
  /* Only verdict-specific overrides live here.                                  */
  .verdict-card {
    /* Left accent stripe: color driven by --state-color inline var */
    border-left-color: var(--state-color, var(--gold));
    padding: var(--space-4) var(--space-4) var(--space-3);
    gap: var(--space-3);
  }

  /* ── Row 1: header ──────────────────────────────────────────────────── */
  .vc-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .vc-title-group {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .vc-title {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    /* Clamp to 2 lines — preserves grid height uniformity */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .vc-title-link {
    color: var(--text-primary);
    text-decoration: none;
    transition: color var(--transition-hover);
  }

  .vc-title-link:hover { color: var(--gold); }

  .vc-state-badge {
    align-self: flex-start;
    font-size: var(--text-3xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    padding: var(--space-1) var(--space-2);
    border: 1px solid;
    border-radius: var(--radius-badge);
    background: transparent;
    white-space: nowrap;
    opacity: 0.85;
  }

  /* ── Row 2: conviction ──────────────────────────────────────────────── */
  .vc-conviction {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .vc-conviction-glyph {
    font-size: var(--text-base);
    line-height: 1;
    opacity: 0.7;
  }

  .vc-conviction-value {
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
  }

  .vc-conviction-label {
    font-size: var(--text-3xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-ghost);
    align-self: center;
  }

  /* ── Row 3: stance bar ──────────────────────────────────────────────── */
  .vc-stance-bar {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .vc-stance-segments {
    display: flex;
    height: 6px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    gap: 2px;
    background: var(--border-subtle);
  }

  .vc-stance-seg {
    height: 100%;
    border-radius: 2px;
    transition: width var(--transition-flow);
    min-width: 4px; /* always visible even at 1% */
  }

  .vc-stance-seg--agree    { background: var(--stance-agree); }
  .vc-stance-seg--torn     { background: var(--stance-torn); }
  .vc-stance-seg--disagree { background: var(--stance-disagree); }

  .vc-stance-legend {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .vc-leg {
    font-size: var(--text-2xs);
    font-weight: var(--weight-semibold);
    font-family: var(--font-mono);   /* numeric gravitas — Tanya §8 */
  }

  .vc-leg--agree    { color: var(--stance-agree); }
  .vc-leg--torn     { color: var(--stance-torn); }
  .vc-leg--disagree { color: var(--stance-disagree); }

  .vc-leg-total {
    font-size: var(--text-3xs);
    color: var(--text-ghost);
    margin-left: auto;
  }

  /* ── No stances placeholder ─────────────────────────────────────────── */
  .vc-no-stances {
    font-size: var(--text-xs);
    font-style: italic;
    color: var(--text-disabled);
    margin: 0;
  }

  /* ── Row 4: actions ─────────────────────────────────────────────────── */
  .vc-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-2);
    border-top: 1px solid var(--border-faint);
  }

  .vc-cta {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--gold);
    text-decoration: none;
    transition: opacity var(--transition-hover);
  }

  .vc-cta:hover { opacity: 0.7; }

  .vc-cta--ghost   { color: var(--text-tertiary); }
  .vc-cta--verdict { color: var(--stance-agree); } /* emerald — loop closed */

  .vc-audit-link {
    font-size: var(--text-2xs);
    color: var(--text-dim);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    transition: color var(--transition-hover);
  }

  .vc-audit-link:hover { color: var(--text-secondary); }

  /* ── Fossil: desaturate the whole card ──────────────────────────────── */
  /* Extends .card-fossil from card-base.css via verdict-card--fossil class */
  .verdict-card--fossil {
    opacity: 0.7;
    filter: saturate(0.5);
  }

  .verdict-card--fossil:hover {
    opacity: 0.9;
    filter: saturate(0.7);
  }

  /* ── Reduced motion ─────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .vc-stance-seg { transition: none; }
  }
</style>
