---
// src/components/RisenBadge.astro
// Small "risen" indicator on homepage cards that were recently resurrected.
// Fades after 7 days (controlled by postMeta.recentlyRisen).
// Mood-tinted, subtle — a quiet signal, not a spotlight.

interface Props { visible: boolean; }

const { visible } = Astro.props;
---

{visible && (
  <span class="risen-badge" aria-label="Risen from the graveyard">
    &#x2191; risen
  </span>
)}

<style>
  .risen-badge {
    display: inline-block;
    font-size: var(--text-3xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--mood-accent) 65%, transparent);
    background: color-mix(in oklch, var(--mood-accent) 8%, transparent);
    border: 1px solid color-mix(in oklch, var(--mood-accent) 12%, transparent);
    border-radius: 999px;
    padding: 0.1rem 0.5rem;
    margin-left: 0.4rem;
    vertical-align: middle;
  }
</style>
