---
// src/components/OpenLoopCard.astro
// A single open-loop question card with four-stage crystallization styling.
// Fresh thoughts arrive soft and translucent; aged ones harden into
// denser backgrounds, thicker borders, tighter radii, deeper shadows.
// Crystallized (ratio = 1.0): pinned to history behind museum glass.
// Hovering a crystallized card triggers a single-pass cold shimmer sweep.

import DecayBar from './DecayBar.astro';
import { decayRatio } from '../lib/pulse';
import type { OpenLoop } from '../lib/pulse';

interface Props { loop: OpenLoop; }

const { loop } = Astro.props;
const ratio = decayRatio(loop.dateAdded, loop.decayDays);

function loopStage(d: number): 'fresh' | 'aging' | 'stale' | 'crystallized' {
  if (d >= 1.0) return 'crystallized';
  if (d < 0.33) return 'fresh';
  if (d < 0.66) return 'aging';
  return 'stale';
}

function crystallizedDate(dateAdded: string, decayDays: number): string {
  const ms = new Date(dateAdded).getTime() + decayDays * 86_400_000;
  return new Date(ms).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

const stage = loopStage(ratio);
const isCrystallized = stage === 'crystallized';
// Additive classes per Tanya §Crystallized: crystallized cards carry both stale + crystallized
const cardClass = isCrystallized
  ? 'loop-card loop-stale loop-crystallized'
  : `loop-card loop-${stage}`;
const style = `--decay: ${ratio.toFixed(3)};`;
---

<article class={cardClass} style={style}
         data-posted={loop.dateAdded} data-max-days={String(loop.decayDays)}>
  <header class="loop-head">
    <DecayBar mode="glyph" decayFactor={ratio} />
    <span class="loop-question">{loop.question}</span>
  </header>
  {loop.context && <p class="loop-context">{loop.context}</p>}
  {isCrystallized && (
    <footer class="loop-crystal-badge" aria-label="Crystallized — no longer active">
      ◆ crystallized · {crystallizedDate(loop.dateAdded, loop.decayDays)}
    </footer>
  )}
</article>

<style>
  /* ── Base card — decay INCREASES density (inverse of normal aging) ──── */
  .loop-card {
    --d: var(--decay);
    position: relative;
    padding: calc(0.6rem + 0.6rem * (1 - var(--d)));
    border-radius: calc(8px + 4px * (1 - var(--d)));
    background: color-mix(in oklch, white calc(3% + 6% * var(--d)), transparent);
    border: calc(1px + 1px * var(--d)) solid
      color-mix(in oklch, var(--mood-accent) calc(6% + 14% * var(--d)), transparent);
    box-shadow:
      0 1px calc(4px + 8px * var(--d))
        color-mix(in oklch, var(--mood-accent) calc(2% + 8% * var(--d)), transparent),
      0 calc(2px * var(--d)) calc(16px * var(--d))
        color-mix(in oklch, var(--mood-accent) calc(4% * var(--d)), transparent);
    transition: box-shadow var(--transition-hover, 120ms);
  }

  /* ── Crystallized override — sealed behind museum glass, no elevation ── */
  /* No box-shadow lift on hover: crystallized cards are pinned to history. */
  /* Inset ring = subtle crystalline seal (Tanya §Crystallized).            */
  .loop-crystallized {
    background: oklch(14% 0.008 240 / 0.6);
    box-shadow: inset 0 0 0 1px oklch(60% 0.06 230 / 0.15);
    transition: none;
  }
  .loop-crystallized:hover { box-shadow: inset 0 0 0 1px oklch(60% 0.06 230 / 0.15); }

  /* ── Shimmer ::before layer — cold blue-white sweep on hover ──────────── */
  /* Off-screen at rest (-200%); animates through card on hover; stays      */
  /* off-screen after (forwards fill). overflow: visible preserves shadow.  */
  .loop-crystallized::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      105deg,
      transparent 30%,
      oklch(95% 0.02 210 / 0.14) 50%,
      transparent 70%
    );
    background-size: 300% 100%;
    background-position: -200% center;
    z-index: var(--z-shimmer, 2);
    pointer-events: none;
  }
  .loop-crystallized:hover::before {
    animation: shimmer-glass var(--duration-museum, 1400ms)
               var(--ease-in-out, cubic-bezier(0.65, 0, 0.35, 1))
               1 forwards;
  }

  /* ── Crystallized badge ─────────────────────────────────────────────── */
  .loop-crystal-badge {
    margin-top: var(--space-2, 0.5rem);
    font-family: var(--font-mono);
    font-size: var(--text-3xs, 0.58rem);
    color: var(--text-tertiary, rgba(255,255,255,0.38));
    letter-spacing: var(--tracking-wide, 0.04em);
    user-select: none;
  }

  /* ── Shared text styles ─────────────────────────────────────────────── */
  .loop-head {
    display: flex; align-items: baseline; gap: 0.5rem;
  }
  .loop-question {
    --loop-font-boost: 0.12rem;
    font-size: calc(var(--text-sm) + var(--loop-font-boost) * (1 - var(--d)));
    line-height: 1.45;
    opacity: calc(0.55 + 0.45 * var(--d));
    font-weight: calc(400 + 100 * var(--d));
  }
  .loop-context {
    margin: 0.4rem 0 0 1.35rem;
    font-size: var(--text-xs);
    line-height: 1.4;
    opacity: calc(0.3 + 0.3 * var(--d));
  }

  /* v152 motion-sanctuary (Mike §C): the shimmer sweep is hover-polish only;
     vestibular-sensitive readers get a static crystallized surface.        */
  @media (prefers-reduced-motion: reduce) {
    .loop-crystallized:hover::before { animation: none; }
  }
</style>
