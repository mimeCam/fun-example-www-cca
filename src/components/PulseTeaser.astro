---
// src/components/PulseTeaser.astro
// Shows the freshest active loop on the homepage as a discovery hook.
// Replaces the old HomePulse wall-whisper approach.
// Links to /pulse for full context.

import FreshnessIndicator from './FreshnessIndicator.astro';
import { decayRatio, decayLabel } from '../lib/pulse';
import type { OpenLoop } from '../lib/pulse';

interface Props { loop: OpenLoop; }

const { loop } = Astro.props;
const ratio = decayRatio(loop.dateAdded, loop.decayDays);
const label = decayLabel(ratio);
const style = `--decay: ${ratio.toFixed(3)};`;
---

<a href="/pulse" class={`pulse-teaser pt-${label}`} style={style}>
  <span class="pt-badge">
    <FreshnessIndicator label={label} />
    still itching
  </span>
  <p class="pt-question">{loop.question}</p>
  {loop.context && (
    <p class="pt-context">{loop.context}</p>
  )}
</a>

<style>
  .pulse-teaser {
    display: block;
    max-width: 32rem;
    margin: 0 auto 2.5rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: inherit;
    border-left: 2px solid
      rgba(var(--mood-accent-rgb, 120,120,120), 0.35);
    transition: border-color 0.2s ease;
  }
  .pulse-teaser:hover {
    border-left-color: var(--mood-accent, currentColor);
  }
  .pt-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.4;
    margin-bottom: 0.4rem;
  }
  .pt-question {
    font-size: 0.88rem;
    line-height: 1.45;
    margin: 0;
    opacity: calc(0.6 + 0.4 * (1 - var(--decay)));
  }
  .pt-context {
    font-size: 0.72rem;
    margin: 0.3rem 0 0;
    opacity: 0.35;
  }
</style>
