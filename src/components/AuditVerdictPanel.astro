---
// src/components/AuditVerdictPanel.astro
// Verdict outcome section for the audit receipt page.
// Three visual states: pending | resolved-uncontested | resolved-contested.
// Motion: ceremony profile fade-in — this is a high-gravity result section.
// Zero new JS. Pure SSR HTML. Colors via design tokens only.
// Credits: Mike (napkin plan §AuditVerdictPanel), Tanya (UX §11)

import type { VerdictDisplay } from '../lib/verdict-display';

interface Props {
  verdictDisplay: VerdictDisplay;
}

const { verdictDisplay: vd } = Astro.props;

const isPending   = vd.verdict === null;
const isContested = vd.isContested;
const isResolved  = !isPending;

// Map verdict value to CSS modifier class
function colorMod(v: string | null, contested: boolean): string {
  if (contested)         return 'contested';
  if (!v)                return 'pending';
  if (v === 'still-true') return 'true';
  if (v === 'wrong' || v === 'abandoned') return 'wrong';
  return 'evolved';
}

const mod = colorMod(vd.verdict, isContested);

// Verdict badge icon
const icon = isContested
  ? '⚠'
  : isPending
    ? '◌'
    : vd.verdict === 'still-true'
      ? '✓'
      : vd.verdict === 'wrong' || vd.verdict === 'abandoned'
        ? '✗'
        : '~';

// Heading text — uppercase, stamped feel per Tanya §14 (letter-spacing 0.12em)
const heading = isContested
  ? `CONTESTED — ${vd.verdictLabel.toUpperCase()}`
  : isPending
    ? 'VERDICT PENDING'
    : vd.verdictLabel.toUpperCase();

// Score contribution display copy
const CONTRIB_COPY: Record<VerdictDisplay['scoreContrib'], { symbol: string; label: string }> = {
  correct:   { symbol: '✓', label: 'correct' },
  wrong:     { symbol: '✗', label: 'wrong' },
  neutral:   { symbol: '~', label: 'neutral (evolved, excluded from avg)' },
  contested: { symbol: '⊘', label: 'excluded (contested)' },
  pending:   { symbol: '◌', label: 'no contribution yet' },
};
const contrib = CONTRIB_COPY[vd.scoreContrib];

// Declared date — long form (Tanya §14: monospace data; dates are data)
const declaredDate = vd.declaredAt
  ? new Date(vd.declaredAt).toLocaleDateString('en-US', {
      year: 'numeric', month: 'long', day: 'numeric',
    })
  : null;
---

<section class={`avp avp--${mod}`} aria-label="Verdict outcome">

  <!-- Badge: icon + outcome heading -->
  <div class="avp__badge">
    <span class="avp__icon" aria-hidden="true">{icon}</span>
    <span class="avp__heading">{heading}</span>
  </div>

  <!-- State A: pending -->
  {isPending && (
    <p class="avp__sub">Conviction sealed. Verdict window open.</p>
  )}

  <!-- States B & C: resolved -->
  {isResolved && (
    <dl class="avp__meta">

      {declaredDate && (
        <>
          <dt class="avp__dt">Declared</dt>
          <dd class="avp__dd">{declaredDate}</dd>
        </>
      )}

      {/* Contested: show challenge share + dispute state */}
      {isContested && vd.challengeShare !== null && (
        <>
          <dt class="avp__dt">Challenged by</dt>
          <dd class="avp__dd">
            {Math.round(vd.challengeShare)}% of disagree-stancers
            {vd.disputeState !== 'none' && (
              <span class="avp__dispute-tag">
                &nbsp;·&nbsp;
                {vd.disputeState === 'upheld' ? 'dispute upheld' : 'verdict overturned'}
              </span>
            )}
          </dd>
        </>
      )}

      {/* Uncontested: show dispute summary */}
      {!isContested && vd.disputeState === 'none' && (
        <>
          <dt class="avp__dt">Disputes</dt>
          <dd class="avp__dd avp__dd--muted">None filed</dd>
        </>
      )}

      {!isContested && vd.disputeState === 'upheld' && (
        <>
          <dt class="avp__dt">Dispute</dt>
          <dd class="avp__dd">Filed · upheld (verdict stands)</dd>
        </>
      )}

      <dt class="avp__dt">Score contribution</dt>
      <dd class="avp__dd">
        <span class="avp__contrib-sym" aria-hidden="true">{contrib.symbol}</span>
        {contrib.label}
      </dd>

    </dl>
  )}

  {/* State A: pending — score contribution note below sub-text */}
  {isPending && (
    <p class="avp__no-contrib">No score contribution yet.</p>
  )}

</section>

<style>
  /* ── Base panel ────────────────────────────────────────────────────────── */
  .avp {
    margin-top: 2.5rem;
    padding: 1.5rem;
    border-radius: var(--radius-card);
    border: 1px solid var(--verdict-pending-border);
    background: var(--verdict-pending-bg);
    animation: avp-enter var(--motion-ceremony-duration, 600ms)
               var(--motion-ceremony-easing, cubic-bezier(0.34, 1.56, 0.64, 1))
               both;
  }

  /* ── Color variants — tokens only, no raw hex ──────────────────────────── */
  .avp--true {
    border-color: var(--verdict-true-border);
    background:   var(--verdict-true-bg);
  }
  .avp--wrong {
    border-color: var(--verdict-wrong-border);
    background:   var(--verdict-wrong-bg);
  }
  .avp--evolved {
    border-color: var(--verdict-evolved-border);
    background:   var(--verdict-evolved-bg);
  }
  .avp--contested {
    border-color: var(--gold-border);
    background:   var(--gold-bg);
  }
  .avp--pending {
    border-color: var(--verdict-pending-border);
    background:   var(--verdict-pending-bg);
  }

  /* ── Badge row ─────────────────────────────────────────────────────────── */
  .avp__badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.1rem;
  }

  .avp__icon {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    opacity: 0.9;
    line-height: 1;
  }

  .avp__heading {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-ceremony);   /* Tanya §14: verdict word stamped, generous tracking */
    text-transform: uppercase;
    line-height: 1;
  }

  /* Heading color per variant */
  .avp--true .avp__heading,     .avp--true .avp__icon     { color: var(--verdict-true); }
  .avp--wrong .avp__heading,    .avp--wrong .avp__icon    { color: var(--verdict-wrong); }
  .avp--evolved .avp__heading,  .avp--evolved .avp__icon  { color: var(--verdict-evolved); }
  .avp--contested .avp__heading,.avp--contested .avp__icon { color: var(--gold); }
  .avp--pending .avp__heading,  .avp--pending .avp__icon  { color: var(--text-disabled); }

  /* ── Pending sub-text ──────────────────────────────────────────────────── */
  .avp__sub {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin: 0 0 0.5rem;
    font-style: italic;
    line-height: 1.5;
  }

  /* ── Meta definition list (resolved states) ────────────────────────────── */
  .avp__meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 1.25rem;
    row-gap: 0.45rem;
    margin: 0;
  }

  .avp__dt {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: var(--tracking-relaxed);
    white-space: nowrap;
    align-self: baseline;
    padding-top: 0.05rem;
  }

  .avp__dd {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
    align-self: baseline;
  }

  .avp__dd--muted { color: var(--text-tertiary); }

  .avp__dispute-tag {
    color: var(--text-tertiary);
    font-size: var(--text-xs);
  }

  /* Score contribution symbol — monospace (Tanya §13: IBM Plex Mono = data) */
  .avp__contrib-sym {
    font-family: var(--font-mono);
    margin-right: 0.3rem;
    opacity: 0.7;
  }

  /* ── No-contribution note (pending state) ──────────────────────────────── */
  .avp__no-contrib {
    font-size: var(--text-xs);
    color: var(--text-disabled);
    margin: 0.5rem 0 0;
    letter-spacing: var(--tracking-snug);
  }

  /* ── Ceremony entrance animation ───────────────────────────────────────── */
  @keyframes avp-enter {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0);   }
  }

  /* ── Responsive: stack dt/dd on narrow screens ─────────────────────────── */
  @media (max-width: 480px) {
    .avp__meta {
      grid-template-columns: 1fr;
      row-gap: 0.2rem;
    }
    .avp__dt { color: var(--text-ghost); }
    .avp__dd { margin-bottom: 0.4rem; }
  }
</style>
