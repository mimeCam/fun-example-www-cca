---
// src/components/LandingHero.astro
// Living Landing Hero — visceral 5-second product demonstration.
// A synthetic demo post breathes, decays, and revives in the first viewport.
// No API calls. No DB. Pure decay physics + CSS custom properties.
//
// Props:
//   decayProgress — SSR-computed starting factor (0–1, typically ~0.68 for demo)
//   stage         — initial stage string, drives data-stage atmosphere + label
//
// Client module (landing-hero.ts) takes over after hydration:
//   · Accelerated timeline: 0→100 days in ~10s real-time, auto-loops
//   · Stage transition flash: edge-triggered threshold crossing
//   · Hold progress ring: conic-gradient fill during pointer hold
//   · Day counter: live "Day X / 100" below decay bar
//   · prefers-reduced-motion: static snapshot at endangered stage
//
// Credits: Mike Koch (arch §LandingHero), Tanya Donska (UX §4)

import BloomParticles from './BloomParticles.astro';
import '../styles/landing-hero.css';

interface Props {
  decayProgress: number;  // 0–1
  stage: string;          // 'fresh' | 'fading' | 'endangered' | 'ghost' | 'fossil'
}

const { decayProgress, stage } = Astro.props;

// SSR renders a fresh snapshot; client RAF takes over immediately
const ssrFactor = 0;  // start from fresh
const ssrStage  = 'fresh';
const ssrBpm    = 72; // fresh heartbeat
const pulsePeriod = `${Math.round(60_000 / ssrBpm)}ms`;

// Inline critical vars for first paint — RAF updates on next tick
const inlineVars = [
  `--decay-progress:${ssrFactor.toFixed(3)}`,
  `--hero-pulse-period:${pulsePeriod}`,
  `--stage-index:0`,
].join(';');
---

<section
  id="landing-hero"
  class="landing-hero"
  data-stage={ssrStage}
  data-decay-progress={ssrFactor.toFixed(3)}
  style={inlineVars}
  aria-label={`Demo post: ${ssrStage}, 0% decayed`}
>
  <!-- Hero tagline: 2-line staggered fade-in -->
  <p class="hero-tagline" aria-hidden="true">
    <span class="hero-tagline-line hero-tagline-line--1">Everywhere else, your words haunt the internet forever.</span>
    <span class="hero-tagline-line hero-tagline-line--2">Here, they have to earn it.</span>
  </p>

  <article class="hero-card" aria-hidden="true">

    <!-- Header: pulse dot + stage label -->
    <header class="hero-card-header">
      <span class="hero-card-dot" aria-hidden="true"></span>
      <span class="hero-card-stage-label">{ssrStage}</span>
    </header>

    <!-- Faux title lines — motion IS the explanation (Tanya §4) -->
    <div class="hero-card-body" aria-hidden="true">
      <div class="hero-title-bar hero-title-bar--long"></div>
      <div class="hero-title-bar hero-title-bar--mid"></div>
    </div>

    <!-- Decay bar: width = --decay-progress × 100% -->
    <div class="hero-decay-track">
      <div
        class="hero-decay-fill"
        role="progressbar"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="0"
        aria-label="Decay level"
      ></div>
      <div class="hero-decay-glow" aria-hidden="true"></div>
    </div>

    <!-- Day counter: updated every RAF tick -->
    <span class="hero-day-counter" aria-hidden="true">Day 0 / 100</span>

    <!-- Hold-to-keep with progress ring -->
    <div class="hero-keep-wrap">
      <BloomParticles variant="revival" />
      <button
        class="hero-keep-btn"
        data-demo-keep
        type="button"
        aria-label="Hold to save this post"
      >
        <span class="hero-hold-ring" aria-hidden="true"></span>
        <span class="hero-keep-icon" aria-hidden="true">&#9829;</span>
        <span class="hero-keep-label">hold to keep alive</span>
      </button>
    </div>

  </article>
</section>

<script>
  import { initLandingHero } from '../lib/client/landing-hero';
  initLandingHero();
</script>
