---
// src/components/GraveyardEmptyState.astro
// Rendered when the graveyard is empty — silence as intentional design.
// No "no results" language. The product is waiting; that is honest.
// Mike §6 / Tanya §8: "The graveyard is waiting."
---

<div class="empty-state">
  <p class="empty-primary">The graveyard is silent.</p>
  <p class="empty-secondary">No words have faded here yet.</p>
  <a href="/" class="empty-link">← return to the living</a>
</div>

<style>
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 6rem 1rem 8rem;
    text-align: center;
  }

  .empty-primary {
    margin: 0;
    font-size: var(--text-prose);
    font-weight: 400;
    color: var(--color-grave-text);
    opacity: 0.7;
  }

  /* Breathing animation: subtitle barely alive — Tanya §3.4 */
  .empty-secondary {
    margin: 0;
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-grave-ghost);
    animation: empty-breathe var(--motion-cycle-breath) ease-in-out infinite;
  }

  .empty-link {
    margin-top: 1.5rem;
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-grave-ghost);
    text-decoration: none;
    transition: color var(--motion-flow-duration) ease;
    /* Invisible tap target expansion — Tanya §6.2 */
    padding: 14px 0;
  }

  .empty-link:hover,
  .empty-link:focus-visible {
    color: var(--color-grave-text);
    outline: none;
  }

  /* Unique keyframe name: avoids collision with graveyard.css 'breathe' */
  @keyframes empty-breathe {
    0%, 100% { opacity: 0.55; }
    50%       { opacity: 0.85; }
  }

  @media (prefers-reduced-motion: reduce) {
    .empty-secondary { animation: none; opacity: 0.65; }
  }
</style>
