    transition: background var(--motion-snap-duration) var(--motion-snap-easing), border-color var(--motion-snap-duration) var(--motion-snap-easing), opacity var(--motion-snap-duration) var(--motion-snap-easing);
  }
  .sc-cta:disabled { opacity: 0.45; cursor: not-allowed; }
  .sc-cta:not(:disabled):hover { background: var(--gold-bg-strong); border-color: var(--gold-border-strong); }
  .sc-cta--sign { margin-top: var(--space-5); font-weight: var(--weight-bold); background: var(--gold); color: oklch(10% 0.01 50); border-color: var(--gold); }
  .sc-cta--sign:not(:disabled):hover { background: oklch(from var(--gold) calc(l + 0.05) c h); border-color: oklch(from var(--gold) calc(l + 0.05) c h); }
  .sc-cta--loading .sc-spinner { display: inline-block; }
  .sc-spinner { display: none; }

  /* Conviction hold button */
  .cs-btn-wrap { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); }
  .cs-seal-btn {
    position: relative; display: flex; align-items: center; gap: var(--space-3);
    background: var(--gold-bg); border: 1px solid var(--gold-border);
    border-radius: var(--radius-md); padding: var(--space-3) var(--space-6);
    min-height: 52px; cursor: pointer;
    transition: background var(--motion-duration-fast) var(--motion-easing-standard), border-color var(--motion-duration-fast) var(--motion-easing-standard), box-shadow var(--motion-duration-base) var(--motion-easing-spring);
  }
  .cs-seal-btn:hover { background: var(--gold-hover, var(--gold-bg-strong)); border-color: color-mix(in oklch, var(--gold) 50%, transparent); }
  .cs-arc-svg { flex-shrink: 0; opacity: 0.6; }
  .cs-arc-track { fill: none; stroke: var(--border-subtle); stroke-width: 2; }
  .cs-btn-label { font-size: var(--text-xs); font-weight: var(--weight-bold); letter-spacing: var(--tracking-widest); text-transform: uppercase; color: var(--gold); }
  .cs-spinner { flex-shrink: 0; }
  .cs-error   { display: none; font-size: var(--text-xs); color: var(--verdict-wrong); text-align: center; }

  /* Confirm phase */
  .sc-confirm-block { background: var(--surface-inset, rgba(0,0,0,0.12)); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); padding: var(--space-4) var(--space-5); margin-bottom: var(--space-5); }
  .sc-confirm-eyebrow { display: block; font-size: var(--text-2xs); letter-spacing: var(--tracking-widest); text-transform: uppercase; color: var(--text-ghost); margin-bottom: var(--space-2); }
  .sc-confirm-quote   { font-size: var(--text-base); line-height: 1.6; color: var(--text-primary); font-style: italic; margin: 0 0 var(--space-3); border: none; padding: 0; }
  .sc-confirm-score-row { display: flex; align-items: baseline; gap: var(--space-2); }
  .sc-confirm-score-label { font-size: var(--text-xs); color: var(--text-ghost); }
  .sc-confirm-score-val   { font-family: var(--font-mono); font-size: var(--text-base); color: var(--gold); font-weight: var(--weight-bold); }
