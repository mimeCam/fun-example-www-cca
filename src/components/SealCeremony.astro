  @media (prefers-reduced-motion: reduce) {
    .sc-phase--confirm, .sc-phase--anchor, .sc-phase--notarize, .sc-phase--receipt { animation: none; }
    .sc-arc-fill, .sc-cta, .sc-textarea, .seal-ceremony { transition: none; }
  }
</style>
