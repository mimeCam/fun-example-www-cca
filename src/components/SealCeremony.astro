  }

  /* Header */
  .sc-header { position: relative; margin-bottom: var(--space-5); }
  .sc-eyebrow { display: block; font-size: var(--text-2xs); font-weight: var(--weight-bold); letter-spacing: var(--tracking-widest); text-transform: uppercase; color: var(--gold-dim); margin-bottom: var(--space-2); }
  .sc-title   { font-size: var(--text-lg); font-weight: var(--weight-semibold); line-height: var(--leading-snug); letter-spacing: var(--tracking-tight); color: var(--text-primary); margin: 0 0 var(--space-3); }
  .sc-risk    { font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.5; margin: 0; }
