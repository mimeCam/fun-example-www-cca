  .sc-input-label { display: block; font-size: var(--text-xs); font-weight: var(--weight-semibold); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--text-tertiary); margin-bottom: var(--space-2); }
  .sc-dots { display: flex; gap: var(--space-2); align-items: center; }
  .sc-score-readout { display: inline-flex; align-items: baseline; gap: 2px; }
  .sc-score-num     { font-family: var(--font-mono); font-size: var(--text-lg); color: var(--gold); font-weight: var(--weight-bold); }
  .sc-score-denom-sm, .sc-score-denom { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--gold-dim); }

  /* Weight meter + textarea */
  .cs-meter-wrap { height: 24px; display: flex; align-items: flex-end; margin-bottom: var(--space-4); }
  .cs-meter { height: 100%; }
  .sc-textarea {
    width: 100%; background: var(--surface-inset, rgba(0,0,0,0.15));
    border: none; border-bottom: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm) var(--radius-sm) 0 0; color: var(--text-primary);
    font-size: var(--text-base); line-height: 1.6; padding: var(--space-3) var(--space-4);
    resize: vertical; box-sizing: border-box; margin: var(--space-2) 0 var(--space-5);
    transition: border-color var(--motion-snap-duration) var(--motion-snap-easing);
    font-family: inherit;
  }
  .sc-textarea:focus { outline: none; border-color: var(--gold-border); }

  /* Self-seal CTA */
  .sc-compose-footer { display: flex; flex-direction: column; align-items: flex-start; gap: var(--space-2); }
  .sc-cta {
    display: inline-flex; align-items: center; gap: var(--space-2);
    background: var(--gold-bg); border: 1px solid var(--gold-border);
    border-radius: var(--radius-full); color: var(--gold); cursor: pointer;
    font-size: var(--text-sm); font-weight: var(--weight-semibold);
