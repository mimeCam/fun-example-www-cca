  .sc-notarize-preview { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4) 0; border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); margin-bottom: var(--space-4); }
  .sc-lock-icon      { color: var(--gold-dim); flex-shrink: 0; }
  .sc-notarize-label { font-size: var(--text-xs); color: var(--text-secondary); line-height: 1.5; }
  .sc-confirm-check-label { display: flex; align-items: center; gap: var(--space-3); font-size: var(--text-sm); color: var(--text-secondary); cursor: pointer; }
  .sc-confirm-check { width: 16px; height: 16px; accent-color: var(--gold); cursor: pointer; flex-shrink: 0; }

  /* Anchor phase */
  .sc-phase--anchor { padding: var(--space-10) 0; gap: var(--space-4); text-align: center; }
  .sc-anchor-visual  { position: relative; width: 64px; height: 64px; display: flex; align-items: center; justify-content: center; }
  .sc-anchor-arc-svg { position: absolute; inset: 0; overflow: visible; }
  .sc-arc-track { fill: none; stroke: var(--border-subtle); stroke-width: 3; }
  .sc-arc-fill  { fill: none; stroke: var(--gold); stroke-width: 3; stroke-dasharray: 176; stroke-dashoffset: 176; stroke-linecap: round; transform-origin: center; transform: rotate(-90deg); transition: stroke-dashoffset 1800ms linear; }
  .sc-arc-fill.is-filling, .seal-ceremony[data-phase="anchor"] .sc-arc-fill { stroke-dashoffset: 0; }
  .sc-anchor-lock  { color: var(--gold-dim); z-index: var(--z-card); }
  .sc-anchor-label { font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--text-primary); letter-spacing: var(--tracking-wide); margin: 0; }
  .sc-anchor-sub   { font-size: var(--text-xs); color: var(--text-tertiary); margin: 0; max-width: 30ch; text-align: center; }

  /* Unsealed notice + mobile + reduced motion */
  .cs-unsealed-notice { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4) var(--space-5); border: 1px dashed var(--gold-border); border-radius: var(--radius-tombstone); background: var(--gold-bg); }
  .cs-unsealed-icon  { font-size: var(--text-sm); color: var(--gold-dim); }
  .cs-unsealed-label { font-size: var(--text-xs); color: var(--text-tertiary); font-style: italic; }

  @media (max-width: 640px) {
    .seal-ceremony, .conviction-seal--ceremony { padding: var(--space-5); }
