---
// src/components/SealCeremony.astro
// Self-service conviction seal — 4-phase state machine.
// data-phase="compose|confirm|anchor|receipt" drives all CSS transitions.
// Fetches a capability token from /api/author-token, then seals via /api/seal-self.
// Zero runtime JS framework — vanilla fetch + attribute swap on data-phase.
//
// Phases:
//   compose  → author enters score + conviction note
//   confirm  → read-only preview + "I stand behind this" checkbox
//   anchor   → POST in flight, gold arc animation (1800ms minimum)
//   receipt  → SealReceipt.astro display, share button
//
// Sensory layer: seal-phase-orchestrator.ts owns all score sound/haptic/tier logic.
// Credits: Mike (4-phase spec, capability token, §seal-phase-orchestrator),
//          Tanya (ceremony UX, motion contract, §score-tier-labels)

import SealReceipt      from './SealReceipt.astro';
import NotarizeStamp   from './NotarizeStamp.astro';
import BloomParticles  from './BloomParticles.astro';

interface Props {
  slug:        string;
  title:       string;
  authorSlug?: string; // default 'host' for single-author platforms
}

const { slug, title, authorSlug = 'host' } = Astro.props;
---

<div
  class="seal-ceremony"
  data-phase="compose"
  data-slug={slug}
  data-author={authorSlug}
  data-score="5"
  data-seal-score-tier="mid"
  aria-label="Seal your conviction"
  data-atmosphere="gold"
>

  <!-- ── PHASE: COMPOSE ─────────────────────────────────────────── -->
  <div class="sc-phase sc-phase--compose">
    <header class="sc-header">
      <span class="sc-eyebrow">SEAL YOUR CONVICTION</span>
      <h2 class="sc-title">{title}</h2>
      <p class="sc-risk">
        Once sealed, this enters the accountability loop.
        The community can dispute within 72 hours.
        <strong>There is no unseal.</strong>
      </p>
    </header>

    <!-- Score selector -->
    <div class="sc-score-group" role="group" aria-label="Conviction strength 1 to 10">
      <span class="sc-input-label">Conviction strength</span>
      <div class="sc-dots cs-dots" data-dots>
        {Array.from({ length: 10 }, (_, i) => (
          <button
            type="button"
            class={`seal-dot${i < 5 ? ' is-filled' : ''}`}
            data-value={i + 1}
            aria-label={`Score ${i + 1} out of 10`}
            aria-pressed={i < 5 ? 'true' : 'false'}
          ></button>
        ))}
      </div>
      <span class="sc-score-readout">
        <span class="sc-score-num" data-score-display>5</span>
        <span class="sc-score-denom">/10</span>
      </span>
    </div>
    <!-- Semantic tier label: updated by seal-phase-orchestrator on each dot click -->
    <span class="sc-score-tier-label" data-score-tier-label aria-live="polite">Moderate</span>

    <!-- Conviction note -->
    <label class="sc-input-label" for={`sc-note-${slug}`}>Your conviction in one sentence</label>
    <textarea
      id={`sc-note-${slug}`}
      class="sc-textarea"
      rows="2"
      maxlength="280"
      placeholder="State your conviction clearly. You will be held to this."
      data-note
    ></textarea>

    <div class="sc-compose-footer">
      <button class="sc-cta" data-compose-cta type="button" disabled>
        Seal this conviction
        <span class="seal-spinner sc-spinner" aria-hidden="true"></span>
      </button>
      <p class="sc-error seal-error" data-error aria-live="polite"></p>
    </div>
  </div>

  <!-- ── PHASE: CONFIRM ─────────────────────────────────────────── -->
  <div class="sc-phase sc-phase--confirm" aria-hidden="true">
    <div class="sc-confirm-block">
      <span class="sc-confirm-eyebrow">Your conviction</span>
      <blockquote class="sc-confirm-quote" data-confirm-quote></blockquote>
      <div class="sc-confirm-score-row">
        <span class="sc-confirm-score-label">Strength</span>
        <span class="sc-confirm-score-val" data-confirm-score></span>
        <span class="sc-confirm-score-denom">/10</span>
      </div>
    </div>

    <!-- NotarizeStamp preview: SVG lock that morphs on press -->
    <div class="sc-notarize-preview" aria-hidden="true">
      <svg class="sc-lock-icon" viewBox="0 0 24 24" width="32" height="32"
        fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <rect x="3" y="11" width="18" height="11" rx="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      <span class="sc-notarize-label">This cannot be unsaid. The clock starts now.</span>
    </div>

    <label class="sc-confirm-check-label">
      <input type="checkbox" class="sc-confirm-check" data-confirm-check />
      <span>I stand behind this, permanently.</span>
    </label>

    <button class="sc-cta sc-cta--sign" data-confirm-cta type="button" disabled>
      Sign &amp; Anchor
    </button>
  </div>

  <!-- ── PHASE: ANCHOR ──────────────────────────────────────────── -->
  <div class="sc-phase sc-phase--anchor" aria-hidden="true" aria-live="polite">
    <div class="sc-anchor-visual" aria-hidden="true">
      <!-- Gold progress arc around lock icon -->
      <svg class="sc-anchor-arc-svg" viewBox="0 0 64 64" width="64" height="64">
        <circle class="sc-arc-track" cx="32" cy="32" r="28"/>
        <circle class="sc-arc-fill seal-arc" cx="32" cy="32" r="28" data-arc/>
      </svg>
      <svg class="sc-anchor-lock" viewBox="0 0 24 24" width="28" height="28"
        fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <rect x="3" y="11" width="18" height="11" rx="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>
    <p class="sc-anchor-label">Anchoring to the public record…</p>
    <p class="sc-anchor-sub">Generating cryptographic proof. This may take a moment.</p>
  </div>

  <!-- ── PHASE: NOTARIZE (3.5) ────────────────────────────────── -->
  <!-- NotarizeStamp CSS fires on [data-seal-phase="notarize"] ancestor. -->
  <!-- JS sets data-seal-phase="notarize" on the ceremony root.          -->
  <div class="sc-phase sc-phase--notarize" aria-hidden="true" aria-live="polite">
    <NotarizeStamp />
  </div>

  <!-- ── PHASE: RECEIPT ─────────────────────────────────────────── -->
  <div class="sc-phase sc-phase--receipt" aria-hidden="true" data-receipt-phase>
    <!-- SealReceipt expects [data-seal-phase="4"] on an ancestor. -->
    <!-- JS sets data-seal-phase="4" on this wrapper when receipt begins. -->
    <SealReceipt />
    <!-- Gold bloom burst fires when .seal-ceremony gains .blooming-receipt -->
    <BloomParticles variant="receipt" />
  </div>

</div>

<script>
  import {
    initSealSound, playSealLock, playNotarizeChime, playReceiptReveal, playSealError,
  } from '../lib/client/seal-sound';
  import { hapticForEvent }                    from '../lib/client/seal-haptic';
  import { initOrchestrator, onScoreChange }   from '../lib/client/seal-phase-orchestrator';

  document.querySelectorAll<HTMLElement>('.seal-ceremony').forEach(initCeremony);

  function initCeremony(el: HTMLElement): void {
    const slug = el.dataset.slug!;
    const authorSlug = el.dataset.author!;
    let score = 5;
    let token = '';
    // Initialise AudioContext on first gesture — satisfies autoplay policy
    el.addEventListener('pointerdown', () => initSealSound(), { once: true });
    // Orchestrator: score tier label, hesitation beat, score sound/haptic
    initOrchestrator(el);
    setupDots(el, v => { score = v; onScoreChange(el, v); });
    const noteEl = el.querySelector<HTMLTextAreaElement>('[data-note]')!;
    noteEl.addEventListener('input', () => toggleComposeCta(el, noteEl.value.trim()));
    el.querySelector('[data-compose-cta]')!.addEventListener('click', () =>
      onCompose(el, slug, authorSlug, score, noteEl.value.trim())
        .then(t => { token = t; })
        .catch(err => showError(el, err.message)),
    );
    el.querySelector<HTMLInputElement>('[data-confirm-check]')!
      .addEventListener('change', e => {
        const btn = el.querySelector<HTMLButtonElement>('[data-confirm-cta]')!;
        btn.disabled = !(e.target as HTMLInputElement).checked;
      });
    el.querySelector('[data-confirm-cta]')!.addEventListener('click', () =>
      onConfirm(el, slug, authorSlug, score, noteEl.value.trim(), token)
        .catch(err => showError(el, err.message)),
    );
  }

  // ── Score dots ──────────────────────────────────────────────────

  function setupDots(el: HTMLElement, onChange: (v: number) => void): void {
    const dots = el.querySelectorAll<HTMLElement>('[data-dots] .seal-dot');
    dots.forEach((dot, i) => dot.addEventListener('click', () => {
      const val = i + 1;
      springFillDot(dot);
      syncDots(dots, val);
      el.querySelector('[data-score-display]')!.textContent = String(val);
      onChange(val);
      toggleComposeCta(el, el.querySelector<HTMLTextAreaElement>('[data-note]')!.value.trim());
    }));
  }

  function syncDots(dots: NodeListOf<HTMLElement>, val: number): void {
    dots.forEach((d, i) => {
      d.classList.toggle('is-filled', i < val);
      d.setAttribute('aria-pressed', String(i < val));
    });
  }

  /** Spring-fill animation on the clicked dot (200ms spring — Tanya §10.1). */
  function springFillDot(dot: HTMLElement): void {
    dot.classList.remove('is-spring-filling');
    void dot.offsetWidth;  // reflow: resets animation so it replays on repeat clicks
    dot.classList.add('is-spring-filling');
    setTimeout(() => dot.classList.remove('is-spring-filling'), 250);
  }

  // ── CTA enable/disable ─────────────────────────────────────────

  function toggleComposeCta(el: HTMLElement, note: string): void {
    const btn = el.querySelector<HTMLButtonElement>('[data-compose-cta]')!;
    btn.disabled = note.length < 10;
  }

  // ── Phase transitions ──────────────────────────────────────────
  // SEAL_PHASE_MAP: data-seal-phase mirrors for notarize-stamp.css + SealReceipt.css

  const SEAL_PHASE_MAP: Record<string, string> = { anchor: '3', notarize: 'notarize' };

  function setPhase(el: HTMLElement, phase: string): void {
    el.dataset.phase = phase;
    const sp = SEAL_PHASE_MAP[phase];
    if (sp) el.dataset.sealPhase = sp; else delete el.dataset.sealPhase;
    el.querySelectorAll<HTMLElement>('.sc-phase').forEach(p => {
      p.setAttribute('aria-hidden', String(!p.classList.contains(`sc-phase--${phase}`)));
    });
  }

  // ── Sound + haptic per phase ───────────────────────────────────

  function playForPhase(phase: string): void {
    if (phase === 'anchor')   { playSealLock();      hapticForEvent('LOCK');     }
    if (phase === 'notarize') { playNotarizeChime(); hapticForEvent('NOTARIZE'); }
    if (phase === 'receipt')  { playReceiptReveal(); hapticForEvent('RECEIPT');  }
  }

  // ── Network calls ──────────────────────────────────────────────

  async function fetchToken(postSlug: string, authorSlug: string): Promise<string> {
    const r = await fetch('/api/author-token', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ postSlug, authorSlug }),
    });
    const data = await r.json();
    if (!r.ok) throw new Error(data.error ?? 'Token request failed');
    return data.token as string;
  }

  async function submitSeal(
    slug: string, authorSlug: string, score: number, note: string, token: string,
  ): Promise<Record<string, unknown>> {
    const r = await fetch('/api/seal-self', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug, authorSlug, score, authorNote: note, token }),
    });
    const data = await r.json();
    if (!r.ok) throw new Error(data.error ?? 'Seal failed');
    return data as Record<string, unknown>;
  }

  // ── Phase handlers ─────────────────────────────────────────────

  async function onCompose(
    el: HTMLElement, slug: string, authorSlug: string, score: number, note: string,
  ): Promise<string> {
    if (note.length < 10) throw new Error('Note too short — be specific.');
    clearError(el);
    const btn = el.querySelector<HTMLButtonElement>('[data-compose-cta]')!;
    btn.disabled = true;
    btn.classList.add('sc-cta--loading');
    const t = await fetchToken(slug, authorSlug).finally(() => {
      btn.disabled = false;
      btn.classList.remove('sc-cta--loading');
    });
    el.querySelector('[data-confirm-quote]')!.textContent = `"${note}"`;
    el.querySelector('[data-confirm-score]')!.textContent = String(score);
    setPhase(el, 'confirm');
    return t;
  }

  async function onConfirm(
    el: HTMLElement, slug: string, authorSlug: string,
    score: number, note: string, token: string,
  ): Promise<void> {
    clearError(el);
    setPhase(el, 'anchor');
    playForPhase('anchor');
    // 1800ms minimum — the weight of this action deserves ceremony time
    const [data] = await Promise.all([
      submitSeal(slug, authorSlug, score, note, token),
      new Promise<void>(r => setTimeout(r, 1800)),
    ]);
    await runNotarize(el, data as Record<string, unknown>);
    runReceipt(el, data as Record<string, unknown>, slug);
  }

  // ── Phase 3.5: notarize ceremony ──────────────────────────────

  async function runNotarize(el: HTMLElement, data: Record<string, unknown>): Promise<void> {
    populateStamp(el, data);
    setPhase(el, 'notarize');
    playForPhase('notarize');
    await new Promise<void>(r => setTimeout(r, 800));  // --notarize-pause-duration
  }

  function populateStamp(el: HTMLElement, data: Record<string, unknown>): void {
    const d  = new Date(data.sealedAt as number);
    const ts = d.toLocaleString('en-US',
      { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' });
    setText(el, '[data-ns-label]', data.tst_token ? 'NOTARIZED' : 'Anchoring locally…');
    setText(el, '[data-ns-ts]', ts);
    setText(el, '[data-ns-hash]', `${String(data.hash ?? '').slice(0, 32)}…`);
    const timeEl = el.querySelector<HTMLTimeElement>('[data-ns-ts]');
    if (timeEl) timeEl.dateTime = d.toISOString();
  }

  // ── Phase 4: receipt ───────────────────────────────────────────

  function runReceipt(el: HTMLElement, data: Record<string, unknown>, slug: string): void {
    populateReceipt(el, data, slug);
    el.querySelector<HTMLElement>('[data-receipt-phase]')!.dataset.sealPhase = '4';
    setPhase(el, 'receipt');
    playForPhase('receipt');
    triggerReceiptBloom(el);
  }

  function triggerReceiptBloom(el: HTMLElement): void {
    el.classList.add('blooming-receipt');
    setTimeout(() => el.classList.remove('blooming-receipt'), 800);
  }

  // ── Receipt population ─────────────────────────────────────────

  function populateReceipt(el: HTMLElement, data: Record<string, unknown>, slug: string): void {
    const sealedAt = new Date(data.sealedAt as number).toLocaleDateString(
      'en-US', { month: 'short', day: 'numeric', year: 'numeric' },
    );
    setText(el, '[data-receipt-date]',  sealedAt);
    setText(el, '[data-receipt-score]', String(data.score ?? ''));
    setText(el, '[data-receipt-hash]',  String(data.hash ?? ''));
    const tstNote = data.tst_token
      ? `Anchored — token present (${String(data.tst_token).slice(0, 8)}…)`
      : 'Anchoring locally — OTS proof pending';
    setText(el, '[data-receipt-tst-note]', tstNote);
    if (data.anchorUrl) {
      const anchor = el.querySelector<HTMLAnchorElement>('[data-receipt-anchor]');
      const row    = el.querySelector<HTMLElement>('[data-receipt-anchor-row]');
      if (anchor) anchor.href = data.anchorUrl as string;
      if (row)    row.style.display = '';
    }
    wireDownload(el, data, slug);
    const auditEl = el.querySelector<HTMLAnchorElement>('[data-receipt-audit]');
    if (auditEl) auditEl.href = `/audit/${slug}`;
  }

  function setText(el: HTMLElement, selector: string, text: string): void {
    const target = el.querySelector<HTMLElement>(selector);
    if (target) target.textContent = text;
  }

  function wireDownload(el: HTMLElement, data: Record<string, unknown>, slug: string): void {
    const btn = el.querySelector<HTMLButtonElement>('[data-receipt-download]');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const url  = URL.createObjectURL(blob);
      Object.assign(document.createElement('a'), { href: url, download: `seal-receipt-${slug}.json` }).click();
      URL.revokeObjectURL(url);
    }, { once: true });
  }

  // ── Error recovery ─────────────────────────────────────────────

  function showError(el: HTMLElement, msg: string): void {
    setPhase(el, 'compose');  // reset — lets user retry from compose
    const errEl = el.querySelector<HTMLElement>('[data-error]');
    if (errEl) errEl.textContent = msg;
    const btn = el.querySelector<HTMLButtonElement>('[data-compose-cta]');
    if (btn) { btn.disabled = false; btn.classList.remove('sc-cta--loading'); }
    playSealError();
  }

  function clearError(el: HTMLElement): void {
    const errEl = el.querySelector<HTMLElement>('[data-error]');
    if (errEl) errEl.textContent = '';
  }
</script>

<style>
  /* ── Outer wrapper: phases shown/hidden via data-phase ───────── */

  .seal-ceremony {
    container-type: inline-size;
    border:         1px solid var(--gold-border);
    border-radius:  var(--radius-xl, 24px);    /* Tanya §4 — premium container */
    background:     var(--surface-raised);
    box-shadow:     var(--shadow-e3);
    padding:        var(--space-7) var(--space-6);
    margin:         var(--space-6) 0;
    transition:
      box-shadow   var(--motion-flow-duration, 300ms) var(--motion-flow-easing, ease),
      border-color var(--motion-flow-duration, 300ms) var(--motion-flow-easing, ease);
  }

  /* ── Phase shadow escalation (Tanya §ShadowDepthHierarchy) ─────────────── */
  /* Scoped here so specificity beats global gold-atmosphere rule.              */
  /* confirm=ceremony ring; receipt=E4 gold ambient (Tanya §1 Phase 4).        */

  .seal-ceremony[data-phase="confirm"] {
    box-shadow: var(--shadow-seal-ceremony);
  }

  .seal-ceremony[data-phase="receipt"] {
    box-shadow: var(--shadow-e4);
  }

  /* ── Score tier border escalation (scoped — beats global gold-border) ───── */

  .seal-ceremony[data-seal-score-tier="high"] {
    border-color: color-mix(in oklch, var(--seal-score-tier-high) 30%, transparent);
  }

  .seal-ceremony[data-seal-score-tier="max"] {
    border-color: color-mix(in oklch, var(--seal-score-tier-max) 40%, transparent);
    box-shadow:
      var(--shadow-e3),
      0 0 16px color-mix(in oklch, var(--gold) 8%, transparent);
  }

  /* ── Phase visibility: phase div shows only when matching ─────── */

  .sc-phase { display: none; }

  .seal-ceremony[data-phase="compose"]   .sc-phase--compose   { display: block; }
  .seal-ceremony[data-phase="confirm"]   .sc-phase--confirm   { display: block; }
  .seal-ceremony[data-phase="anchor"]    .sc-phase--anchor    { display: flex; flex-direction: column; align-items: center; }
  .seal-ceremony[data-phase="notarize"]  .sc-phase--notarize  { display: flex; flex-direction: column; align-items: center; }
  .seal-ceremony[data-phase="receipt"]   .sc-phase--receipt   { display: block; }

  /* Phase entry animations (FLOW → CONFIRM, SNAP → ANCHOR, CEREMONY → RECEIPT) */

  .sc-phase--confirm,
  .sc-phase--anchor,
  .sc-phase--notarize,
  .sc-phase--receipt {
    animation: sc-phase-in var(--motion-flow-duration) var(--motion-flow-easing) both;
  }

  @keyframes sc-phase-in {
    from { opacity: 0; translate: 0 6px; }
    to   { opacity: 1; translate: 0 0;   }
  }

  /* ── Header ──────────────────────────────────────────────────── */

  .sc-eyebrow {
    display:        block;
    font-size:      var(--text-2xs);
    font-weight:    var(--weight-bold);
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color:          var(--gold-dim);
    margin-bottom:  var(--space-2);
  }

  .sc-title {
    font-size:      var(--text-lg);
    font-weight:    var(--weight-semibold);
    line-height:    1.3;
    letter-spacing: -0.02em;
    color:          var(--text-primary);
    margin:         0 0 var(--space-3);
  }

  .sc-risk {
    font-size:   var(--text-sm);
    color:       var(--text-secondary);
    line-height: 1.5;
    margin:      0 0 var(--space-5);
  }

  .sc-risk strong { color: var(--text-primary); }

  /* ── Score dots ───────────────────────────────────────────────── */

  .sc-score-group {
    margin-bottom: var(--space-4);
  }

  .sc-input-label {
    display:        block;
    font-size:      var(--text-xs);
    font-weight:    var(--weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color:          var(--text-tertiary);
    margin-bottom:  var(--space-2);
  }

  .sc-dots {
    display:     flex;
    gap:         var(--space-2);
    align-items: center;
  }

  .sc-score-readout {
    display:     inline-flex;
    align-items: baseline;
    gap:         2px;
    margin-left: var(--space-3);
  }

  .sc-score-num  { font-family: var(--font-mono); font-size: var(--text-lg); color: var(--gold); font-weight: var(--weight-bold); }
  .sc-score-denom { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--gold-dim); }

  /* ── Textarea ─────────────────────────────────────────────────── */

  .sc-textarea {
    width:            100%;
    background:       var(--surface-inset, rgba(0,0,0,0.15));
    border:           none;
    border-bottom:    1px solid var(--border-subtle);
    border-radius:    var(--radius-sm) var(--radius-sm) 0 0;
    color:            var(--text-primary);
    font-size:        var(--text-base);
    line-height:      1.6;
    padding:          var(--space-3) var(--space-4);
    resize:           vertical;
    transition:       border-color var(--motion-snap-duration) var(--motion-snap-easing);
    box-sizing:       border-box;
    margin-bottom:    var(--space-5);
    margin-top:       var(--space-2);
  }

  .sc-textarea:focus {
    outline:       none;
    border-color:  var(--gold-border);
  }

  /* ── Compose footer ───────────────────────────────────────────── */

  .sc-compose-footer {
    display:        flex;
    flex-direction: column;
    align-items:    flex-start;
    gap:            var(--space-2);
  }

  /* ── CTA button ───────────────────────────────────────────────── */

  .sc-cta {
    display:        inline-flex;
    align-items:    center;
    gap:            var(--space-2);
    background:     var(--gold-bg);
    border:         1px solid var(--gold-border);
    border-radius:  var(--radius-full);
    color:          var(--gold);
    cursor:         pointer;
    font-size:      var(--text-sm);
    font-weight:    var(--weight-semibold);
    letter-spacing: 0.06em;
    padding:        var(--space-3) var(--space-6);
    transition:
      background   var(--motion-snap-duration) var(--motion-snap-easing),
      border-color var(--motion-snap-duration) var(--motion-snap-easing),
      opacity      var(--motion-snap-duration) var(--motion-snap-easing);
  }

