---
// src/components/ContradictionCard.astro
// Displays a pair of disagreeing posts with a reflection note.
// Minimal — just links + the author's honest reflection.
//
// TODO: link to actual post pages once blog slugs are validated

import type { Contradiction } from '../lib/pulse';

interface Props { item: Contradiction; }

const { item } = Astro.props;
---

<article class="contradiction">
  <div class="tension-pair">
    <a class="post-ref" href={`/blog/${item.postA.slug}`}>{item.postA.title}</a>
    <span class="versus" aria-hidden="true">⇄</span>
    <a class="post-ref" href={`/blog/${item.postB.slug}`}>{item.postB.title}</a>
  </div>
  <p class="reflection">{item.reflection}</p>
</article>

<style>
  .contradiction {
    padding: 0.75rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(var(--mood-accent-rgb, 120,120,120), 0.10);
  }
  .tension-pair {
    display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
  }
  .post-ref {
    font-size: 0.78rem; opacity: 0.7;
    text-decoration-style: dotted; color: var(--mood-accent, inherit);
  }
  .versus { font-size: 0.7rem; opacity: 0.35; }
  .reflection {
    margin: 0.4rem 0 0; font-size: 0.72rem;
    line-height: 1.45; opacity: 0.5; font-style: italic;
  }
</style>
