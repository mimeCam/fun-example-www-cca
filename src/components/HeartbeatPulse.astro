---
// src/components/HeartbeatPulse.astro
// Ambient presence indicator — a warm ember that glows when SSE shows
// other readers are active. Three states: cold, warm, glowing.
// Positioned near the bottom-left, above QuietFollow.
// The counter shows session heartbeats (aria-live for screen readers).
---

<div id="heartbeat-presence" class="hb-presence hb-cold" aria-hidden="true">
  <span class="hb-ember"></span>
  <span class="hb-count" hidden aria-live="polite"></span>
</div>

<style>
  .hb-presence {
    position: fixed;
    bottom: 3.5rem;
    left: 1rem;
    z-index: 7;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    pointer-events: none;
  }

  .hb-ember {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    transition: background 1.2s ease, box-shadow 1.2s ease;
  }

  /* --- Cold: barely visible dot --- */
  .hb-cold .hb-ember {
    background: rgba(var(--mood-accent-rgb, 120,120,120), 0.15);
    box-shadow: 0 0 0 0 transparent;
  }

  /* --- Warm: soft glow --- */
  .hb-warm .hb-ember {
    background: rgba(var(--mood-accent-rgb, 120,120,120), 0.5);
    box-shadow: 0 0 8px 2px rgba(var(--mood-accent-rgb, 120,120,120), 0.2);
  }

  /* --- Glowing: active ember --- */
  .hb-glowing .hb-ember {
    background: rgba(var(--mood-accent-rgb, 120,120,120), 0.85);
    box-shadow: 0 0 16px 4px rgba(var(--mood-accent-rgb, 120,120,120), 0.35);
    animation: hb-active-pulse 2s ease-in-out infinite;
  }

  /* --- Counter badge --- */
  .hb-count {
    font-size: 0.6rem;
    letter-spacing: 0.03em;
    opacity: 0.4;
    color: var(--mood-accent, currentColor);
    font-variant-numeric: tabular-nums;
  }

  /* --- Breathing animation (when alone, synthetic warmth) --- */
  .hb-breath .hb-ember {
    animation: hb-breathe 2s ease-in-out;
  }

  @keyframes hb-breathe {
    0%   { opacity: 0.15; }
    50%  { opacity: 0.45; box-shadow: 0 0 6px 1px rgba(var(--mood-accent-rgb, 120,120,120), 0.12); }
    100% { opacity: 0.15; }
  }

  @keyframes hb-active-pulse {
    0%, 100% { box-shadow: 0 0 12px 3px rgba(var(--mood-accent-rgb, 120,120,120), 0.25); }
    50%      { box-shadow: 0 0 20px 6px rgba(var(--mood-accent-rgb, 120,120,120), 0.45); }
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    .hb-ember {
      animation: none !important;
      transition: background 0.1s, box-shadow 0.1s;
    }
    .hb-breath .hb-ember {
      animation: none !important;
      opacity: 0.35;
    }
  }

  /* --- Mobile --- */
  @media (max-width: 640px) {
    .hb-presence {
      bottom: 3rem;
      left: 0.75rem;
    }
    .hb-ember {
      width: 6px;
      height: 6px;
    }
  }
</style>
