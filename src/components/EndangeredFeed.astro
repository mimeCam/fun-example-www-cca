---
// src/components/EndangeredFeed.astro
// Endangered discovery feed — SSE-powered live triage page.
// LAYOUT SHELL: header + flex-column cards + empty state.
// ALL card rendering delegated to EndangeredCard — zero card markup here.
//
// Live updates: SSE from /api/endangered-sse pushes EndangeredPost[] snapshots.
// Client updates data-* attrs + CSS `order` on canonical EndangeredCards.
// 2-phase dismiss (bloom → collapse) when a post leaves the endangered range.
//
// Credits: Mike (architecture §1 — composition over duplication),
//          Tanya (UX spec §13.1 — CSS-only re-sort, urgency tiers)

import EndangeredCard from './EndangeredCard.astro';
import { endangeredFeedScript } from '../lib/endangered';
import type { PostDisplayData } from '../lib/postMeta';

interface Props {
  posts: PostDisplayData[];
}

const { posts } = Astro.props;
const sorted = [...posts].sort(byMostEndangered);

function byMostEndangered(
  a: PostDisplayData,
  b: PostDisplayData,
): number {
  return b.decay - a.decay;
}
---

<section
  class="endangered-feed"
  id="endangered-feed"
  aria-label="Posts at risk of being lost"
  aria-live="polite"
>
  {sorted.length > 0 ? (
    <>
      <header class="feed-header">
        <span class="feed-label">FADING NOW</span>
        <span class="feed-count" id="feed-count">
          {sorted.length} {sorted.length === 1 ? 'post' : 'posts'} at risk
        </span>
      </header>

      <div class="feed-cards" id="feed-cards">
        {sorted.map((post, i) => (
          <div
            class="feed-card-wrap"
            data-slug={post.slug}
            style={'order: ' + i}
          >
            <EndangeredCard post={post} />
          </div>
        ))}
      </div>
    </>
  ) : (
    <div class="feed-empty" id="feed-empty" role="status">
      <p class="feed-empty-headline">No posts are currently endangered.</p>
      <p class="feed-empty-sub">When posts approach their final days, they appear here.</p>
    </div>
  )}
</section>

<script set:html={endangeredFeedScript()} />
