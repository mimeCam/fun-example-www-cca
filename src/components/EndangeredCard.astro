---
// src/components/EndangeredCard.astro
// Urgency-focused card for posts approaching entombment.
// NOT a subclass of DecayCard — separate component, same CSS vars, same revival engine.
// Composition over inheritance. Two components, one engine.
//
// Visual: desaturated, pulsing border, countdown text.
// Interaction: same hover-dwell revival via revivalEngineScript().
//
// Credits: Mike (architecture — "polymorphism is a killer"), Tanya (UX spec §3.2B)

import { formatPubDate } from '../lib/dates';
import { countdownLabel, urgencyLevel, endangeredStyleString } from '../lib/endangered';
import { decayStyleString } from '../lib/decay-engine';
import type { PostDisplayData } from '../lib/postMeta';

interface Props { post: PostDisplayData; }

const { post } = Astro.props;
const href = `/blog/${post.slug}`;
const formattedDate = formatPubDate(post.pubDate);
const urgency = urgencyLevel(post.decay);
const countdown = countdownLabel(post.decay);
const style = [decayStyleString(post.decay), endangeredStyleString(post.decay)].join(';');
---

<article
  class="endangered-card decay-card"
  style={style}
  data-slug={post.slug}
  data-pub-date={post.pubDateISO}
  data-decay-factor={post.decay.toFixed(4)}
  data-revival-count={post.revivalCount}
  data-urgency={urgency}
  tabindex="0"
  aria-label={`${post.title} — endangered, ${countdown}. Hold to revive.`}
>
  <a href={href} class="post-link">
    <time datetime={post.pubDateISO} class="post-date">{formattedDate}</time>
    <h2 class="post-title">{post.title}</h2>
  </a>
  <div class="endangered-card-footer">
    <span class="endangered-countdown">{countdown}</span>
    <a href={href} class="endangered-tend-link">tend this post &rarr;</a>
  </div>
</article>
