---
// src/components/NowCard.astro
// Glass card for /now page. One card, one --decay variable, one story.
// Glows warm when fresh, flattens to near-monochrome when dormant.
// Quip counter-decays: rises in prominence as content fades.
//
// TODO: add dust texture overlay at high decay (v2)
// TODO: animate card entrance on first paint (v2)

import type { NowData, FreshnessInfo } from '../lib/now';

interface Props {
  data: NowData;
  freshness: FreshnessInfo;
  decay: number;
}

const { data, freshness, decay } = Astro.props;
---

<section class="now-card" style={`--decay: ${decay.toFixed(3)};`} data-posted={data.updated} data-max-days="90">
  <header class="now-header">
    <span class="now-label">{freshness.label}</span>
    {data.location && <span class="now-location">📍 {data.location}</span>}
  </header>

  <ul class="now-doing" role="list">
    {data.doing.map(entry => (
      <li><span aria-hidden="true">{entry.emoji}</span> {entry.text}</li>
    ))}
  </ul>

  {data.thinking && (
    <blockquote class="now-thinking">"{data.thinking}"</blockquote>
  )}

  <footer class="now-quip">{freshness.quip}</footer>
</section>

<style>
  .now-card {
    --alive: calc(1 - var(--decay));
    max-width: 36rem;
    margin: 0 auto;
    padding: 2rem;
    border-radius: 16px;
    background: rgba(255, 255, 255, calc(0.06 + 0.06 * var(--alive)));
    backdrop-filter: blur(calc(6px + 10px * var(--alive)));
    -webkit-backdrop-filter: blur(calc(6px + 10px * var(--alive)));
    border: 1px solid rgba(var(--mood-accent-rgb, 0,0,0), calc(0.08 + 0.14 * var(--alive)));
    box-shadow:
      0 calc(4px + 12px * var(--alive)) calc(24px + 16px * var(--alive))
        rgba(var(--mood-shadow-rgb, 0,0,0), calc(0.06 + 0.18 * var(--alive)));
  }

  .now-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
    font-size: 0.8rem;
    opacity: calc(0.5 + 0.5 * var(--alive));
    color: var(--mood-accent, currentColor);
  }

  .now-doing {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    opacity: calc(0.4 + 0.6 * var(--alive));
  }

  .now-thinking {
    margin: 0 0 1.25rem;
    padding-left: 1rem;
    border-left: 2px solid rgba(var(--mood-accent-rgb, 0,0,0), calc(0.15 + 0.25 * var(--alive)));
    font-style: italic;
    opacity: calc(0.45 + 0.55 * var(--alive));
  }

  /* Counter-decay: quip becomes MORE visible as content fades */
  .now-quip {
    font-size: 0.78rem;
    font-style: italic;
    text-align: right;
    opacity: calc(0.35 + 0.55 * var(--decay));
    color: var(--mood-accent, currentColor);
  }
</style>
