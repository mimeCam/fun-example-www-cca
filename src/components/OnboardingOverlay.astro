---
// src/components/OnboardingOverlay.astro
// Full-screen conviction onboarding overlay — 3-step post lifecycle explainer.
//
// CSS state machine: [data-step="1|2|3"] on the root drives all visibility.
// JS only swaps the attribute — zero rendering in JS.
//
// Steps:
//   1 — "Posts decay"       — decay bar animation
//   2 — "Authors seal bets" — conviction seal ceremony
//   3 — "Truth is tracked"  — batting average + verdict
//
// Starts hidden (hidden attr). Client onboarding.ts removes [hidden] at idle.
// Dismiss: close button (always), Escape key, swipe-left past step 3.
//
// ConvictionDemo is rendered once; its CSS :global([data-step]) selectors
// control which demo state is visible — no 3× HTML duplication.
//
// Credits: Mike Koch (arch spec 2026-04-11), Tanya Donska (design tokens)

import ConvictionDemo  from './ConvictionDemo.astro';
import ConvictionStrip from './ConvictionStrip.astro';
---

<div
  id="onboarding-overlay"
  class="ov"
  role="dialog"
  aria-modal="true"
  aria-label="Welcome to Conviction Ledger"
  data-step="1"
  hidden
>
  <!-- ── Backdrop ──────────────────────────────────────────── -->
  <div class="ov-backdrop" aria-hidden="true"></div>

  <!-- ── Panel ─────────────────────────────────────────────── -->
  <div class="ov-panel">

    <!-- Close button — always visible -->
    <button
      class="ov-close"
      type="button"
      aria-label="Dismiss onboarding"
      data-ov-dismiss
    >✕</button>

    <!-- Progress dots -->
    <div class="ov-dots" aria-hidden="true">
      <button class="ov-dot" data-ov-dot="1" aria-label="Go to step 1" tabindex="-1"></button>
      <button class="ov-dot" data-ov-dot="2" aria-label="Go to step 2" tabindex="-1"></button>
      <button class="ov-dot" data-ov-dot="3" aria-label="Go to step 3" tabindex="-1"></button>
    </div>

    <!-- ── Step headers (one shown at a time) ───────────────── -->
    <div class="ov-steps">

      <div class="ov-step step-1" role="region" aria-label="Step 1 of 3">
        <p class="ov-step__eyebrow">1 of 3</p>
        <h2 class="ov-step__title">Posts have a heartbeat.</h2>
        <p class="ov-step__body">
          Every post on this site loses vitality over time. Without readers
          it fades and eventually dies. Attention is the only currency that
          keeps an idea alive.
        </p>
      </div>

      <div class="ov-step step-2" role="region" aria-label="Step 2 of 3">
        <p class="ov-step__eyebrow">2 of 3</p>
        <h2 class="ov-step__title">Authors bet on their claims.</h2>
        <p class="ov-step__body">
          A sealed post is a public bet. The author locks a conviction score
          (1–10) before the verdict is known. High conviction, high stakes.
          The seal is permanent and tamper-evident.
        </p>
      </div>

      <div class="ov-step step-3" role="region" aria-label="Step 3 of 3">
        <p class="ov-step__eyebrow">3 of 3</p>
        <h2 class="ov-step__title">Truth is tracked.</h2>
        <p class="ov-step__body">
          When a verdict lands, the batting average updates. Every correct
          call raises it. Every wrong one lowers it. The record is public
          and permanent — skin in the game.
        </p>
      </div>

    </div><!-- /ov-steps -->

    <!-- ── Demo: rendered once, CSS state machine controls state ── -->
    <ConvictionDemo />

    <!-- ConvictionStrip: visible only on step 3 (CSS state machine) -->
    <!-- Replaces abstract batting-average text with the live component. -->
    <!-- Credits: Tanya §3 (placement A), Mike arch §Step 3 wiring     -->
    <div class="ov-strip-slot">
      <ConvictionStrip variant="overlay" />
    </div>

    <!-- ── Navigation ─────────────────────────────────────────── -->
    <div class="ov-nav">
      <button class="ov-btn ov-btn--ghost" type="button" data-ov-prev aria-label="Previous step">
        ← prev
      </button>
      <button class="ov-btn ov-btn--primary" type="button" data-ov-next aria-label="Next step">
        <span class="ov-next-label">next →</span>
        <span class="ov-done-label">got it — let me read</span>
      </button>
    </div>

  </div><!-- /ov-panel -->
</div><!-- /ov -->

<script>
  import { init } from '../lib/client/onboarding';
  if ('requestIdleCallback' in window) {
    (window as typeof window & { requestIdleCallback: (cb: () => void, opts?: { timeout: number }) => void })
      .requestIdleCallback(init, { timeout: 1000 });
  } else {
    setTimeout(init, 800);
  }
</script>

<style>
  /* ── Overlay root ─────────────────────────────────────────────── */
  .ov {
    position: fixed;
    inset: 0;
    z-index: var(--z-onboarding);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
  }

  .ov[hidden] { display: none; }

  /* Entrance — panel rises from below */
  .ov--enter .ov-panel {
    animation: ov-enter var(--motion-duration-deliberate) var(--motion-easing-spring) both;
  }

  /* Exit — panel fades out downward */
  .ov--exit .ov-panel {
    animation: ov-exit var(--motion-duration-base) var(--motion-easing-standard) both;
  }

  .ov--exit .ov-backdrop {
    animation: ov-backdrop-out var(--motion-duration-base) ease both;
  }

  @keyframes ov-enter {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes ov-exit {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(16px); }
  }

  @keyframes ov-backdrop-out {
    from { opacity: 1; }
    to   { opacity: 0; }
  }

  /* ── Backdrop ────────────────────────────────────────────────── */
  .ov-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(12, 12, 14, 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* ── Panel ───────────────────────────────────────────────────── */
  .ov-panel {
    position: relative;
    z-index: 1;
    background: var(--surface-deep, oklch(11% 0.010 50));
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-modal);
    width: 100%;
    max-width: 28rem;
    max-height: calc(100dvh - var(--space-8));
    overflow-y: auto;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    scrollbar-width: none;
  }

  .ov-panel::-webkit-scrollbar { display: none; }

  /* ── Close button ────────────────────────────────────────────── */
  .ov-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: none;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    color: var(--text-ghost);
    font-size: var(--text-xs);
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color var(--motion-duration-fast) ease,
                border-color var(--motion-duration-fast) ease;
  }

  .ov-close:hover {
    color: var(--text-secondary);
    border-color: var(--border-medium);
  }

  /* ── Progress dots ───────────────────────────────────────────── */
  .ov-dots {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    padding-top: var(--space-2);
  }

  .ov-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    border: none;
    background: var(--border-medium);
    cursor: pointer;
    padding: 0;
    transition: background var(--motion-duration-base) ease,
                transform var(--motion-duration-fast) ease;
  }

  .ov-dot:hover { transform: scale(1.4); }

  /* Active dot driven by [data-step] on overlay root */
  [data-step="1"] .ov-dot[data-ov-dot="1"],
  [data-step="2"] .ov-dot[data-ov-dot="2"],
  [data-step="3"] .ov-dot[data-ov-dot="3"] {
    background: var(--gold);
    transform: scale(1.3);
  }

  /* ── Step text sections ── CSS state machine ─────────────────── */
  .ov-step { display: none; }

  [data-step="1"] .step-1,
  [data-step="2"] .step-2,
  [data-step="3"] .step-3 { display: block; }

  /* ── Step header ─────────────────────────────────────────────── */
  .ov-step__eyebrow {
    font-size: var(--text-2xs);
    font-family: var(--font-mono);
    color: var(--gold-dim);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    margin: 0 0 var(--space-2);
  }

  .ov-step__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-2);
  }

  .ov-step__body {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-prose);
    margin: 0;
  }

  /* ── ConvictionStrip slot — step 3 only ─────────────────────── */
  /* Hidden on steps 1 & 2; revealed on step 3 (CSS state machine).  */
  /* ConvictionDemo hides on step 3 — strip takes the demo role.     */
  .ov-strip-slot { display: none; }
  [data-step="3"] .ov-strip-slot { display: block; }
  [data-step="3"] :global([data-conviction-demo]) { display: none; }

  /* ── Navigation row ──────────────────────────────────────────── */
  .ov-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-4);
  }

  .ov-btn {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    cursor: pointer;
    letter-spacing: var(--tracking-wide);
    transition: color var(--motion-duration-fast) ease,
                border-color var(--motion-duration-fast) ease,
                background var(--motion-duration-fast) ease;
  }

  .ov-btn--ghost {
    background: none;
    border: 1px solid var(--border-subtle);
    color: var(--text-ghost);
  }

  .ov-btn--ghost:hover {
    color: var(--text-secondary);
    border-color: var(--border-medium);
  }

  .ov-btn--primary {
    background: var(--gold-bg);
    border: 1px solid var(--gold-border);
    color: var(--gold);
    flex-shrink: 0;
  }

  .ov-btn--primary:hover {
    background: rgba(245, 166, 35, 0.14);
    border-color: var(--gold-dim);
  }

  /* Hide prev on step 1 */
  [data-step="1"] [data-ov-prev] {
    opacity: 0;
    pointer-events: none;
  }

  /* Toggle "next →" vs "got it" label based on step */
  .ov-done-label { display: none; }
  [data-step="3"] .ov-next-label { display: none; }
  [data-step="3"] .ov-done-label { display: inline; }

  /* ── Mobile: bottom sheet ────────────────────────────────────── */
  @media (max-width: 480px) {
    .ov { padding: 0; align-items: flex-end; }

    .ov-panel {
      max-width: 100%;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      padding: var(--space-5) var(--space-4) calc(var(--space-5) + env(safe-area-inset-bottom));
      max-height: 90dvh;
    }
  }

  /* ── Reduced motion ──────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .ov--enter .ov-panel,
    .ov--exit .ov-panel,
    .ov--exit .ov-backdrop { animation: none; }
  }
</style>
