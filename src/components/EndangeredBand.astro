---
// src/components/EndangeredBand.astro
// Homepage surface for posts approaching entombment (decay ≥ 0.80, < 0.95).
// Renders between archive band and Murmurs — the "last chance" threshold.
//
// Empty state: section doesn't render (handled by parent conditional).
// Posts sorted by most-endangered first (highest decay).
// SavedMoment fires when the last card is revived and the band empties.
//
// Credits: Mike (napkin plan §2), Tanya (UX spec §3.2B — dashed container,
//          warm gradient, single-card emphasis)

import EndangeredCard from './EndangeredCard.astro';
import SavedMoment from './SavedMoment.astro';
import type { PostDisplayData } from '../lib/postMeta';

interface Props { posts: PostDisplayData[]; }

const { posts } = Astro.props;
const sorted = [...posts].sort(byMostEndangered);

function byMostEndangered(a: PostDisplayData, b: PostDisplayData): number {
  return b.decay - a.decay;
}
---

<section
  class="band band--endangered"
  aria-label="Posts about to be forgotten"
  aria-live="polite"
  data-endangered-count={sorted.length}
>
  <div class="endangered-header">
    <div class="endangered-header-left">
      <h2 class="endangered-label">
        <span class="endangered-pulse-dot"></span>
        Fading away
      </h2>
      <p class="endangered-hint">These posts die without your attention</p>
    </div>
    <a href="/endangered" class="endangered-view-all">view all &rarr;</a>
  </div>

  <div class="endangered-cards" data-endangered-count={sorted.length}>
    {sorted.map(post => <EndangeredCard post={post} />)}
  </div>
  <SavedMoment />
</section>
