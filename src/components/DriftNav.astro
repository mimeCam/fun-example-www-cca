---
// src/components/DriftNav.astro
// Prominent 3-link wayfinding bar — Home, Now, Wall.
// Designed for discoverability; sits at page bottom as a "where next?" prompt.
// Consumes mood palette via CSS custom properties. Zero JS. 44px touch targets.
//
// TODO: v2 — mood-accent animated underline, erosion/decay text effects

import { getActivePage, type PageId } from '../lib/nav';

const pageId = getActivePage(Astro.url.pathname);

const links: { label: string; href: string; id: PageId }[] = [
  { label: 'home',  href: '/',    id: 'home' },
  { label: 'now',   href: '/now', id: 'now'  },
  { label: 'wall',  href: '/wall', id: 'wall' },
];
---

<nav class="drift-nav" aria-label="Quick navigation">
  {links.map(l => (
    <a
      href={l.href}
      class:list={['drift-link', { active: pageId === l.id }]}
      aria-current={pageId === l.id ? 'page' : undefined}
    >
      {l.label}
    </a>
  ))}
</nav>

<style>
  .drift-nav {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    padding: 1.5rem 1rem;
    margin-top: 3rem;
  }

  .drift-link {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    text-decoration: none;
    color: var(--mood-accent, currentColor);
    opacity: 0.7;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    padding: 0 0.75rem;
    transition: opacity 0.2s ease;
  }

  .drift-link:hover,
  .drift-link:focus-visible {
    opacity: 1;
  }

  .drift-link.active {
    opacity: 1;
    border-bottom: 1px solid var(--mood-accent, currentColor);
  }

  @media (prefers-reduced-motion: reduce) {
    .drift-link { transition: none; }
  }
</style>
