---
// src/components/TidepoolEntry.astro
// Single link card for the tidepool — curated external links with decay.
// Fresh links show a foreign teal hue that blends into --mood-accent over 45 days.
// Uses data-posted / data-max-days so liveDecayScript() refreshes at visit.
//
// TODO: add copy-link button with navigator.clipboard (~15 lines inline JS)

import type { ComputedTidepoolLink } from '../lib/tidepool';
import { DECAY_WINDOW } from '../lib/tidepool';

interface Props { entry: ComputedTidepoolLink }

const { entry } = Astro.props;
const { link, decay, state, domain } = entry;
---

<article
  class={`tidepool-entry tp-${state}`}
  data-posted={link.date}
  data-max-days={String(DECAY_WINDOW)}
  style={`--decay:${decay.toFixed(3)}`}
>
  <a href={link.url} class="tp-title" target="_blank" rel="noopener noreferrer">
    {link.title}
  </a>
  <span class="tp-domain">{domain}</span>
  {link.note && <p class="tp-note">{link.note}</p>}
</article>

<style>
  .tidepool-entry {
    --alive: calc(1 - var(--decay));
    --foreign-hue: oklch(72% 0.15 220);
    --blend: calc(var(--decay) * 100%);
    max-width: 36rem;
    padding: calc(0.6rem + 0.4rem * var(--alive)) 0.75rem;
    border-left: 3px solid color-mix(
      in oklch, var(--foreign-hue), var(--mood-accent, #9CA3AF) var(--blend)
    );
    border-radius: 0 12px 12px 0;
    opacity: calc(0.55 + 0.45 * var(--alive));
    box-shadow: inset 2px 0 8px rgba(var(--mood-shadow-rgb, 120,120,120), calc(0.03 + 0.07 * var(--alive)));
    margin-bottom: calc(0.5rem + 0.5rem * var(--alive));
    transition: opacity 0.3s ease;
  }
  .tp-title {
    font-size: calc(0.82rem + 0.06rem * var(--alive));
    text-decoration: none;
    color: inherit;
    opacity: calc(0.7 + 0.3 * var(--alive));
    display: block;
    margin-bottom: 0.2rem;
  }
  .tp-title:hover { text-decoration: underline; }
  .tp-domain {
    font-size: 0.65rem;
    opacity: 0.4;
    letter-spacing: 0.03em;
  }
  .tp-note {
    font-size: 0.78rem;
    font-style: italic;
    opacity: calc(0.4 + 0.3 * var(--alive));
    margin: 0.3rem 0 0;
    line-height: 1.4;
  }
</style>
