---
// src/components/WallEntry.astro
// A single active wall entry. --decay drives spatial compression:
// fresh thoughts are big and airy, old ones physically shrink.
// Entry-level mood colors are scoped via inline style vars.
//
// TODO: add geology texture class per mood (v2)
// TODO: dust overlay at high decay (v2)
// TODO: hover-reveal # link for anchor sharing (v2)

import type { ComputedWallEntry } from '../lib/wall';
import { resolveMood } from '../lib/mood';

interface Props {
  computed: ComputedWallEntry;
}

const { computed } = Astro.props;
const { entry, decay, quip, state } = computed;
const mood = resolveMood(entry.mood);
const entryStyle = `--decay: ${decay.toFixed(3)}; --entry-accent-rgb: ${mood.accent_rgb};`;
---

<article id={entry.id} class={`wall-entry wall-${state}`} style={entryStyle} data-posted={entry.posted} data-max-days="30">
  <p class="wall-text">{entry.text}</p>
  <footer class="wall-meta">
    <span class="wall-quip">{quip}</span>
    <span class="wall-mood">{mood.label}</span>
  </footer>
</article>

<style>
  .wall-entry {
    --alive: calc(1 - var(--decay));
    padding: calc(0.75rem + 1.25rem * var(--alive));
    border-radius: calc(2px + 10px * var(--alive));
    background: rgba(255, 255, 255, calc(0.04 + 0.06 * var(--alive)));
    border: 1px solid rgba(var(--entry-accent-rgb, 0,0,0), calc(0.06 + 0.14 * var(--alive)));
    box-shadow:
      0 calc(2px + 10px * var(--alive)) calc(16px + 16px * var(--alive))
        rgba(var(--entry-accent-rgb, 0,0,0), calc(0.04 + 0.14 * var(--alive)));
    transition: none;
  }

  .wall-text {
    margin: 0;
    font-size: calc(0.8rem + 0.35rem * var(--alive));
    line-height: calc(1.3 + 0.35 * var(--alive));
    opacity: calc(0.5 + 0.5 * var(--alive));
  }

  .wall-meta {
    display: flex;
    justify-content: space-between;
    margin-top: calc(0.4rem + 0.4rem * var(--alive));
    font-size: 0.72rem;
    opacity: calc(0.3 + 0.4 * var(--alive));
  }

  .wall-quip {
    font-style: italic;
    color: rgba(var(--entry-accent-rgb, 0,0,0), calc(0.4 + 0.5 * var(--alive)));
  }

  .wall-mood {
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>
