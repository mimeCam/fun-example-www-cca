---
// src/components/PlanetariumWindow.astro
// Cropped constellation hero for the homepage — a "window" into the star field.
// Shows a glimpse of the first constellation, inviting exploration.
// Links to /constellations. Pure CSS, no JS.
//
// TODO: show top-3 brightest stars across all constellations instead of first only
// TODO: animate line drawing on page load via stroke-dashoffset

import { computeAllConstellations } from '../lib/constellation';
import rawConstellations from '../data/constellations.json';

const all = computeAllConstellations(rawConstellations);
const preview = all[0];
const stars = preview?.stars.slice(0, 4) ?? [];
---

{preview && (
  <a href="/constellations" class="pw-link" aria-label="Explore constellations">
    <div class="planetarium-window">
      <svg viewBox="20 20 60 40" preserveAspectRatio="xMidYMid slice"
           class="pw-svg" aria-hidden="true">
        {stars.slice(1).map((s, i) => (
          <line x1={stars[i].x} y1={stars[i].y} x2={s.x} y2={s.y}
                class="pw-line" stroke-opacity={s.brightness * 0.25} />
        ))}
        {stars.map(s => (
          <g>
            <circle cx={s.x} cy={s.y} r="0.8" class="pw-glow"
                    opacity={s.brightness * 0.35} />
            <circle cx={s.x} cy={s.y} r="0.3" class="pw-core"
                    opacity={s.brightness} />
          </g>
        ))}
      </svg>
      <span class="pw-caption">{preview.constellation.name}</span>
    </div>
  </a>
)}

<style>
  .pw-link { text-decoration: none; display: block; }
  .planetarium-window {
    position: relative;
    height: 10rem;
    overflow: hidden;
    border-radius: 12px;
    background: radial-gradient(ellipse at 50% 60%, #0d1117, #010409);
    margin-bottom: 1.5rem;
    transition: box-shadow 300ms ease;
  }
  .pw-link:hover .planetarium-window {
    box-shadow: 0 0 24px rgba(var(--mood-accent-rgb, 107,163,196), 0.15);
  }
  .pw-svg { width: 100%; height: 100%; }
  .pw-line {
    stroke: var(--mood-accent, rgba(255,255,255,0.4));
    stroke-width: 0.08; stroke-dasharray: 0.4 0.2;
  }
  .pw-glow {
    fill: var(--mood-accent, rgba(255,255,255,0.3));
    animation: pw-twinkle 5s ease-in-out infinite alternate;
  }
  .pw-core { fill: #e8e8f0; }
  .pw-caption {
    position: absolute; bottom: 0.6rem; right: 0.8rem;
    font-size: 0.6rem; color: rgba(255,255,255,0.35);
    letter-spacing: 0.05em; font-style: italic;
  }
  @keyframes pw-twinkle {
    0%, 100% { filter: blur(0.2px); }
    50%      { filter: blur(0.6px); opacity: 0.6; }
  }
  @media (prefers-reduced-motion: reduce) { .pw-glow { animation: none; } }
</style>
