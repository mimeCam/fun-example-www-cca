---
// src/components/DriftButton.astro
// Floating 48px circle button that triggers the Drift scene.
// Dims permanently after one use — scarcity as ritual.
// No props needed. Pure ambient UI element.
//
// TODO: v1.1 — subtle breathing animation before first click
// TODO: v1.1 — mood-aware glow color on hover
---

<button
  data-drift-btn
  type="button"
  aria-label="Drift — resurface a forgotten thought"
  title="Drift"
>
  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
    <path d="M10 2a8 8 0 1 0 8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M18 2v5h-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<style>
  button[data-drift-btn] {
    position: fixed;
    bottom: 2rem;
    left: 2rem;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(var(--mood-accent-rgb, 156, 163, 175), 0.25);
    background: rgba(var(--mood-accent-rgb, 156, 163, 175), 0.08);
    color: rgba(var(--mood-accent-rgb, 156, 163, 175), 0.7);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.4s, background 0.3s, border-color 0.3s;
    z-index: 90;
    backdrop-filter: blur(8px);
  }
  button[data-drift-btn]:hover:not(:disabled) {
    background: rgba(var(--mood-accent-rgb, 156, 163, 175), 0.16);
    border-color: rgba(var(--mood-accent-rgb, 156, 163, 175), 0.5);
    color: rgba(var(--mood-accent-rgb, 156, 163, 175), 1);
  }
  button[data-drift-btn].drift-used {
    opacity: 0.2;
    cursor: default;
    pointer-events: none;
  }
</style>
