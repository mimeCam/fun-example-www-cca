---
// src/components/RewardWhisper.astro
// Post-revival reward toast — bottom-right, auto-dismiss.
// Replaces RevivalReward.astro template + revivalToast DOM creation.
//
// CSS-only enter/exit. No JS animation frames.
// A11y: role="status", aria-live="polite".
---

<div
  id="reward-whisper"
  class="reward-toast"
  role="status"
  aria-live="polite"
>
  <span class="reward-label">You remembered it.</span>
  <span class="reward-count"></span>
</div>

<style>
  .reward-toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 20;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(var(--mood-accent-rgb, 120, 120, 120), 0.12);
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 300ms ease, transform 300ms ease;
  }

  .reward-toast:global(.reward--visible) {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .reward-toast:global(.reward--exiting) {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 300ms ease-in, transform 300ms ease-in;
  }

  .reward-label {
    font-size: 0.75rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.7);
  }

  .reward-count {
    display: block;
    font-size: 0.65rem;
    color: rgba(var(--mood-accent-rgb, 120, 120, 120), 0.6);
    margin-top: 0.15rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .reward-toast {
      transition: none;
    }
    .reward-toast:global(.reward--visible) {
      opacity: 1;
      transform: none;
    }
    .reward-toast:global(.reward--exiting) {
      opacity: 0;
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .reward-toast {
      right: 1rem;
      bottom: 1rem;
    }
  }
</style>
