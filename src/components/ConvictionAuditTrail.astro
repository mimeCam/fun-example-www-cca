---
// src/components/ConvictionAuditTrail.astro
// Collapsible hash-chain timeline at the bottom of each post.
// Uses <details> — native collapse, zero JS, zero Lighthouse CLS impact.
// Color-coded by event type: gold (seal), green (revival), red (death), purple (resurrection).
//
// Credits: Mike (spec), Tanya (placement — below GhostEchoes, before PostNav)

import { getEntriesForSlug } from '../lib/conviction-ledger';
import type { LedgerEntry } from '../lib/conviction-ledger';

interface Props {
  slug: string;
}

const { slug } = Astro.props;

let entries: LedgerEntry[] = [];

try {
  entries = getEntriesForSlug(slug);
} catch {
  // DB unavailable at build time — render nothing
}

if (!entries.length) return;

const EVENT_LABEL: Record<string, string> = {
  seal: 'Sealed',
  revival: 'Revival',
  death: 'Death',
  resurrection: 'Resurrection',
};

function fmtDate(ts: number): string {
  return new Date(ts).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
  });
}

function fmtMinutes(seconds: number): string {
  const m = Math.round(seconds / 60);
  return m === 1 ? '1 min read' : `${m} min read`;
}
---

<details class="audit-trail">
  <summary class="audit-toggle" aria-label="Toggle conviction audit trail">
    <span class="audit-icon" aria-hidden="true">⛓</span>
    <span class="audit-label">conviction audit trail</span>
    <span class="audit-count">{entries.length}</span>
  </summary>

  <ol class="audit-list" aria-label="Conviction timeline">
    {entries.map((entry) => (
      <li class={`audit-entry entry--${entry.event_type}`}>

        <div class="entry-row">
          <span class="entry-badge">{EVENT_LABEL[entry.event_type] ?? entry.event_type}</span>
          <time class="entry-time" datetime={new Date(entry.timestamp).toISOString()}>
            {fmtDate(entry.timestamp)}
          </time>
          {entry.conviction_score !== null && (
            <span class="entry-score">{entry.conviction_score}/10</span>
          )}
        </div>

        {entry.author_note && (
          <p class="entry-note">"{entry.author_note}"</p>
        )}

        {(entry.revival_count > 0 || entry.reader_seconds > 0) && (
          <div class="entry-stats">
            {entry.revival_count > 0 && (
              <span>+{entry.revival_count} revival{entry.revival_count !== 1 ? 's' : ''}</span>
            )}
            {entry.reader_seconds > 0 && <span>{fmtMinutes(entry.reader_seconds)}</span>}
          </div>
        )}

        <code class="hash-prefix" title={`Full hash: ${entry.hash}`}>
          #{entry.hash.slice(0, 8)}
        </code>

      </li>
    ))}
  </ol>
</details>

<style>
  .audit-trail {
    margin: 2rem 0 0;
    border-top: 1px solid var(--border-subtle);
    padding-top: 1rem;
  }

  /* Strip default disclosure triangle */
  .audit-trail summary           { list-style: none; }
  .audit-trail summary::-webkit-details-marker { display: none; }

  .audit-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--text-dim);
    user-select: none;
    transition: color 200ms ease;
    width: fit-content;
  }

  .audit-toggle:hover { color: var(--text-secondary); }

  .audit-icon  { font-size: var(--text-sm); }
  .audit-label { text-transform: uppercase; }

  .audit-count {
    background: var(--border-subtle);
    border-radius: 3px;
    padding: 0.05em 0.35em;
    font-size: var(--text-2xs);
    opacity: 0.7;
  }

  /* Timeline list — left ruled line gives chain feel */
  .audit-list {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0 0 0 1rem;
    border-left: 1px solid var(--border-light);
    display: flex;
    flex-direction: column;
  }

  .audit-entry {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-faint);
    font-size: var(--text-sm);
  }

  .audit-entry:last-child { border-bottom: none; }

  /* Entry header row */
  .entry-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
  }

  /* Event type badge */
  .entry-badge {
    font-size: var(--text-2xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.15em 0.55em;
    border-radius: 3px;
  }

  /* Palette — matches Tanya's decay spectrum semantics */
  .entry--seal         .entry-badge { background: color-mix(in oklch, var(--gold) 14%, transparent); color: var(--gold-mid); }
  .entry--revival      .entry-badge { background: color-mix(in oklch, var(--verdict-true) 11%, transparent); color: color-mix(in oklch, var(--verdict-true) 85%, transparent); }
  .entry--death        .entry-badge { background: color-mix(in oklch, var(--verdict-wrong) 11%, transparent); color: color-mix(in oklch, var(--verdict-wrong) 85%, transparent); }
  .entry--resurrection .entry-badge { background: color-mix(in oklch, var(--verdict-evolved) 11%, transparent); color: color-mix(in oklch, var(--verdict-evolved) 85%, transparent); }

  .entry-time {
    font-size: var(--text-xs);
    color: var(--text-dim);
    margin-left: auto;
  }

  .entry-score {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-secondary);
  }

  /* Author wager note */
  .entry-note {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    font-style: italic;
    margin: 0.2rem 0 0.35rem;
    line-height: 1.45;
  }

  /* Cumulative stats row */
  .entry-stats {
    display: flex;
    gap: 0.75rem;
    font-size: var(--text-2xs);
    color: var(--text-dim);
    margin-bottom: 0.35rem;
  }

  .hash-prefix {
    font-family: var(--font-mono);
    font-size: var(--text-3xs);
    color: var(--text-faint);
    letter-spacing: var(--tracking-wide);
    background: none;
    padding: 0;
    cursor: default;
  }

</style>
