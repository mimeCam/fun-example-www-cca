---
// src/components/DisputeChallenge.astro
// "Challenge Moment" — hold-to-challenge gesture for disagreeing readers.
// Eligible: reader staked 'disagree' + verdict sealed + hasn't disputed yet.
// Hold 800ms (SPRING profile) to commit — same UX grammar as KeepButton,
// inverse emotional register: amber → red fill (challenge = consequential).
// Credits: Mike (napkin plan §Challenge-Moment, §hold-gesture-deliberate-reuse),
//          Tanya (§StanceDrawer interaction pattern, §color-as-signal axiom)

import type { DisputeState } from '../lib/verdict-dispute';

interface Props {
  slug:          string;
  verdictSealed: boolean;
  disputeState:  DisputeState;
}

const { slug, verdictSealed, disputeState } = Astro.props;
---

{verdictSealed && (
  <section
    class="dispute-challenge"
    id="dispute-challenge"
    data-slug={slug}
    aria-label="Challenge this verdict"
    style="display:none"
  >
    <div class="dispute-challenge__inner">

      <!-- Eyebrow -->
      <p class="dispute-challenge__eyebrow">You disagreed. The verdict is sealed.</p>

      <!-- Headline -->
      <h3 class="dispute-challenge__headline">Contest this outcome?</h3>

      <!-- Body copy -->
      <p class="dispute-challenge__body">
        Hold the button for 2 seconds to file a formal challenge.
        If <strong>1 in 3</strong> dissenting readers challenge this verdict,
        it becomes <strong>contested</strong> — excluded from the batting average
        until the author responds.
      </p>

      <!-- Reason selector -->
      <fieldset class="dispute-challenge__reasons" id="dispute-reasons">
        <legend class="dispute-challenge__reasons-legend">Reason <span class="dispute-challenge__optional">(optional)</span></legend>
        {(['Too vague', 'Outcome contradicts claim', 'Moved goalposts', 'Other'] as const).map(r => (
          <label class="dispute-challenge__reason-label">
            <input
              type="radio"
              name="dispute-reason"
              value={r}
              class="dispute-challenge__reason-input"
            />
            <span class="dispute-challenge__reason-text">{r}</span>
          </label>
        ))}
      </fieldset>

      <!-- Hold-to-challenge button -->
      <div class="dispute-challenge__btn-wrap">
        <button
          class="dispute-challenge__btn"
          id="dispute-submit-btn"
          data-slug={slug}
          type="button"
          aria-label="Hold to file a formal dispute against this verdict"
        >
          <span class="dispute-challenge__btn-fill" aria-hidden="true"></span>
          <span class="dispute-challenge__btn-label">Hold to Challenge</span>
        </button>
        <p class="dispute-challenge__hint" id="dispute-hint" aria-live="polite"></p>
      </div>

      <!-- Post-submit feedback -->
      <div class="dispute-challenge__feedback" id="dispute-feedback" aria-live="polite" hidden></div>

    </div>
  </section>
)}

<script>
(function mountDisputeChallenge() {
  const section = document.getElementById('dispute-challenge');
  if (!section) return;

  const slug       = section.dataset.slug ?? '';
  const STANCE_KEY = `stance-${slug}`;
  const DISPUTE_KEY = `dispute-${slug}`;

  // ── Guards ────────────────────────────────────────────────────────────────

  function hasDisagreed(): boolean {
    try { return localStorage.getItem(STANCE_KEY) === 'disagree'; } catch { return false; }
  }

  function alreadyDisputed(): boolean {
    try { return localStorage.getItem(DISPUTE_KEY) === '1'; } catch { return false; }
  }

  function getSessionId(): string | null {
    try { return localStorage.getItem('_sid'); } catch { return null; }
  }

  function selectedReason(): string {
    const checked = document.querySelector<HTMLInputElement>('input[name="dispute-reason"]:checked');
    return checked?.value ?? '';
  }

  // Show section only for eligible readers
  if (!hasDisagreed() || alreadyDisputed()) return;
  section.style.display = '';

  // ── Hold gesture ──────────────────────────────────────────────────────────

  const btn      = document.getElementById('dispute-submit-btn') as HTMLButtonElement | null;
  const fill     = btn?.querySelector<HTMLElement>('.dispute-challenge__btn-fill');
  const label    = btn?.querySelector<HTMLElement>('.dispute-challenge__btn-label');
  const hint     = document.getElementById('dispute-hint');
  const feedback = document.getElementById('dispute-feedback') as HTMLElement | null;
  if (!btn || !fill || !label || !feedback) return;

  const HOLD_MS = 2000;
  let holdTimer: ReturnType<typeof setTimeout> | null = null;

  function startHold(): void {
    if (btn!.classList.contains('disputed')) return;
    btn!.classList.add('holding');
    fill!.style.transitionDuration = `${HOLD_MS}ms`;
    if (hint) hint.textContent = 'Keep holding…';
    holdTimer = setTimeout(commitDispute, HOLD_MS);
  }

  function cancelHold(): void {
    if (holdTimer) { clearTimeout(holdTimer); holdTimer = null; }
    btn!.classList.remove('holding');
    fill!.style.transitionDuration = '200ms';
    if (hint) hint.textContent = '';
  }

  function lockButton(): void {
    btn!.classList.add('disputed');
    btn!.setAttribute('disabled', 'true');
    label!.textContent = 'Challenged ✓';
    if (hint) hint.textContent = '';
  }

  function restoreButton(): void {
    btn!.classList.remove('holding');
    fill!.style.transitionDuration = '200ms';
    label!.textContent = 'Hold to Challenge';
    if (hint) hint.textContent = '';
  }

  // ── Submit ────────────────────────────────────────────────────────────────

  async function commitDispute(): Promise<void> {
    holdTimer = null;
    btn!.classList.remove('holding');
    const sessionId = getSessionId();
    if (!sessionId) { showError('Session not found — refresh and try again.'); return; }

    lockButton();
    try {
      const res  = await fetch('/api/verdict-dispute', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Session-Id': sessionId },
        body: JSON.stringify({ slug, reason: selectedReason() }),
      });
      const data = await res.json() as Record<string, unknown>;
      if (data.ok) {
        localStorage.setItem(DISPUTE_KEY, '1');
        showSuccess(data);
      } else {
        restoreButton();
        showError((data.error as string) ?? 'Could not file dispute.');
      }
    } catch {
      restoreButton();
      showError('Network error — try again.');
    }
  }

  function showSuccess(data: Record<string, unknown>): void {
    const state = (data.state as { status?: string } | undefined)?.status ?? 'open';
    feedback!.textContent = state === 'contested'
      ? 'Verdict is now contested — the author must respond.'
      : 'Challenge recorded. Quorum threshold not yet reached.';
    feedback!.hidden = false;
    document.dispatchEvent(new CustomEvent('dispute:recorded', { detail: { slug, state: data.state } }));
  }

  function showError(msg: string): void {
    feedback!.textContent = msg;
    feedback!.hidden = false;
  }

  // ── Event wiring ──────────────────────────────────────────────────────────

  btn.addEventListener('mousedown',   startHold);
  btn.addEventListener('touchstart',  startHold, { passive: true });
  btn.addEventListener('mouseup',     cancelHold);
  btn.addEventListener('mouseleave',  cancelHold);
  btn.addEventListener('touchend',    cancelHold);
  btn.addEventListener('touchcancel', cancelHold);
  btn.addEventListener('keydown', (e) => {
    if (e.key === ' ' || e.key === 'Enter') startHold();
  });
  btn.addEventListener('keyup', (e) => {
    if (e.key === ' ' || e.key === 'Enter') cancelHold();
  });
})();
</script>

<style>
  /* ── Section wrapper ──────────────────────────────────────────────────── */
  .dispute-challenge {
    padding: 1.5rem;
    background: color-mix(in oklch, var(--gold) 2.5%, transparent);
    border: 1px solid var(--gold-bg-strong);
    border-radius: var(--radius-md);
  }

  .dispute-challenge__inner {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  /* ── Typography ── */
  .dispute-challenge__eyebrow {
    font-size: var(--text-2xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--gold-dim);
    margin: 0;
  }

  .dispute-challenge__headline {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
    margin: 0;
    letter-spacing: var(--tracking-tight);
  }

  .dispute-challenge__body {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .dispute-challenge__body strong {
    color: var(--text-primary);
    font-weight: var(--weight-semibold);
  }

  /* ── Reason fieldset ── */
  .dispute-challenge__reasons {
    border: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .dispute-challenge__reasons-legend {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--text-secondary);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin-bottom: 0.45rem;
    float: none;
    padding: 0;
  }

  .dispute-challenge__optional {
    font-weight: var(--weight-normal);
    opacity: 0.5;
    text-transform: none;
    letter-spacing: 0;
  }

  .dispute-challenge__reason-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }

  .dispute-challenge__reason-input {
    accent-color: var(--color-dispute-contested);
    width: 14px;
    height: 14px;
    cursor: pointer;
    flex-shrink: 0;
  }

  .dispute-challenge__reason-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    transition: color var(--motion-snap-duration) var(--motion-snap-easing);
  }

  .dispute-challenge__reason-label:hover .dispute-challenge__reason-text {
    color: var(--text-primary);
  }

  /* ── Hold-to-challenge button ── */
  .dispute-challenge__btn-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }

  .dispute-challenge__btn {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.5rem 1.5rem;
    border: 1.5px solid var(--gold-border-strong);
    border-radius: var(--radius-sm);
    background: color-mix(in oklch, var(--gold) 5%, transparent);
    color: var(--gold-mid);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    font-family: inherit;
    letter-spacing: var(--tracking-snug);
    cursor: pointer;
    user-select: none;
    transition:
      border-color  var(--motion-snap-duration) var(--motion-snap-easing),
      background    var(--motion-snap-duration) var(--motion-snap-easing),
      color         var(--motion-snap-duration) var(--motion-snap-easing),
      transform     var(--motion-snap-duration) var(--motion-snap-easing);
  }

  .dispute-challenge__btn:hover:not(:disabled):not(.disputed) {
    border-color: var(--gold-dim);
    background:   var(--gold-bg);
    transform: scale(1.01);
  }

  .dispute-challenge__btn:active:not(.disputed) { transform: scale(0.98); }

  /* Fill layer — scaleX 0→1 on hold */
  .dispute-challenge__btn-fill {
    position: absolute;
    inset: 0;
    transform: scaleX(0);
    transform-origin: left center;
    background: linear-gradient(90deg, var(--color-dispute-fill-from), var(--color-dispute-fill-to));
    opacity: 0.22;
    transition: transform var(--motion-flow-duration) linear;
    pointer-events: none;
  }

  .dispute-challenge__btn.holding .dispute-challenge__btn-fill {
    transform: scaleX(1);
    /* duration is overridden by JS to HOLD_MS */
  }

  /* Button label stays above the fill */
  .dispute-challenge__btn-label {
    position: relative;
    z-index: var(--z-card);
  }

  /* Committed state */
  .dispute-challenge__btn.disputed {
    border-color: var(--gold-bg-strong);
    background:   color-mix(in oklch, var(--gold) 4%, transparent);
    color: var(--gold-dim);
    cursor: default;
  }

  .dispute-challenge__btn:disabled {
    cursor: not-allowed;
  }

  /* ── Hint below button ── */
  .dispute-challenge__hint {
    font-size: var(--text-xs);
    color: var(--text-ghost);
    margin: 0;
    min-height: 1.1em;
    transition: opacity var(--motion-flow-duration) var(--motion-flow-easing);
  }

  /* ── Post-submit feedback ── */
  .dispute-challenge__feedback {
    margin-top: 0.25rem;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
  }

  .dispute-challenge__feedback:not([hidden]) {
    animation: badge-enter var(--motion-flow-duration) var(--motion-flow-easing) both;
  }

  /* v152 motion-sanctuary (Mike §C): the entry fade is pure polish; reduced-
     motion readers see the feedback appear synchronously instead.          */
  @media (prefers-reduced-motion: reduce) {
    .dispute-challenge__feedback:not([hidden]) { animation: none; }
  }
</style>
