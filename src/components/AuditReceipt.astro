---
// src/components/AuditReceipt.astro
// Visual receipt for a sealed conviction — the notary stamp made readable.
// Shows: SEALED stamp, score, sealed-at, hash prefix, anchor link, verify command.
// Pure SSR. Zero client JS — <details> handles the collapsible. Tailwind-free.
//
// Security: verifyInstruction from audit-verifier.ts never includes hmac_seal.
// anchorVerification is a live Gist check — null when no anchor exists yet.
//
// Credits: Mike (spec — AuditReceipt + Conviction Anchor), Tanya (§5 — honest copy)

import type { RedactedSeal }    from '../lib/audit-verifier';
import type { AnchorVerification } from '../lib/anchor-verifier';
import type { TstData }          from '../lib/timestamp-store';
import { verifyToken }           from '../lib/rfc3161-verifier';

interface Props {
  seal:               RedactedSeal | null;
  postTitle:          string;
  anchorVerification?: AnchorVerification | null;
  tstData?:           TstData | null;
  otsData?: { status: string; blockHeight?: number; blockTime?: number; calendarUrl?: string } | null;
  derHexLines?:       string[] | null;
  chainIntegrityOk?:  boolean | null;
}

const {
  seal,
  postTitle,
  anchorVerification  = null,
  tstData             = null,
  otsData             = null,
  derHexLines         = null,
  chainIntegrityOk    = null,
} = Astro.props;
const tstVerification = tstData ? await verifyToken(tstData.tst_token) : null;

const ANCHOR_BADGE: Record<string, { label: string; cls: string }> = {
  'verified':    { label: '✓ Verified externally',  cls: 'anchor-badge--verified'   },
  'mismatch':    { label: '⚠ MISMATCH — tampered?', cls: 'anchor-badge--mismatch'   },
  'unreachable': { label: '~ GitHub unreachable',    cls: 'anchor-badge--unreachable' },
  'no-anchor':   { label: '⏳ Anchor pending',       cls: 'anchor-badge--pending'    },
};
const anchorBadge = anchorVerification ? ANCHOR_BADGE[anchorVerification.status] : null;

function fmtDate(ts: number): string {
  return new Date(ts).toLocaleDateString('en-US', {
    month: 'long', day: 'numeric', year: 'numeric',
  });
}
---

<div class="audit-receipt" aria-label="Conviction seal receipt">

  <!-- Stamp header — SEALED or NOT YET SEALED -->
  <div class:list={['receipt-stamp', seal ? 'receipt-stamp--sealed' : 'receipt-stamp--open']}>
    <span class="stamp-glyph" aria-hidden="true">{seal ? '🔒' : '◇'}</span>
    <span class="stamp-word">{seal ? 'SEALED' : 'NOT YET SEALED'}</span>
  </div>

  <!-- Post title -->
  <h2 class="receipt-title">{postTitle}</h2>

  {seal ? (
    <>
      <!-- Score row -->
      <div class="receipt-row">
        <span class="receipt-label">Conviction score</span>
        <span class="receipt-value receipt-value--score">{seal.score} / 10</span>
      </div>

      <!-- Sealed at: human date + Unix ms for independent verification -->
      <div class="receipt-row">
        <span class="receipt-label">Sealed at</span>
        <div class="receipt-value-stack">
          <span class="receipt-value">{fmtDate(seal.sealedAt)}</span>
          <span class="receipt-meta">{seal.sealedAt} ms</span>
        </div>
      </div>

      <!-- Hash prefix: first 16 hex chars -->
      <div class="receipt-row">
        <span class="receipt-label">Chain hash</span>
        <code class="receipt-hash">
          SHA-256: {seal.hashPrefix}<span class="hash-ellipsis">…</span>
        </code>
      </div>

      <!-- External anchor — GitHub Gist tamper-evident record -->
      <div class="receipt-row">
        <span class="receipt-label">External anchor</span>
        <div class="receipt-anchor-cell">
          {seal.anchorUrl ? (
            <a href={seal.anchorUrl} class="receipt-anchor-link" target="_blank" rel="noopener noreferrer">
              ⚓ github.com/gist ↗
            </a>
          ) : (
            <span class="receipt-anchor-pending">⏳ anchor pending</span>
          )}
          {anchorBadge && (
            <span class:list={['anchor-badge', anchorBadge.cls]}>{anchorBadge.label}</span>
          )}
        </div>
      </div>

      <!-- RFC 3161 trusted timestamp row -->
      {tstData && tstVerification && (
        <div class="receipt-row">
          <span class="receipt-label">RFC 3161 TST</span>
          <div class="receipt-anchor-cell">
            {tstVerification.verified && tstVerification.timestamp ? (
              <span class="receipt-tst-verified">
                ⏱ {tstVerification.tsaName} · {new Date(tstVerification.timestamp).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' })}
              </span>
            ) : (
              <span class="receipt-anchor-pending">⏳ parsing token…</span>
            )}
            <code class="receipt-tst-token" title="Base64 TimeStampToken — copy for offline verification">
              {tstData.tst_token.slice(0, 32)}…
            </code>
          </div>
        </div>
      )}

      <!-- OTS Bitcoin anchor row -->
      {otsData && otsData.status !== 'none' && (
        <div class="receipt-row">
          <span class="receipt-label">Bitcoin anchor</span>
          <div class="receipt-anchor-cell">
            {otsData.status === 'confirmed' && otsData.blockHeight ? (
              <span class="receipt-ots-confirmed">
                &#8383; Anchored in block #{otsData.blockHeight}
                {otsData.blockTime ? ` · ${new Date(otsData.blockTime * 1000).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'UTC' })} UTC` : ''}
              </span>
            ) : otsData.status === 'pending' ? (
              <span class="receipt-anchor-pending">&#8987; Pending Bitcoin confirmation (~60 min)</span>
            ) : (
              <span class="receipt-anchor-pending">~ Verifying…</span>
            )}
          </div>
        </div>
      )}

      <!-- Chain integrity indicator — real-time tamper check -->
      {chainIntegrityOk !== null && (
        <div class:list={['receipt-chain-status', chainIntegrityOk ? 'receipt-chain-status--ok' : 'receipt-chain-status--broken']}>
          <span class="chain-dot" aria-hidden="true">{chainIntegrityOk ? '●' : '✗'}</span>
          {chainIntegrityOk
            ? 'Chain hash verified — record intact'
            : 'Chain hash mismatch — this record may have been tampered with'}
        </div>
      )}

      <!-- Download buttons — .tsr and .ots file downloads -->
      <div class="receipt-downloads">
        {tstData && (
          <a
            href={`/api/audit-download/${seal.slug}?type=tsr`}
            class="receipt-dl-btn"
            download={`conviction-${seal.slug}.tsr`}
          >↓ conviction-{seal.slug}.tsr</a>
        )}
        {otsData && otsData.status !== 'none' && (
          <a
            href={`/api/audit-download/${seal.slug}?type=ots`}
            class="receipt-dl-btn"
            download={`conviction-${seal.slug}.ots`}
          >↓ conviction-{seal.slug}.ots</a>
        )}
      </div>

      <!-- DER hex dump — raw RFC 3161 token bytes for offline verification -->
      {derHexLines && derHexLines.length > 0 && (
        <details class="receipt-verify">
          <summary class="receipt-verify-toggle">
            Raw DER bytes ({derHexLines.length * 16 - (16 - derHexLines[derHexLines.length - 1].split(' ').length)} bytes total)
          </summary>
          <div class="receipt-verify-body">
            <p class="verify-explain">
              RFC 3161 TimeStampToken — raw DER, 16 bytes per row. Save as <code>.tsr</code> for offline verification.
            </p>
            <pre class="verify-cmd verify-cmd--hex"><code>{derHexLines.join('\n')}</code></pre>
          </div>
        </details>
      )}

      <!-- Verify command — native <details>, zero JS -->
      <details class="receipt-verify">
        <summary class="receipt-verify-toggle">
          How to verify this seal independently
        </summary>
        <div class="receipt-verify-body">
          <p class="verify-explain">
            HMAC verification (requires <code>ADMIN_SECRET</code>):
          </p>
          <pre class="verify-cmd"><code>{seal.verifyInstruction}</code></pre>
          {tstData && (
            <>
              <p class="verify-explain" style="margin-top:0.65rem">
                RFC 3161 verification (public — no secret needed):
              </p>
              <div class="verify-cmd-wrapper">
                <pre class="verify-cmd verify-cmd--copyable" id="openssl-cmd"><code>{`echo '${tstData.tst_token}' \\\n  | base64 -d > conviction-${seal.slug}.tsr\nopenssl ts -verify \\\n  -in conviction-${seal.slug}.tsr \\\n  -data <(echo -n "${seal.slug}:${seal.score}:${seal.sealedAt}") \\\n  -CAfile freetsa.crt`}</code></pre>
                <button
                  class="verify-copy-btn"
                  data-copied="false"
                  onclick={`(function(b){navigator.clipboard.writeText(document.getElementById('openssl-cmd').textContent||'').then(()=>{b.dataset.copied='true';setTimeout(()=>{b.dataset.copied='false'},1500)}).catch(()=>{});})(this)`}
                  aria-label="Copy openssl command to clipboard"
                >
                  <span class="copy-label-default">Copy command</span>
                  <span class="copy-label-done">Copied ✓</span>
                </button>
              </div>
              <p class="verify-explain verify-explain--note">
                Anyone can run this without any private key. The TSA cert is at
                <a href="https://freetsa.org/files/cacert.pem" target="_blank" rel="noopener" class="verify-link">freetsa.org/files/cacert.pem</a>.
              </p>
            </>
          )}
          <p class="verify-explain verify-explain--note" style={tstData ? '' : undefined}>
            HMAC formula: <code>slug:score:timestamp_ms</code> — server-signed at publish time.
          </p>
        </div>
      </details>
    </>
  ) : (
    <p class="receipt-unsealed-note">
      This post exists but has not been sealed yet.
      The conviction score will appear here once the author locks it before publication.
    </p>
  )}

</div>

<style>
  .audit-receipt {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 1.75rem 2rem;
    background: var(--surface-sealed);
    box-shadow: 0 2px 12px oklch(6% 0.01 260 / 0.6),
                inset 0 1px 0 oklch(30% 0.02 260 / 0.5);
  }

  /* ── Stamp ── */
  .receipt-stamp {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .receipt-stamp--sealed {
    background: var(--gold-bg);
    border: 1px solid var(--gold-border);
    color: var(--gold);
  }

  .receipt-stamp--open {
    background: var(--surface-raised);
    border: 1px dashed var(--border-medium);
    color: var(--text-tertiary);
  }

  .stamp-glyph { font-size: var(--text-xs); line-height: 1; }

  /* ── Title ── */
  .receipt-title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    line-height: 1.3;
    color: var(--text-primary);
    margin: 0 0 1.25rem;
  }

  /* ── Receipt rows ── */
  .receipt-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border-faint);
  }

  .receipt-row:last-of-type { border-bottom: none; }

  .receipt-label {
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-dim);
    min-width: 8rem;
    padding-top: 0.1rem;
    flex-shrink: 0;
  }

  .receipt-value {
    font-size: var(--text-sm);
    color: var(--text-primary);
  }

  .receipt-value--score {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--gold);
    letter-spacing: var(--tracking-tight);
  }

  .receipt-value-stack {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .receipt-meta {
    font-size: var(--text-2xs);
    font-family: var(--font-mono);
    color: var(--text-dim);
    letter-spacing: var(--tracking-normal);
  }

  .receipt-hash {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    background: var(--surface-raised);
    padding: 0.15em 0.5em;
    border-radius: 4px;
    letter-spacing: var(--tracking-wide);
  }

  .hash-ellipsis { opacity: 0.45; }

  /* ── Verify collapsible ── */
  .receipt-verify {
    margin-top: 1.25rem;
    border-top: 1px solid var(--border-subtle);
    padding-top: 0.85rem;
  }

  .receipt-verify summary { list-style: none; }
  .receipt-verify summary::-webkit-details-marker { display: none; }

  .receipt-verify-toggle {
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wide);
    color: var(--text-dim);
    cursor: pointer;
    user-select: none;
    transition: color var(--motion-duration-fast) ease;
  }

  .receipt-verify-toggle::before { content: '▸ '; font-size: var(--text-3xs); }
  details[open] .receipt-verify-toggle::before { content: '▾ '; }
  .receipt-verify-toggle:hover { color: var(--text-secondary); }

  .receipt-verify-body {
    padding-top: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .verify-explain {
    font-size: var(--text-xs);
    line-height: 1.6;
    color: var(--text-tertiary);
    margin: 0;
  }

  .verify-explain--note { color: var(--text-dim); font-style: italic; }

  .verify-explain code {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--gold-mid);
    padding: 0 3px;
  }

  .verify-cmd {
    background: color-mix(in oklch, white 3%, transparent);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    padding: 0.75em 1em;
    overflow-x: auto;
  }

  .verify-cmd code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: 1.5;
    white-space: pre;
  }

  /* ── RFC 3161 TST row elements ── */
  .receipt-tst-verified {
    font-size:  var(--text-sm);
    color:      var(--verdict-true);
    font-weight: var(--weight-medium);
  }

  .receipt-tst-token {
    font-family: var(--font-mono);
    font-size:   var(--text-2xs);
    color:       var(--text-dim);
    letter-spacing: var(--tracking-normal);
    word-break:  break-all;
  }

  .receipt-ots-confirmed {
    font-size:   var(--text-sm);
    color:       var(--gold);
    font-weight: var(--weight-medium);
    font-family: var(--font-mono);
  }

  .verify-link {
    color: var(--gold-mid);
    text-decoration: none;
  }
  .verify-link:hover { color: var(--gold); }

  /* ── Unsealed note ── */
  .receipt-unsealed-note {
    font-size: var(--text-xs);
    line-height: 1.6;
    color: var(--text-tertiary);
    font-style: italic;
    margin: 0;
  }

  /* ── Anchor cell ── */
  .receipt-anchor-cell {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .receipt-anchor-link {
    font-size: var(--text-sm);
    color: var(--gold);
    text-decoration: none;
    letter-spacing: var(--tracking-normal);
    transition: color var(--motion-duration-fast) ease;
  }

  .receipt-anchor-link:hover { color: var(--gold); }

  .receipt-anchor-pending {
    font-size: var(--text-xs);
    color: var(--text-dim);
    font-style: italic;
  }

  /* ── Anchor verification badge ── */
  .anchor-badge {
    display: inline-block;
    font-size: var(--text-2xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    width: fit-content;
  }

  .anchor-badge--verified {
    background: var(--verdict-true-bg);
    border: 1px solid var(--verdict-true-border);
    color: var(--verdict-true);
  }

  .anchor-badge--mismatch {
    background: var(--verdict-wrong-bg);
    border: 1px solid var(--verdict-wrong-border);
    color: var(--verdict-wrong);
  }

  .anchor-badge--unreachable {
    background: var(--surface-raised);
    border: 1px dashed var(--border-medium);
    color: var(--text-dim);
  }

  .anchor-badge--pending {
    background: var(--gold-bg);
    border: 1px dashed var(--gold-border);
    color: var(--gold-dim);
  }

  /* ── Chain integrity indicator ── */
  .receipt-chain-status {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    margin-top: 1rem;
    margin-bottom: 0.25rem;
  }

  .receipt-chain-status--ok {
    background: var(--verdict-true-bg);
    border: 1px solid var(--verdict-true-border);
    color: var(--verdict-true);
  }

  .receipt-chain-status--broken {
    background: var(--verdict-wrong-bg);
    border: 1px solid var(--verdict-wrong-border);
    color: var(--verdict-wrong);
  }

  .chain-dot { font-size: var(--text-3xs); line-height: 1; }

  /* ── Download buttons ── */
  .receipt-downloads {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .receipt-dl-btn {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wide);
    color: var(--text-tertiary);
    border: 1px solid var(--border-medium);
    border-radius: 4px;
    padding: 0.3rem 0.65rem;
    text-decoration: none;
    transition: color var(--motion-snap-duration) ease, border-color var(--motion-snap-duration) ease;
    white-space: nowrap;
  }

  .receipt-dl-btn:hover {
    color: var(--gold);
    border-color: var(--gold-border);
  }

  /* ── DER hex dump ── */
  .verify-cmd--hex code {
    font-size: var(--text-2xs);
    line-height: 1.8;
    letter-spacing: var(--tracking-wide);
    color: var(--text-tertiary);
  }

  /* ── Copy button for openssl command ── */
  .verify-cmd-wrapper {
    position: relative;
  }

  .verify-copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-size: var(--text-2xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wide);
    color: var(--text-dim);
    background: color-mix(in oklch, white 5%, transparent);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    padding: 0.2rem 0.5rem;
    cursor: pointer;
    transition: color var(--motion-snap-duration) ease, border-color var(--motion-snap-duration) ease;
    line-height: 1;
  }

  .verify-copy-btn:hover {
    color: var(--text-secondary);
    border-color: var(--text-faint);
  }

  /* Snap transition per motion.css SNAP profile (120ms) */
  .copy-label-default,
  .copy-label-done { transition: opacity var(--motion-snap-duration) ease; }

  .verify-copy-btn[data-copied="false"] .copy-label-default { opacity: 1; }
  .verify-copy-btn[data-copied="false"] .copy-label-done    { opacity: 0; position: absolute; }
  .verify-copy-btn[data-copied="true"]  .copy-label-default { opacity: 0; position: absolute; }
  .verify-copy-btn[data-copied="true"]  .copy-label-done    { opacity: 1; color: var(--verdict-true); }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .audit-receipt { padding: 1.25rem 1.25rem; }
    .receipt-row   { flex-direction: column; gap: 0.3rem; }
    .receipt-label { min-width: unset; }
  }
</style>
