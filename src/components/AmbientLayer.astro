---
// src/components/AmbientLayer.astro
// Living background gradient that makes each page feel like a *place*.
// Mood colors flow via CSS vars set by BaseLayout on :root.
// Time-tint layer reads --time-tint / --time-tint-opacity set by inline JS.
// Pure CSS — no islands, no hydration. Graceful no-JS fallback.
//
// Seasonal modifiers (--season-hue-shift, --season-sat-mult, --season-opacity-mult)
// are set by an inline script from seasonal.ts. They apply a subtle temperature
// and chroma shift that drifts smoothly through the year via cosine interpolation.
//
// TODO: add subtle grain/noise texture overlay (v2)
// TODO: explore radial gradient variant for detail pages
---

<div class="ambient-layer" data-ambient aria-hidden="true"></div>
<div class="ambient-time-tint" aria-hidden="true"></div>

<style>
  .ambient-layer {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: linear-gradient(
      135deg,
      var(--mood-from, transparent),
      var(--mood-to, transparent)
    );
    opacity: calc(var(--mood-opacity, 0) * var(--season-opacity-mult, 1));
    filter: hue-rotate(var(--season-hue-shift, 0deg))
            saturate(var(--season-sat-mult, 1));
    animation: ambient-drift var(--mood-speed, 12s) ease-in-out infinite alternate;
  }

  .ambient-time-tint {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: var(--time-tint, transparent);
    opacity: var(--time-tint-opacity, 0);
    transition: opacity 2s ease-in-out, background 2s ease;
  }

  @keyframes ambient-drift {
    0%   { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }
</style>
