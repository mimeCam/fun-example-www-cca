---
// src/components/Echo.astro
// A quiet cross-post reference — one curated sentence linking to another post.
// Renders nothing when echo data is absent. CSS-only, zero client JS.
// Inherits mood system via --mood-accent-rgb custom property.

interface Props {
  text?: string;
  fromSlug?: string;
  fromTitle?: string;
}

const { text, fromSlug, fromTitle } = Astro.props;
const hasEcho = text && fromSlug;
---

{hasEcho && (
  <aside class="echo" aria-label="Echo from another post">
    <p class="echo-quote">"{text}"</p>
    <p class="echo-attribution">
      <span class="echo-dash">&mdash;</span>
      <a href={`/blog/${fromSlug}/`}>{fromTitle || fromSlug}</a>
    </p>
  </aside>
)}

<style>
  .echo {
    margin-top: 4rem;
    padding-left: 1.25rem;
    opacity: 0;
    animation: echo-arrive 1.2s ease-out 0.8s forwards;
  }

  .echo-quote {
    font-size: 0.95rem;
    font-style: italic;
    line-height: 1.6;
    color: rgba(var(--mood-accent-rgb), 0.55);
    margin: 0 0 0.5rem;
  }

  .echo-attribution {
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: rgba(var(--mood-accent-rgb), 0.35);
    margin: 0;
  }

  .echo-dash {
    margin-right: 0.25em;
  }

  .echo-attribution a {
    color: rgba(var(--mood-accent-rgb), 0.45);
    text-decoration: none;
    border-bottom: 1px solid rgba(var(--mood-accent-rgb), 0.12);
    transition: color 180ms ease, border-bottom-color 180ms ease;
  }

  .echo-attribution a:hover {
    color: rgba(var(--mood-accent-rgb), 0.65);
    border-bottom-color: rgba(var(--mood-accent-rgb), 0.25);
  }

  @keyframes echo-arrive {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .echo { padding-right: 3.5rem; }
  }
</style>
