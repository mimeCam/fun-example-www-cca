---
// src/components/PresenceBand.astro
// Honest reader presence band — shows real reader count on /blog/[slug].
// count >= 2: "N readers keeping this alive" + breathing dot.
// count  = 1: "you are here" (just you).
// count  = 0: empty — the blog looks dead. That's the point.
//
// SSR: renders shell. Client: presence-unified.ts hydrates via SSE.
// Used on /blog/[slug] (per-post) and optionally on index (global).
//
// Credits: Mike (architecture), Tanya (UX spec), Elon (honest-zero)

interface Props {
  /** When true, renders in compact mode for the homepage. */
  compact?: boolean;
  /** Connection scope: "global" for homepage aggregate, "slug" for per-post. */
  scope?: 'global' | 'slug';
}

const { compact = false, scope = 'slug' } = Astro.props;
---

<div
  class:list={['presence-band', { 'presence-band--compact': compact }]}
  id="presence-band"
  data-scope={scope}
  aria-live="polite"
  aria-atomic="true"
  role="status"
>
  <span class="presence-dot" id="presence-dot" aria-hidden="true" style="display:none"></span>
  <span class="presence-text" id="presence-text"></span>
  <span class="presence-count" id="presence-count" aria-hidden="true">0</span>
  <span class="presence-fallback" id="presence-fallback" style="display:none"></span>
</div>

<style>
  .presence-band {
    text-align: center;
    padding: 0.75rem 1rem 0.25rem;
    max-width: 38rem;
    margin: 0 auto;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .presence-band.presence-active {
    opacity: 1;
  }

  .presence-band--compact {
    max-width: 44rem;
    padding: 0.5rem 1rem 0.25rem;
  }

  .presence-text {
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: var(--mood-accent, #9CA3AF);
    opacity: 0.55;
  }

  .presence-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--mood-accent, #9CA3AF);
    display: inline-block;
    vertical-align: middle;
    margin-right: 0.4rem;
    animation: presence-breathe var(--presence-tempo, 3s) ease-in-out infinite;
  }

  .presence-count {
    display: none;
  }

  .presence-fallback {
    font-size: 0.68rem;
    letter-spacing: 0.03em;
    color: var(--mood-accent, #9CA3AF);
    opacity: 0.38;
    font-style: italic;
  }

  @keyframes presence-breathe {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.15); }
  }

  @media (prefers-reduced-motion: reduce) {
    .presence-dot {
      animation: none;
      opacity: 0.6;
    }
    .presence-band {
      transition: none;
    }
  }
</style>
