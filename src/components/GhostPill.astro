---
// src/components/GhostPill.astro
// Warm, glowing pill that lives inside the mood-bar.
// Label for a hidden checkbox (#ghost-toggle) in BaseLayout.
// When checked, GhostDrawer becomes visible via CSS sibling selector.
// Zero JS. Disappears when no ghosts are alive.

import { getGhosts } from '../lib/ghost';
import ghostData from '../data/ghosts.json';

const ghosts = getGhosts(ghostData);
const count = ghosts.length;
const show = count > 0;
---

{show && (
  <label for="ghost-toggle" class="ghost-pill" aria-label={`${count} ghost${count === 1 ? '' : 's'} haunting`}>
    <span class="ghost-glow" aria-hidden="true" />
    {count} ghost{count === 1 ? '' : 's'}
  </label>
)}

<style>
  .ghost-pill {
    position: relative;
    border-radius: 18px;
    padding: 0.25rem 0.85rem;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    border: 1px solid rgba(212, 149, 106, 0.22);
    background: rgba(212, 149, 106, 0.08);
    color: #d4956a;
    cursor: pointer;
    opacity: 0.65;
    transition: opacity 200ms ease, box-shadow 200ms ease;
    user-select: none;
  }
  .ghost-pill:hover {
    opacity: 0.9;
    box-shadow: 0 0 10px rgba(212, 149, 106, 0.25);
  }
  .ghost-glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: radial-gradient(circle, rgba(212, 149, 106, 0.12), transparent 70%);
    animation: ghost-breathe 4s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes ghost-breathe {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ghost-glow { animation: none; opacity: 0.6; }
  }
</style>
