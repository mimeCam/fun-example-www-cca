---
// src/components/BattingUnlockCeremony.astro
// One-time ceremony that plays when batting average is first unlocked.
// Fires on page load if unlocked=true and localStorage flag not set.
// Also listens to the 'bah:unlock' CustomEvent for real-time delivery
// (dispatched by ba-unlock-progress.ts when the 5th verdict resolves live).
//
// Three-phase sequence (driven by CSS class additions, no RAF math):
//   Phase 1 (0ms)   — ring receives .bpr--has-shattered → lock icon exits
//   Phase 2 (300ms) — gold flash overlay fades in/out
//   Phase 3 (700ms) — 'batting-unlock-complete' event fires → callers can decorate
//
// Dismiss logic: localStorage key `batting-unlock-ceremony-${authorSlug}`.
// If key present: ceremony is skipped. localStorage survives page reloads.
// If author clears storage they see it again — that's delightful, not a bug.
//
// Circuit breaker: if unlocked=true on page load AND ceremony not yet shown,
// runs after 200ms regardless of SSE status (handles stale-cache scenario).
//
// Credits: Mike Koch (napkin spec §4), Tanya Donska (UX §7.3)

interface Props {
  authorSlug: string;
  unlocked:   boolean;
}

const { authorSlug, unlocked } = Astro.props;
---

{/*
  Only inserted in the DOM when unlocked — skips parsing for cold authors.
  The flash overlay sits above the ring visually, pointer-events: none.
*/}
{unlocked && (
  <div
    class="buc"
    data-buc-slug={authorSlug}
    aria-live="polite"
    aria-atomic="true"
    aria-label="Batting average unlocked"
  >
    <span class="buc__flash" aria-hidden="true"></span>
    <p class="buc__announce" aria-hidden="true">🏆 Batting average unlocked</p>
  </div>
)}

<script>
// ── Ceremony controller — runs once per unlock per browser ────────────────

const FLAG   = (slug: string) => `batting-unlock-ceremony-${slug}`;
const DELAY  = 200;  // ms before ceremony starts (lets ring render first)
const HOLD   = 900;  // ms ceremony is "active" before settling

function dismissed(slug: string): boolean {
  return !!localStorage.getItem(FLAG(slug));
}

function dismiss(slug: string): void {
  localStorage.setItem(FLAG(slug), '1');
}

function shatterRing(slug: string): void {
  document.querySelector(`[data-bpr-slug="${slug}"]`)
    ?.classList.add('bpr--has-shattered');
}

function runCeremony(el: HTMLElement, slug: string): void {
  if (dismissed(slug)) return;
  dismiss(slug);
  el.classList.add('buc--active');
  shatterRing(slug);
  el.querySelector('.buc__announce')?.removeAttribute('aria-hidden');
  setTimeout(() => el.classList.remove('buc--active'), HOLD);
  el.dispatchEvent(new CustomEvent('batting-unlock-complete', { bubbles: true }));
}

function scheduleForEl(el: HTMLElement): void {
  const slug = el.dataset.bucSlug ?? '';
  if (dismissed(slug)) return;
  // Page-load path: server says unlocked, ceremony not yet shown
  setTimeout(() => runCeremony(el, slug), DELAY);
  // Real-time path: ba-unlock-progress.ts dispatches bah:unlock on 5th verdict
  document.addEventListener('bah:unlock', (e: Event) => {
    const detail = (e as CustomEvent<{ authorSlug?: string }>).detail;
    if (detail?.authorSlug !== slug) return;
    runCeremony(el, slug);
  });
}

function init(): void {
  document.querySelectorAll<HTMLElement>('[data-buc-slug]').forEach(scheduleForEl);
}

document.readyState === 'loading'
  ? document.addEventListener('DOMContentLoaded', init)
  : init();
</script>

<style>
/* ── Ceremony overlay — sits beside the ring, no position:absolute needed ── */
.buc {
  display:         flex;
  flex-direction:  column;
  align-items:     center;
  gap:             var(--space-2);
  pointer-events:  none;
}

/* Gold flash spans behind the ring (sibling, not overlay — avoids z stacking) */
.buc__flash {
  display:       block;
  width:         96px;
  height:        96px;
  border-radius: var(--radius-full);
  background:    radial-gradient(circle, var(--gold-bg) 0%, transparent 70%);
  opacity:       0;
  transform:     scale(0.6);
  transition:
    opacity   var(--motion-duration-base) ease-out,
    transform var(--motion-duration-base) var(--motion-easing-spring,
      cubic-bezier(0.34, 1.56, 0.64, 1));
}

/* Announcement label — hidden until ceremony fires */
.buc__announce {
  margin:      0;
  font-size:   var(--text-sm);
  color:       var(--gold);
  font-weight: var(--weight-semibold);
  opacity:     0;
  transform:   translateY(4px);
  transition:
    opacity   300ms ease-out 200ms,
    transform 300ms var(--motion-easing-spring, cubic-bezier(0.34, 1.56, 0.64, 1)) 200ms;
}

/* ── Active state — ceremony running ──────────────────────────────────────── */
.buc--active .buc__flash {
  opacity:   0.9;
  transform: scale(1.15);
}

.buc--active .buc__announce {
  opacity:   1;
  transform: translateY(0);
}

/* ── Reduced motion — suppress all transitions, preserve semantic announce ── */
@media (prefers-reduced-motion: reduce) {
  .buc__flash,
  .buc__announce {
    transition: none !important;
    animation:  none !important;
  }
  /* Still show the announcement text instantly when active */
  .buc--active .buc__announce {
    opacity: 1;
    transform: none;
  }
}
</style>
