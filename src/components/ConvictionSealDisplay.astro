---
// src/components/ConvictionSealDisplay.astro
// Sealed conviction hero — permanent record, zero JavaScript.
// Renders when sealEntry exists and score !== null.
// All visual state is CSS-only; no client-side hydration ever touches this.
//
// Contract: receives fully-derived props from ConvictionSeal.astro (orchestrator).
// DB logic, deriveConvictionStage() — all of that lives in the orchestrator only.
//
// Credits: Mike (§Architecture, §CSS-state-machine),
//          Tanya (§6.3 Phase 4 receipt spec, §7 token application map)

import DecayClock   from './DecayClock.astro';
import TrustBadge   from './TrustBadge.astro';
import type { ConvictionStage } from './TrustBadge.astro';
import TensionBadge from './TensionBadge.astro';
import type { GraceState }        from '../lib/cold-start';
import type { ConvictionVerdict } from '../lib/decay-engine';
import type { TensionResult }     from '../lib/tension-score';
import type { TstData }           from '../lib/timestamp-store';
import { clockUrgency }           from '../lib/death-clock';

interface Props {
  slug:            string;
  score:           number;
  note:            string | null;
  shortHash:       string;
  sealedAt:        string;
  sealTimestamp:   string;          // ISO string for <time datetime>
  convictionStage: ConvictionStage;
  graceState?:     GraceState;
  revivalCount?:   number;
  conviction?:     ConvictionVerdict | null;
  tensionResult?:  TensionResult | null;
  tst?:            TstData | null;
}

const {
  slug, score, note, shortHash, sealedAt, sealTimestamp,
  convictionStage, graceState, revivalCount = 0,
  conviction = null, tensionResult = null, tst = null,
} = Astro.props;

const barPct         = (score / 10) * 100;
const clockDays      = graceState?.warming ? 1 : (graceState?.daysRemaining ?? 0);
const clockUrgencyVal = clockUrgency(clockDays);
const deadlineISO    = (graceState && !graceState.warming && clockDays > 0)
  ? new Date(Date.now() + clockDays * 86_400_000).toISOString()
  : null;
---

<section
  class="conviction-seal conviction-seal--sealed"
  aria-label="Author conviction — sealed before publication"
>
  <!-- Label row -->
  <div class="cs-label-row" aria-hidden="true">
    <span class="cs-label-icon">⚡</span>
    <span class="cs-label-text">CONVICTION</span>
    <span class="cs-label-sep">·</span>
    <span class="cs-label-sub">SEALED BEFORE FIRST READ</span>
    <span class="cs-label-trust">
      <TrustBadge tst={tst} slug={slug} convictionStage={convictionStage} />
    </span>
  </div>

  <!-- Score row -->
  <div class="cs-score-row">
    <div class="cs-stamp" aria-label={`Conviction score: ${score} out of 10`}>
      <span class="cs-score-digit">{score}</span>
      <span class="cs-score-denom">/10</span>
    </div>
    <div class="cs-wager">
      <div class="cs-bar-track" role="progressbar" aria-valuenow={score} aria-valuemin={1} aria-valuemax={10}>
        <div class="cs-bar-fill" style={`width:${barPct}%`}></div>
      </div>
      {note && <p class="cs-note">"{note}"</p>}
      <time class="cs-sealed-at" datetime={sealTimestamp}>
        sealed {sealedAt}
      </time>
    </div>
  </div>

  <!-- Status row: clock + tension + meta -->
  <div class="cs-status-row">
    {graceState?.warming ? (
      <div class="cs-warming" aria-label={`Warming: ${graceState.readerCount}/${graceState.threshold} readers`}>
        <span class="cs-warming-pct">{graceState.readerCount}/{graceState.threshold}</span>
        <span class="cs-warming-label">readers — clock starts at {graceState.threshold}</span>
      </div>
    ) : (
      <div class="cs-clock-wrap" data-deadline-iso={deadlineISO ?? undefined}>
        <DecayClock variant="ring" daysRemaining={clockDays} urgency={clockUrgencyVal} conviction={conviction} />
      </div>
    )}

    <TensionBadge tensionResult={tensionResult} revivalCount={revivalCount} slug={slug} embedded={true} />

    <div class="cs-meta">
      {revivalCount > 0 && (
        <span class="cs-revivals">↑ {revivalCount} {revivalCount === 1 ? 'revival' : 'revivals'}</span>
      )}
      <a href="#conviction-audit" class="cs-hash" title={`Full hash: ${shortHash}`}>
        #{shortHash}…↓
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Sealed hero container ────────────────────────────────── */
  .conviction-seal {
    margin: 0 0 var(--space-10);
  }

  .conviction-seal--sealed {
    background:    var(--surface-sealed);
    border:        1px solid var(--border-sealed);
    border-left:   3px solid var(--gold-mid);
    border-radius: var(--radius-tombstone);
    padding:       var(--space-5) 1.75rem var(--space-6);
    box-shadow:
      0 1px 4px oklch(0% 0 0 / 0.50),
      inset 0 1px 0 color-mix(in oklch, white 4%, transparent);
  }

  /* Label row */
  .cs-label-row {
    display:       flex;
    align-items:   center;
    gap:           var(--space-1);
    margin-bottom: var(--space-4);
  }

  .cs-label-trust { margin-left: auto; }

  .cs-label-icon {
    font-size: var(--text-2xs);
    color:     var(--gold);
  }

  .cs-label-text {
    font-size:      var(--text-2xs);
    font-weight:    var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color:          var(--gold);
  }

  .cs-label-sep {
    font-size: var(--text-2xs);
    color:     var(--gold-dim);
    margin:    0 0.1rem;
  }

  .cs-label-sub {
    font-size:      var(--text-2xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color:          var(--gold-dim);
  }

  /* Score row */
  .cs-score-row {
    display:       flex;
    align-items:   flex-start;
    gap:           var(--space-5);
    margin-bottom: var(--space-5);
  }

  .cs-stamp {
    flex-shrink: 0;
    display:     flex;
    align-items: baseline;
    gap:         0.1rem;
    line-height: 1;
  }

  .cs-score-digit {
    font-size:   2.2rem;
    font-weight: var(--weight-bold);
    font-family: var(--font-mono);
    color:       var(--gold);
    letter-spacing: var(--tracking-tight);
  }

  .cs-score-denom {
    font-size:      1rem;
    color:          var(--gold-dim);
    align-self:     flex-end;
    padding-bottom: 0.3rem;
  }

  .cs-wager {
    flex:           1;
    display:        flex;
    flex-direction: column;
    gap:            var(--space-2);
    padding-top:    var(--space-2);
    min-width:      0;
  }

  .cs-bar-track {
    height:       6px;
    background:   var(--border-subtle);
    border-radius: 2px;
    overflow:     hidden;
  }

  .cs-bar-fill {
    height:     100%;
    background: linear-gradient(90deg, var(--gold-deep), var(--gold));
    border-radius: 2px;
  }

  .cs-note {
    font-size:   var(--text-sm);
    line-height: var(--leading-normal);
    color:       var(--note-italic-color);
    font-style:  italic;
    margin:      0;
  }

  .cs-sealed-at {
    font-size:      var(--text-2xs);
    color:          var(--text-ghost);
    letter-spacing: var(--tracking-normal);
  }

  /* Status row */
  .cs-status-row {
    display:     flex;
    align-items: center;
    gap:         var(--space-4);
    padding-top: var(--space-4);
    border-top:  1px solid var(--border-subtle);
  }

  .cs-warming {
    display:     flex;
    align-items: center;
    flex-wrap:   wrap;
    gap:         var(--space-1);
    flex:        1;
  }

  .cs-warming-pct {
    font-size:   var(--text-sm);
    font-weight: var(--weight-semibold);
    font-family: var(--font-mono);
    color:       var(--gold-dim);
  }

  .cs-warming-label {
    font-size: var(--text-xs);
    color:     var(--text-tertiary);
  }

  .cs-clock-wrap { flex-shrink: 0; }

  .cs-meta {
    display:     flex;
    align-items: center;
    gap:         var(--space-3);
    margin-left: auto;
    flex-shrink: 0;
  }

  .cs-revivals {
    font-size: var(--text-3xs);
    color:     var(--text-ghost);
  }

  .cs-hash {
    font-size:      var(--text-3xs);
    font-family:    var(--font-mono);
    color:          var(--text-ghost);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    transition:     color var(--motion-duration-fast) var(--motion-easing-standard);
  }

  .cs-hash:hover { color: var(--text-secondary); }

  /* Mobile */
  @media (max-width: 640px) {
    .conviction-seal--sealed { padding: 1.1rem var(--space-5) var(--space-5); }
    .cs-score-digit           { font-size: 2rem; }
    .cs-label-sub,
    .cs-revivals              { display: none; }
    .cs-warming               { flex-direction: column; align-items: flex-start; }
  }
</style>
