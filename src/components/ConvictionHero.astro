---
// src/components/ConvictionHero.astro
// Above-fold conviction hero — the sealed bet made visceral.
// Replaces ConvictionDeclaration in the above-fold position on post detail.
//
// 3-layer layout (Tanya §post-detail — 5-second cold reader requirement):
//   1. Label row  — "⚡ CONVICTION · SEALED BEFORE FIRST READ"
//   2. Hero row   — score stamp + progress bar + wager quote + sealed date
//   3. Footer row — DeathClock · time remaining · revival count · audit link
//
// Panel: dark indigo (oklch 18% 0.025 280) + 3px amber left border.
// Amber = conviction claim. Indigo = the sealed document. Distinct materials.
// Pure server-rendered — zero client JS, works on 3G.
//
// Credits: Mike (spec §Modules, §Key Design Decisions),
//          Tanya (UX §post-detail — ConvictionHero redesign, indigo palette)

import { getSealEntry } from '../lib/conviction-ledger';
import DeathClock from './DeathClock.astro';
import TensionBadge from './TensionBadge.astro';
import { clockUrgency } from '../lib/death-clock';
import type { GraceState } from '../lib/cold-start';
import type { ConvictionVerdict } from '../lib/decay-engine';
import type { TensionResult } from '../lib/tension-score';

interface Props {
  slug:           string;
  graceState:     GraceState;
  revivalCount?:  number;
  conviction?:    ConvictionVerdict | null;
  tensionResult?: TensionResult | null;
}

const { slug, graceState, revivalCount = 0, conviction = null, tensionResult = null } = Astro.props;

let sealEntry = null;

try {
  sealEntry = getSealEntry(slug);
} catch {
  /* DB not ready at build time — render nothing */
}

const score      = sealEntry?.conviction_score ?? null;
const note       = sealEntry?.author_note ?? null;
const barPct     = score !== null ? (score / 10) * 100 : 0;
const shortHash  = sealEntry?.hash.slice(0, 8) ?? '';
const sealedAt   = sealEntry
  ? new Date(sealEntry.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
  : '';

// Clock: only meaningful when not warming.
const clockDays       = graceState.warming ? 1 : graceState.daysRemaining;
const clockUrgencyVal = clockUrgency(clockDays);

// Deadline ISO — drives the live JS countdown when < 48 h remain.
const deadlineISO = (!graceState.warming && clockDays > 0)
  ? new Date(Date.now() + clockDays * 86_400_000).toISOString()
  : null;
---

{!sealEntry && (
  <div class="ch-unsealed" aria-label="Conviction score not yet sealed">
    <span class="ch-unsealed-icon">◇</span>
    <span class="ch-unsealed-label">Conviction score not yet sealed</span>
  </div>
)}

{sealEntry && score !== null && (
<section
  class="conviction-hero"
  aria-label="Author conviction — sealed before publication"
>
  <!-- Layer 1: Label row — answers "what is this?" and "was this pre-read?" in one line (Tanya §post-detail) -->
  <div class="ch-label-row" aria-hidden="true">
    <span class="ch-label-icon">⚡</span>
    <span class="ch-label-text">CONVICTION</span>
    <span class="ch-label-sep">·</span>
    <span class="ch-label-sub">SEALED BEFORE FIRST READ</span>
  </div>

  <!-- Layer 2: Score stamp + progress bar + wager quote -->
  <div class="ch-score-row">
    <div class="ch-stamp" aria-label={`Conviction score: ${score} out of 10`}>
      <span class="ch-score-digit">{score}</span>
      <span class="ch-score-denom">/10</span>
    </div>

    <div class="ch-wager">
      <div class="ch-bar-track" role="progressbar" aria-valuenow={score} aria-valuemin={1} aria-valuemax={10}>
        <div class="ch-bar-fill" style={`width:${barPct}%`}></div>
      </div>
      <p class="ch-note">"{note}"</p>
      <time class="ch-sealed-at" datetime={new Date(sealEntry.timestamp).toISOString()}>
        sealed {sealedAt}
      </time>
    </div>
  </div>

  <!-- Layer 3: DeathClock · time remaining · TensionBadge · revival count · audit link -->
  <div class="ch-status-row">
    {graceState.warming ? (
      <div class="ch-warming" aria-label={`Warming up: ${graceState.readerCount} of ${graceState.threshold} readers`}>
        <span class="ch-warming-pct">{graceState.readerCount}/{graceState.threshold}</span>
        <span class="ch-warming-label">readers — clock starts at {graceState.threshold}</span>
        {graceState.daysUntilClockStarts > 0 && (
          <span class="ch-warming-grace">or {graceState.daysUntilClockStarts}d grace remaining</span>
        )}
      </div>
    ) : (
      <div class="ch-clock-wrap" data-deadline-iso={deadlineISO ?? undefined}>
        <DeathClock
          daysRemaining={graceState.daysRemaining}
          urgency={clockUrgencyVal}
          conviction={conviction}
        />
      </div>
    )}

    <!-- TensionBadge embedded in the status row (Mike §Key Design Decisions #2) -->
    <TensionBadge
      tensionResult={tensionResult}
      revivalCount={revivalCount}
      slug={slug}
      embedded={true}
    />

    <div class="ch-meta">
      {revivalCount > 0 && (
        <span class="ch-revivals">↑ {revivalCount} {revivalCount === 1 ? 'revival' : 'revivals'}</span>
      )}
      <a href="#conviction-audit" class="ch-hash" title={`Full hash: ${sealEntry.hash}`}>
        #{shortHash} ↓
      </a>
    </div>
  </div>
</section>
)}

<style>
  /* Unsealed state: amber dashed border — explicit "not yet sealed" */
  .ch-unsealed {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.25rem;
    margin: 0 0 2.5rem;
    border: 1px dashed rgba(245, 166, 35, 0.3);
    border-radius: 8px;
    background: rgba(245, 166, 35, 0.03);
  }

  .ch-unsealed-icon {
    font-size: 0.85rem;
    color: rgba(245, 166, 35, 0.35);
    line-height: 1;
    flex-shrink: 0;
  }

  .ch-unsealed-label {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.02em;
    font-style: italic;
  }

  /* Container — indigo tint: sealed document, not just another amber widget.
     Amber = conviction claim. Indigo = the container for the claim. (Tanya §design-tokens) */
  .conviction-hero {
    background: oklch(18% 0.025 280);
    border: 1px solid oklch(30% 0.04 280);
    border-left: 3px solid rgba(245, 166, 35, 0.65);
    border-radius: 8px;
    padding: 1.25rem 1.75rem 1.5rem;
    margin: 0 0 2.5rem;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  /* Layer 1 — Label row: answers cold reader's first two questions in one line */
  .ch-label-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .ch-label-icon {
    font-size: 0.65rem;
    line-height: 1;
    color: #F5A623;
  }

  .ch-label-text {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F5A623;
  }

  .ch-label-sep {
    font-size: 0.65rem;
    color: rgba(245, 166, 35, 0.4);
    margin: 0 0.1rem;
  }

  .ch-label-sub {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(245, 166, 35, 0.55);
  }

  /* Layer 2 — Score row: stamp number left, bar + quote right */
  .ch-score-row {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  /* Score stamp: monospace 2.2rem amber — the official grade */
  .ch-stamp {
    flex-shrink: 0;
    display: flex;
    align-items: baseline;
    gap: 0.1rem;
    line-height: 1;
  }

  .ch-score-digit {
    font-size: 2.2rem;
    font-weight: 700;
    font-family: ui-monospace, 'Cascadia Code', monospace;
    color: #F5A623;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .ch-score-denom {
    font-size: 1rem;
    font-weight: 400;
    color: rgba(245, 166, 35, 0.45);
    align-self: flex-end;
    padding-bottom: 0.3rem;
  }

  /* Wager column: bar track + quote + sealed date */
  .ch-wager {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding-top: 0.5rem;
    min-width: 0;
  }

  .ch-bar-track {
    height: 6px;
    background: rgba(255, 255, 255, 0.07);
    border-radius: 2px;
    overflow: hidden;
  }

  .ch-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #D4880A, #F5A623);
    border-radius: 2px;
  }

  /* Wager note: human words — italic warm gray distinguishes from clinical score data */
  .ch-note {
    font-size: 0.88rem;
    line-height: 1.55;
    color: oklch(72% 0.008 0);
    font-style: italic;
    margin: 0;
  }

  /* Mobile only: clamp to 3 lines to preserve card density */
  @media (max-width: 640px) {
    .ch-note {
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
    }
  }

  .ch-sealed-at {
    font-size: 0.67rem;
    color: rgba(255, 255, 255, 0.28);
    letter-spacing: 0.02em;
  }

  /* Layer 3 — Status row: clock (or warming pill) · tension · meta */
  .ch-status-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* Warming state — reader count as progress pill */
  .ch-warming {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem;
    flex: 1;
  }

  .ch-warming-pct {
    font-size: 0.8rem;
    font-weight: 600;
    font-family: ui-monospace, monospace;
    color: rgba(245, 166, 35, 0.8);
    letter-spacing: -0.01em;
  }

  .ch-warming-label {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.38);
  }

  .ch-warming-grace {
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.25);
    font-style: italic;
  }

  .ch-clock-wrap { flex-shrink: 0; }

  /* Footer metadata: revivals · hash (smallest elements, rightmost) */
  .ch-meta {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  /* Revival count: plain text, not a badge (Tanya §post-detail) */
  .ch-revivals {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.32);
  }

  /* Audit link: smallest element, rightmost — for the curious, not the skimmer */
  .ch-hash {
    font-size: 0.63rem;
    font-family: ui-monospace, monospace;
    color: rgba(255, 255, 255, 0.2);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 150ms ease;
    cursor: default;
  }

  .ch-hash:hover { color: rgba(255, 255, 255, 0.5); }

  /* Mobile: stamp shrinks, revivals hidden, labels wrap */
  @media (max-width: 640px) {
    .conviction-hero { padding: 1.1rem 1.25rem 1.25rem; }

    .ch-score-digit { font-size: 2rem; }
    .ch-score-denom { font-size: 0.875rem; }

    .ch-label-sub { display: none; }  /* "SEALED BEFORE FIRST READ" wraps badly at 320px */
    .ch-revivals { display: none; }

    .ch-warming { flex-direction: column; align-items: flex-start; gap: 0.2rem; }
  }
</style>

<!-- Live countdown: ticks h:mm inside DeathClock when < 48 h remain.
     Imported as a named module so it stays unit-testable (Mike §Key Design Decisions #4).
     No-op on posts > 48 h away — scheduleForWrap skips them silently. -->
<script>
  import { wireLiveCountdown } from '../lib/live-conviction-hero';
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', wireLiveCountdown);
  } else {
    wireLiveCountdown();
  }
</script>
