---
// src/components/RiverFilter.astro
// Stage filter pill rail for the unified conviction river.
// State lives in ?stage= URL param — shareable, crawlable, zero client state.
// Always visible — lifecycle stage IS the product's navigation identity.
//
// Stages: live (thriving) · endangered · graveyard
// Count badges are SSR-rendered; a lightweight fetch refreshes them on mount.
//
// Credits: Mike (arch §RiverFilter refactor), Tanya (UX §2 — stage filter pill spec)

import StagePill from './StagePill.astro';
import type { StageFilter, StageCounts } from '../lib/river-data';

export type { StageFilter };

interface Props {
  currentStage: StageFilter;
  counts: StageCounts;
}

const { currentStage, counts } = Astro.props;

const PILLS: { id: StageFilter; label: string }[] = [
  { id: 'live',       label: 'thriving'   },
  { id: 'endangered', label: 'endangered' },
  { id: 'graveyard',  label: 'graveyard'  },
];

function stageHref(id: StageFilter): string {
  return id === 'live' ? '/' : `/?stage=${id}`;
}

function stageCount(id: StageFilter): number {
  if (id === 'live' || id === 'endangered' || id === 'graveyard') return counts[id];
  return 0;
}
---

<nav class="rf-stage" aria-label="Filter posts by lifecycle stage">
  {PILLS.map(pill => (
    <StagePill
      id={pill.id}
      label={pill.label}
      count={stageCount(pill.id)}
      active={currentStage === pill.id || (pill.id === 'live' && currentStage === 'all')}
      href={stageHref(pill.id)}
    />
  ))}
</nav>

<script>
  // Refresh pill counts on mount — keeps badges current without full SSR re-fetch.
  // Non-blocking: silently ignores network errors.
  async function refreshStageCounts(): Promise<void> {
    const res = await fetch('/api/stage-counts').catch(() => null);
    if (!res?.ok) return;
    const data = await res.json().catch(() => null);
    if (!data) return;
    updateCount('live',       data.live       ?? 0);
    updateCount('endangered', data.endangered  ?? 0);
    updateCount('graveyard',  data.graveyard   ?? 0);
  }

  function updateCount(stage: string, n: number): void {
    const el = document.querySelector<HTMLElement>(`[data-stage="${stage}"] .sp-count`);
    if (el) el.textContent = String(n);
  }

  refreshStageCounts();
</script>

<style>
  .rf-stage {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    /* Sticky below SiteNav: filter stays reachable as user scrolls the river. */
    position: sticky;
    top: 48px;                             /* exact SiteNav height */
    z-index: var(--z-sticky);             /* above cards, below drawer/modal */
    background: var(--surface-overlay);   /* rgba(12,12,14,0.75) — glass dark */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    /* Top separator prevents visual merge with nav (Tanya §3.5) */
    border-top: 1px solid var(--border-faint);
    border-bottom: 1px solid var(--border-faint);
    padding: var(--space-2) 0 var(--space-2);
    margin-bottom: var(--space-4);
  }

  @media (max-width: 640px) {
    .rf-stage {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: var(--space-2);
    }
    .rf-stage::-webkit-scrollbar { display: none; }
  }
</style>
