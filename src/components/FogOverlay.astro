---
// src/components/FogOverlay.astro
// Full-viewport fog layer driven by --spectacle-progress (0→1).
// During spectacle: opacity ramps up, blur softens the world.
// After spectacle: fades to zero and becomes inert.
//
// Also adds per-card fog via a global style rule:
// cards with --decay-opacity below 0.45 get a fog ::after.
//
// Position: fixed, covers viewport, pointer-events: none.
// Z-index: above cards (10), below nav (50).
---

<div class="fog-overlay" aria-hidden="true">
  <div class="fog-layer fog-layer--radial"></div>
  <div class="fog-layer fog-layer--drift"></div>
</div>

<style>
  /* ── Viewport fog (spectacle only) ─────────────────── */

  .fog-overlay {
    position: fixed;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    opacity: var(--spectacle-progress, 0);
    transition: opacity 0.3s ease-out;
    will-change: opacity;
  }

  .fog-layer {
    position: absolute;
    inset: 0;
  }

  .fog-layer--radial {
    background: radial-gradient(
      ellipse at 50% 60%,
      rgba(var(--mood-accent-rgb, 120, 120, 120), 0.06) 0%,
      rgba(0, 0, 0, 0.4) 70%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .fog-layer--drift {
    background: linear-gradient(
      170deg,
      transparent 30%,
      rgba(var(--mood-accent-rgb, 120, 120, 120), 0.03) 50%,
      transparent 70%
    );
    animation: fog-drift 12s ease-in-out infinite alternate;
  }

  @keyframes fog-drift {
    from { transform: translateX(-3%) translateY(-1%); }
    to   { transform: translateX(3%) translateY(1%); }
  }

  /* ── Spectacle-active body overrides ───────────────── */

  :global(.spectacle-active) .fog-overlay {
    backdrop-filter: blur(
      calc(var(--spectacle-progress, 0) * 2px)
    );
  }

  /* ── Resist card: punches above fog ────────────────── */

  :global(.spectacle-resist) {
    position: relative;
    z-index: 15;
    box-shadow:
      0 0 32px rgba(var(--mood-accent-rgb, 120, 120, 120), 0.2),
      0 8px 32px rgba(var(--mood-accent-rgb, 120, 120, 120), 0.15) !important;
  }

  /* ── Per-card fog (works outside spectacle too) ────── */
  /* Cards below 0.45 opacity get atmospheric fog ::after */

  :global(.decay-card)::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      ellipse at 50% 60%,
      rgba(var(--mood-accent-rgb, 120, 120, 120), 0.04) 0%,
      transparent 70%
    );
    opacity: 0;
    filter: blur(0px);
    transition: opacity 0.4s ease-out, filter 0.4s ease-out;
  }

  /* ── Reduced motion ────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .fog-layer--drift { animation: none; }
    .fog-overlay { transition: none; }
    :global(.spectacle-active) .fog-overlay {
      backdrop-filter: none;
    }
  }
</style>
