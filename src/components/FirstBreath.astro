---
// src/components/FirstBreath.astro
// SSR-rendered arrival banner — visible once per browser session.
// Server picks the whisper deterministically (phase + day of year),
// so it's meaningful without JS and never flickers on hydration.
// JS choreography (firstBreathScript) owns the 4-beat fade sequence.
// CSS in first-breath.css handles the page bloom + banner transitions.

import { pickWhisper, getCurrentPhase } from '../lib/firstBreath';

const phase = getCurrentPhase();
const whisper = pickWhisper(phase);
---

<aside
  class="first-breath"
  data-breath-whisper
  role="status"
  aria-live="polite"
  aria-label="Time-aware greeting"
>
  <p class="first-breath__text">{whisper.text}</p>
</aside>
