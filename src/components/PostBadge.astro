---
// src/components/PostBadge.astro
// Frosted-glass identity pill: "8 min · Will bother some people"
// Pure display component — no state, no JS, no islands. Pass props, get HTML.
// Adapts to light/dark via mood CSS vars set by BaseLayout on :root.
//
// size='sm' (0.62rem, compact padding) — cards, dense layouts
// size='md' (0.72rem, default)        — detail page headers
// Zero breaking change: existing callsites without size prop get 'md'.
//
// Badge vocabulary: see openloop/badge-guide.md
// Credits: Paul Kim (business analyst — size prop priority item #1)

interface Props {
  readingTime: number;
  badge?: string;
  size?: 'sm' | 'md';
}

const { readingTime, badge, size = 'md' } = Astro.props;
---

<div class={`post-badge post-badge--${size}`}>
  <span class="reading-time">{readingTime} min</span>
  {badge && (
    <>
      <span class="dot" aria-hidden="true">·</span>
      <span class="tone">{badge}</span>
    </>
  )}
</div>

<style>
  .post-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    border-radius: 9999px;
    background: color-mix(in oklch, var(--mood-accent) 10%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid color-mix(in oklch, var(--mood-accent) 18%, transparent);
    box-shadow:
      0 1px 4px color-mix(in oklch, var(--mood-accent) 10%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--mood-accent, currentColor);
    white-space: nowrap;
    user-select: none;
  }

  /* size='md' — detail page headers (default, current behaviour unchanged) */
  .post-badge--md {
    padding: 0.25rem 0.8rem;
    font-size: 0.72rem;
  }

  /* size='sm' — card slots, dense layouts (Tanya §5: compact, prevents crowding) */
  .post-badge--sm {
    padding: 0.2rem 0.6rem;
    font-size: 0.62rem;
  }

  .dot {
    opacity: 0.45;
  }

  .tone {
    font-style: italic;
  }
</style>
