---
// src/components/ConvictionTimeline.astro
// Vertical event timeline for all conviction_ledger entries on a slug.
// CSS-only rendering. No JavaScript. Each row is an <li> with left-border chain line.
// eventType is pattern-matched in-place — no polymorphism, no subclassing.
//
// Credits: Mike (spec — ConvictionTimeline design), Tanya (§design-system — color palette)

import type { TimelineEvent } from '../lib/audit-verifier';

interface Props {
  timeline: TimelineEvent[];
  slug: string;
}

const { timeline, slug } = Astro.props;

function fmtDate(ts: number): string {
  return new Date(ts).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
  });
}

// Color modifier per event type — amber/green/red/purple (Tanya design-system)
const EVENT_MOD: Record<string, string> = {
  seal:         'tl--seal',
  revival:      'tl--revival',
  death:        'tl--death',
  resurrection: 'tl--resurrection',
};
---

{timeline.length > 0 && (
  <section class="conviction-timeline" aria-label="Conviction event history">
    <h3 class="tl-heading">Event History</h3>
    <ol class="tl-list">
      {timeline.map((event) => (
        <li class:list={['tl-entry', EVENT_MOD[event.eventType] ?? '']}>
          <div class="tl-row">
            <span class="tl-label">{event.label}</span>
            <time
              class="tl-time"
              datetime={new Date(event.timestamp).toISOString()}
            >
              {fmtDate(event.timestamp)}
            </time>
          </div>
          {event.revivalCount > 0 && (
            <span class="tl-meta">
              {event.revivalCount} revival{event.revivalCount !== 1 ? 's' : ''} at this point
            </span>
          )}
        </li>
      ))}
    </ol>
  </section>
)}

{timeline.length === 0 && (
  <p class="tl-empty">No ledger events recorded for <code>{slug}</code> yet.</p>
)}

<style>
  .conviction-timeline {
    margin-top: 2rem;
  }

  .tl-heading {
    font-size: var(--text-2xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 0 0 1rem;
  }

  /* Left-rule timeline line */
  .tl-list {
    list-style: none;
    margin: 0;
    padding: 0 0 0 1rem;
    border-left: 1px solid var(--border-light);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tl-entry {
    position: relative;
    padding: 0.7rem 0 0.7rem 0.75rem;
    border-bottom: 1px solid var(--border-faint);
  }

  .tl-entry:last-child { border-bottom: none; }

  /* Timeline dot — positioned on the left-rule line */
  .tl-entry::before {
    content: '';
    position: absolute;
    left: -1.25rem;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border-medium);
    border: 1px solid var(--border-medium);
  }

  /* Dot colors per event type */
  .tl--seal::before        { background: color-mix(in oklch, var(--gold) 50%, transparent);          border-color: color-mix(in oklch, var(--gold) 40%, transparent); }
  .tl--revival::before     { background: color-mix(in oklch, var(--verdict-true) 50%, transparent);  border-color: color-mix(in oklch, var(--verdict-true) 40%, transparent); }
  .tl--death::before       { background: color-mix(in oklch, var(--verdict-wrong) 50%, transparent); border-color: color-mix(in oklch, var(--verdict-wrong) 40%, transparent); }
  .tl--resurrection::before { background: color-mix(in oklch, var(--verdict-evolved) 50%, transparent); border-color: color-mix(in oklch, var(--verdict-evolved) 40%, transparent); }

  .tl-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tl-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--text-secondary);
    flex: 1;
  }

  /* Label colors per event type */
  .tl--seal        .tl-label { color: color-mix(in oklch, var(--gold) 85%, transparent); }
  .tl--revival     .tl-label { color: color-mix(in oklch, var(--verdict-true) 85%, transparent); }
  .tl--death       .tl-label { color: color-mix(in oklch, var(--verdict-wrong) 85%, transparent); }
  .tl--resurrection .tl-label { color: color-mix(in oklch, var(--verdict-evolved) 85%, transparent); }

  .tl-time {
    font-size: var(--text-2xs);
    color: var(--text-dim);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .tl-meta {
    display: block;
    font-size: var(--text-2xs);
    color: var(--text-ghost);
    margin-top: 0.2rem;
    font-style: italic;
  }

  /* Empty state */
  .tl-empty {
    font-size: var(--text-xs);
    color: var(--text-dim);
    font-style: italic;
    margin: 1rem 0 0;
  }

  .tl-empty code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }
</style>
