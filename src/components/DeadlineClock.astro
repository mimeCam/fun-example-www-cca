---
// src/components/DeadlineClock.astro
// Renders a deadline countdown for a post. Only mounted when resolution_deadline exists.
// Urgency bands drive color + pulse animation via CSS custom property --deadline-color.
// States: pending → imminent → critical → expired-unsealed → auto-resolved (sealed).
// Credits: Mike (architecture spec §DeadlineClock), Tanya (UX §urgency bands + dark UI)

import { getDeadlineStatus } from '../lib/deadline-enforcer';
import { buildDeadlineDisplay } from '../lib/deadline-clock';

interface Props {
  slug:        string;
  publishDate: Date;
  deadline:    Date;
}

const { slug, publishDate, deadline } = Astro.props;

const status  = getDeadlineStatus(slug, deadline);
const display = (
  status.status !== 'no-deadline' &&
  status.status !== 'auto-resolved' &&
  status.status !== 'expired-unsealed'
) ? buildDeadlineDisplay(publishDate, deadline) : null;

// UrgencyBand → CSS rgba string
const BAND_COLOR: Record<string, string> = {
  safe:     'rgba(255,255,255,0.25)',
  watch:    'rgba(245,166,35,0.45)',
  warning:  'rgba(245,166,35,0.80)',
  critical: 'rgba(220,70,70,0.90)',
  overdue:  'rgba(220,70,70,1.00)',
};

const bandColor  = display ? (BAND_COLOR[display.urgencyBand] ?? BAND_COLOR.safe) : null;
const isPulsing  = display && (display.urgencyBand === 'critical' || display.urgencyBand === 'overdue');
const deadlineLabel = deadline.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

{status.status === 'auto-resolved' && (
  <div class="dl-clock dl-clock--resolved">
    <span class="dl-label">verdict sealed</span>
    <time class="dl-date">
      {new Date(status.sealedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
    </time>
  </div>
)}

{status.status === 'expired-unsealed' && (
  <div class="dl-clock dl-clock--overdue" style={`--deadline-color: ${BAND_COLOR.overdue}`}>
    <div class="dl-header">
      <span class="dl-icon" aria-hidden="true">⏳</span>
      <span class="dl-label dl-label--pulse">OVERDUE — awaiting sweep</span>
      <time class="dl-date" datetime={deadline.toISOString()}>{deadlineLabel}</time>
    </div>
    <div class="dl-bar" role="progressbar" aria-valuenow={100} aria-valuemin={0} aria-valuemax={100}>
      <div class="dl-bar-fill" style="width:100%" />
    </div>
  </div>
)}

{display && (
  <div
    class={`dl-clock${isPulsing ? ' dl-clock--pulse' : ''}`}
    style={`--deadline-color: ${bandColor}`}
    aria-label={`Resolution deadline: ${display.label}`}
  >
    <div class="dl-header">
      <span class="dl-icon" aria-hidden="true">⏳</span>
      <span class="dl-label">{display.label}</span>
      <time class="dl-date" datetime={deadline.toISOString()}>{deadlineLabel}</time>
    </div>
    <div
      class="dl-bar"
      role="progressbar"
      aria-valuenow={display.percentConsumed}
      aria-valuemin={0}
      aria-valuemax={100}
      aria-label={`${display.percentConsumed}% of deadline window consumed`}
    >
      <div class="dl-bar-fill" style={`width:${display.percentConsumed}%`} />
    </div>
  </div>
)}

<style>
  .dl-clock {
    margin: 1.25rem 0;
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--deadline-color, rgba(255,255,255,0.09));
    border-radius: 8px;
    background: rgba(255,255,255,0.02);
    font-size: 0.78rem;
  }

  .dl-clock--resolved {
    --deadline-color: rgba(255,255,255,0.18);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0.55;
  }

  .dl-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.55rem;
  }

  .dl-icon { font-size: 0.85em; }

  .dl-label {
    font-family: ui-monospace, monospace;
    font-size: 0.73rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--deadline-color, rgba(255,255,255,0.35));
    font-weight: 600;
  }

  .dl-date {
    margin-left: auto;
    font-family: ui-monospace, monospace;
    font-size: 0.68rem;
    color: rgba(255,255,255,0.28);
    letter-spacing: 0.02em;
  }

  /* Progress bar */
  .dl-bar {
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    overflow: hidden;
  }

  .dl-bar-fill {
    height: 100%;
    background: var(--deadline-color, rgba(255,255,255,0.25));
    border-radius: 2px;
    transition: width 300ms ease;
  }

  /* Pulse animation for critical / overdue states */
  .dl-clock--pulse .dl-label,
  .dl-label--pulse {
    animation: dl-pulse 1.6s ease-in-out infinite;
  }

  @keyframes dl-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.45; }
  }
</style>
