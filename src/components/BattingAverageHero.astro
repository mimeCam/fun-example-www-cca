---
// src/components/BattingAverageHero.astro
// Trophy-tier BA hero — trustworthy + beautiful (Paul Kim: "a trophy, not a stat").
// Shows: trophy icon (tier-colored) · BA% + fill bar · selectivity bar · verdict count.
// Locked state: 🔒 Needs N more resolved verdicts to unlock.
// SSR only — server-renders BA per request, zero hydration, zero stale cache.
//
// Props:
//   result    — BattingAverageResult from getBattingAverageResult()
//   anchorUrl — GitHub Gist URL when GITHUB_PAT is wired; null otherwise
//
// SSE hook: data-cm-pct wires into existing SSE stream; trophy spring fires on
// verdict:declared + tier change only, never on page load.
//
// Credits: Mike Koch (arch spec §BA-Integrity), Tanya Donska (UX §4.4 trophy spec),
//          Elon (selection-bias — selectivityRate visible alongside BA, always)

import '../styles/batting-average.css';
import type { BattingAverageResult, TrophyTier } from '../lib/batting-average';
import BattingAverageUnlockProgress from './BattingAverageUnlockProgress.astro';
import TrophyTierLadder from './TrophyTierLadder.astro';

interface Props {
  result:     BattingAverageResult;
  anchorUrl?: string | null;
}

const { result, anchorUrl = null } = Astro.props;

const pctInt    = result.battingAverage !== null ? Math.round(result.battingAverage * 100) : 0;
const selPctInt = result.selectivityRate !== null ? Math.round(result.selectivityRate * 100) : 0;

// Pre-compute style strings — avoids template literals inside JSX attributes
const fillStyle = `--ba-fill-width: ${pctInt}%`;
const selStyle  = `--ba-sel-width: ${selPctInt}%; --ba-fill-width: ${selPctInt}%`;

const tierIcons: Record<TrophyTier, string> = {
  locked:  '🔒',
  bronze:  '🏅',
  silver:  '🥈',
  gold:    '🏆',
  diamond: '💎',
};

const icon        = tierIcons[result.trophyTier];
const pctDisplay  = result.eligible ? `${pctInt}%` : '—';
const selDisplay  = result.selectivityRate !== null ? `${selPctInt}%` : '—';
const needsMore   = 5 - result.resolvedTotal;
const wrongCount  = result.resolvedTotal - result.resolvedCorrect;
---

<section
  class="bah"
  data-ba-tier={result.trophyTier}
  aria-label="Conviction batting average"
>

  <!-- Trophy icon — tier-colored, springs in on verdict:declared if tier changed -->
  <span class="ba-trophy" aria-hidden="true">{icon}</span>

  <!-- Score block: eligible path -->
  {result.eligible && (
    <div class="bah-live">
      <div class="bah-score">
        <span
          class="bah-pct"
          data-cm-pct={pctInt}
          aria-label={`${pctInt} percent batting average`}
        >{pctDisplay}</span>
        <span class="bah-subtitle">Batting Average</span>
      </div>

      <div
        class="ba-fill-bar"
        role="progressbar"
        aria-valuenow={pctInt}
        aria-valuemin={0}
        aria-valuemax={100}
        aria-label="Batting average"
        style={fillStyle}
      >
        <div class="ba-fill-bar__track"></div>
      </div>

      <div class="ba-stats">
        <div class="ba-stats__group">
          <span class="ba-selectivity">{selDisplay} selectivity</span>
          <span class="ba-stats__label">{result.totalSealed} sealed of {result.totalPublished} published</span>
          <div
            class="ba-sel-bar"
            role="progressbar"
            aria-valuenow={selPctInt}
            aria-valuemin={0}
            aria-valuemax={100}
            aria-label="Selectivity"
            style={selStyle}
          >
            <div class="ba-sel-bar__track"></div>
          </div>
        </div>
        <div class="ba-stats__group ba-stats__group--right">
          <span class="ba-selectivity">{result.resolvedTotal}</span>
          <span class="ba-stats__label">Verdicts</span>
        </div>
      </div>

      <div class="bah-pills" aria-label="Score breakdown">
        <span class="bah-pill bah-pill--correct" data-cm-correct={result.resolvedCorrect}>
          ✓ {result.resolvedCorrect} correct
        </span>
        <span class="bah-pill bah-pill--wrong" data-cm-wrong={wrongCount}>
          ✗ {wrongCount} wrong
        </span>
      </div>
    </div>
  )}

  <!-- Unlock swap target — present only in cold state; revealed by JS on bah:unlock -->
  {!result.eligible && (
    <div class="bah-live bah-live--hidden" aria-hidden="true">
      <div class="bah-score">
        <span class="bah-pct" data-cm-pct="0" aria-label="Batting average">0%</span>
        <span class="bah-subtitle">Batting Average</span>
      </div>
      <div class="ba-fill-bar" role="progressbar" aria-valuenow={0} aria-valuemin={0} aria-valuemax={100} style="--ba-fill-width:0%">
        <div class="ba-fill-bar__track"></div>
      </div>
    </div>
  )}

  <!-- Score block: locked path (< MIN_VERDICTS resolved) -->
  {!result.eligible && (
    <div class="bah-cold">
      <div class="bah-score bah-score--cold">
        <div class="bah-ghost-ring" aria-hidden="true">
          <svg class="bah-ring-svg" viewBox="0 0 88 88" overflow="visible" role="presentation">
            <circle class="bah-ring-outer" cx="44" cy="44" r="38" />
            <circle class="bah-ring-inner" cx="44" cy="44" r="30" />
          </svg>
        </div>
        <span class="bah-pct bah-pct--cold" aria-label="Batting average locked">—</span>
        <span class="bah-subtitle bah-subtitle--cold">Batting Average</span>
      </div>

      <BattingAverageUnlockProgress
        resolvedTotal={result.resolvedTotal}
        totalSealed={result.totalSealed}
      />

      <TrophyTierLadder currentTier={result.trophyTier} />
    </div>
  )}

  <!-- Anchor badge — tamper-evidence link -->
  <div class="bah-anchor">
    {anchorUrl
      ? <a href={anchorUrl} target="_blank" rel="noopener noreferrer" class="bah-anchor-link">Anchored on GitHub · tamper-evident ↗</a>
      : <span>Conviction ledger · tamper-evident</span>
    }
  </div>

  <div class="bah-actions">
    <button class="bah-share" type="button" aria-label="Copy link to batting average">
      share score ↗
    </button>
  </div>

  <div class="bah-scroll-cue" aria-hidden="true">↓ see the bets</div>

</section>

<script>
  // BattingAverageHero — client ceremony layer
  // 1. Share button (clipboard API with prompt() fallback)
  // 2. BA count-up + trophy spring on verdict:declared SSE event
  // 3. bah:unlock — cold → live DOM swap (fired by ba-unlock-progress.ts)
  //    Trophy spring fires on tier CHANGE only — not on every page load.
  //
  // Credits: Mike (§3 SSE lifecycle, napkin §UnlockTransition),
  //          Tanya (§4.4 trophy spring spec),
  //          Elon (reduced-motion guard + bah:ceremony-done CustomEvent)

  import { countUp } from '../lib/spring-easing';
  import '../lib/client/ba-unlock-progress'; // boots dot-fill ceremony on cold state

  declare global { interface Window { __heartbeat?: EventSource; } }

  interface VerdictPayload {
    newBattingAvg: number | null;
    correct?:      number;
    wrong?:        number;
    pending?:      number;
    trophyTier?:   string;
  }

  // Stash last verdict payload so bah:unlock handler can animate count-up
  let _lastPayload: VerdictPayload | null = null;

  function getStream(): EventSource {
    if (window.__heartbeat?.readyState !== EventSource.CLOSED) return window.__heartbeat!;
    return (window.__heartbeat = new EventSource('/api/heartbeat'));
  }

  function getPctEl(): HTMLElement | null {
    return document.querySelector<HTMLElement>('.bah-pct[data-cm-pct]');
  }

  function getTrophyEl(): HTMLElement | null {
    return document.querySelector<HTMLElement>('.ba-trophy');
  }

  function fireTrophySpring(el: HTMLElement): void {
    el.classList.remove('ba-trophy--spring');
    void el.offsetWidth;
    el.classList.add('ba-trophy--spring');
  }

  function fireCeremonyDone(pct: number): void {
    document.dispatchEvent(new CustomEvent('bah:ceremony-done', { detail: { pct } }));
  }

  function snapUpdate(el: HTMLElement, to: number, pct: number): void {
    el.textContent   = `${pct}%`;
    el.dataset.cmPct = String(pct);
    fireCeremonyDone(to);
  }

  function animateCountUp(el: HTMLElement, from: number, pct: number, tier?: string): void {
    countUp(from, pct, val => { el.textContent = `${val}%`; }, () => {
      el.dataset.cmPct = String(pct);
      const trophy = getTrophyEl();
      if (trophy && tier) fireTrophySpring(trophy);
      fireCeremonyDone(pct);
    });
  }

  function handleVerdict(payload: VerdictPayload): void {
    if (payload.newBattingAvg === null) return;
    const el = getPctEl();
    if (!el) return;
    const from = parseInt(el.dataset.cmPct ?? '0', 10);
    const pct  = Math.round(payload.newBattingAvg * 100);
    if (from === pct) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      snapUpdate(el, pct, pct); return;
    }
    animateCountUp(el, from, pct, payload.trophyTier);
  }

  // ── Unlock DOM swap — fires when ba-unlock-progress.ts dispatches bah:unlock ──

  function revealLiveSection(): void {
    const live = document.querySelector<HTMLElement>('.bah-live--hidden');
    if (!live) return;
    live.classList.remove('bah-live--hidden');
    live.classList.add('ba-locked--unlocked');
    live.removeAttribute('aria-hidden');
  }

  function fadeColdSection(): void {
    const cold = document.querySelector<HTMLElement>('.bah-cold');
    if (cold) cold.classList.add('ba-locked--fade-out');
  }

  function handleUnlock(e: CustomEvent<VerdictPayload>): void {
    fadeColdSection();
    setTimeout(() => {
      revealLiveSection();
      if (e.detail) handleVerdict(e.detail);
    }, 300);
  }

  // ── Boot ──────────────────────────────────────────────────────────────────────

  function boot(): void {
    const es = getStream();
    es.addEventListener('verdict:declared', (e: MessageEvent) => {
      try {
        _lastPayload = JSON.parse(e.data) as VerdictPayload;
        handleVerdict(_lastPayload);
      } catch { /* ignore */ }
    });
    document.addEventListener('bah:unlock', e => handleUnlock(e as CustomEvent<VerdictPayload>));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot, { once: true });
  } else { boot(); }

  // ── Share button ──────────────────────────────────────────────────────────────

  function bindShareButton(): void {
    const btn = document.querySelector<HTMLButtonElement>('.bah-share');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const url = window.location.href;
      if (navigator.clipboard) {
        navigator.clipboard.writeText(url).then(() => {
          btn.textContent = 'copied ✓';
          setTimeout(() => { btn.textContent = 'share score ↗'; }, 2000);
        });
      } else { window.prompt('Copy this link:', url); }
    });
  }

  bindShareButton();
</script>

<style>
  /* ── Hero layout ──────────────────────────────────────────────────────── */
  .bah {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-12) var(--space-8);
    max-width: 40rem;
    margin: 0 auto;
  }

  .bah-live, .bah-cold {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Unlock swap target — hidden until bah:unlock DOM swap */
  .bah-live--hidden { display: none; }

  /* ── Score block ─────────────────────────────────────────────────────── */
  .bah-score {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .bah-score--cold { position: relative; }

  .bah-pct {
    display: block;
    font-size: var(--text-hero);
    font-weight: var(--weight-bold);
    font-family: var(--font-mono);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display);
    color: var(--ba-tier-color, var(--ba-tier-locked));
  }

  .bah-pct--cold {
    color: var(--text-disabled);
    animation: bah-cold-breathe 4s ease-in-out infinite;
  }

  .bah-subtitle {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    letter-spacing: var(--tracking-wide);
  }

  .bah-subtitle--cold { font-style: italic; color: var(--text-ghost); }

  /* ── Stat row groups ─────────────────────────────────────────────────── */
  .ba-stats__group { display: flex; flex-direction: column; gap: 3px; }
  .ba-stats__group--right { text-align: right; }

  /* ── Ghost ring (cold state) ─────────────────────────────────────────── */
  .bah-ghost-ring {
    position: absolute;
    top: 50%; left: 50%;
    width: 5.5rem; height: 5.5rem;
    pointer-events: none;
    animation: bah-ring-spin 10s linear infinite;
  }

  .bah-ring-svg { width: 100%; height: 100%; overflow: visible; }

  .bah-ring-outer, .bah-ring-inner {
    fill: none;
    stroke: var(--gold-border);
  }

  .bah-ring-outer { stroke-width: 2; stroke-dasharray: 8 5; }
  .bah-ring-inner { stroke-width: 1.5; stroke-dasharray: 5 8; opacity: 0.6; }

  @keyframes bah-ring-spin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* ── Outcome pills ───────────────────────────────────────────────────── */
  .bah-pills {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .bah-pill {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    padding: 3px var(--space-2);
    border-radius: var(--radius-badge);
    white-space: nowrap;
  }

  .bah-pill--correct { background: var(--correct-bg);  color: var(--verdict-true);  }
  .bah-pill--wrong   { background: var(--wrong-bg);    color: var(--verdict-wrong); }

  /* ── Anchor ──────────────────────────────────────────────────────────── */
  .bah-anchor {
    font-size: var(--text-2xs);
    color: var(--text-ghost);
    letter-spacing: var(--tracking-wide);
    border-left: 1px solid var(--gold-border);
    padding-left: var(--space-2);
  }

  .bah-anchor-link {
    color: var(--gold-dim);
    text-decoration: none;
    transition: color var(--motion-duration-fast) var(--motion-easing-standard);
  }

  .bah-anchor-link:hover { color: var(--gold); text-decoration: underline; }

  /* ── Share + scroll cue ──────────────────────────────────────────────── */
  .bah-actions { margin-top: calc(-1 * var(--space-1)); }

  .bah-share {
    background: none;
    border: 1px solid var(--gold-border);
    color: var(--gold-dim);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    padding: 4px var(--space-3);
    border-radius: var(--radius-badge);
    cursor: pointer;
    letter-spacing: var(--tracking-wide);
    transition: color var(--motion-duration-fast) var(--motion-easing-standard),
                border-color var(--motion-duration-fast) var(--motion-easing-standard);
  }

  .bah-share:hover { color: var(--gold); border-color: var(--gold-dim); }

  .bah-scroll-cue {
    font-size: var(--text-xs);
    color: var(--text-ghost);
    letter-spacing: var(--tracking-widest);
    margin-top: auto;
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-subtle);
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .bah { padding: var(--space-8) var(--space-4); gap: var(--space-3); }
    .bah-ghost-ring { width: 3.8rem; height: 3.8rem; }
    .bah-scroll-cue { animation: bah-bob 2s ease-in-out infinite; }
  }

  @keyframes bah-bob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(4px); }
  }

  /* ── Reduced motion ──────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .bah-scroll-cue { animation: none; }
    .bah-pct--cold  { animation: none; }
    .bah-ghost-ring { animation-play-state: paused; }
  }

  @keyframes bah-cold-breathe {
    0%, 100% { opacity: 0.15; }
    50%       { opacity: 0.30; }
  }
</style>
