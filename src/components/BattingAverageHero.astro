---
// src/components/BattingAverageHero.astro
// Zone 1 conviction hero — the first thing a visitor sees.
// Full-height above-fold section: large pct, pills, HMAC badge, share button.
// Zero external client JS — share button is 8 lines of inline clipboard API.
//
// SSE hook: data-cm-pct attribute wires into existing initLiveConviction()
// so the hero number patches live on verdict events — zero SSE code changes.
//
// Cold state: em dash + "no verdicts sealed yet" + "The clock is running."
// No error state, no spinner — the site is honest about its cold start.
//
// Credits: Mike (arch spec — BattingAverageHero), Tanya (UX §18 — Conviction Hero)

import type { BattingAverage } from '../lib/batting-average';

interface Props {
  avg: BattingAverage;
}

const { avg } = Astro.props;

const isLive = avg.status === 'live';
const pctMod = isLive
  ? avg.pct >= 80 ? 'bah--strong' : avg.pct >= 60 ? 'bah--mid' : 'bah--weak'
  : 'bah--cold';
---

<section class:list={['bah', pctMod]} aria-label="Conviction batting average">

  <p class="bah-tagline">I publish ideas with skin in the game.</p>

  {isLive ? (
    <div class="bah-score">
      <span class="bah-pct" data-cm-pct={avg.pct} aria-label={`${avg.pct} percent accuracy`}>
        {avg.pct}%
      </span>
      <span class="bah-subtitle">of sealed bets held true</span>
    </div>

    <div class="bah-pills" aria-label="Score breakdown">
      <span class="bah-pill bah-pill--correct" data-cm-correct={avg.correct}>✓ {avg.correct} correct</span>
      <span class="bah-pill bah-pill--wrong"   data-cm-wrong={avg.wrong}>✗ {avg.wrong} wrong</span>
      <span class="bah-pill bah-pill--pending" data-cm-pending={avg.pending}>◌ {avg.pending} pending</span>
    </div>

    <div class="bah-anchor">
      Anchored on GitHub · tamper-evident
    </div>

    <div class="bah-actions">
      <button class="bah-share" type="button" aria-label="Copy link to batting average">
        share score ↗
      </button>
    </div>
  ) : (
    <div class="bah-score bah-score--cold">
      <span class="bah-pct bah-pct--cold" aria-label="No verdicts yet">—</span>
      <span class="bah-subtitle bah-subtitle--cold">no verdicts sealed yet</span>
    </div>

    <p class="bah-clock">The clock is running.</p>
  )}

  <div class="bah-scroll-cue" aria-hidden="true">↓ see the bets</div>

</section>

<script>
  // Share button: clipboard API with prompt() fallback (Tanya §18, Mike §3)
  const btn = document.querySelector('.bah-share') as HTMLButtonElement | null;
  if (btn) {
    btn.addEventListener('click', () => {
      const url = window.location.href;
      if (navigator.clipboard) {
        navigator.clipboard.writeText(url).then(() => { btn.textContent = 'copied ✓'; setTimeout(() => { btn.textContent = 'share score ↗'; }, 2000); });
      } else {
        window.prompt('Copy this link:', url);
      }
    });
  }
</script>

<style>
  /* ── Hero section — full height above fold (Tanya §18) ── */
  .bah {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    min-height: calc(100vh - 48px); /* subtract nav height */
    padding: 6rem 2rem;
    max-width: 40rem;
    margin: 0 auto;
  }

  /* ── Intro tagline ── */
  .bah-tagline {
    font-size: 1.1rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
    letter-spacing: 0.01em;
  }

  /* ── Score block: large number + subtitle ── */
  .bah-score {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .bah-pct {
    display: block;
    font-size: 4.5rem;
    font-weight: 700;
    font-family: ui-monospace, 'Cascadia Code', monospace;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  /* Color variants — Tanya §18 + §24 amber system */
  .bah--strong .bah-pct { color: #F5A623; }
  .bah--mid    .bah-pct { color: rgba(245, 166, 35, 0.7); }
  .bah--weak   .bah-pct { color: rgba(255, 255, 255, 0.5); }
  .bah-pct--cold        { color: rgba(255, 255, 255, 0.2); }

  .bah-subtitle {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.02em;
  }

  .bah-subtitle--cold {
    font-style: italic;
    color: rgba(255, 255, 255, 0.3);
  }

  /* ── Pill badges ── */
  .bah-pills {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .bah-pill {
    font-size: 0.72rem;
    font-family: ui-monospace, monospace;
    padding: 3px 8px;
    border-radius: 4px;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .bah-pill--correct { background: rgba(80, 200, 100, 0.1);  color: rgba(100, 210, 120, 0.85); }
  .bah-pill--wrong   { background: rgba(220, 80,  80,  0.1); color: rgba(230, 100, 100, 0.85); }
  .bah-pill--pending { background: rgba(255, 255, 255, 0.05); color: rgba(255, 255, 255, 0.45); }

  /* ── HMAC anchor badge ── */
  .bah-anchor {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.03em;
    border-left: 1px solid rgba(245, 166, 35, 0.25);
    padding-left: 0.6rem;
  }

  /* ── "The clock is running." — cold state ── */
  .bah-clock {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* ── Share button ── */
  .bah-actions { margin-top: -0.5rem; }

  .bah-share {
    background: none;
    border: 1px solid rgba(245, 166, 35, 0.2);
    color: rgba(245, 166, 35, 0.6);
    font-size: 0.7rem;
    font-family: ui-monospace, monospace;
    padding: 4px 10px;
    border-radius: 4px;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .bah-share:hover {
    color: #F5A623;
    border-color: rgba(245, 166, 35, 0.45);
  }

  /* ── Scroll cue ── */
  .bah-scroll-cue {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.06em;
    margin-top: auto;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .bah { padding: 4rem 1rem; gap: 1.25rem; }
    .bah-pct { font-size: 2.8rem; }
    .bah-tagline { font-size: 0.9rem; }
    .bah-scroll-cue {
      animation: bah-bob 2s ease-in-out infinite;
    }
  }

  @keyframes bah-bob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .bah-scroll-cue { animation: none; }
  }
</style>
