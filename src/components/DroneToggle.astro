---
// src/components/DroneToggle.astro
// Ambient drone on/off button. Requires window.__drone (droneController).
// Respects prefers-reduced-motion by hiding entirely.
// TODO: show droneMoodLabel text on hover/focus
// TODO: animate icon between play ▶ and pause ❚❚ states
---

<button
  id="drone-toggle"
  type="button"
  aria-label="Toggle ambient drone"
  aria-pressed="false"
  class="fixed bottom-4 right-4 z-40
         w-10 h-10 rounded-full
         bg-black/20 backdrop-blur-sm
         border border-white/10
         text-white/50 hover:text-white/80
         transition-opacity duration-300
         cursor-pointer select-none
         motion-reduce:hidden"
>
  <span id="drone-icon" class="text-sm" aria-hidden="true">♫</span>
</button>

<script>
  const btn = document.getElementById('drone-toggle');
  if (btn && (window as any).__drone) {
    btn.addEventListener('click', () => {
      const playing = (window as any).__drone.toggle();
      btn.setAttribute('aria-pressed', String(playing));
      btn.style.opacity = playing ? '1' : '';
    });
  }
</script>
