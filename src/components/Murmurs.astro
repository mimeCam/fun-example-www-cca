---
// src/components/Murmurs.astro
// Read-only micro-thoughts from the wall, folded into the homepage.
// Recent entries rendered inline; fossils collapsed behind a divider.
// No form, no submission — CLI only (node cli/whisper.mjs).
//
// Credits: Tanya (UX spec §3 — murmurs zone), Mike (wall fold plan)

import { partitionEntries } from '../lib/wall';
import type { WallEntry, ComputedWallEntry } from '../lib/wall';
import wallRaw from '../data/wall.json';

const MAX_RECENT = 5;
const MAX_FOSSILS = 5;

const entries = wallRaw as WallEntry[];
const { active, fossils } = partitionEntries(entries);
const recentVisible = active.slice(0, MAX_RECENT);
const fossilVisible = fossils.slice(0, MAX_FOSSILS);
const hasMore = active.length > MAX_RECENT;
const hiddenFossils = Math.max(0, fossils.length - MAX_FOSSILS);

/** Human-readable age label from day count. */
function formatAge(days: number): string {
  if (days < 1) return 'today';
  if (days === 1) return '1d';
  return `${Math.floor(days)}d`;
}

/** CSS-safe decay string. */
function cssDecay(m: ComputedWallEntry): string {
  return m.decay.toFixed(3);
}
---

{(recentVisible.length > 0 || fossilVisible.length > 0) && (
  <section class="murmurs-zone" aria-label="Murmurs">

    {recentVisible.length > 0 && (
      <div class="murmurs-recent">
        {recentVisible.map(m => (
          <div
            class="murmur"
            style={`--decay: ${cssDecay(m)}`}
          >
            <span class="murmur-text">{m.entry.text}</span>
            <span class="murmur-age">{formatAge(m.days)}</span>
          </div>
        ))}
        {hasMore && (
          <span class="murmurs-more">
            + {active.length - MAX_RECENT} older murmurs fading
          </span>
        )}
      </div>
    )}

    {fossilVisible.length > 0 && (
      <div class="murmurs-fossils">
        <span class="murmurs-divider" aria-hidden="true">older...</span>
        {fossilVisible.map(f => (
          <div class="murmur murmur--fossil">
            <span class="murmur-text">{f.entry.text}</span>
            <span class="murmur-age">{formatAge(f.days)}</span>
          </div>
        ))}
        {hiddenFossils > 0 && (
          <span class="murmurs-more">
            + {hiddenFossils} more buried deeper
          </span>
        )}
      </div>
    )}

  </section>
)}

<style>
  .murmurs-zone {
    max-width: 40rem;
    margin: 2rem auto 0;
    padding: 1rem 1.25rem;
    border: 1px dashed var(--border-light);
    border-radius: var(--radius, 12px);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .murmurs-recent {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .murmur {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    opacity: calc(0.35 + 0.45 * (1 - var(--decay)));
  }

  .murmur--fossil {
    opacity: 0.2;
    font-size: var(--text-xs);
  }

  .murmur-text {
    font-size: var(--text-sm);
    line-height: 1.4;
    color: var(--text-secondary);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .murmur--fossil .murmur-text {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  .murmur-age {
    font-size: var(--text-2xs);
    color: var(--text-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .murmurs-divider {
    display: block;
    text-align: center;
    font-size: var(--text-2xs);
    font-style: italic;
    opacity: 0.2;
    margin: 0.4rem 0 0.2rem;
    letter-spacing: 0.06em;
  }

  .murmurs-fossils {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .murmurs-more {
    display: block;
    text-align: center;
    font-size: var(--text-2xs);
    font-style: italic;
    opacity: 0.3;
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .murmurs-zone { padding: 0.75rem 1rem; }
  }
</style>
