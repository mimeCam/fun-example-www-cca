---
// src/components/ConvictionSeal.astro
// Unified seal ceremony — replaces AdminSealForm + ConvictionHero + ConvictionDeclaration.
// Sealed state: full conviction display (score, clock, tension, trust badge).
// Unsealed state: 5-phase ceremony form (idle → hover → press → lock → receipt).
//
// CSS custom property --seal-phase (0–3.5–4) drives all visual transitions.
// Progressive enhancement: works as plain <form> without JS.
//
// Credits: Mike (§Architecture, §CSS-state-machine), Tanya (§Moment-1 ceremony spec),
//          DevBrain (@starting-style, spring-curve timing)

import { getSealEntry }        from '../lib/conviction-ledger';
import { getDisputeResolution } from '../lib/verdict-dispute';
import DecayClock               from './DecayClock.astro';
import TrustBadge               from './TrustBadge.astro';
import type { ConvictionStage } from './TrustBadge.astro';
import TensionBadge             from './TensionBadge.astro';
import NotarizeStamp            from './NotarizeStamp.astro';
import SealReceipt              from './SealReceipt.astro';
import ShareSealButton          from './ShareSealButton.astro';
import { clockUrgency }         from '../lib/death-clock';
import type { GraceState }          from '../lib/cold-start';
import type { ConvictionVerdict }   from '../lib/decay-engine';
import type { TensionResult }       from '../lib/tension-score';
import type { TstData }             from '../lib/timestamp-store';

interface Props {
  slug:           string;
  title?:         string;           // for admin context header
  context?:       'post' | 'admin'; // 'admin' always shows form
  // Sealed display props (ConvictionHero parity)
  graceState?:    GraceState;
  revivalCount?:  number;
  conviction?:    ConvictionVerdict | null;
  tensionResult?: TensionResult | null;
  tst?:           TstData | null;
}

const {
  slug, title, context = 'post',
  graceState, revivalCount = 0,
  conviction = null, tensionResult = null, tst = null,
} = Astro.props;

let sealEntry   = null;
let resolution  = null;
try { sealEntry  = getSealEntry(slug);        } catch { /* DB not ready at build time */ }
try { resolution = getDisputeResolution(slug); } catch { /* DB not ready at build time */ }

function deriveConvictionStage(): ConvictionStage {
  if (!sealEntry) return 'unsealed';
  if (!tst)       return 'pending';
  if (!resolution) return 'sealed';
  return resolution.state as ConvictionStage;
}

const convictionStage = deriveConvictionStage();
const sealed     = !!sealEntry;
const score      = sealEntry?.conviction_score ?? null;
const note       = sealEntry?.author_note      ?? null;
const barPct     = score !== null ? (score / 10) * 100 : 0;
const shortHash  = sealEntry?.hash?.slice(0, 16) ?? '';
const sealedAt   = sealEntry
  ? new Date(sealEntry.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
  : '';

const clockDays       = graceState?.warming ? 1 : (graceState?.daysRemaining ?? 0);
const clockUrgencyVal = clockUrgency(clockDays);
const deadlineISO     = (graceState && !graceState.warming && clockDays > 0)
  ? new Date(Date.now() + clockDays * 86_400_000).toISOString()
  : null;
---

{sealed && score !== null && (
<section
  class="conviction-seal conviction-seal--sealed"
  aria-label="Author conviction — sealed before publication"
>
  <!-- Label row -->
  <div class="cs-label-row" aria-hidden="true">
    <span class="cs-label-icon">⚡</span>
    <span class="cs-label-text">CONVICTION</span>
    <span class="cs-label-sep">·</span>
    <span class="cs-label-sub">SEALED BEFORE FIRST READ</span>
    <span class="cs-label-trust"><TrustBadge tst={tst} slug={slug} convictionStage={convictionStage} /></span>
  </div>

  <!-- Score row -->
  <div class="cs-score-row">
    <div class="cs-stamp" aria-label={`Conviction score: ${score} out of 10`}>
      <span class="cs-score-digit">{score}</span>
      <span class="cs-score-denom">/10</span>
    </div>
    <div class="cs-wager">
      <div class="cs-bar-track" role="progressbar" aria-valuenow={score} aria-valuemin={1} aria-valuemax={10}>
        <div class="cs-bar-fill" style={`width:${barPct}%`}></div>
      </div>
      <p class="cs-note">"{note}"</p>
      <time class="cs-sealed-at" datetime={new Date(sealEntry!.timestamp).toISOString()}>
        sealed {sealedAt}
      </time>
    </div>
  </div>

  <!-- Status row: clock + tension + meta -->
  <div class="cs-status-row">
    {graceState?.warming ? (
      <div class="cs-warming" aria-label={`Warming: ${graceState.readerCount}/${graceState.threshold} readers`}>
        <span class="cs-warming-pct">{graceState.readerCount}/{graceState.threshold}</span>
        <span class="cs-warming-label">readers — clock starts at {graceState.threshold}</span>
      </div>
    ) : (
      <div class="cs-clock-wrap" data-deadline-iso={deadlineISO ?? undefined}>
        <DecayClock variant="ring" daysRemaining={clockDays} urgency={clockUrgencyVal} conviction={conviction} />
      </div>
    )}

    <TensionBadge tensionResult={tensionResult} revivalCount={revivalCount} slug={slug} embedded={true} />

    <div class="cs-meta">
      {revivalCount > 0 && (
        <span class="cs-revivals">↑ {revivalCount} {revivalCount === 1 ? 'revival' : 'revivals'}</span>
      )}
      <a href="#conviction-audit" class="cs-hash" title={`Full hash: ${sealEntry!.hash}`}>
        #{shortHash}…↓
      </a>
    </div>
  </div>
</section>
)}

{!sealed && (
<div
  class={`conviction-seal conviction-seal--ceremony ${context === 'admin' ? 'conviction-seal--admin' : ''}`}
  data-slug={slug}
  data-seal-phase="0"
  style="--seal-phase:0"
>
  <!-- Author-gated notice: visible to non-authors on post page -->
  {context === 'post' && (
    <div class="cs-unsealed-notice" data-unsealed-notice>
      <span class="cs-unsealed-icon">◇</span>
      <span class="cs-unsealed-label">Conviction score not yet sealed</span>
    </div>
  )}

  <!-- Ceremony form: always visible in admin; revealed by JS on post page -->
  <form
    class="seal-form cs-form"
    method="POST"
    action="/api/conviction-seal"
    data-seal-form
    aria-label="Seal your conviction"
    style={context === 'post' ? 'display:none' : ''}
  >
    {title && <p class="cs-form-title">{title}</p>}

    <div class="cs-form-header">
      <span class="cs-eyebrow">UNSEALED CLAIM</span>
      <p class="cs-form-headline">Stake your reputation on this.</p>
      <p class="cs-form-body">
        Once sealed, it enters the accountability loop. The community can dispute
        it within 72 hours. There is no unseal.
      </p>
    </div>

    <!-- Score dots: 10 discrete levels — more deliberate than a slider -->
    <div class="cs-dots-wrap" role="group" aria-label="Conviction score 1 to 10">
      <div class="cs-dots" data-dots>
        {Array.from({ length: 10 }, (_, i) => (
          <button
            type="button"
            class="seal-dot"
            data-value={i + 1}
            aria-label={`Score ${i + 1} out of 10`}
            aria-pressed="false"
          ></button>
        ))}
      </div>
      <span class="cs-score-readout">
        <span data-score-display>5</span><span class="cs-score-denom-sm">/10</span>
      </span>
    </div>

    <!-- Weight meter: visual feedback tied to --seal-phase -->
    <div class="cs-meter-wrap" aria-hidden="true">
      <div class="seal-weight-meter cs-meter" data-weight-meter></div>
    </div>

    <input type="hidden" name="slug" value={slug} />
    <input type="hidden" name="score" value="5" data-score-input />

    <label class="cs-label" for={`cs-note-${slug}`}>Author note</label>
    <textarea
      id={`cs-note-${slug}`}
      name="authorNote"
      rows="3"
      maxlength="280"
      placeholder="One sentence: what you believed when you sealed this."
      class="cs-textarea"
      required
    ></textarea>

    <!-- Seal button with SVG arc ring for hold-to-seal -->
    <div class="cs-btn-wrap">
      <button type="submit" class="seal-btn cs-seal-btn" data-seal-btn>
        <svg class="cs-arc-svg" viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
          <circle cx="20" cy="20" r="18" class="cs-arc-track" />
          <circle cx="20" cy="20" r="18" class="seal-arc" data-arc />
        </svg>
        <span class="seal-btn-label cs-btn-label">SEAL THIS CLAIM</span>
        <span class="seal-spinner cs-spinner" aria-hidden="true"></span>
      </button>
      <p class="seal-error cs-error" data-error aria-live="polite"></p>
    </div>

    <!-- Phase 3 lock overlay: irreversibility notice + cancel CTA -->
    <!-- Visibility driven by [data-seal-phase="3"] in seal-ceremony.css -->
    <div class="seal-lock-overlay" aria-live="polite">
      <p class="seal-irrev-notice">
        Sealing your conviction. This cannot be undone — your credibility is on record.
      </p>
      <button type="button" class="seal-cancel-btn" data-cancel-btn>
        Cancel
      </button>
    </div>
  </form>

  <!-- Phase 4 receipt: SealReceipt notary document — outside form, shown at phase 4 -->
  <!-- Visibility driven by [data-seal-phase="4"] in seal-ceremony.css              -->
  <SealReceipt />

  <!-- Phase 5: ShareSealButton — share card rises below receipt after seal (Tanya §5) -->
  <!-- Score populated by JS via [data-share-score]; visibility driven by phase 4 CSS  -->
  <ShareSealButton slug={slug} title={title ?? slug} />

  <!-- Phase 3.5 notarize ceremony — outside form so form display:none doesn't hide it -->
  <!-- Shown by [data-seal-phase="3.5"] selector; hidden at all other phases            -->
  <NotarizeStamp />
</div>
)}

<style>
  @import '../styles/seal-ceremony.css';

  /* ── Shared container ────────────────────────────────────── */
  .conviction-seal {
    margin: 0 0 var(--space-10);
  }

  /* ── Sealed display (was ConvictionHero) ─────────────────── */
  .conviction-seal--sealed {
    background:   oklch(18% 0.025 280);
    border:       1px solid oklch(30% 0.04 280);
    border-left:  3px solid rgba(245, 166, 35, 0.65);
    border-radius: var(--radius-tombstone);
    padding:       var(--space-5) 1.75rem var(--space-6);
    box-shadow:    0 1px 4px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.04);
  }

  /* Label row */
  .cs-label-row {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin-bottom: var(--space-4);
  }

  .cs-label-trust { margin-left: auto; }

  .cs-label-icon { font-size: var(--text-2xs); color: var(--gold); }

  .cs-label-text {
    font-size: var(--text-2xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--gold);
  }

  .cs-label-sep { font-size: var(--text-2xs); color: var(--gold-dim); margin: 0 0.1rem; }

  .cs-label-sub {
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgba(245, 166, 35, 0.55);
  }

  /* Score row */
  .cs-score-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    margin-bottom: var(--space-5);
  }

  .cs-stamp {
    flex-shrink: 0;
    display: flex;
    align-items: baseline;
    gap: 0.1rem;
    line-height: 1;
  }

  .cs-score-digit {
    font-size: 2.2rem;
    font-weight: var(--weight-bold);
    font-family: var(--font-mono);
    color: var(--gold);
    letter-spacing: var(--tracking-tight);
  }

  .cs-score-denom {
    font-size: 1rem;
