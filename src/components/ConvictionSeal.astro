    font-size: var(--text-sm);
    color: var(--gold-dim);
  }

  /* Weight meter */
  .cs-meter-wrap {
    height: 24px;
    display: flex;
    align-items: flex-end;
    margin-bottom: var(--space-4);
  }

  .cs-meter { height: 100%; }

  /* Form fields */
  .cs-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-2);
  }

  .cs-textarea {
    width: 100%;
    background:    var(--surface-raised);
    border:        1px solid var(--border-interactive);
    border-radius: var(--radius-sm);
    padding:       var(--space-3) var(--space-3);
    font-size:     var(--text-sm);
    color:         var(--text-primary);
    resize:        vertical;
    outline:       none;
    font-family:   inherit;
    line-height:   var(--leading-normal);
    transition:    border-color var(--motion-duration-fast) var(--motion-easing-standard);
    box-sizing:    border-box;
    margin-bottom: var(--space-6);
  }

  .cs-textarea:focus { border-color: var(--border-focus); }

  /* Seal button */
  .cs-btn-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .cs-seal-btn {
    position:    relative;
    display:     flex;
    align-items: center;
    gap:         var(--space-3);
    background:  var(--gold-bg);
    border:      1px solid var(--gold-border);
    border-radius: var(--radius-md);
    padding:     var(--space-3) var(--space-6);
    min-height:  52px;
    cursor:      pointer;
    transition:
      background  var(--motion-duration-fast) var(--motion-easing-standard),
      border-color var(--motion-duration-fast) var(--motion-easing-standard),
      box-shadow  var(--motion-duration-base)  var(--motion-easing-spring);
  }

  .cs-seal-btn:hover {
    background:   rgba(245, 166, 35, 0.14);
    border-color: rgba(245, 166, 35, 0.5);
    box-shadow:   0 0 0 1px var(--gold-border);
  }

  .cs-arc-svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .cs-arc-track {
    fill:   none;
    stroke: var(--border-subtle);
    stroke-width: 2;
  }

  .seal-arc { stroke-width: 2; }

  .cs-btn-label {
    font-size:      var(--text-xs);
    font-weight:    var(--weight-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color:          var(--gold);
  }

  .cs-spinner { flex-shrink: 0; }

  .cs-error {
    display:   none;
    font-size: var(--text-xs);
    color:     var(--verdict-wrong);
    text-align: center;
  }

  /* Receipt: SealReceipt.astro owns its own styles.
   * Only display control lives here via seal-ceremony.css selectors. */

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .conviction-seal--sealed { padding: 1.1rem var(--space-5) var(--space-5); }
    .cs-score-digit          { font-size: 2rem; }
    .cs-label-sub, .cs-revivals { display: none; }
    .cs-warming              { flex-direction: column; align-items: flex-start; }
    .conviction-seal--ceremony { padding: var(--space-5); }
    .cs-dots                 { flex-wrap: wrap; }
  }
</style>

<script>
  import { createCeremony }         from '../lib/seal-ceremony';
  import type { SealPhase, ReceiptData } from '../lib/seal-ceremony';
  import { ceremonyStart, ceremonyAbort, ceremonyResolve, ceremonyComplete } from '../lib/ceremony-atmosphere';

  /** Map seal phase transitions to atmosphere lifecycle. */
  function handleCeremonyAtmosphere(phase: SealPhase, slug: string, active: { v: boolean }): void {
    if (phase === 2) { active.v = true; ceremonyStart(slug); }
    else if (phase === 4) {
      active.v = false;
      setTimeout(() => ceremonyResolve(slug), 300);
      setTimeout(() => ceremonyComplete(slug), 3300); // restore neutral after receipt settles
    }
    else if (phase === 0 && active.v) { active.v = false; ceremonyAbort(slug); }
  }

  function initSealForm(container: HTMLElement): void {
    const form       = container.querySelector<HTMLFormElement>('[data-seal-form]')!;
    const dotsEl     = container.querySelector<HTMLElement>('[data-dots]')!;
    const scoreInput = container.querySelector<HTMLInputElement>('[data-score-input]')!;
    const scoreDisp  = container.querySelector<HTMLElement>('[data-score-display]')!;
    const arc        = container.querySelector<SVGCircleElement>('[data-arc]')!;
    const errorEl    = container.querySelector<HTMLElement>('[data-error]')!;
    const receipt    = container.querySelector<HTMLElement>('[data-receipt]')!;
    const stamp      = container.querySelector<HTMLElement>('[data-notarize-stamp]')!;
    const cancelBtn  = container.querySelector<HTMLButtonElement>('[data-cancel-btn]')!;
    const slug       = container.dataset.slug!;

    let score    = 5;
    let holdTimer: ReturnType<typeof setTimeout> | null = null;

    // Boxed boolean — mutated by handleCeremonyAtmosphere across closures.
    const active = { v: false };

    const ceremony = createCeremony(slug, {
      onPhase: (phase) => {
        container.dataset.sealPhase = String(phase);
        container.style.setProperty('--seal-phase', String(phase));
        // --seal-weight: pre-computed float for weight meter (avoids calc on string 'notarize')
        const weight = phase === 'notarize' ? '0.875' : String((phase as number) / 4);
        container.style.setProperty('--seal-weight', weight);
        arc.classList.toggle('is-filling', phase === 2);
        handleCeremonyAtmosphere(phase, slug, active);
      },
      onNotarize: (data) => populateNotarize(stamp, data),
      onReceipt:  (data) => {
        populateReceipt(receipt, data, slug);
        populateShareCard(container, data);
        container.dispatchEvent(new CustomEvent('conviction:sealed', { bubbles: true, detail: { slug } }));
      },
      onError:    (msg)  => { errorEl.textContent = msg; errorEl.style.display = 'block'; },
      onAlreadySealed: () => showAlreadySealed(errorEl),
      onCancel:   () => { /* clean slate — atmosphere already restored by onPhase(0) */ },
    });

    cancelBtn.addEventListener('click', () => ceremony.cancel());

    // Escape key: abort only when not locked (phase < 3 = POST not yet in flight).
    const onEscape = (e: KeyboardEvent): void => {
      if (e.key === 'Escape' && ceremony.phase() < 3 && active.v) ceremonyAbort(slug);
    };
    // Navigation: unconditional cleanup — prevents gold atmosphere leaking across pages.
    const onNavigation = (): void => { if (active.v) { active.v = false; ceremonyAbort(slug); } };

    document.addEventListener('keydown', onEscape);
    document.addEventListener('astro:before-preparation', onNavigation);

    function setScore(n: number): void {
      score = n;
      scoreInput.value = String(n);
      scoreDisp.textContent = String(n);
      dotsEl.querySelectorAll<HTMLElement>('.seal-dot').forEach((dot, i) => {
        dot.classList.toggle('is-filled', i < n);
        dot.setAttribute('aria-pressed', String(i < n));
      });
    }

    function startHold(): void {
      ceremony.press();
      holdTimer = setTimeout(() => submitForm(), 600);
    }

    function cancelHold(): void {
      if (holdTimer) { clearTimeout(holdTimer); holdTimer = null; }
      ceremony.release();
    }

    async function submitForm(): Promise<void> {
      holdTimer = null;
      const note = (form.querySelector<HTMLTextAreaElement>('textarea'))!.value.trim();
      if (!note) { errorEl.textContent = 'Author note is required'; errorEl.style.display = 'block'; ceremony.release(); return; }
      errorEl.style.display = 'none';
      await ceremony.submit(score, note);
    }

    dotsEl.addEventListener('click', (e) => {
      const dot = (e.target as HTMLElement).closest<HTMLElement>('.seal-dot');
      if (dot?.dataset.value) setScore(Number(dot.dataset.value));
    });

    const btn = container.querySelector<HTMLButtonElement>('[data-seal-btn]')!;
    btn.addEventListener('mousedown',  startHold);
    btn.addEventListener('touchstart', startHold, { passive: true });
    btn.addEventListener('mouseup',    cancelHold);
    btn.addEventListener('mouseleave', cancelHold);
    btn.addEventListener('touchend',   cancelHold);

    form.addEventListener('submit', (e) => { e.preventDefault(); submitForm(); });

    container.querySelector<HTMLElement>('[data-seal-btn]')
      ?.addEventListener('mouseenter', () => ceremony.hover());
    container.querySelector<HTMLElement>('[data-seal-btn]')
      ?.addEventListener('mouseleave', () => ceremony.unhover());

    setScore(5);
  }

  /** Populates the phase 3.5 NotarizeStamp shell with live seal data. */
  function populateNotarize(el: HTMLElement, data: ReceiptData): void {
    const tsEl    = el.querySelector<HTMLElement>('[data-ns-ts]')!;
    const hashEl  = el.querySelector<HTMLElement>('[data-ns-hash]')!;
    const labelEl = el.querySelector<HTMLElement>('[data-ns-label]')!;
    const dt      = new Date(data.sealedAt);
    tsEl.textContent  = dt.toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'UTC' });
    tsEl.setAttribute('datetime', dt.toISOString());
    hashEl.textContent  = data.hash.slice(0, 32) + '…';
    // Null tst_token path: ceremony still plays, label explains state — no JS error.
    labelEl.textContent = data.tst_token ? 'NOTARIZED' : 'Anchoring locally…';
  }

  /** 409 response — sealed already is good news, not an error. Show gold informative text. */
  function showAlreadySealed(el: HTMLElement): void {
    el.textContent = '✓ Already sealed — conviction is locked.';
    el.style.cssText = 'display:block; color: var(--gold-dim, rgba(245,166,35,0.65));';
  }

  function populateReceipt(el: HTMLElement, data: ReceiptData, slug: string): void {
    const dateEl      = el.querySelector<HTMLElement>('[data-receipt-date]')!;
    const scoreEl     = el.querySelector<HTMLElement>('[data-receipt-score]')!;
    const hashEl      = el.querySelector<HTMLElement>('[data-receipt-hash]')!;
    const anchorRow   = el.querySelector<HTMLElement>('[data-receipt-anchor-row]')!;
    const anchorEl    = el.querySelector<HTMLAnchorElement>('[data-receipt-anchor]')!;
    const tstNoteEl   = el.querySelector<HTMLElement>('[data-receipt-tst-note]')!;
    const downloadBtn = el.querySelector<HTMLButtonElement>('[data-receipt-download]')!;
    const auditLink   = el.querySelector<HTMLAnchorElement>('[data-receipt-audit]')!;

    dateEl.textContent  = new Date(data.sealedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    (dateEl as HTMLTimeElement).dateTime = new Date(data.sealedAt).toISOString();
    scoreEl.textContent = String(data.score);
    hashEl.textContent  = data.hash;
    tstNoteEl.textContent = data.tst_token ? 'Notarized via RFC 3161' : 'Local anchor (TSA unavailable)';
    auditLink.href      = `/audit/${slug}`;

    if (data.anchorUrl) {
      anchorEl.href = data.anchorUrl;
      anchorRow.style.display = '';
    }

    wireDownload(downloadBtn, data);
  }

  /** Populates the Phase 5 share card score slot — title is SSR-baked. */
  function populateShareCard(container: HTMLElement, data: ReceiptData): void {
    const card    = container.querySelector<HTMLElement>('[data-share-card]');
    const scoreEl = card?.querySelector<HTMLElement>('[data-share-score]');
    if (scoreEl) scoreEl.textContent = String(data.score);
  }

  /** Create a Blob URL download from the full receipt payload. */
  function wireDownload(btn: HTMLButtonElement, data: ReceiptData): void {
    const json  = JSON.stringify(data, null, 2);
    const blob  = new Blob([json], { type: 'application/json' });
    const url   = URL.createObjectURL(blob);
    const fname = `conviction-receipt-${data.postSlug ?? 'seal'}.json`;

    btn.addEventListener('click', () => {
      const a = Object.assign(document.createElement('a'), { href: url, download: fname });
      a.click();
    }, { once: false });
  }

  function revealForAdmin(container: HTMLElement): void {
    const notice = container.querySelector<HTMLElement>('[data-unsealed-notice]');
    const form   = container.querySelector<HTMLElement>('[data-seal-form]');
    if (notice) notice.style.display = 'none';
    if (form)   form.style.display   = '';
  }

  function isAdminCookiePresent(): boolean {
    return document.cookie.includes('admin_token=');
  }

  document.querySelectorAll<HTMLElement>('[data-slug][data-seal-phase]').forEach(el => {
    // Reveal form for admins on post pages
    if (el.classList.contains('conviction-seal--ceremony') && !el.classList.contains('conviction-seal--admin')) {
      if (isAdminCookiePresent()) revealForAdmin(el);
    }
    initSealForm(el);
  });
</script>
