  .cs-unsealed-notice {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 0.85rem var(--space-5);
    border: 1px dashed var(--gold-border);
    border-radius: var(--radius-tombstone);
    background: var(--gold-bg);
  }

  .cs-unsealed-icon { font-size: var(--text-sm); color: var(--gold-dim); }

  .cs-unsealed-label {
