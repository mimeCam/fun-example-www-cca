  }

  .cs-form-body {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Score dots */
  .cs-dots-wrap {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .cs-dots {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .cs-score-readout {
