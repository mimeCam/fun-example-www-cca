---
// src/components/ErosionBar.astro
// Visual conviction life-drain bar for endangered post cards.
// One job: render a depleting gradient bar, warm amber → danger red.
//
// Initial pct and hue are server-rendered (no layout shift).
// Client JS recomputes --erosion-pct/--erosion-hue on each revival event.
//
// CSS-first: all animation and color live in endangered.css.
// No local script — the endangeredClientScript IIFE owns updates.
//
// Credits: Mike (napkin plan §3 — "one bar, one job, one truth"),
//          Tanya (UX spec §2 — conviction spectrum amber→red)

import { erosionBarPct, erosionHue } from '../lib/endangered';
import type { UrgencyLevel } from '../lib/endangered';

interface Props {
  decayFactor: number;
  urgency: UrgencyLevel;
}

const { decayFactor, urgency } = Astro.props;
const pct = erosionBarPct(decayFactor);
const hue = erosionHue(urgency);
---

<div
  class="erosion-bar"
  role="meter"
  aria-label="Post vitality"
  aria-valuenow={pct}
  aria-valuemin="0"
  aria-valuemax="100"
  style={`--erosion-pct:${pct}%;--erosion-hue:${hue}deg`}
>
  <div class="erosion-fill"></div>
</div>
