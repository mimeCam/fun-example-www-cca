---
// src/components/DisputeTally.astro
// Live dispute tally badge — SSE subscriber for real-time challenge count.
// Always visible when verdict is sealed — transparency by default.
// State badge: OPEN → CONTESTED → OVERTURNED / UPHELD.
// SSE source: /api/dispute-sse?slug=X (emits DisputeSummary every 3s).
// Credits: Mike (napkin plan §DisputeTally, design decision #6 — ratio is public),
//          Tanya (§badge-enter motion, §text-secondary alpha ramp)

import type { DisputeState } from '../lib/verdict-dispute';

interface Props {
  slug:         string;
  disputeState: DisputeState;
}

const { slug, disputeState } = Astro.props;

const visible =
  disputeState.status === 'clean' || disputeState.status === 'contested';

// Derive initial label + badge class from SSR snapshot
const initLabel = visible
  ? `${(disputeState as { disputes: number }).disputes}/${(disputeState as { total: number }).total} disputed`
  : '';

const initStatus = visible
  ? (disputeState.status === 'contested' ? 'contested' : 'open')
  : 'open';
---

{visible && (
  <span
    class="dispute-tally"
    id={`dispute-tally-${slug}`}
    data-slug={slug}
    data-status={initStatus}
    title="Reader dispute ratio for this verdict"
    aria-label={`${initLabel} — ${initStatus}`}
  >
    <!-- Dot -->
    <span class="dispute-tally__dot" aria-hidden="true"></span>

    <!-- Count -->
    <span class="dispute-tally__count" id={`dispute-tally-count-${slug}`}>{initLabel}</span>

    <!-- State badge -->
    <span
      class="dispute-state-badge"
      id={`dispute-tally-badge-${slug}`}
      data-status={initStatus}
    >
      {initStatus === 'contested' ? 'CONTESTED' : 'OPEN'}
    </span>
  </span>
)}

<script>
(function mountDisputeTallySSE() {
  // Find all tally spans on this page (there should be one per verdict)
  const tallies = document.querySelectorAll<HTMLElement>('.dispute-tally[data-slug]');
  if (!tallies.length) return;

  tallies.forEach(tally => {
    const slug = tally.dataset.slug;
    if (!slug) return;

    const countEl = document.getElementById(`dispute-tally-count-${slug}`);
    const badgeEl = document.getElementById(`dispute-tally-badge-${slug}`);
    if (!countEl || !badgeEl) return;

    let es: EventSource | null = null;
    let retryDelay = 3000;

    function connect(): void {
      es = new EventSource(`/api/dispute-sse?slug=${encodeURIComponent(slug!)}`);
      es.onmessage = (evt) => {
        retryDelay = 3000;
        try { applyUpdate(JSON.parse(evt.data)); } catch { /* malformed — skip */ }
      };
      es.onerror = () => {
        es?.close();
        setTimeout(connect, retryDelay);
        retryDelay = Math.min(retryDelay * 2, 30_000);
      };
    }

    function applyUpdate(summary: { status: string; challenges: number; threshold: number }): void {
      const { status, challenges, threshold } = summary;
      const label = `${challenges}/${threshold} disputed`;

      countEl!.textContent = label;
      tally.setAttribute('data-status', status);
      tally.setAttribute('aria-label', `${label} — ${status}`);
      badgeEl!.setAttribute('data-status', status);
      badgeEl!.textContent = status.toUpperCase();

      // Flash contested badge on first contest
      if (status === 'contested' && !tally.dataset.wasContested) {
        tally.dataset.wasContested = '1';
        tally.style.animation = 'none';
        requestAnimationFrame(() => {
          tally.style.animation = 'contested-flash 600ms ease both';
        });
      }

      // Sync quorum bar if present on same page
      syncQuorumBar(summary as Parameters<typeof syncQuorumBar>[0]);
    }

    connect();
  });

  function syncQuorumBar(summary: {
    status: string; challenges: number; threshold: number; ratio: number
  }): void {
    const bar = document.getElementById('quorum-bar');
    if (!bar) return;
    bar.setAttribute('data-status', summary.status);
    const countEl = document.getElementById('quorum-count');
    if (countEl) countEl.textContent = String(summary.challenges);
  }

  // Also listen for manual dispute:recorded events from DisputeChallenge
  document.addEventListener('dispute:recorded', ((e: CustomEvent) => {
    const { state } = e.detail ?? {};
    if (state) syncQuorumBar(state as Parameters<typeof syncQuorumBar>[0]);
  }) as EventListener);
})();
</script>

<style>
  /* ── Tally badge ── */
  .dispute-tally {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
    letter-spacing: var(--tracking-normal);
    padding: 0.2rem 0.6rem 0.2rem 0.45rem;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    transition:
      color         var(--motion-flow-duration) var(--motion-flow-easing),
      border-color  var(--motion-flow-duration) var(--motion-flow-easing),
      background    var(--motion-flow-duration) var(--motion-flow-easing);
  }

  .dispute-tally[data-status="open"] {
    color: var(--text-tertiary);
    border-color: var(--border-subtle);
  }

  .dispute-tally[data-status="contested"] {
    color: var(--color-dispute-contested);
    border-color: var(--color-dispute-contested-border);
    background: var(--color-dispute-contested-bg);
  }

  .dispute-tally[data-status="overturned"] {
    color: var(--color-dispute-overturned);
    border-color: var(--color-dispute-overturned-border);
    background: var(--color-dispute-overturned-bg);
  }

  .dispute-tally[data-status="upheld"] {
    color: var(--color-dispute-upheld);
    border-color: var(--color-dispute-upheld-border);
    background: var(--color-dispute-upheld-bg);
  }

  /* ── Presence dot ── */
  .dispute-tally__dot {
    width: 5px;
    height: 5px;
    border-radius: var(--radius-full);
    background: currentColor;
    opacity: 0.6;
    flex-shrink: 0;
  }

  .dispute-tally[data-status="contested"] .dispute-tally__dot {
    animation: nav-breathe calc(var(--motion-ambient) * 5) ease-in-out infinite;
    opacity: 1;
  }

  /* ── Count text ── */
  .dispute-tally__count {
    color: inherit;
    font-size: var(--text-xs);
    transition: color var(--motion-flow-duration) var(--motion-flow-easing);
  }

  /* v152 motion-sanctuary (Mike §C): infinite loop — must gate explicitly so
     vestibular-sensitive readers never meet the pulsing dot.               */
  @media (prefers-reduced-motion: reduce) {
    .dispute-tally[data-status="contested"] .dispute-tally__dot { animation: none; }
  }
</style>
