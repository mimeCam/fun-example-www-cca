---
// src/components/StanceDrawer.astro
// Non-blocking stance capture drawer — slides up from the bottom 800ms after revival.
// Triggered by the 'stance:prompt' CustomEvent (dispatched by revival-counter.ts).
// Auto-dismisses after 30s via a CSS animation progress bar — zero JS timers.
// Full accessibility: aria-modal, focus trap, aria-live region, reduced-motion support.
//
// Flow: stance:prompt → open drawer → user picks stance → POST /api/stance → close.
// Dismissing without a pick is penalty-free. Skip is always available.
//
// Credits: Mike (arch spec), Tanya (UX §5.2 — post-action stance, zero friction gate)

interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<!-- Atmospheric overlay — focus-pull behind the drawer, pointer-events: none -->
<div class="stance-overlay" data-stance-overlay aria-hidden="true"></div>

<div
  class="stance-drawer"
  data-stance-drawer
  data-slug={slug}
  role="dialog"
  aria-modal="true"
  aria-label="Your verdict on this belief"
  aria-hidden="true"
  tabindex="-1"
>
  <!-- Accessibility: live region announces submission result to screen readers -->
  <div class="stance-sr-live" aria-live="polite" aria-atomic="true"></div>

  <div class="stance-inner" role="document">

    <!-- Drag handle: swipe-to-dismiss affordance — pill signals "pullable" (Mike P0-B, Tanya §5.2) -->
    <div class="stance-handle" aria-hidden="true"></div>

    <!-- Progress bar: CSS-only 30s auto-dismiss timer -->
    <div class="stance-progress" aria-hidden="true">
      <div class="stance-progress-bar"></div>
    </div>

    <header class="stance-header">
      <span class="stance-question">Your verdict on this belief</span>
      <button class="stance-close" data-stance-close type="button" aria-label="Dismiss">✕</button>
    </header>

    <!-- Three stance buttons — fixed, no polymorphism (Mike's spec) -->
    <div class="stance-choices" role="group" aria-label="Choose your stance">
      <button class="stance-btn" data-stance="agree"    type="button" aria-pressed="false">
        <span class="stance-btn-glyph" aria-hidden="true">◉</span>
        <span>Agree</span>
      </button>
      <button class="stance-btn" data-stance="torn"     type="button" aria-pressed="false">
        <span class="stance-btn-glyph" aria-hidden="true">◈</span>
        <span>Torn</span>
      </button>
      <button class="stance-btn" data-stance="disagree" type="button" aria-pressed="false">
        <span class="stance-btn-glyph" aria-hidden="true">◇</span>
        <span>Disagree</span>
      </button>
    </div>

    <!-- Conviction slider — appears after stance is selected -->
    <div class="stance-slider-row" data-slider-row aria-hidden="true">
      <label class="stance-slider-label" for="stance-score">How sure are you?</label>
      <div class="stance-slider-track">
        <span class="stance-slider-cap" aria-hidden="true">mild</span>
        <input
          id="stance-score"
          class="stance-slider"
          type="range"
          min="1"
          max="5"
          value="3"
          step="1"
          data-stance-score
          aria-label="Conviction strength 1 (mild) to 5 (certain)"
        />
        <span class="stance-slider-cap" aria-hidden="true">certain</span>
      </div>
    </div>

    <div class="stance-actions">
      <button class="stance-submit" data-stance-submit type="button" disabled aria-disabled="true">
        Submit verdict
      </button>
      <button class="stance-skip" data-stance-skip type="button">skip</button>
    </div>

  </div>
</div>

<style>
  /* ── Atmospheric overlay — focus-pull, purely visual ─────── */
  .stance-overlay {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: var(--overlay-scrim);
    backdrop-filter: blur(1px);
    -webkit-backdrop-filter: blur(1px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 200ms ease;
  }

  .stance-overlay[data-open] { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .stance-overlay { transition: none; }
  }

  /* ── Drawer shell — fixed bottom, full-width on mobile ─────── */
  .stance-drawer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: none;
    transform: translateY(100%);
    transition: transform 320ms cubic-bezier(0.34, 1.56, 0.64, 1);
    /* Body scroll lock applied via JS on open */
  }

  .stance-drawer[data-open] {
    display: block;
    transform: translateY(0);
  }

  /* Entrance from below */
  @starting-style {
    .stance-drawer[data-open] { transform: translateY(100%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .stance-drawer, .stance-drawer[data-open] { transition: none; transform: none; }
  }

  /* ── Inner card — glass-morphism ───────────────────────────── */
  .stance-inner {
    max-width: 480px;
    margin: 0 auto;
    padding: 0 0 env(safe-area-inset-bottom, 0);
    background: var(--surface-modal);
    border: 1px solid var(--border-light);
    border-bottom: none;
    border-radius: 12px 12px 0 0;
    box-shadow: var(--shadow-drawer);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    overflow: hidden;
  }

  /* ── Progress bar — CSS @keyframes 30s auto-dismiss ────────── */
  .stance-progress {
    height: 2px;
    background: var(--border-subtle);
    width: 100%;
  }

  .stance-progress-bar {
    height: 100%;
    /* teal — the timer is the reader's patience, not the author's claim (Tanya §3) */
    background: oklch(62% 0.14 185 / 0.4);
    width: 100%;
    transform-origin: left center;
    animation: progressShrink 30s linear forwards;
    animation-play-state: running;
  }

  /* Pause timer on hover — polite UX */
  .stance-inner:hover .stance-progress-bar {
    animation-play-state: paused;
  }

  @keyframes progressShrink {
    from { width: 100%; }
    to   { width: 0%;   }
  }

  @media (prefers-reduced-motion: reduce) {
    .stance-progress-bar { animation: none; width: 100%; }
  }

  /* ── Drag handle pill (Mike P0-B, Tanya §5.2) ──────────────── */
  /* Full roundness = "handle" vocabulary in design system (Tanya §7 radius law) */
  /* 8px top margin respects 4pt grid; no JS required */
  .stance-handle {
    width: 40px;
    height: 4px;
    margin: 8px auto 0;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.18);
    transition: background var(--motion-duration-fast) ease;
  }

  .stance-handle:hover {
    background: rgba(255, 255, 255, 0.28);
  }

  /* ── Header ─────────────────────────────────────────────────── */
  .stance-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1rem 0.5rem;
  }

  .stance-question {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .stance-close {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    color: var(--text-dim);
    background: transparent;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition: color 150ms ease, background 150ms ease;
    padding: 0;
    font-family: inherit;
  }

  .stance-close:hover {
    color: var(--text-primary);
    background: var(--surface-hover);
  }

  /* ── Stance choice buttons ──────────────────────────────────── */
  .stance-choices {
    display: flex;
    gap: 0.5rem;
    padding: 0.4rem 1rem 0.75rem;
  }

  .stance-btn {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.6rem 0.5rem;
    font-size: 0.72rem;
    font-family: inherit;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text-secondary);
    background: var(--surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    cursor: pointer;
    transition: background 150ms ease, border-color 150ms ease, color 150ms ease, transform 120ms ease;
  }

  .stance-btn:hover {
    background: var(--surface-hover);
    border-color: var(--border-interactive-hover);
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  .stance-btn[aria-pressed="true"] {
    background: var(--gold-bg-strong);
    border-color: var(--gold-border-strong);
    color: var(--stance-torn);
  }

  .stance-btn[data-stance="agree"][aria-pressed="true"] {
    background: oklch(25% 0.08 185 / 0.15);
    border-color: oklch(68% 0.14 185 / 0.45);
    color: oklch(68% 0.14 185);
  }

  .stance-btn[data-stance="disagree"][aria-pressed="true"] {
    background: var(--stance-disagree-bg);
    border-color: var(--stance-disagree-border);
    color: var(--stance-disagree-color);
  }

  .stance-btn-glyph { font-size: 1.1rem; }

  /* ── Conviction slider — hidden until stance selected ───────── */
  .stance-slider-row {
    padding: 0 1rem 0.6rem;
    display: none;
  }

  .stance-slider-row[data-visible] { display: block; }

  .stance-slider-label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.4rem;
  }

  .stance-slider-track {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .stance-slider-cap {
    font-size: 0.62rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .stance-slider {
    flex: 1;
    height: 3px;
    appearance: none;
    background: var(--border-medium);
    border-radius: 9999px;
    outline: none;
    cursor: pointer;
  }

  .stance-slider::-webkit-slider-thumb {
    appearance: none;
    width: 14px;
    height: 14px;
    background: var(--gold);
    border-radius: 50%;
    cursor: pointer;
    transition: transform 120ms ease;
  }

  .stance-slider::-webkit-slider-thumb:hover { transform: scale(1.2); }

  /* ── Actions row ─────────────────────────────────────────────── */
  .stance-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.25rem 1rem 1rem;
  }

  .stance-submit {
    padding: 0.45rem 1.1rem;
    font-size: 0.76rem;
    font-family: inherit;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--surface-base);
    background: var(--gold);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 180ms ease, transform 120ms ease;
  }

  .stance-submit:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    transform: none;
  }

  .stance-submit:not(:disabled):hover { opacity: 0.85; }
  .stance-submit:not(:disabled):active { transform: scale(0.97); }

  .stance-skip {
    font-size: 0.68rem;
    font-family: inherit;
    color: var(--text-ghost);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: color 150ms ease;
    padding: 0;
  }

  .stance-skip:hover { color: var(--text-secondary); }

  /* ── SR-only live region ─────────────────────────────────────── */
  .stance-sr-live {
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
  }
</style>

<script>
  // StanceDrawer — client orchestration.
  // Listens for 'stance:prompt' (dispatched by revival-counter.ts +800ms after revival).
  // Posts to /api/stance on submit; closes on skip/dismiss/auto-timeout.
  // Exactly one open drawer at a time — re-open guard via data-open attribute.

  (function initStanceDrawer() {
    const drawer = document.querySelector<HTMLElement>('[data-stance-drawer]');
    if (!drawer) return;

    const slug = drawer.dataset.slug ?? '';

    // ── Focus trap elements ──────────────────────────────────────
    function getFocusables(): HTMLElement[] {
      return Array.from(
        drawer.querySelectorAll<HTMLElement>('button:not(:disabled), input, [tabindex="0"]')
      );
    }

    // ── Auto-dismiss wiring ──────────────────────────────────────
    let autoTimer: ReturnType<typeof setTimeout> | null = null;

    function scheduleAutoDismiss(): void {
      autoTimer = setTimeout(() => closeDrawer(false), 30_000);
    }

    function cancelAutoDismiss(): void {
      if (autoTimer) { clearTimeout(autoTimer); autoTimer = null; }
    }

    const overlay = document.querySelector<HTMLElement>('[data-stance-overlay]');

    // ── Open / Close ─────────────────────────────────────────────
    function openDrawer(): void {
      if (drawer.hasAttribute('data-open')) return;
      drawer.setAttribute('data-open', '');
      drawer.setAttribute('aria-hidden', 'false');
      overlay?.setAttribute('data-open', '');
      document.body.style.overflow = 'hidden';
      scheduleAutoDismiss();
      attachDismissListeners();
      const first = getFocusables()[0];
      setTimeout(() => first?.focus(), 340); // after slide-in
    }

    function closeDrawer(submitted: boolean): void {
      if (!drawer.hasAttribute('data-open')) return;
      cancelAutoDismiss();
      drawer.removeAttribute('data-open');
      drawer.setAttribute('aria-hidden', 'true');
      overlay?.removeAttribute('data-open');
      document.body.style.overflow = '';
      detachDismissListeners();
      if (!submitted) resetForm();
    }

    // ── Reset form state ─────────────────────────────────────────
    function resetForm(): void {
      drawer.querySelectorAll<HTMLButtonElement>('[data-stance]')
        .forEach(b => b.setAttribute('aria-pressed', 'false'));
      const slider = drawer.querySelector<HTMLInputElement>('[data-stance-score]');
      if (slider) slider.value = '3';
      const sliderRow = drawer.querySelector<HTMLElement>('[data-slider-row]');
      if (sliderRow) delete sliderRow.dataset.visible;
      setSubmitEnabled(false);
    }

    // ── Stance selection ─────────────────────────────────────────
    function getSelectedStance(): string | null {
      const active = drawer.querySelector<HTMLButtonElement>('[data-stance][aria-pressed="true"]');
      return active?.dataset.stance ?? null;
    }

    function setSubmitEnabled(on: boolean): void {
      const btn = drawer.querySelector<HTMLButtonElement>('[data-stance-submit]');
      if (!btn) return;
      btn.disabled = !on;
      btn.setAttribute('aria-disabled', String(!on));
    }

    function handleStanceClick(btn: HTMLButtonElement): void {
      drawer.querySelectorAll<HTMLButtonElement>('[data-stance]')
        .forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      const sliderRow = drawer.querySelector<HTMLElement>('[data-slider-row]');
      if (sliderRow) sliderRow.dataset.visible = '';
      sliderRow?.setAttribute('aria-hidden', 'false');
      setSubmitEnabled(true);
    }

    // ── Submit ───────────────────────────────────────────────────
    async function submitStance(): Promise<void> {
      const stance = getSelectedStance();
      if (!stance) return;
      const score = parseInt(
        (drawer.querySelector<HTMLInputElement>('[data-stance-score]')?.value ?? '3'),
        10,
      );
      const sessionId = getSessionId();

      setSubmitEnabled(false);
      announce('Recording your verdict…');

      try {
        const headers: Record<string, string> = { 'Content-Type': 'application/json' };
        if (sessionId) headers['x-session-id'] = sessionId;
        await fetch('/api/stance', {
          method: 'POST', keepalive: true, headers,
          body: JSON.stringify({ slug, stance, score }),
        });
        flashConfirmation();
        announce('Verdict recorded.');
      } catch {
        announce('Could not record verdict — dismissed.');
        closeDrawer(true);
      }
    }

    /** Briefly show "Verdict recorded ✓" on the submit button before closing. */
    function flashConfirmation(): void {
      const btn = drawer.querySelector<HTMLButtonElement>('[data-stance-submit]');
      if (!btn) { closeDrawer(true); return; }
      btn.textContent = 'Verdict recorded ✓';
      btn.style.color = 'var(--stance-agree)';
      setTimeout(() => closeDrawer(true), 400);
    }

    // ── Dismiss listeners ────────────────────────────────────────
    let _keyHandler: ((e: KeyboardEvent) => void) | null = null;
    let _touchStartY = 0;

    function attachDismissListeners(): void {
      _keyHandler = (e: KeyboardEvent) => {
        if (e.key === 'Escape') { e.preventDefault(); closeDrawer(false); }
        if (e.key === 'Tab') trapFocus(e);
      };
      document.addEventListener('keydown', _keyHandler);
      drawer.addEventListener('touchstart', handleTouchStart, { passive: true });
      drawer.addEventListener('touchend', handleTouchEnd, { passive: true });
    }

    function detachDismissListeners(): void {
      if (_keyHandler) document.removeEventListener('keydown', _keyHandler);
      drawer.removeEventListener('touchstart', handleTouchStart);
      drawer.removeEventListener('touchend', handleTouchEnd);
    }

    function handleTouchStart(e: TouchEvent): void {
      _touchStartY = e.touches[0]?.clientY ?? 0;
    }

    function handleTouchEnd(e: TouchEvent): void {
      const dy = (e.changedTouches[0]?.clientY ?? 0) - _touchStartY;
      if (dy > 60) closeDrawer(false); // swipe-down-to-dismiss
    }

    function trapFocus(e: KeyboardEvent): void {
      const focusable = getFocusables();
      if (!focusable.length) return;
      const first = focusable[0];
      const last  = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault(); last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault(); first.focus();
      }
    }

    // ── SR live region ───────────────────────────────────────────
    function announce(msg: string): void {
      const live = drawer.querySelector('.stance-sr-live');
      if (live) live.textContent = msg;
    }

    // ── Helpers ──────────────────────────────────────────────────
    function getSessionId(): string | null {
      try { return sessionStorage.getItem('session-token'); } catch { return null; }
    }

    // ── Wire static buttons ──────────────────────────────────────
    drawer.querySelectorAll<HTMLButtonElement>('[data-stance]')
      .forEach(btn => btn.addEventListener('click', () => handleStanceClick(btn)));

    drawer.querySelector('[data-stance-close]')
      ?.addEventListener('click', () => closeDrawer(false));

    drawer.querySelector('[data-stance-skip]')
      ?.addEventListener('click', () => closeDrawer(false));

    drawer.querySelector('[data-stance-submit]')
      ?.addEventListener('click', () => submitStance());

    // ── Listen for stance:prompt (from revival-counter.ts) ───────
    document.addEventListener('stance:prompt', (e: Event) => {
      const detail = (e as CustomEvent<{ slug: string }>).detail;
      if (detail?.slug !== slug) return;
      // Don't prompt if session has already recorded a stance for this post
      if (hasRecordedStance(slug)) return;
      openDrawer();
    });

    function hasRecordedStance(s: string): boolean {
      try { return sessionStorage.getItem(`stance:${s}`) === '1'; } catch { return false; }
    }
  })();
</script>
