---
// src/components/DeathClock.astro
// Visual post countdown ring. Rendered SSR. No hydration island.
// CSS custom properties set server-side; ring animates purely in CSS.
// Use compact={true} inside card footers (smaller ring).
//
// Credits: Mike (architecture spec), Tanya (UX §6 — cold-start fix)

import type { ClockUrgency } from '../lib/death-clock';
import {
  deathClockDayDisplay,
  deathClockUnitDisplay,
  deathClockA11yLabel,
  clockStyleString,
} from '../lib/death-clock';
import type { ConvictionVerdict } from '../lib/decay-engine';

interface Props {
  daysRemaining: number;
  urgency: ClockUrgency;
  compact?: boolean;
  conviction?: ConvictionVerdict | null;
}

const { daysRemaining, urgency, compact = false, conviction = null } = Astro.props;

const dayDisplay  = deathClockDayDisplay(daysRemaining, urgency);
const unitDisplay = deathClockUnitDisplay(daysRemaining);
const a11yLabel   = deathClockA11yLabel(daysRemaining);
const inlineStyle = clockStyleString(urgency, daysRemaining, conviction);
---

<div
  class:list={['death-clock', compact && 'death-clock--compact']}
  data-urgency={urgency}
  data-days-remaining={daysRemaining}
  data-conviction={conviction ?? undefined}
  style={inlineStyle}
  aria-label={a11yLabel}
  title={a11yLabel}
  role="img"
>
  <svg
    class="death-clock__ring-wrap"
    viewBox="0 0 64 64"
    aria-hidden="true"
    focusable="false"
  >
    <!-- Track ring (background) -->
    <circle
      class="death-clock__track"
      cx="32" cy="32" r="28"
    />
    <!-- Progress ring (countdown arc) -->
    <circle
      class="death-clock__ring"
      cx="32" cy="32" r="28"
    />
  </svg>

  <div class="death-clock__label" aria-hidden="true">
    <span class="death-clock__days">{dayDisplay}</span>
    <span class="death-clock__unit">{unitDisplay}</span>
  </div>
</div>

<style>
  .death-clock {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 3.75rem;
    height: 3.75rem;
    flex-shrink: 0;
  }

  .death-clock--compact {
    width: 2.75rem;
    height: 2.75rem;
  }

  .death-clock__ring-wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .death-clock__track {
    fill: none;
    stroke: rgba(255, 255, 255, 0.07);
    stroke-width: 3;
  }

  .death-clock__ring {
    fill: none;
    stroke: hsl(var(--clock-urgency-hue, 220) 65% 60%);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 176;
    stroke-dashoffset: var(--clock-dashoffset, 0);
    transform-origin: 32px 32px;
    transform: rotate(-90deg);
    transition: stroke-dashoffset 600ms ease, stroke 300ms ease, filter 300ms ease;
    /* Conviction tint: subtle outer glow reflecting author belief state.
       transparent = no glow (unaudited / no convictions). */
    filter: drop-shadow(0 0 4px var(--clock-conviction-tint, transparent));
  }

  .death-clock__label {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.05rem;
    line-height: 1;
    pointer-events: none;
  }

  .death-clock__days {
    font-size: 0.9rem;
    font-weight: 700;
    color: hsl(var(--clock-urgency-hue, 220) 65% 72%);
    line-height: 1;
  }

  .death-clock__unit {
    font-size: 0.44rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.55;
    color: hsl(var(--clock-urgency-hue, 220) 40% 65%);
  }

  .death-clock--compact .death-clock__days {
    font-size: 0.7rem;
  }

  .death-clock--compact .death-clock__unit {
    font-size: 0.38rem;
  }
</style>
