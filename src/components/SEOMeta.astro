---
// src/components/SEOMeta.astro
// Renders OG + Twitter Card meta tags and JSON-LD scripts in <head>.
// Every page passes props; defaults come from seo.config.ts.
//
// Usage: <SEOMeta title="My Post" description="..." url="/blog/my-post" type="article" />
//
// JSON-LD: pass pre-serialized strings via `jsonLd`. Each string becomes its own
// <script type="application/ld+json"> — separate tags are easier to validate in
// Google's Rich Results Test tool (Mike §POI 4).

import { resolveMeta, canonicalUrl, ogImageUrl } from '../config/seo.config';
import type { PageMeta } from '../config/seo.config';

interface Props extends PageMeta {
  /** When set, uses dynamic decay-encoded OG image at /api/og/{slug}.png */
  ogSlug?: string;
  /** Pre-serialized JSON-LD schema strings — one <script> tag per entry. */
  jsonLd?: string | string[];
}

const { ogSlug, jsonLd, ...pageMeta } = Astro.props;
const resolved = resolveMeta(pageMeta);
if (ogSlug) resolved.image = ogImageUrl(ogSlug);

const schemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!-- Primary Meta -->
<title>{resolved.title}</title>
<meta name="description" content={resolved.description} />
<link rel="canonical" href={resolved.url} />

<!-- Open Graph -->
<meta property="og:type" content={resolved.type} />
<meta property="og:title" content={resolved.title} />
<meta property="og:description" content={resolved.description} />
<meta property="og:image" content={resolved.image} />
<meta property="og:url" content={resolved.url} />
<meta property="og:site_name" content={resolved.siteName} />
<meta property="og:locale" content={resolved.locale} />
{resolved.publishedAt && (
  <meta property="article:published_time" content={resolved.publishedAt} />
)}

<!-- Article-specific Open Graph (blog posts only) -->
{resolved.type === 'article' && (
  <>
    <meta property="article:author" content={resolved.siteName} />
    <meta property="article:section" content="Blog" />
  </>
)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={resolved.title} />
<meta name="twitter:description" content={resolved.description} />
<meta name="twitter:image" content={resolved.image} />
{resolved.twitterHandle && (
  <meta name="twitter:site" content={resolved.twitterHandle} />
)}

<!-- JSON-LD Structured Data — one script per schema (easier to validate) -->
{schemas.map(schema => (
  <script type="application/ld+json" set:html={schema} />
))}
