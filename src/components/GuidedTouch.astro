---
// src/components/GuidedTouch.astro
// Interactive first-visit demo — replaces FirstVisitWhisper.
// Walks the visitor through one decay→revival cycle on a real card.
//
// Show, don't tell. Spotlight pulses on most-decayed card,
// ghost cursor drifts toward it, visitor hovers → card revives.
// Short-circuits if visitor hovers ANY card first.
//
// A11y: role="status", aria-live="polite", prefers-reduced-motion.
// Gate: localStorage 'guided_touch_seen' — plays once per device.
//
// Design: Mike Koch (architect), Elon (first-principles),
//         Paul Kim (business analysis).

import { guidedTouchScript } from '../lib/guidedTouch';
const demoScript = guidedTouchScript();
---

<!-- Spotlight overlay — dark + radial cutout on target card -->
<div
  id="gt-spotlight"
  class="gt-spotlight"
  aria-hidden="true"
></div>

<!-- Ghost cursor — drifts toward target card -->
<div
  id="gt-cursor"
  class="gt-cursor"
  aria-hidden="true"
>
  <span id="gt-tooltip" class="gt-tooltip">hover to revive</span>
</div>

<!-- Whisper message — revealed after revival -->
<div
  id="gt-whisper"
  class="gt-whisper"
  role="status"
  aria-live="polite"
></div>

<!-- A11y: screen reader announcements -->
<div
  id="gt-sr"
  class="gt-sr-only"
  aria-live="polite"
  role="status"
></div>

<!-- Orchestrator script -->
<script set:html={demoScript} />

<style>
  /* ── SR-only region ──────────────────────────────── */

  .gt-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Reduced-motion: instant static fallback ─────── */

  @media (prefers-reduced-motion: reduce) {
    .gt-spotlight,
    .gt-cursor {
      display: none !important;
    }
  }
</style>
