---
// src/components/TombstoneCard.astro
// Ghost card for the /graveyard page. Monochrome, low-opacity, faint border.
// No hover-revival — resurrection requires a deliberate click.
// Shows epitaph: title, publication date, entombment age ("days forgotten").

import { entombmentAge } from '../lib/entomb';
import { formatPubDate } from '../lib/dates';
import type { PostDisplayData } from '../lib/postMeta';

interface Props { post: PostDisplayData; }

const { post } = Astro.props;
const formattedDate = formatPubDate(post.pubDate);
const forgotten = entombmentAge(post.pubDateISO, 365);
const daysLabel = forgotten === 1 ? 'day' : 'days';
---

<article
  class="tombstone"
  data-slug={post.slug}
  aria-label={`${post.title} — forgotten ${forgotten} ${daysLabel}`}
>
  <time datetime={post.pubDateISO} class="tomb-date">
    {formattedDate}
  </time>
  <h2 class="tomb-title">{post.title}</h2>
  {post.description && (
    <p class="tomb-epitaph">{post.description}</p>
  )}
  <div class="tomb-footer">
    <span class="tomb-forgotten">
      {forgotten} {daysLabel} forgotten
    </span>
    <button
      class="resurrect-btn"
      data-resurrect-slug={post.slug}
      aria-label={`Resurrect "${post.title}"`}
    >
      &#x2191; resurrect
    </button>
  </div>
</article>

<style>
  .tombstone {
    position: relative;
    padding: 1.5rem 1.75rem;
    border-radius: var(--radius, 12px);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(150, 150, 150, 0.08);
    max-width: 40rem;
    margin: 0 auto 1.25rem;
    opacity: 0.45;
    filter: saturate(0);
    transition: opacity 0.4s ease, filter 0.4s ease;
  }

  .tombstone:hover {
    opacity: 0.6;
    filter: saturate(0.2);
  }

  .tomb-date {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 0.25rem;
  }

  .tomb-title {
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.3;
    color: rgba(180, 180, 180, 0.7);
  }

  .tomb-epitaph {
    margin: 0.4rem 0 0;
    font-size: 0.82rem;
    line-height: 1.5;
    opacity: 0.4;
    font-style: italic;
  }

  .tomb-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
    gap: 1rem;
  }

  .tomb-forgotten {
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.4;
  }

  .resurrect-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.3rem 0.75rem;
    font-size: 0.65rem;
    font-family: inherit;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(200, 200, 200, 0.7);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(200, 200, 200, 0.15);
    border-radius: 999px;
    cursor: pointer;
    transition:
      border-color 200ms ease,
      background 300ms ease,
      opacity 400ms ease,
      transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .resurrect-btn:hover {
    border-color: rgba(200, 200, 200, 0.35);
    background: rgba(255, 255, 255, 0.08);
  }

  .resurrect-btn:active {
    transform: scale(0.96);
  }

  .resurrect-btn.risen {
    opacity: 0.4;
    cursor: default;
    pointer-events: none;
  }
</style>
