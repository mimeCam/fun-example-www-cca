---
// src/components/TombstoneCard.astro
// Epitaph card for the /graveyard page.
// Layout: "HERE LIES · cover ghost · title · description · Born/Faded · stats · resurrect"
// Cover image renders near-monochrome — a ghost of the post's living self.
// Monochrome locked via --color-grave-* tokens, not CSS opacity on the element.
// Resurrection requires a deliberate click — no hover-revival (Mike, Tanya §3.3).
//
// WARNING: Do NOT merge with DecayCard. Different visual contracts. — Mike
// Credits: Mike (epitaph layout spec), Tanya (UX spec §3.3, §3.5, §6.2)

import { formatPubDate } from '../lib/dates';
import { daysSince } from '../lib/temporal';
import type { PostDisplayData } from '../lib/postMeta';
import { survivalTier, generateEpitaph, tierCSSClass, tierLabel } from '../lib/epitaph-engine';
import { CLOCK_MAX_DAYS } from '../lib/death-clock';
import { causeLabel, causeDescription, causeCSSClass } from '../lib/cause-of-death';

interface Props { post: PostDisplayData; }

const { post } = Astro.props;

const formattedPubDate  = formatPubDate(post.pubDate);
const entombDate        = post.entombedAt ? formatPubDate(post.entombedAt) : null;
const forgotten         = forgottenDays(post);
const daysLabel         = forgotten === 1 ? 'day' : 'days';
const readingMins       = Math.round(post.readingSeconds / 60);
const statsProse        = buildStatsProse(post.revivalCount, readingMins);

// Epitaph engine — deterministic narrative + tier badge
const survDays  = calcSurvivalDays(post);
const tier      = survivalTier(survDays, post.revivalCount);
const epitaph   = generateEpitaph(post.slug, survDays, post.revivalCount, readingMins);
const tierCss   = tierCSSClass(tier);
const tombAge   = (Math.min(survDays / CLOCK_MAX_DAYS, 1)).toFixed(3);

/** Days since entombment, falling back to days since publish. */
function forgottenDays(p: PostDisplayData): number {
  return p.entombedAt
    ? daysSince(p.entombedAt.toISOString())
    : daysSince(p.pubDateISO);
}

/** Prose-style stat line: "remembered by 3 readers · 4 min held alive" */
function buildStatsProse(revivals: number, mins: number): string {
  const parts: string[] = [];
  if (revivals > 0) parts.push(`remembered by ${revivals} ${revivals === 1 ? 'reader' : 'readers'}`);
  if (mins > 0)     parts.push(`${mins} min held alive`);
  return parts.join(' · ');
}

/** UTC-safe survival days from pub → entombment (or now). */
function calcSurvivalDays(p: PostDisplayData): number {
  const end = p.entombedAt ?? new Date();
  return Math.max(0, Math.round((end.getTime() - p.pubDate.getTime()) / 86_400_000));
}
---

<article
  class="tombstone tombstone-card"
  data-slug={post.slug}
  data-survival-days={survDays}
  style={`--tomb-age:${tombAge}`}
  aria-label={`${post.title} — forgotten ${forgotten} ${daysLabel}`}
>
  {post.coverImage && (
    <div class="tomb-cover-wrap" aria-hidden="true">
      <img src={post.coverImage} alt="" class="tomb-cover-img" loading="lazy" decoding="async" />
    </div>
  )}
  <div class="tombstone-inner">

    <div class="tomb-header-row">
      <span class="tomb-here-lies">here lies</span>
      <div class="tomb-badges">
        {post.causeOfDeath && (
          <span
            class={`tomb-cause ${causeCSSClass(post.causeOfDeath)}`}
            title={causeDescription(post.causeOfDeath)}
          >
            {causeLabel(post.causeOfDeath)}
          </span>
        )}
        <span class={`tomb-tier ${tierCss}`}>{tierLabel(tier)}</span>
      </div>
    </div>

    <h2 class="tomb-title">{post.title}</h2>

    <p class="tomb-epitaph">{epitaph}</p>

    {/* post.description preserved for accessibility */}
    {post.description && <meta itemprop="description" content={post.description} />}

    <dl class="tomb-dates">
      <div class="tomb-date-row">
        <dt>born</dt>
        <dd><time datetime={post.pubDateISO}>{formattedPubDate}</time></dd>
      </div>
      {entombDate && (
        <div class="tomb-date-row">
          <dt>faded</dt>
          <dd>{entombDate} · forgotten {forgotten} {daysLabel}</dd>
        </div>
      )}
      {!entombDate && (
        <div class="tomb-date-row">
          <dt>lost</dt>
          <dd>forgotten {forgotten} {daysLabel}</dd>
        </div>
      )}
    </dl>

    {statsProse && (
      <p class="tomb-stats-prose">{statsProse}</p>
    )}

    <div class="tomb-footer">
      <button
        class="resurrect-btn"
        data-resurrect-slug={post.slug}
        aria-label={`Resurrect "${post.title}"`}
      >
        ↑ breathe life back
      </button>
    </div>

  </div>
</article>

<style>
  /* Card shell: stone-like — angular top radius (sits in ground — Tanya §6) */
  /* --tomb-age: 0.0 (new) → 1.0 (ancient) — drives stone surface darkness */
  .tombstone {
    background: oklch(calc(12% + var(--tomb-age, 0.5) * 6%) 0.01 50 / 0.95);
    border: 1px solid var(--color-grave-border);
    border-radius: 8px 8px 0 0;   /* Tanya: tombstones sit in the ground */
    box-shadow: none;              /* Tanya: the dead cast no shadow */
    padding: 0;
    overflow: hidden;
  }

  /* Ghost cover image — monochrome, barely visible. Friction is the point. */
  .tomb-cover-wrap {
    width: 100%;
    aspect-ratio: 16 / 5;
    overflow: hidden;
    border-radius: 8px 8px 0 0;
  }

  .tomb-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Full desaturation — the image is a memory, not a fact */
    filter: saturate(0.08) opacity(0.25) blur(0.5px);
    mix-blend-mode: luminosity;
  }

  /* Inner wrapper: padding lives here so cover image bleeds edge-to-edge */
  .tombstone-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 20px 24px;
  }

  /* Row: "here lies" left, tier badge right */
  .tomb-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.1rem;
  }

  /* "here lies" — tiny label above the title, like a headstone inscription cap */
  .tomb-here-lies {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-grave-ghost);
  }

  /* Survival tier badge — pill, uses hue arc positions per tier */
  .tomb-tier {
    font-size: 0.52rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 999px;
    border: 1px solid currentColor;
    opacity: 0.65;
  }

  .tier-legendary { color: oklch(65% 0.12 160); }   /* sage — stood the test */
  .tier-contested { color: oklch(68% 0.14  45); }   /* amber — fought over */
  .tier-quiet     { color: oklch(55% 0.06 270); }   /* muted blue — gentle exit */
  .tier-forgotten { color: var(--color-grave-ghost); } /* achromatic — no story */

  /* Badge row: cause (left) + tier (right), both inline */
  .tomb-badges {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  /*
   * Cause-of-death badge — editorial verdict: WHY it died.
   * Separate visual contract from tier badge (HOW LONG it fought).
   * Earthy desaturated oklch palette — monochrome-safe for the Graveyard.
   * Tanya §3: "The Graveyard strips colour. Everything becomes monochrome."
   */
  .tomb-cause {
    font-size: 0.52rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 3px;          /* near-sharp — Tanya §6: Graveyard cards are hard */
    border: 1px solid currentColor;
    opacity: 0.75;
    cursor: default;
  }

  /* Five cause colours — desaturated earthy tones, dark-mode safe */
  .cause-superseded { color: oklch(58% 0.05 200); }  /* muted teal — voluntary exit */
  .cause-unsealed   { color: oklch(55% 0.04  50); }  /* warm grey-amber — incomplete */
  .cause-rejected   { color: oklch(52% 0.08  20); }  /* muted rust — reader verdict */
  .cause-abandoned  { color: oklch(48% 0.03 280); }  /* cool grey — silence */
  .cause-decayed    { color: oklch(45% 0.03  50); }  /* stone grey — time's default */

  /* Engraved text illusion: layered text-shadow — Mike §1 */
  .tomb-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-grave-text);
    text-wrap: balance;
    text-shadow:
      0  1px 0 oklch(8%  0.01 50),
      0 -1px 0 oklch(30% 0.01 50);
  }

  /* Description as italic epitaph — quoted, muted */
  .tomb-epitaph {
    margin: 0;
    font-size: 0.88rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--color-grave-ghost);
  }

  /* Born / Faded dates — quiet, horizontal, prose-like */
  .tomb-dates {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin: 0.35rem 0 0;
    padding: 0;
  }

  .tomb-date-row {
    display: flex;
    gap: 0.4rem;
    align-items: baseline;
    font-size: 0.68rem;
    letter-spacing: 0.03em;
    color: var(--color-grave-ghost);
  }

  .tomb-date-row dt {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 400;
    font-size: 0.6rem;
    flex-shrink: 0;
  }

  .tomb-date-row dd { margin: 0; }

  /* Prose stat line: "remembered by 3 readers · 4 min held alive" */
  .tomb-stats-prose {
    margin: 0.25rem 0 0;
    font-size: 0.68rem;
    color: var(--color-grave-ghost);
    letter-spacing: 0.02em;
  }

  /* Footer: resurrect affordance — right-aligned, text-only — Tanya §3.3 */
  .tomb-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.85rem;
  }

  /* Text-only resurrect: no border, no background, no hover box — Tanya §3.3 */
  .resurrect-btn {
    /* Reset button chrome */
    appearance: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;

    /* Text styling */
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--color-grave-ghost);
    transition: color 200ms ease;

    /* Invisible padding: 44px tap target without visual weight — Tanya §6.2 */
    padding: 14px 0 14px 1rem;
  }

  .resurrect-btn:hover,
  .resurrect-btn:focus-visible {
    color: var(--mood-accent, oklch(72% 0.12 65));
    outline: none;
  }

  /* Risen state: amber text, no pointer — JS applies this class */
  .resurrect-btn.risen {
    color: var(--mood-accent, oklch(72% 0.12 65));
    cursor: default;
    pointer-events: none;
    opacity: 0.85;
  }
</style>
