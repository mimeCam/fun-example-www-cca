---
// src/components/TombstoneCard.astro
// Epitaph card for the /graveyard page.
// Layout: "HERE LIES · title · description · Born/Faded · stats · resurrect"
// Monochrome locked via --color-grave-* tokens, not CSS opacity on the element.
// Resurrection requires a deliberate click — no hover-revival (Mike, Tanya §3.3).
//
// WARNING: Do NOT merge with DecayCard. Different visual contracts. — Mike
// Credits: Mike (epitaph layout spec), Tanya (UX spec §3.3, §3.5, §6.2)

import { formatPubDate } from '../lib/dates';
import { daysSince } from '../lib/temporal';
import type { PostDisplayData } from '../lib/postMeta';

interface Props { post: PostDisplayData; }

const { post } = Astro.props;

const formattedPubDate  = formatPubDate(post.pubDate);
const entombDate        = post.entombedAt ? formatPubDate(post.entombedAt) : null;
const forgotten         = forgottenDays(post);
const daysLabel         = forgotten === 1 ? 'day' : 'days';
const readingMins       = Math.round(post.readingSeconds / 60);
const statsProse        = buildStatsProse(post.revivalCount, readingMins);

/** Days since entombment, falling back to days since publish. */
function forgottenDays(p: PostDisplayData): number {
  return p.entombedAt
    ? daysSince(p.entombedAt.toISOString())
    : daysSince(p.pubDateISO);
}

/** Prose-style stat line: "remembered by 3 readers · 4 min held alive" */
function buildStatsProse(revivals: number, mins: number): string {
  const parts: string[] = [];
  if (revivals > 0) parts.push(`remembered by ${revivals} ${revivals === 1 ? 'reader' : 'readers'}`);
  if (mins > 0)     parts.push(`${mins} min held alive`);
  return parts.join(' · ');
}
---

<article
  class="tombstone tombstone-card"
  data-slug={post.slug}
  aria-label={`${post.title} — forgotten ${forgotten} ${daysLabel}`}
>
  <div class="tombstone-inner">

    <span class="tomb-here-lies">here lies</span>

    <h2 class="tomb-title">{post.title}</h2>

    {post.description && (
      <p class="tomb-epitaph">&#8220;{post.description}&#8221;</p>
    )}

    <dl class="tomb-dates">
      <div class="tomb-date-row">
        <dt>born</dt>
        <dd><time datetime={post.pubDateISO}>{formattedPubDate}</time></dd>
      </div>
      {entombDate && (
        <div class="tomb-date-row">
          <dt>faded</dt>
          <dd>{entombDate} · forgotten {forgotten} {daysLabel}</dd>
        </div>
      )}
      {!entombDate && (
        <div class="tomb-date-row">
          <dt>lost</dt>
          <dd>forgotten {forgotten} {daysLabel}</dd>
        </div>
      )}
    </dl>

    {statsProse && (
      <p class="tomb-stats-prose">{statsProse}</p>
    )}

    <div class="tomb-footer">
      <button
        class="resurrect-btn"
        data-resurrect-slug={post.slug}
        aria-label={`Resurrect "${post.title}"`}
      >
        ↑ breathe life back
      </button>
    </div>

  </div>
</article>

<style>
  /* Card shell: stone-like — angular radius, inset shadow, surface colour */
  .tombstone {
    background: var(--color-grave-surface);
    border: 1px solid var(--color-grave-border);
    border-radius: var(--radius-grave, 6px);
    box-shadow: var(--shadow-grave-card);
    padding: 20px 24px;
  }

  /* Inner wrapper carries the breathing animation from graveyard.css */
  .tombstone-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* "here lies" — tiny label above the title, like a headstone inscription cap */
  .tomb-here-lies {
    display: block;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-grave-ghost);
    margin-bottom: 0.1rem;
  }

  /* Engraved text illusion: layered text-shadow — Mike §1 */
  .tomb-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-grave-text);
    text-wrap: balance;
    text-shadow:
      0  1px 0 oklch(8%  0.01 50),
      0 -1px 0 oklch(30% 0.01 50);
  }

  /* Description as italic epitaph — quoted, muted */
  .tomb-epitaph {
    margin: 0;
    font-size: 0.88rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--color-grave-ghost);
  }

  /* Born / Faded dates — quiet, horizontal, prose-like */
  .tomb-dates {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin: 0.35rem 0 0;
    padding: 0;
  }

  .tomb-date-row {
    display: flex;
    gap: 0.4rem;
    align-items: baseline;
    font-size: 0.68rem;
    letter-spacing: 0.03em;
    color: var(--color-grave-ghost);
  }

  .tomb-date-row dt {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 400;
    font-size: 0.6rem;
    flex-shrink: 0;
  }

  .tomb-date-row dd { margin: 0; }

  /* Prose stat line: "remembered by 3 readers · 4 min held alive" */
  .tomb-stats-prose {
    margin: 0.25rem 0 0;
    font-size: 0.68rem;
    color: var(--color-grave-ghost);
    letter-spacing: 0.02em;
  }

  /* Footer: resurrect affordance — right-aligned, text-only — Tanya §3.3 */
  .tomb-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.85rem;
  }

  /* Text-only resurrect: no border, no background, no hover box — Tanya §3.3 */
  .resurrect-btn {
    /* Reset button chrome */
    appearance: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;

    /* Text styling */
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--color-grave-ghost);
    transition: color 200ms ease;

    /* Invisible padding: 44px tap target without visual weight — Tanya §6.2 */
    padding: 14px 0 14px 1rem;
  }

  .resurrect-btn:hover,
  .resurrect-btn:focus-visible {
    color: var(--mood-accent, oklch(72% 0.12 65));
    outline: none;
  }

  /* Risen state: amber text, no pointer — JS applies this class */
  .resurrect-btn.risen {
    color: var(--mood-accent, oklch(72% 0.12 65));
    cursor: default;
    pointer-events: none;
    opacity: 0.85;
  }
</style>
