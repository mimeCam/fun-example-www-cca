---
// src/components/TrustBadge.astro
// RFC 3161 trust badge — 5-state conviction lifecycle display.
// States: unsealed · pending · sealed · upheld · overturned
//
// SSR shell: renders initial state at page load (zero own client JS).
// Client ceremony: trust-badge-ceremony.ts polls /api/conviction-stats?slug=
// and triggers a 3D flip animation on state change.
//
// Flip structure: front (current) + back (next, empty) enables CSS 3D flip.
// Token-only CSS: all colors from design system — zero hardcoded hex/rgba.
//
// Credits: Mike (arch §TrustBadge, §ceremony-system), Tanya (§4.2 token fix),
//          Elon ("land it like a verdict, not a notification — ease-spring CEREMONY 600ms")

import type { TstData } from '../lib/timestamp-store';
import { verifyToken }  from '../lib/rfc3161-verifier';

export type ConvictionStage = 'unsealed' | 'pending' | 'sealed' | 'upheld' | 'overturned';

interface Props {
  tst:             TstData | null;
  slug:            string;
  convictionStage: ConvictionStage;
}

const { tst, slug, convictionStage } = Astro.props;

const verification = tst ? await verifyToken(tst.tst_token) : null;
const auditHref    = `/audit/${slug}`;

function fmtDate(d: Date): string {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function sealedLabel(): string {
  if (!verification?.timestamp || !verification.tsaName) return 'sealed · awaiting verdict';
  return `Timestamped · ${verification.tsaName} · ${fmtDate(verification.timestamp)}`;
}

// Whether the current state should link to the audit page
const isLinked = convictionStage === 'sealed' && !!verification?.verified
  || convictionStage === 'upheld'
  || convictionStage === 'overturned';

const badgeLabels: Record<ConvictionStage, string> = {
  unsealed:   'unsealed',
  pending:    'timestamp pending',
  sealed:     sealedLabel(),
  upheld:     'upheld',
  overturned: 'overturned',
};
const badgeIcons: Record<ConvictionStage, string> = {
  unsealed:   '◌',
  pending:    '◷',
  sealed:     '⏱',
  upheld:     '✓',
  overturned: '✗',
};

const label = badgeLabels[convictionStage];
const icon  = badgeIcons[convictionStage];
---

<div class="trust-badge-flip" data-badge-slug={slug} data-badge-state={convictionStage}>
  <div class="badge-card">

    <!-- Front face: SSR-rendered current state -->
    <div class="badge-face badge-face--front">
      {isLinked ? (
        <a href={auditHref} class="badge-inner"
           title="RFC 3161 timestamp — click for full proof"
           aria-label={`Conviction: ${label}`}>
          <span class="badge-icon" aria-hidden="true">{icon}</span>
          <span class="badge-text">{label}</span>
        </a>
      ) : (
        <span class="badge-inner" aria-label={`Conviction: ${label}`}>
          <span class="badge-icon" aria-hidden="true">{icon}</span>
          <span class="badge-text">{label}</span>
        </span>
      )}
    </div>

    <!-- Back face: populated by trust-badge-ceremony.ts before each flip.
         Empty at SSR time — the JS fills it silently before .is-flipping fires. -->
    <div class="badge-face badge-face--back" aria-hidden="true"></div>

  </div>
</div>

<script>
  import { mountBadgeCeremonies } from '../lib/client/trust-badge-ceremony';
  mountBadgeCeremonies();
</script>

<style>
  /* ── Flip card scaffolding ──────────────────────────────────────────── */
  .trust-badge-flip {
    display:  inline-block;
    position: relative;
  }

  .badge-card {
    position:        relative;
    display:         inline-block;
    transform-style: preserve-3d;
  }

  /* Back face: absolutely positioned over front, initially transparent */
  .badge-face--back {
    position:        absolute;
    inset:           0;
    pointer-events:  none;
    /* Starts at -90° (face-down); ceremony rotates it to 0° */
    transform:       perspective(400px) rotateY(-90deg);
    opacity:         0;
  }

  /* ── Visual badge element ─────────────────────────────────────────── */
  /* .badge-inner is the styled pill — inside front and JS-injected back */
  .badge-inner {
    display:         inline-flex;
    align-items:     center;
    gap:             0.35rem;
    font-size:       var(--text-xs);
    font-weight:     var(--weight-medium);
    letter-spacing:  var(--tracking-relaxed);
    padding:         0.22rem 0.6rem;
    border-radius:   var(--radius-pill);
    text-decoration: none;
    white-space:     nowrap;
    /* Token-driven colors — set on ancestor [data-badge-state] in trust-badge.css */
    background:      var(--badge-bg,     var(--surface-raised));
    border:          1px solid var(--badge-border, var(--border-medium));
    color:           var(--badge-color,  var(--text-tertiary));
    transition:
      background   var(--motion-snap-duration) var(--motion-snap-easing),
      border-color var(--motion-snap-duration) var(--motion-snap-easing),
      box-shadow   var(--motion-snap-duration) var(--motion-snap-easing);
  }

  /* Linked badges get a pointer — unlinked are static */
  a.badge-inner { cursor: pointer; }
  span.badge-inner { cursor: default; }

  .badge-icon { font-size: var(--text-xs); line-height: 1; }
  .badge-text { line-height: 1; }
</style>
