---
// src/components/RadialRing.astro
// Single shared SVG progressbar for the touch/keyboard revival gesture.
// Hidden by default; radialRing.ts shows, positions, and animates it.
// radialRingA11y.ts updates aria-valuenow and the live-region sibling.
//
// Rendered once in BaseLayout — never re-created by JS.
// Z-index 40: above cards, below modals (matches old overlay).

const RING_SIZE = 48;
const RADIUS    = 20;
const CIRCUM    = +(2 * Math.PI * RADIUS).toFixed(2);
const CX        = RING_SIZE / 2;
---

<!--
  revival-ring-overlay: fixed inset-0 pointer-events-none container.
  revival-ring-svg:     the progressbar; JS positions via left/top.
  revival-a11y-announce: polite live region read by screen readers.
-->
<div id="revival-ring-overlay" class="revival-ring-overlay" aria-hidden="true">
  <svg
    id="revival-ring-svg"
    class="revival-ring"
    width={RING_SIZE}
    height={RING_SIZE}
    viewBox={`0 0 ${RING_SIZE} ${RING_SIZE}`}
    role="progressbar"
    aria-label="Hold to revive this post"
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="0"
    style="display:none"
  >
    <circle
      class="revival-ring__track"
      cx={CX}
      cy={CX}
      r={RADIUS}
      stroke-dasharray={CIRCUM}
      stroke-dashoffset={CIRCUM}
    />
  </svg>
</div>

<div
  id="revival-a11y-announce"
  class="sr-only"
  role="status"
  aria-live="polite"
  aria-atomic="true"
></div>

<style>
  /* Visually hidden but accessible — same technique as .sr-only in Tailwind. */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>
