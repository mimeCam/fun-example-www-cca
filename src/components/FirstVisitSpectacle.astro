---
// src/components/FirstVisitSpectacle.astro
// First-visit spectacle: 2-second silent visual handshake.
// Teaches the decay-revival mechanic through pure cinema — no words needed.
//
// Flow: BLOOM → DECAY → RESIST → HANDOFF → done (removed from DOM)
// Gate: localStorage('spectacle_done') via checkFirstVisit() in onboardProbe.ts
// A11y: aria-hidden; respects prefers-reduced-motion at two levels (CSS + JS)
//
// HANDOFF phase now fires a programmatic demo revival (slug='__demo__') so
// the user sees the full radial-ring → bloom path before interacting.
// /api/revive guards __demo__ and returns early without touching the DB.
---

<!--
  Overlay is aria-hidden — screen readers skip entirely.
  The revival mechanic is discovered through interaction, not announced.
  [data-phase] drives all CSS transitions; no inline styles from JS.
-->
<div id="spectacle-overlay" aria-hidden="true" data-phase="idle">
  <div class="spectacle-card">
    <div class="spectacle-bloom-ring"></div>
    <p class="spectacle-card-date">Today</p>
    <h2 class="spectacle-card-title">Words fade here</h2>
    <p class="spectacle-card-body">
      Content ages unless someone remembers it.
    </p>
    <div class="spectacle-keep-hint" aria-hidden="true"></div>
  </div>
</div>

<script>
  import { createSpectacleController, DEFAULT_DURATIONS } from '../lib/spectacle/controller';
  import { checkFirstVisit, markSpectacleDone } from '../lib/onboardProbe';

  // ── Demo revival helpers ──────────────────────────────────────────────────

  /** Center coords of the spectacle demo card, fallback to viewport centre. */
  function demoCardCenter(): { x: number; y: number } {
    const card = document.querySelector('.spectacle-card') as HTMLElement | null;
    if (!card) return { x: window.innerWidth / 2, y: window.innerHeight / 2 };
    const r = card.getBoundingClientRect();
    return { x: r.left + r.width / 2, y: r.top + r.height / 2 };
  }

  /** Dispatch a revival:* custom event with the given detail. */
  function emitRevival(name: string, detail: Record<string, unknown>): void {
    document.dispatchEvent(new CustomEvent(`revival:${name}`, { detail }));
  }

  /**
   * Run a 600ms programmatic demo revival.
   * Emits start → progress ticks → success with slug='__demo__'.
   * The API guards __demo__ and returns ok:true without DB writes.
   */
  function runDemoRevival(): void {
    const HOLD_MS = 600;
    const TICK_MS = 16;
    const pos = demoCardCenter();

    emitRevival('start', { slug: '__demo__', x: pos.x, y: pos.y });

    let elapsed = 0;
    const timer = setInterval(() => {
      elapsed += TICK_MS;
      const progress = Math.min(elapsed / HOLD_MS, 1);
      emitRevival('progress', { slug: '__demo__', progress });
      if (progress >= 1) {
        clearInterval(timer);
        emitRevival('success', { slug: '__demo__', newCount: 0, source: 'spectacle' });
      }
    }, TICK_MS);
  }

  // ── Spectacle FSM ─────────────────────────────────────────────────────────

  function initSpectacle(): void {
    if (!checkFirstVisit()) return;

    const overlay = document.getElementById('spectacle-overlay');
    if (!overlay) return;

    const ctrl = createSpectacleController({
      durations: DEFAULT_DURATIONS,
      onPhase(phase) {
        (overlay as HTMLElement).dataset.phase = phase;
        if (phase === 'handoff') runDemoRevival();
      },
      onDone() {
        overlay.remove();
        markSpectacleDone();
        document.dispatchEvent(new CustomEvent('spectacle:done'));
      },
    });

    attachSkipListeners(ctrl, overlay as HTMLElement);

    // Double-rAF gate: ensures overlay is painted before BLOOM fires.
    // Without this, BLOOM triggers during layout on mobile → stutter.
    requestAnimationFrame(() => requestAnimationFrame(() => ctrl.start()));
  }

  function attachSkipListeners(
    ctrl: ReturnType<typeof createSpectacleController>,
    overlay: HTMLElement,
  ): void {
    const skip = () => ctrl.skip();
    document.addEventListener('keydown', (e) => e.key === 'Escape' && skip(), { once: true });
    overlay.addEventListener('pointerdown', skip, { once: true });
  }

  // Start after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSpectacle, { once: true });
  } else {
    initSpectacle();
  }
</script>
