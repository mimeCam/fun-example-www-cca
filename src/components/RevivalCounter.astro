---
// src/components/RevivalCounter.astro
// Live Collective Memory Display — "N people are keeping this alive."
//
// SSR: reads initial count and injects it as data attr (no flicker, no "0" flash).
// Client: revival-counter.ts subscribes to /api/heartbeat and animates via odometer.
//
// Spring tick: data-ticking attr on .revival-count-number triggers
// revival-count-tick keyframe in revival-moment.css — set by RevivalMoment IIFE.
//
// Usage: place in blog/[slug].astro revival footer, pass slug + initialCount.
// Credits: Mike (architecture), Tanya (UX spec §4.1), Paul Kim (revival loop mandate)

interface Props {
  slug: string;
  initialCount: number;
  decayFactor: number;
  lifespan?: number;
}

const { slug, initialCount, decayFactor, lifespan = 365 } = Astro.props;
const showCount = initialCount > 0;
---

<div
  class="revival-counter-root"
  data-slug={slug}
  data-initial-count={initialCount}
  data-decay-factor={decayFactor.toFixed(4)}
  data-lifespan={lifespan}
>
  <p class="revival-collective" aria-live="polite">
    {showCount && (
      <>
        <span
          class="revival-count-number"
          data-revival-count-display
          aria-label={`${initialCount} keeping this alive`}
        >{initialCount}</span>
        <span class="revival-count-label">
          {' '}{initialCount === 1 ? 'person is' : 'people are'} keeping this alive
        </span>
      </>
    )}
    {!showCount && (
      <span
        class="revival-count-number revival-count-number--zero"
        data-revival-count-display
        aria-label="0 keeping this alive"
      >0</span>
    )}
  </p>

  <div class="days-banner" aria-live="polite" aria-atomic="true"></div>
</div>

<style>
  .revival-counter-root {
    text-align: center;
    margin: var(--space-2) 0 var(--space-4);
  }

  /* Secondary label copy — steps back to let the number breathe */
  .revival-collective {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    letter-spacing: var(--tracking-micro);
    min-height: 1.4em;
    transition: color var(--motion-flow-duration) var(--motion-flow-easing);
  }

  /* IBM Plex Mono for the count — numeric gravitas (Tanya §1, Mike token spec) */
  .revival-count-number {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: color-mix(in oklch, var(--mood-accent) 85%, transparent);
    letter-spacing: var(--tracking-tight);
    display: inline-block;
    min-width: 1.5ch;
    /* Transition: color during data-ticking flash is handled by revival-moment.css */
    transition: color var(--motion-flow-duration) var(--motion-flow-easing);
  }

  /* Zero state — ghost, not disabled */
  .revival-count-number--zero {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-normal);
    color: var(--text-disabled);
  }

  .revival-count-label {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  /* Days banner — hidden by default, revealed by revival-counter.ts */
  .days-banner {
    font-size: var(--text-xs);
    color: color-mix(in oklch, var(--mood-accent) 75%, transparent);
    letter-spacing: var(--tracking-wide);
    min-height: 1.2em;
    margin-top: var(--space-1);
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity   var(--motion-flow-duration) var(--motion-flow-easing),
      transform var(--motion-flow-duration) var(--motion-flow-easing);
  }

  .days-banner--visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  import { initRevivalCounter } from '../lib/revival-counter';

  const root = document.querySelector<HTMLElement>('.revival-counter-root');
  if (root) {
    initRevivalCounter({
      slug:         root.dataset.slug ?? '',
      initialCount: parseInt(root.dataset.initialCount ?? '0', 10),
      decayFactor:  parseFloat(root.dataset.decayFactor ?? '0'),
      lifespan:     parseInt(root.dataset.lifespan ?? '365', 10),
    });
  }
</script>
