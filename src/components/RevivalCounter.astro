---
// src/components/RevivalCounter.astro
// Live Collective Memory Display — "N people are keeping this alive."
//
// SSR: reads initial count and injects it as data attr (no flicker, no "0" flash).
// Client: revival-counter.ts subscribes to /api/heartbeat and animates via odometer.
//
// Usage: place in blog/[slug].astro revival footer, pass slug + initialCount.
// Credits: Mike (architecture), Tanya (UX spec §4.1), Paul Kim (revival loop mandate)

interface Props {
  slug: string;
  initialCount: number;
  decayFactor: number;
  lifespan?: number;
}

const { slug, initialCount, decayFactor, lifespan = 365 } = Astro.props;
const showCount = initialCount > 0;
---

<div
  class="revival-counter-root"
  data-slug={slug}
  data-initial-count={initialCount}
  data-decay-factor={decayFactor.toFixed(4)}
  data-lifespan={lifespan}
>
  <p class="revival-collective" aria-live="polite">
    {showCount && (
      <>
        <span
          class="revival-count-number"
          data-revival-count-display
          aria-label={`${initialCount} keeping this alive`}
        >{initialCount}</span>
        <span class="revival-count-label">
          {' '}{initialCount === 1 ? 'person is' : 'people are'} keeping this alive
        </span>
      </>
    )}
    {!showCount && (
      <span
        class="revival-count-number revival-count-number--zero"
        data-revival-count-display
        aria-label="0 keeping this alive"
      >0</span>
    )}
  </p>

  <div class="days-banner" aria-live="polite" aria-atomic="true"></div>
</div>

<style>
  .revival-counter-root {
    text-align: center;
    margin: 0.5rem 0 1rem;
  }

  .revival-collective {
    margin: 0;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.01em;
    min-height: 1.4em;
    transition: color 400ms ease;
  }

  .revival-count-number {
    font-size: 1.4rem;
    font-weight: 700;
    color: rgba(var(--mood-accent-rgb, 120,120,120), 0.85);
    letter-spacing: -0.01em;
    display: inline-block;
    min-width: 1.5ch;
    transition: color 300ms ease;
  }

  .revival-count-number--zero {
    font-size: 0.82rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.20);
  }

  .revival-count-label {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.45);
  }

  /* Days banner — hidden by default, revealed by JS */
  .days-banner {
    font-size: 0.78rem;
    color: rgba(var(--mood-accent-rgb, 140, 120, 80), 0.75);
    letter-spacing: 0.02em;
    min-height: 1.2em;
    margin-top: 0.25rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 300ms ease, transform 300ms ease;
  }

  .days-banner--visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  import { initRevivalCounter } from '../lib/revival-counter';

  const root = document.querySelector<HTMLElement>('.revival-counter-root');
  if (root) {
    initRevivalCounter({
      slug: root.dataset.slug ?? '',
      initialCount: parseInt(root.dataset.initialCount ?? '0', 10),
      decayFactor: parseFloat(root.dataset.decayFactor ?? '0'),
      lifespan: parseInt(root.dataset.lifespan ?? '365', 10),
    });
  }
</script>
