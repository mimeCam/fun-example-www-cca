---
// src/components/FreshnessIndicator.astro
// Icon-based freshness stage: ○ Soft, ◐ Setting, ◆ Crystallized.
// Driven by a DecayLabel from pulse.ts — no JS, pure markup.

import type { DecayLabel } from '../lib/pulse';

interface Props { label: DecayLabel; }

const ICONS: Record<DecayLabel, { glyph: string; title: string }> = {
  fresh: { glyph: '○', title: 'Soft — freshly formed thought' },
  aging: { glyph: '◐', title: 'Setting — gaining definition' },
  stale: { glyph: '◆', title: 'Crystallized — mineral permanence' },
};

const { glyph, title } = ICONS[Astro.props.label];
---

<span class={`freshness freshness-${Astro.props.label}`} title={title} aria-label={title}>
  {glyph}
</span>

<style>
  .freshness { font-size: 0.85rem; line-height: 1; cursor: default; }
  .freshness-fresh { opacity: 0.5; }
  .freshness-aging { opacity: 0.7; }
  .freshness-stale { opacity: 0.95; }
</style>
