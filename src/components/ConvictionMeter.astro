---
// src/components/ConvictionMeter.astro
// Sitewide conviction batting average — the author's credibility made visible.
// Zero client JS. Pure SSR. Data is passed in; no fetching inside this component.
//
// Placement: between <SiteNav> and page content on /, /now, /graveyard.
// Color thresholds (Tanya §2): amber ≥70%, yellow 50–69%, slate <50%, grey cold.
//
// Credits: Mike (spec §2 — component design, pct formula),
//          Tanya (UX §2 — chip spec, threshold states, plain-English copy)

import type { BattingAverage } from '../lib/batting-average';

interface Props {
  avg: BattingAverage;
}

const { avg } = Astro.props;

// Derive CSS modifier class from pct threshold — Tanya §2 threshold table.
function meterMod(a: BattingAverage): string {
  if (a.status === 'cold') return 'cm--cold';
  if (a.pct >= 70) return 'cm--amber';
  if (a.pct >= 50) return 'cm--yellow';
  return 'cm--slate';
}

// Plain-English tagline copy.
function tagline(a: BattingAverage): string {
  if (a.status === 'cold') return '';
  const resolved = a.correct + a.wrong;
  if (resolved === 0) return `${a.total} sealed ${a.total === 1 ? 'prediction' : 'predictions'} in play — none resolved yet.`;
  return `Called ${a.correct} of ${resolved} resolved ${resolved === 1 ? 'prediction' : 'predictions'} correctly.`;
}

const mod    = meterMod(avg);
const line   = tagline(avg);
const isLive = avg.status === 'live';
---

<aside id="conviction-meter" class:list={['conviction-meter', mod]} aria-label="Author conviction batting average">

  {avg.status === 'cold' && (
    <span class="cm-cold">No sealed predictions yet.</span>
  )}

  {isLive && (
    <div class="cm-body">
      <div class="cm-headline">
        <span class="cm-pct" data-cm-pct={avg.pct} aria-label={`${avg.pct} percent accuracy`}>{avg.pct}%</span>
        <div class="cm-pills" aria-label="Breakdown">
          <span class="cm-pill cm-pill--correct" data-cm-correct={avg.correct} title="Predictions that proved right">✓ {avg.correct} correct</span>
          <span class="cm-pill cm-pill--wrong"   data-cm-wrong={avg.wrong}     title="Predictions that proved wrong">✗ {avg.wrong} wrong</span>
          <span class="cm-pill cm-pill--pending" data-cm-pending={avg.pending} title="Active predictions, not yet resolved">⏳ {avg.pending} pending</span>
        </div>
      </div>

      <p class="cm-tagline">{line}</p>

      <details class="cm-disclosure">
        <summary class="cm-disclosure-toggle">How is this calculated?</summary>
        <div class="cm-disclosure-body">
          <p>
            Before publishing each post, a conviction score (1–10) is
            author-locked before publication via a server-signed HMAC seal.
            The score cannot be edited retroactively — the server's signature
            would be invalid if tampered with.
          </p>
          <p>
            A prediction is <strong>correct</strong> when it scores 7 or higher and the
            post eventually dies — the author stood by a strong belief and time bore it
            out. It is <strong>wrong</strong> when it scores 4 or lower at death.
            Scores 5–6 are genuinely ambiguous and excluded from the calculation.
            <em>Pending</em> posts are live bets still in play; they never count against
            the average until resolved.
          </p>
          <p>
            The number above is <code>correct ÷ (correct + wrong)</code>.
            Pending predictions are not in the denominator — an open bet is honest, not
            a failure. Inspect the seal on any post at
            <a href="/audit/" class="cm-audit-link">
              /audit/[slug]
            </a>.
          </p>
        </div>
      </details>
    </div>
  )}

</aside>

<style>
  .conviction-meter {
    border-radius: var(--radius-input);
    padding: 1rem 1.25rem;
    margin: 0 0 2rem;
    border: 1px solid transparent;
  }

  /* ── Color variants — Tanya §2 threshold table ── */

  .cm--cold {
    background: color-mix(in oklch, white 3%, transparent);
    border-color: var(--border-subtle);
  }

  .cm--amber {
    background: color-mix(in oklch, var(--gold) 5%, transparent);
    border-color: color-mix(in oklch, var(--gold) 15%, transparent);
    box-shadow: 0 0 20px color-mix(in oklch, var(--gold) 6%, transparent);
  }

  .cm--yellow {
    background: color-mix(in oklch, var(--stance-torn) 4%, transparent);
    border-color: color-mix(in oklch, var(--stance-torn) 12%, transparent);
  }

  .cm--slate {
    background: color-mix(in oklch, white 3%, transparent);
    border-color: var(--border-light);
  }

  /* ── Cold label ── */

  .cm-cold {
    font-size: var(--text-xs);
    color: var(--text-dim);
    font-style: italic;
    letter-spacing: var(--tracking-wide);
  }

  /* ── Live body ── */

  .cm-body {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .cm-headline {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Large pct digit — the single most important number on the page */
  .cm-pct {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    font-family: var(--font-mono);
    line-height: 1;
    letter-spacing: var(--tracking-display);
  }

  .cm--amber  .cm-pct { color: var(--gold); }
  .cm--yellow .cm-pct { color: color-mix(in oklch, var(--stance-torn) 85%, transparent); }
  .cm--slate  .cm-pct { color: var(--text-tertiary); }

  /* Pill badges: correct / wrong / pending */
  .cm-pills {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .cm-pill {
    font-size: var(--text-2xs);
    font-family: var(--font-mono);
    padding: 2px 7px;
    border-radius: 4px;
    letter-spacing: var(--tracking-normal);
    white-space: nowrap;
  }

  .cm-pill--correct { background: var(--verdict-true-bg);  color: color-mix(in oklch, var(--verdict-true) 80%, transparent); }
  .cm-pill--wrong   { background: var(--verdict-wrong-bg); color: color-mix(in oklch, var(--verdict-wrong) 75%, transparent); }
  .cm-pill--pending { background: color-mix(in oklch, white 5%, transparent); color: var(--text-tertiary); }

  /* One-line tagline — plain English, no jargon */
  .cm-tagline {
    font-size: var(--text-xs);
    line-height: 1.5;
    color: var(--text-tertiary);
    margin: 0;
    letter-spacing: var(--tracking-normal);
  }

  /* Collapsible "How is this calculated?" */
  .cm-disclosure { border-top: 1px solid var(--border-faint); padding-top: 0.65rem; }

  .cm-disclosure-toggle {
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-wide);
    color: var(--text-dim);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: color var(--motion-duration-fast) ease;
  }

  .cm-disclosure-toggle::-webkit-details-marker { display: none; }
  .cm-disclosure-toggle::before { content: '▸ '; font-size: var(--text-3xs); }
  details[open] .cm-disclosure-toggle::before { content: '▾ '; }

  .cm-disclosure-toggle:hover { color: var(--text-secondary); }

  .cm-disclosure-body {
    padding-top: 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cm-disclosure-body p {
    font-size: var(--text-xs);
    line-height: 1.6;
    color: var(--text-tertiary);
    margin: 0;
  }

  .cm-disclosure-body strong { color: var(--text-secondary); font-weight: var(--weight-semibold); }
  .cm-disclosure-body em     { font-style: italic; }

  .cm-disclosure-body code {
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--gold-mid);
    padding: 0 3px;
  }

  .cm-audit-link {
    color: var(--text-tertiary);
    text-underline-offset: 2px;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    transition: color var(--motion-duration-fast) ease;
  }

  .cm-audit-link:hover { color: var(--text-secondary); }

  /* ── Mobile ── */

  @media (max-width: 640px) {
    .conviction-meter { padding: 0.85rem 1rem; }
    .cm-pct           { font-size: var(--text-lg); }
    .cm-headline      { gap: 0.65rem; }
  }
</style>

{/* Live-verdict wire: imports fire only on the client, deferred — non-blocking. */}
<script>
  import { initLiveConviction } from '../lib/client/live-conviction';
  initLiveConviction();
</script>
