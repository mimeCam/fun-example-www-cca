---
// src/components/HomePulse.astro
// Bleeds the latest wall whisper onto the homepage as an ambient epigraph.
// Uses data-posted / data-max-days so liveDecayScript() refreshes at visit.
//
// TODO: animate entrance with a slow staggered fade-in
// TODO: link to /wall on click for discovery

import type { ComputedWallEntry } from '../lib/wall';
import { resolveMood, moodToCSSVars } from '../lib/mood';

interface Props { entry: ComputedWallEntry }

const { entry } = Astro.props;
const accent = moodToCSSVars(resolveMood(entry.entry.mood))['--mood-accent-rgb'];
---

<aside
  class="home-pulse"
  data-posted={entry.entry.posted}
  data-max-days="30"
  style={`--decay:${entry.decay};--entry-accent-rgb:${accent}`}
>
  <p class="home-pulse__text">{entry.entry.text}</p>
  <span class="home-pulse__quip">{entry.quip}</span>
</aside>

<style>
  .home-pulse {
    max-width: 32rem;
    margin: 0 auto 2rem;
    padding: 1rem 1.25rem;
    border-left: 2px solid
      rgba(var(--entry-accent-rgb), calc(0.4 - var(--decay) * 0.3));
    opacity: calc(0.85 - var(--decay) * 0.35);
    transition: opacity 0.3s ease;
  }
  .home-pulse__text {
    font-size: 0.9rem;
    font-style: italic;
    margin: 0 0 0.25rem;
    opacity: 0.8;
  }
  .home-pulse__quip {
    font-size: 0.72rem;
    opacity: 0.4;
  }
</style>
