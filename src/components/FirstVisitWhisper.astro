---
// src/components/FirstVisitWhisper.astro
// Non-blocking ambient onboarding hint. Replaces FirstVisitSpectacle.
//
// Shows on first visit only (localStorage gate: 'whisper_seen').
// Sits inline in document flow between cards — no overlay, no blocking.
// Auto-dismisses after sequence completes or on any click.
//
// A11y: role="status", aria-live="polite", prefers-reduced-motion.
// Design: matches decay visual language via --mood-accent-rgb vars.
---

<div
  id="first-visit-whisper"
  class="whisper-container"
  role="status"
  aria-live="polite"
>
  <!-- Step 1: decay awareness -->
  <div class="whisper-step whisper-step-1" data-step="1">
    <p class="whisper-text">
      posts fade over time.
      <br />
      <span class="whisper-accent">your attention keeps them alive.</span>
    </p>
  </div>

  <!-- Step 2: graveyard discovery -->
  <div class="whisper-step whisper-step-2" data-step="2">
    <p class="whisper-text">
      gone posts rest in
      <a href="/graveyard" class="whisper-link">the graveyard</a>.
    </p>
  </div>

  <!-- A11y live region (visually hidden, announced by SR) -->
  <div class="whisper-sr-only" aria-live="polite"></div>
</div>

<script>
  import {
    shouldWhisper,
    observeCards,
    runWhisperSequence,
    type WhisperElements,
  } from '../lib/whisperSequence';

  function initWhisper(): void {
    if (!shouldWhisper()) return hideContainer();

    const els = getWhisperElements();
    if (!els) return;

    const visibleCards = trackVisibleCards();
    const handle = runWhisperSequence(els);

    registerCleanup(handle, visibleCards.observer);
  }

  function hideContainer(): void {
    const el = document.getElementById('first-visit-whisper');
    if (el) el.style.display = 'none';
  }

  function getWhisperElements(): WhisperElements | null {
    const container = document.getElementById('first-visit-whisper');
    const step1 = container?.querySelector('[data-step="1"]') as HTMLElement;
    const step2 = container?.querySelector('[data-step="2"]') as HTMLElement;
    const liveRegion = container?.querySelector('.whisper-sr-only') as HTMLElement;

    if (!container || !step1 || !step2 || !liveRegion) return null;
    return { container, step1, step2, liveRegion };
  }

  function trackVisibleCards() {
    const visible = new Set<HTMLElement>();
    const observer = observeCards(
      (card) => visible.add(card),
      (card) => visible.delete(card),
    );
    return { visible, observer };
  }

  function registerCleanup(
    handle: { destroy: () => void },
    observer: IntersectionObserver,
  ): void {
    document.addEventListener('whisper:dismiss', () => {
      handle.destroy();
      observer.disconnect();
    }, { once: true });
  }

  // Start after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWhisper, { once: true });
  } else {
    initWhisper();
  }
</script>

<style>
  /* ── Container: inline flow, centered ─────────────── */

  .whisper-container {
    position: relative;
    max-width: 240px;
    margin: -0.25rem auto 1.5rem;
    padding: 0;
    text-align: center;
    pointer-events: none;
    opacity: 0;
    height: 0;
    overflow: hidden;
    transition: height 600ms ease, opacity 600ms ease;
  }

  /* ── Visible state ────────────────────────────────── */

  .whisper-container:global(.whisper--visible) {
    opacity: 1;
    height: auto;
    overflow: visible;
    pointer-events: auto;
    cursor: pointer;
  }

  /* ── Exiting state ────────────────────────────────── */

  .whisper-container:global(.whisper--exiting) {
    opacity: 0;
    pointer-events: none;
    transition: opacity 600ms ease-in;
  }

  /* ── Step container ───────────────────────────────── */

  .whisper-step {
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(var(--mood-accent-rgb, 120, 120, 120), 0.08);
    border-radius: 10px;
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .whisper-step:global(.whisper-step--active) {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    position: relative;
    animation: whisper-in 800ms ease-out forwards;
  }

  .whisper-step:global(.whisper-step--exiting) {
    animation: whisper-out 600ms ease-in forwards;
    pointer-events: none;
    position: absolute;
  }

  /* ── Text styling ─────────────────────────────────── */

  .whisper-text {
    font-size: 0.72rem;
    line-height: 1.6;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  .whisper-accent {
    color: rgb(var(--mood-accent-rgb, 120, 120, 120));
    opacity: 0.7;
  }

  .whisper-link {
    color: rgb(var(--mood-accent-rgb, 120, 120, 120));
    opacity: 0.7;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    transition: opacity 200ms ease;
  }

  .whisper-link:hover {
    opacity: 1;
  }

  /* ── Keyframes ────────────────────────────────────── */

  @keyframes whisper-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes whisper-out {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-4px);
    }
  }

  /* ── Visually hidden (SR only) ────────────────────── */

  .whisper-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Reduced motion ───────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .whisper-container {
      transition: none;
    }

    .whisper-step:global(.whisper-step--active) {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .whisper-step:global(.whisper-step--exiting) {
      animation: none;
      opacity: 0;
    }
  }

  /* ── Mobile: wider whisper ────────────────────────── */

  @media (max-width: 640px) {
    .whisper-container {
      max-width: 85%;
    }
  }
</style>
