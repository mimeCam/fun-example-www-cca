---
// src/components/SiteNav.astro
// Minimal sticky nav — logo (left) · /now · /graveyard (right cluster).
// Three items max (Tanya §12). Active page underlined in amber (conviction gold).
// Erosion bar retained on blog post detail pages only.
//
// Presence elements use the same IDs as the old PresenceBand so
// presence-unified.ts hydrates them automatically.
//
// Credits: Tanya (UX spec §12 — Navigation), Elon (strip nav links)

import { getActivePage } from '../lib/nav';

const path        = Astro.url.pathname;
const pageId      = getActivePage(path);
const isBlogPost  = pageId === 'blog';
const presenceScope = isBlogPost ? 'slug' : 'global';
---

<nav class:list={['site-nav', { 'has-erosion': isBlogPost }]} aria-label="Site">
  <a href="/" class:list={['site-name', pageId === 'home' && 'nav-link--active']}>
    octopoid
  </a>

  <div class="nav-links">
    <a href="/now" class:list={['nav-link', pageId === 'now' && 'nav-link--active']}>
      now
    </a>
    <a href="/graveyard" class:list={['nav-link', pageId === 'graveyard' && 'nav-link--active']}>
      graveyard
    </a>
  </div>

  <div
    class="presence-indicator"
    id="presence-band"
    data-scope={presenceScope}
    aria-live="polite"
    aria-atomic="true"
    role="status"
  >
    <span class="presence-dot" id="presence-dot" aria-hidden="true" style="display:none"></span>
    <span class="presence-text" id="presence-text"></span>
    <span class="presence-count" id="presence-count" aria-hidden="true">0</span>
    <span class="presence-fallback" id="presence-fallback" style="display:none"></span>
  </div>

  {isBlogPost && <div class="erosion-bar" aria-hidden="true" />}
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    height: 48px;
    padding: 0 1.5rem;
    gap: 1.25rem;
    background: rgba(12, 12, 14, 0.75);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* Site name / logo */
  .site-name {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.88);
    text-decoration: none;
    transition: opacity 120ms ease;
    flex-shrink: 0;
  }
  .site-name:hover { opacity: 0.7; }

  /* Secondary nav links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-link {
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.38);
    text-decoration: none;
    transition: color 150ms ease;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover { color: rgba(255, 255, 255, 0.7); }

  /* Active page: amber underline — conviction gold is the active signal */
  .nav-link--active,
  .site-name.nav-link--active {
    color: rgba(255, 255, 255, 0.75);
    border-bottom-color: #F5A623;
  }

  /* ── Presence indicator (right side) ── */

  .presence-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0;
    transition: opacity 0.4s ease;
    margin-left: auto;
  }

  .presence-indicator.presence-active { opacity: 1; }

  .presence-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--mood-accent, #D4956A);
    animation: nav-breathe 3.5s ease-in-out infinite;
  }

  .presence-text {
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }

  .presence-count { display: none; }

  .presence-fallback {
    font-size: 0.63rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.35);
    font-style: italic;
  }

  @keyframes nav-breathe {
    0%, 100% { opacity: 0.4; transform: scale(0.6); }
    50% { opacity: 0.8; transform: scale(1.0); }
  }

  /* ── Erosion bar (blog posts only) ── */

  .site-nav.has-erosion {
    border-bottom: none;
    position: relative;
  }

  .erosion-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 0 0 2px 2px;
    background: linear-gradient(
      90deg,
      rgba(var(--mood-accent-rgb, 212,149,106), 0.18),
      rgba(var(--mood-accent-rgb, 212,149,106), 0.18)
    );
    box-shadow: 0 1px 6px rgba(var(--mood-accent-rgb, 212,149,106), 0.10);
    transform-origin: left;
    transform: scaleX(var(--erosion-progress, 1));
    opacity: calc(
      (0.3 + 0.7 * var(--erosion-progress, 1)) *
      clamp(0, var(--erosion-progress, 1) / 0.05, 1)
    );
    mask-image: linear-gradient(to right, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);
    transition: transform 120ms ease-out, opacity 120ms ease-out;
    pointer-events: none;
  }

  /* ── Responsive ── */

  @media (max-width: 640px) {
    .site-nav { padding: 0 1rem; gap: 0.75rem; }
    .nav-link { font-size: 0.68rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .presence-dot { animation: none; opacity: 0.6; }
    .presence-indicator { transition: none; }
    .erosion-bar { transition: none; }
  }
</style>
