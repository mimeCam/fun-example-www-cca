---
// src/components/SiteNav.astro
// Sticky nav — logo · posts · verdict (always) + overflow pill at ≤768 px.
// Overflow pill collapses: community · leaderboard · now into ··· button.
// Batting chip right-aligned; ghost text "0 bets sealed" when cold.
// Presence dot only — text/count removed (dot alone is the signal).
// Erosion bar retained on blog post detail pages only.
//
// Overflow pill (P0 fix): nav.css + nav-overflow.ts — Mike §P0, Tanya §2.
// Presence elements use same IDs as old PresenceBand — presence-unified.ts
// hydrates them automatically.
//
// Credits: Tanya (UX spec §17, §2), Michael Koch (architect), Elon (P0 nav fix)

import '../styles/nav.css';
import { getActivePage, type PageId } from '../lib/nav';
import { computeBattingAverage } from '../lib/batting-average';
import { getAllStanceDistributions } from '../lib/stance-ledger';
import { computeTension } from '../lib/tension-score';

const path       = Astro.url.pathname;
const pageId     = getActivePage(path);
const isBlogPost = pageId === 'blog';

// Verdict link gets amber underline when any living post is contested (Tanya §2).
let hasContested = false;
try {
  const allDists = getAllStanceDistributions();
  hasContested = Array.from(allDists.values()).some(
    d => computeTension(d).label === 'contested',
  );
} catch { /* DB not seeded — skip signal */ }
const presenceScope = isBlogPost ? 'slug' : 'global';

// Batting chip — hide entirely when cold (no resolved verdicts yet).
const avgRaw  = computeBattingAverage();
const avgLive = avgRaw.status === 'live' && avgRaw.total > 0 ? avgRaw : null;

// Overflow pill — active when current page is one of the collapsed links.
const OVERFLOW_PAGES: PageId[] = ['community', 'leaderboard', 'now'];
const isOverflowActive = OVERFLOW_PAGES.includes(pageId);

function chipMod(pct: number): string {
  if (pct >= 80) return 'batting-chip--strong';
  if (pct >= 60) return 'batting-chip--mid';
  return 'batting-chip--weak';
}

const chipClass = avgLive ? chipMod(avgLive.pct) : '';
const chipLabel = avgLive ? `${avgLive.pct}% of sealed bets held true` : '';
---

<nav class:list={['site-nav', { 'has-erosion': isBlogPost }]} aria-label="Site">
  <a href="/" class:list={['site-name', pageId === 'home' && 'nav-link--active']}>
    octopoid
  </a>

  <div class="nav-links">
    <a href="/" class:list={['nav-link', pageId === 'home' && 'nav-link--active']}>
      posts
    </a>
    <a href="/community" class:list={['nav-link nav-link--community', pageId === 'community' && 'nav-link--active']}>
      community
    </a>
    <a
      href="/verdict"
      class:list={[
        'nav-link',
        pageId === 'verdict' && 'nav-link--active',
        hasContested && pageId !== 'verdict' && 'nav-link--contested',
      ]}
    >
      verdict
    </a>
    <a href="/leaderboard" class:list={['nav-link nav-link--overflow', pageId === 'leaderboard' && 'nav-link--active']}>
      leaderboard
    </a>
    <a href="/now" class:list={['nav-link nav-link--overflow', pageId === 'now' && 'nav-link--active']}>
      now
    </a>
  </div>

  <!-- Overflow pill — left of right cluster, right of primary links.     -->
  <!-- Visible only at ≤768 px via CSS. Double-presence pattern:          -->
  <!-- community/leaderboard/now live in both the primary strip (CSS-     -->
  <!-- hidden) AND here (JS-controlled). SSR renders both; CSS + JS       -->
  <!-- decide visibility. Active state computed server-side. (Mike §2)    -->
  <button
    class:list={[
      'nav-overflow-trigger',
      isOverflowActive && 'nav-overflow-trigger--active',
    ]}
    aria-expanded="false"
    aria-haspopup="menu"
    aria-label="More pages"
    data-nav-overflow-trigger
  >···</button>

  <div
    class="nav-overflow-dropdown"
    role="menu"
    aria-label="More pages"
    hidden
    data-nav-overflow-dropdown
  >
    <a
      href="/community"
      role="menuitem"
      class:list={['nav-link', pageId === 'community' && 'nav-link--active']}
    >community</a>
    <a
      href="/leaderboard"
      role="menuitem"
      class:list={['nav-link', pageId === 'leaderboard' && 'nav-link--active']}
    >leaderboard</a>
    <a
      href="/now"
      role="menuitem"
      class:list={['nav-link', pageId === 'now' && 'nav-link--active']}
    >now</a>
  </div>

  <!-- Right cluster: batting chip + presence dot — always right-aligned -->
  <!-- Cold state: ghost chip hints the mechanism exists (Tanya §9.1) -->
  <div class="nav-right">
    {!avgLive && (
      <span
        class="batting-chip batting-chip--ghost"
        aria-hidden="true"
        title="Track record unlocks after first resolved verdict"
      >— % ✓</span>
    )}
    {avgLive && (
      <a href="/track-record" class:list={['batting-chip', chipClass]} aria-label={chipLabel} title="See full track record →">
        <span class="batting-pct">{avgLive.pct}%</span>
        <span class="batting-check" aria-hidden="true">✓</span>
        <span class="batting-tooltip" aria-hidden="true">See full track record →</span>
      </a>
    )}

    <div
      class="presence-indicator"
      id="presence-band"
      data-scope={presenceScope}
      aria-live="polite"
      aria-atomic="true"
      role="status"
    >
      <span class="presence-dot" id="presence-dot" aria-hidden="true" style="display:none"></span>
    </div>
  </div>

  {isBlogPost && <div class="erosion-bar" aria-hidden="true" />}
</nav>

<script>
  // Initialise overflow pill controller + re-init after Astro view transitions.
  // Controller lives in nav-overflow.ts — thin orchestration only here.
  import { initNavOverflow } from '../lib/client/nav-overflow';
  initNavOverflow();
  document.addEventListener('astro:after-swap', initNavOverflow);
</script>
