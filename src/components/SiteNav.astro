---
// src/components/SiteNav.astro
// Minimal sticky nav — three words + mood dot in frosted glass.
// Highlights current page via Astro.url pathname matching.
// Zero JS. Consistent with glassmorphism language.

import { getActivePage, type PageId } from '../lib/nav';
import MoodDot from './MoodDot.astro';
import moodConfig from '../data/mood.config.json';

const path = Astro.url.pathname;
const pageId = getActivePage(path);
const isBlogPost = pageId === 'blog';

// Nav: 3-link max — field (homepage) + graveyard + now.
// "field" reinforces the living-landscape metaphor.
// Constellations accessible via link at bottom of homepage / post detail.
const links: { label: string; href: string; id: PageId }[] = [
  { label: 'field',     href: '/',          id: 'home'      },
  { label: 'graveyard', href: '/graveyard', id: 'graveyard' },
  { label: 'now',       href: '/now',       id: 'now'       },
];
---

<nav class:list={['site-nav', { 'has-erosion': isBlogPost }]} aria-label="Site navigation">
  <MoodDot mood={moodConfig.current_mood} />
  {links.map(l => (
    <a href={l.href}
       class:list={['nav-link', { active: pageId === l.id }]}
       aria-current={pageId === l.id ? 'page' : undefined}>
      {l.label}
    </a>
  ))}
  {isBlogPost && <div class="erosion-bar" aria-hidden="true" />}
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    justify-content: center;
    gap: 2rem;
    height: 48px;
    align-items: center;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(var(--mood-accent-rgb, 0,0,0), 0.08);
  }

  .nav-link {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    text-decoration: none;
    color: inherit;
    opacity: 0.55;
    transition: opacity 120ms ease;
  }

  .nav-link:hover { opacity: 0.85; }

  .nav-link.active {
    opacity: 1;
    border-bottom: 1px solid var(--mood-accent, currentColor);
  }

  /* Erosion bar — replaces border-bottom on blog posts */
  .site-nav.has-erosion {
    border-bottom: none;
    position: relative;
  }

  .erosion-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 0 0 2px 2px;
    /* Mood-tinted gradient — bar mirrors the ambient palette */
    background: linear-gradient(
      90deg,
      var(--mood-from, rgba(var(--mood-accent-rgb, 0,0,0), 0.18)),
      var(--mood-to,   rgba(var(--mood-accent-rgb, 0,0,0), 0.18))
    );
    box-shadow: 0 1px 6px rgba(var(--mood-accent-rgb, 0,0,0), 0.10);
    transform-origin: left;
    transform: scaleX(var(--erosion-progress, 1));
    /* Quiet exhale: fade smoothly to 0 in the final 5% */
    --ep: var(--erosion-progress, 1);
    opacity: calc(
      (0.3 + 0.7 * var(--ep)) *
      clamp(0, var(--ep) / 0.05, 1)
    );
    mask-image: linear-gradient(to right, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);
    transition: transform 120ms ease-out, opacity 120ms ease-out;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .erosion-bar { transition: none; }
  }
</style>
