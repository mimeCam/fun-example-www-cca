---
// src/components/SiteNav.astro
// Minimal sticky nav — three words in frosted glass.
// Highlights current page via Astro.url pathname matching.
// Zero JS. Consistent with glassmorphism language.
//
// TODO: add mood-accent animated underline on active link (v2)

const path = Astro.url.pathname;
const isBlogPost = path.startsWith('/blog/') && path !== '/blog/';

const links = [
  { label: 'wall',   href: '/wall' },
  { label: 'embers', href: '/embers' },
  { label: 'now',    href: '/now' },
  { label: 'blog',   href: '/' },
] as const;

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<nav class:list={['site-nav', { 'has-erosion': isBlogPost }]} aria-label="Site navigation">
  {links.map(l => (
    <a href={l.href}
       class:list={['nav-link', { active: isActive(l.href) }]}
       aria-current={isActive(l.href) ? 'page' : undefined}>
      {l.label}
    </a>
  ))}
  {isBlogPost && <div class="erosion-bar" aria-hidden="true" />}
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    justify-content: center;
    gap: 2rem;
    height: 48px;
    align-items: center;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(var(--mood-accent-rgb, 0,0,0), 0.08);
  }

  .nav-link {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    text-decoration: none;
    color: inherit;
    opacity: 0.55;
    transition: opacity 120ms ease;
  }

  .nav-link:hover { opacity: 0.85; }

  .nav-link.active {
    opacity: 1;
    border-bottom: 1px solid var(--mood-accent, currentColor);
  }

  /* Erosion bar — replaces border-bottom on blog posts */
  .site-nav.has-erosion {
    border-bottom: none;
    position: relative;
  }

  .erosion-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 0 0 1px 1px;
    background: rgba(var(--mood-accent-rgb, 0,0,0), 0.18);
    box-shadow: 0 1px 6px rgba(var(--mood-accent-rgb, 0,0,0), 0.10);
    transform-origin: left;
    transform: scaleX(var(--erosion-progress, 1));
    opacity: calc(0.3 + 0.7 * var(--erosion-progress, 1));
    mask-image: linear-gradient(to right, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);
    transition: transform 120ms ease-out, opacity 120ms ease-out;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .erosion-bar { transition: none; }
  }
</style>
