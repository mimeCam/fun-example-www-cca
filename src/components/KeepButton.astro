---
// src/components/KeepButton.astro
// Redesigned "Keep Alive" revival button — per Tanya §4.1.
// Feels like signing a petition, not clicking a like button.
//
// Props:
//   slug        — post slug for /api/revive
//   count       — current revival count (0 = hide number, >0 = show inline)
//   urgency     — 'critical' triggers pulsing glow ring
//   conviction  — 'still-true' triggers subtle gold ring
//   decayFactor — when provided, enables Pact Ritual (PactPanel + keep-pact.ts)
//   lifespan    — post lifespan in days (used by PactPanel ring)
//
// Client wiring:
//   With decayFactor:    keep-pact.ts wires the button (pact ritual flow)
//   Without decayFactor: inline script below handles feed cards + banner buttons

import PactPanel from './PactPanel.astro';

interface Props {
  slug:         string;
  count?:       number;
  urgency?:     'critical' | 'dying' | 'fading' | 'alive' | string;
  conviction?:  string | null;
  decayFactor?: number;
  lifespan?:    number;
}

const { slug, count = 0, urgency, conviction, decayFactor, lifespan = 365 } = Astro.props;
const isCritical  = urgency === 'critical';
const isStillTrue = conviction === 'still-true';
const hasPact     = decayFactor !== undefined;
---

<div class:list={['pact-wrapper', hasPact && 'pact-wrapper--active']}>
  <button
    class:list={['keep-btn', isCritical && 'keep-btn--critical', isStillTrue && 'keep-btn--still-true']}
    data-keep-slug={slug}
    data-pact-trigger={hasPact ? '' : undefined}
    data-keep-state="idle"
    aria-label="Keep this post alive"
    aria-pressed="false"
    role="button"
    type="button"
  >
    <!-- Arc ring: JS sets strokeDashoffset; CSS state selectors colour it.
         Circumference = 2π × r=20 ≈ 125.664. rotate(-90deg) so fill starts at top. -->
    <svg class="keep-arc" viewBox="0 0 48 48" aria-hidden="true" focusable="false">
      <circle class="keep-arc-track"  cx="24" cy="24" r="20" />
      <circle class="keep-arc-circle" cx="24" cy="24" r="20"
        stroke-dasharray="125.664"
        stroke-dashoffset="125.664"
      />
    </svg>
    <span class="keep-icon">&#9829;</span>
    <span class="keep-label">KEEP</span>
    {count > 0  && <span class="keep-count"> &middot; {count}</span>}
    {count === 0 && <span class="keep-count keep-count--hidden"></span>}
  </button>

  {hasPact && (
    <PactPanel
      slug={slug}
      count={count}
      decayFactor={decayFactor!}
      lifespan={lifespan}
      conviction={conviction}
    />
  )}
</div>

<style>
  /* ── Wrapper — anchors PactPanel absolutely below the button ── */
  .pact-wrapper {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
  }

  .pact-wrapper--active {
    position: relative;   /* PactPanel uses position:absolute + top:100% */
  }

  /* ── Button ─────────────────────────────────────────────────── */
  /* Tanya §3: pill shape, mono font — feels like a command, not a suggestion */
  .keep-btn {
    position: relative;           /* anchor the SVG arc absolutely */
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    min-width: 88px;
    height: 36px;
    padding: 0 1.25rem;
    font-size: var(--text-xs, 0.72rem);
    font-weight: var(--weight-semibold, 600);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-widest, 0.10em);
    color: rgba(var(--mood-accent-rgb, 120,120,120), 0.80);
    background: rgba(var(--mood-accent-rgb, 120,120,120), 0.06);
    border: 1.5px solid rgba(var(--mood-accent-rgb, 120,120,120), 0.25);
    border-radius: var(--radius-pill, 9999px);
    cursor: pointer;
    transition:
      border-color var(--motion-flow-duration) var(--motion-easing-spring),
      background   var(--motion-flow-duration) var(--motion-easing-spring),
      box-shadow   var(--motion-flow-duration) ease,
      transform    var(--motion-flow-duration) var(--motion-easing-spring),
      opacity      var(--duration-slow) ease-out;
  }

  .keep-btn:hover {
    background:   rgba(var(--clock-urgency-color, var(--mood-accent-rgb, 120,120,120)), 0.14);
    border-color: rgba(var(--clock-urgency-color, var(--mood-accent-rgb, 120,120,120)), 0.45);
    box-shadow:   0 0 16px rgba(var(--clock-urgency-color, var(--mood-accent-rgb, 120,120,120)), 0.18);
    transform: scale(1.02);
  }

  /* Phase 1 — Resistance: slight compression, like pressing a real button */
  .keep-btn:active {
    transform: scale(0.96);
    cursor: grabbing;
    background: rgba(var(--mood-accent-rgb, 120,120,120), 0.10);
  }

  /* Pact open — button glows subtly */
  .keep-btn[data-pact-state="open"] {
    border-color: rgba(var(--mood-accent-rgb, 200,160,60), 0.55);
    box-shadow:   0 0 12px rgba(var(--mood-accent-rgb, 200,160,60), 0.20);
  }

  /* Sealing state — brief pulse */
  .keep-btn[data-pact-state="sealing"] {
    animation: pact-seal-pulse 400ms ease forwards;
  }

  @keyframes pact-seal-pulse {
    0%   { box-shadow: 0 0 0   rgba(var(--mood-accent-rgb,200,160,60), 0); }
    50%  { box-shadow: 0 0 20px rgba(var(--mood-accent-rgb,200,160,60), 0.35); }
    100% { box-shadow: 0 0 0   rgba(var(--mood-accent-rgb,200,160,60), 0); }
  }

  /* Kept state — status, not disabled */
  .keep-btn.kept {
    opacity: 0.55;
    cursor: default;
    pointer-events: none;
    background:   rgba(var(--mood-accent-rgb, 120,120,120), 0.08);
    border-color: rgba(var(--mood-accent-rgb, 120,120,120), 0.12);
  }

  /* Critical urgency — pulsing ring */
  .keep-btn--critical {
    border-color: rgba(255, 80, 40, 0.40);
    animation: pulse-ring 2s ease-in-out infinite;
  }

  /* still-true conviction — faint gold ring */
  .keep-btn--still-true { box-shadow: 0 0 8px rgba(200, 160, 60, 0.18); }

  @keyframes pulse-ring {
    0%, 100% { box-shadow: 0 0 0 0   rgba(255, 80, 40, 0.0); }
    50%       { box-shadow: 0 0 0 4px rgba(255, 80, 40, 0.18); }
  }

  .keep-icon  { font-size: 0.85rem; }

  .keep-count {
    font-size: 0.72rem;
    opacity: 0.70;
    transition: opacity 200ms ease;
  }
  .keep-count--hidden { display: none; }

  /* ── Arc ring — SVG positioned over button center ─────────────── */
  .keep-arc {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 56px;
    height: 56px;
    transform: translate(-50%, -50%) rotate(-90deg);  /* 0° = top */
    pointer-events: none;
    opacity: 0;
    transition: opacity 120ms ease;
    overflow: visible;
  }

  /* Arc visible while holding/at-threshold/submitting */
  .keep-btn[data-keep-state="holding"]           .keep-arc,
  .keep-btn[data-keep-state="threshold_reached"] .keep-arc,
  .keep-btn[data-keep-state="submitting"]        .keep-arc { opacity: 1; }

  .keep-arc-track {
    fill: none;
    stroke: rgba(var(--mood-accent-rgb, 120,120,120), 0.12);
    stroke-width: 2;
  }

  .keep-arc-circle {
    fill: none;
    stroke: rgba(var(--mood-accent-rgb, 212,149,106), 0.65);
    stroke-width: 2.5;
    stroke-linecap: round;
    transition: stroke 200ms ease;   /* colour shift at TENSION */
  }

  /* Gold stroke at threshold — "commitment colour" */
  .keep-btn[data-keep-state="threshold_reached"] .keep-arc-circle,
  .keep-btn[data-keep-state="submitting"]        .keep-arc-circle {
    stroke: var(--gold, #F5A623);
  }

  /* ── State: threshold_reached — brief scale overshoot ─────────── */
  .keep-btn[data-keep-state="threshold_reached"] {
    animation: keep-peak-burst 400ms var(--ease-spring, cubic-bezier(0.34,1.56,0.64,1)) forwards;
  }

  @keyframes keep-peak-burst {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.08); }
    100% { transform: scale(1); }
  }

  /* ── State: revived — warm glow then settle ───────────────────── */
  .keep-btn[data-keep-state="revived"] {
    background:    rgba(var(--mood-accent-rgb, 212,149,106), 0.14);
    border-color:  rgba(var(--mood-accent-rgb, 212,149,106), 0.50);
    box-shadow:    0 0 20px rgba(var(--mood-accent-rgb, 212,149,106), 0.22);
    animation: keep-bloom-glow var(--duration-bloom, 1200ms) ease-out forwards;
    opacity: 0.55;
    cursor: default;
    pointer-events: none;
  }

  @keyframes keep-bloom-glow {
    0%   { box-shadow: 0 0 0   rgba(var(--mood-accent-rgb, 212,149,106), 0.35); }
    30%  { box-shadow: 0 0 24px rgba(var(--mood-accent-rgb, 212,149,106), 0.28); }
    100% { box-shadow: 0 0 0   rgba(var(--mood-accent-rgb, 212,149,106), 0); }
  }
</style>

<!-- Orchestrator bootstrap: wires RevivalOrchestrator to all feed-card KeepButtons.
     Single source of truth for hold-to-revive interaction. (Mike Koch arch spec §1)
     Astro bundles this via Vite — imports TypeScript from src/lib/client/. -->
<script>
  import { initOrchestrators } from '../lib/client/revival-orchestrator';
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initOrchestrators);
  } else {
    initOrchestrators();
  }
</script>

<script>
  // Delegated handler for KeepButtons WITHOUT the pact ritual wired.
  // Covers: feed cards, DeathClockBanner — anywhere without decayFactor + RevivalCounter.
  // Skips: buttons with data-pact-trigger (handled by keep-pact.ts)
  //        buttons in .revival-footer (handled by revival-counter.ts)
  (function wireKeepButtons() {
    const BLOOM_MS = 1200; // matches --duration-bloom in motion.css

    function getSessionId(): string | null {
      try { return sessionStorage.getItem('session-token'); } catch { return null; }
    }

    function isOwned(btn: HTMLButtonElement): boolean {
      return !!(btn.dataset.orchestrated || btn.dataset.wired ||
                btn.dataset.pactTrigger !== undefined ||
                btn.classList.contains('kept'));
    }

    function markKept(btn: HTMLButtonElement): void {
      btn.classList.add('kept');
      const label = btn.querySelector('.keep-label');
      if (label) label.textContent = 'KEPT';
      const icon = btn.querySelector('.keep-icon');
      if (icon) icon.textContent = '✓';
    }

    function updateCount(btn: HTMLButtonElement, count: number): void {
      const span = btn.querySelector('.keep-count');
      if (!span) return;
      if (count > 0) { span.textContent = ` · ${count}`; span.classList.remove('keep-count--hidden'); }
      else { span.classList.add('keep-count--hidden'); }
    }

    function rollback(btn: HTMLButtonElement, prevCount: number): void {
      btn.classList.remove('kept');
      const label = btn.querySelector('.keep-label');
      if (label) label.textContent = 'KEEP';
      const icon = btn.querySelector('.keep-icon');
      if (icon) icon.textContent = '♥';
      updateCount(btn, prevCount);
    }

    /** Add .blooming to parent card; returns cleanup fn for rollback. */
    function addBlooming(card: HTMLElement | null): () => void {
      if (!card) return () => {};
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return () => {};
      card.classList.add('blooming');
      const t = setTimeout(() => card.classList.remove('blooming'), BLOOM_MS);
      return () => { clearTimeout(t); card.classList.remove('blooming'); };
    }

    function getPrevCount(btn: HTMLButtonElement): number {
      const span = btn.querySelector('.keep-count');
      return parseInt(span?.textContent?.replace(/\D/g, '') ?? '0', 10) || 0;
    }

    function makeHeaders(): Record<string, string> {
      const h: Record<string, string> = { 'Content-Type': 'application/json' };
      const sid = getSessionId();
      if (sid) h['x-session-id'] = sid;
      return h;
    }

    function submitRevive(slug: string): Promise<{ ok: boolean; count: number }> {
      return fetch('/api/revive', {
        method: 'POST', keepalive: true, headers: makeHeaders(),
        body: JSON.stringify({ slug }),
      }).then(r => {
        if (!r.ok) return Promise.reject(new Error(String(r.status)));
        return r.json() as Promise<{ ok: boolean; count: number }>;
      });
    }

    function handleClick(btn: HTMLButtonElement): void {
      if (isOwned(btn)) return;
      const slug = btn.dataset.keepSlug;
      if (!slug) return;
      const prevCount = getPrevCount(btn);
      markKept(btn);
      updateCount(btn, prevCount + 1);
      // Optimistic bloom — removed on error, kept on success (auto-expires)
      const removeBlooming = addBlooming(btn.closest<HTMLElement>('.decay-card'));
      submitRevive(slug)
        .then((data) => { if (data?.ok) updateCount(btn, data.count); })
        .catch(() => { rollback(btn, prevCount); removeBlooming(); });
    }

    document.addEventListener('click', (e) => {
      const btn = (e.target as Element).closest<HTMLButtonElement>('.keep-btn[data-keep-slug]');
      if (!btn) return;
      if (btn.closest('.revival-footer')) return; // revival-counter.ts owns these
      handleClick(btn);
    });
  })();
</script>
