---
// src/components/ConvictionDemo.astro
// Hardcoded ghost post cycling through all lifecycle states.
// Pure presentational — zero lib imports, zero DB calls, zero props.
//
// Rendered once inside OnboardingOverlay.astro.
// Step visibility uses :global([data-step]) selectors to respond to the
// overlay's data-step attribute — avoids duplicating markup 3×.
// Astro style scoping bypass intentional here (see CSS section below).
//
// Hardcoded values (intentionally frozen — never breaks on lib changes):
//   decay factor : 0.42  (mid-life, amber zone)
//   conviction   : 8/10
//   verdict      : still-true
//   batting avg  : 73%
//
// Credits: Mike Koch (arch spec 2026-04-11), Tanya Donska (design tokens)
---

<div class="demo" aria-hidden="true">

  <!-- ── Step 1: A post decays over time ──────────────────────────── -->
  <div class="demo-step demo-s1">
    <div class="demo-card demo-card--aging">
      <div class="demo-card__meta">
        <span class="demo-tag">essay</span>
        <span class="demo-date">18 days ago</span>
      </div>
      <p class="demo-title">Will AI writing become indistinguishable from human prose by 2027?</p>
      <p class="demo-excerpt">The line is blurring faster than most researchers predicted—</p>
      <div class="demo-decay">
        <div class="demo-decay__bar">
          <div class="demo-decay__fill demo-decay__fill--anim"></div>
        </div>
        <span class="demo-decay__label">58% vitality · fading</span>
      </div>
    </div>
    <p class="demo-caption">This post is aging. Without readers, it will fade completely.</p>
  </div>

  <!-- ── Step 2: Author seals a conviction ────────────────────────── -->
  <div class="demo-step demo-s2">
    <div class="demo-card demo-card--sealed">
      <div class="demo-card__meta">
        <span class="demo-tag">essay</span>
        <div class="demo-seal-badge">
          <span class="demo-seal-icon">◆</span>
          <span class="demo-seal-score">8<span class="demo-seal-denom">/10</span></span>
          <span class="demo-seal-label">conviction sealed</span>
        </div>
      </div>
      <p class="demo-title">Will AI writing become indistinguishable from human prose by 2027?</p>
      <div class="demo-decay">
        <div class="demo-decay__bar">
          <div class="demo-decay__fill demo-decay__fill--fresh"></div>
        </div>
        <span class="demo-decay__label">revival locked in · readers respond</span>
      </div>
    </div>
    <p class="demo-caption">The author bet on this claim at conviction&nbsp;8/10. Now the clock runs until a verdict.</p>
  </div>

  <!-- ── Step 3: Verdict lands → batting average updates ──────────── -->
  <div class="demo-step demo-s3">
    <div class="demo-ba-block">
      <div class="demo-ba-score">
        <span class="demo-ba-pct">73%</span>
        <span class="demo-ba-label">of sealed bets held true</span>
      </div>
      <div class="demo-ba-pills">
        <span class="demo-pill demo-pill--correct">✓ 8 correct</span>
        <span class="demo-pill demo-pill--wrong">✗ 2 wrong</span>
        <span class="demo-pill demo-pill--pending">◌ 1 pending</span>
      </div>
    </div>
    <div class="demo-verdict-strip">
      <span class="demo-verdict-dot demo-verdict-dot--true"></span>
      <span class="demo-verdict-text">AI writing — <strong>still true</strong> · resolved 3 days ago</span>
    </div>
    <p class="demo-caption">Every resolved bet updates the batting average. The record is public and permanent.</p>
  </div>

</div>

<style>
  /* ── Container ──────────────────────────────────────────────── */
  .demo {
    width: 100%;
    max-width: 22rem;
    margin: 0 auto;
  }

  /* Steps hidden by default; overlay's [data-step] reveals the active one.
   * :global() bypasses Astro scoping so the overlay root attribute is matched. */
  .demo-step { display: none; }
  :global([data-step="1"]) .demo-s1 { display: block; }
  :global([data-step="2"]) .demo-s2 { display: block; }
  :global([data-step="3"]) .demo-s3 { display: block; }

  /* ── Ghost post card ────────────────────────────────────────── */
  .demo-card {
    background: var(--surface-raised);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .demo-card--sealed {
    border-color: var(--gold-border);
    box-shadow: var(--shadow-seal-ceremony);
    animation: demo-seal-appear 600ms var(--motion-easing-spring) both;
  }

  @keyframes demo-seal-appear {
    from { opacity: 0; transform: translateY(6px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .demo-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .demo-tag {
    font-size: var(--text-2xs);
    font-family: var(--font-mono);
    color: var(--text-ghost);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    background: var(--surface-raised);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-faint);
  }

  .demo-date {
    font-size: var(--text-2xs);
    color: var(--text-ghost);
    font-family: var(--font-mono);
    margin-left: auto;
  }

  /* ── Conviction seal badge (step 2) ─────────────────────────── */
  .demo-seal-badge {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    background: var(--gold-bg);
    border: 1px solid var(--gold-border);
    border-radius: var(--radius-sm);
    padding: 3px 8px;
    animation: demo-seal-pop 400ms var(--motion-easing-spring) 200ms both;
  }

  @keyframes demo-seal-pop {
    from { opacity: 0; transform: scale(0.7); }
    to   { opacity: 1; transform: scale(1); }
  }

  .demo-seal-icon { font-size: var(--text-xs); color: var(--gold); }

  .demo-seal-score {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    font-weight: var(--weight-semibold);
    color: var(--gold);
    line-height: 1;
  }

  .demo-seal-denom {
    font-size: var(--text-2xs);
    color: var(--gold-dim);
  }

  .demo-seal-label {
    font-size: var(--text-2xs);
    color: var(--gold-dim);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  /* ── Post title + excerpt ───────────────────────────────────── */
  .demo-title {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-primary);
    line-height: var(--leading-snug);
    margin: 0;
  }

  .demo-excerpt {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
    font-style: italic;
  }

  /* ── Decay bar ──────────────────────────────────────────────── */
  .demo-decay {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .demo-decay__bar {
    height: 3px;
    background: var(--border-subtle);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .demo-decay__fill {
    height: 100%;
    border-radius: var(--radius-full);
  }

  /* Aging state: amber, ~58% width, animates from green */
  .demo-decay__fill--anim {
    width: 58%;
    background: oklch(72% 0.16 70);
    animation: demo-decay-drain 2s ease-out both;
  }

  @keyframes demo-decay-drain {
    from { width: 85%; background: oklch(64% 0.19 145); }
    to   { width: 58%; background: oklch(72% 0.16 70);  }
  }

  /* Sealed/fresh: green, full */
  .demo-decay__fill--fresh {
    width: 92%;
    background: oklch(64% 0.19 145);
    animation: demo-decay-revive 600ms var(--motion-easing-spring) 300ms both;
  }

  @keyframes demo-decay-revive {
    from { width: 58%; }
    to   { width: 92%; }
  }

  .demo-decay__label {
    font-size: var(--text-2xs);
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-normal);
  }

  /* ── Batting average block (step 3) ─────────────────────────── */
  .demo-ba-block {
    background: var(--surface-raised);
    border-radius: var(--radius-md);
    border: 1px solid var(--gold-border);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    animation: demo-ba-rise 500ms var(--motion-easing-spring) both;
  }

  @keyframes demo-ba-rise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .demo-ba-score {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .demo-ba-pct {
    font-size: var(--text-3xl);
    font-family: var(--font-mono);
    font-weight: var(--weight-bold);
    color: var(--gold);
    line-height: 1;
    letter-spacing: var(--tracking-display);
    animation: demo-ba-count 800ms ease-out both;
  }

  @keyframes demo-ba-count {
    from { opacity: 0; transform: scale(0.9); }
    to   { opacity: 1; transform: scale(1); }
  }

  .demo-ba-label {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    letter-spacing: var(--tracking-wide);
  }

  /* ── Verdict pills ──────────────────────────────────────────── */
  .demo-ba-pills {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .demo-pill {
    font-size: var(--text-2xs);
    font-family: var(--font-mono);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .demo-pill--correct { background: var(--correct-bg);  color: var(--verdict-true); }
  .demo-pill--wrong   { background: var(--wrong-bg);    color: var(--verdict-wrong); }
  .demo-pill--pending { background: var(--pending-bg);  color: var(--text-tertiary); }

  /* ── Verdict strip ──────────────────────────────────────────── */
  .demo-verdict-strip {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--correct-bg);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(74, 222, 128, 0.15);
    animation: demo-verdict-slide 400ms ease-out 400ms both;
  }

  @keyframes demo-verdict-slide {
    from { opacity: 0; transform: translateX(-6px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .demo-verdict-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  .demo-verdict-dot--true { background: var(--verdict-true); }

  .demo-verdict-text {
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }

  .demo-verdict-text strong {
    color: var(--verdict-true);
    font-weight: var(--weight-medium);
  }

  /* ── Caption ────────────────────────────────────────────────── */
  .demo-caption {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-align: center;
    line-height: var(--leading-normal);
    margin: var(--space-4) 0 0;
  }

  /* ── Reduced motion: collapse all animations ─────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .demo-decay__fill--anim,
    .demo-decay__fill--fresh,
    .demo-card--sealed,
    .demo-seal-badge,
    .demo-ba-block,
    .demo-ba-pct,
    .demo-verdict-strip {
      animation: none;
    }
  }
</style>
