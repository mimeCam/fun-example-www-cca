---
// src/components/ShareSheet.astro
// Contextual share button + toast — progressive enhancement.
// Zero-JS initial render: static link visible, enhanced by shareScript().
// Fades in after 60% scroll via --erosion-progress (set by [slug].astro).
//
// Props: title and description for share payload.
// Respects prefers-reduced-motion, mood-accent theming, and a11y.

interface Props {
  title: string;
  description?: string;
}

const { title, description = '' } = Astro.props;
---

<aside
  class="share-sheet"
  data-share-root
  data-share-title={title}
  data-share-text={description}
  aria-label="Share this post"
>
  <button
    class="share-btn"
    data-share-btn
    type="button"
    aria-label="Share this post"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round"
         stroke-linejoin="round" aria-hidden="true">
      <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8" />
      <polyline points="16 6 12 2 8 6" />
      <line x1="12" y1="2" x2="12" y2="15" />
    </svg>
    <span class="share-label">share</span>
  </button>
  <div class="share-toast" data-share-toast role="status" aria-live="off"></div>
</aside>

<style>
  .share-sheet {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: var(--z-sticky);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity var(--motion-flow-duration) var(--motion-flow-easing),
                transform var(--motion-flow-duration) var(--motion-flow-easing);
    pointer-events: none;
  }

  .share-sheet.share--revealed {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .share-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    border: 1px solid color-mix(in oklch, var(--mood-accent) 20%, transparent);
    border-radius: var(--radius-pill, 999px);
    background: var(--surface-inset-deep);
    backdrop-filter: blur(12px);
    color: var(--mood-accent);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-loose);
    text-transform: lowercase;
    cursor: pointer;
    transition: background var(--motion-snap-duration) var(--motion-snap-easing),
                border-color var(--motion-snap-duration) var(--motion-snap-easing);
  }

  .share-btn:hover {
    background: var(--surface-overlay);
    border-color: color-mix(in oklch, var(--mood-accent) 40%, transparent);
  }

  .share-btn:focus-visible {
    outline: 2px solid var(--mood-accent, currentColor);
    outline-offset: 2px;
  }

  .share-toast {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    right: 0;
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-sm);
    background: var(--surface-overlay);
    backdrop-filter: blur(8px);
    color: var(--text-primary);
    font-size: var(--text-xs);
    white-space: nowrap;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity var(--motion-flow-duration) var(--motion-flow-easing),
                transform var(--motion-flow-duration) var(--motion-flow-easing);
    pointer-events: none;
  }

  .share-toast.share-toast--visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .share-sheet,
    .share-toast { transition: none; }
    .share-sheet.share--revealed { transform: none; }
  }

  @media (max-width: 640px) {
    .share-sheet { bottom: 1rem; right: 1rem; }
    .share-label { display: none; }
  }
</style>
