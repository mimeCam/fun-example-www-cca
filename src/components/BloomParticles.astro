---
// src/components/BloomParticles.astro
// CSS-only particle burst for Revival Bloom — radial polar spawn.
//
// 14 spans at evenly-distributed angles. Each span has:
//   --angle  per-particle rotation (0–360°, equal steps)
//   --delay  stagger offset (0–78ms, 6ms per particle)
//
// Geometry: rotate(--angle) translateY(-48px) — pure polar coordinates.
// No canvas. No JS. No x/y pre-computation.
//
// Triggered by .decay-card.blooming class (added by wireKeepButtons in KeepButton.astro).
// Easing: --motion-spring-easing (CSS linear() from motion.css — Baseline 2024).
//
// Architecture: Mike Koch (polar spawn spec) · UX: Tanya §3 (bloom ceremony)

const PARTICLE_COUNT = 14;
const STAGGER_MS     = 6;   // delay per particle (total spread = 14 × 6 = 84ms)

function buildParticles(count: number) {
  return Array.from({ length: count }, (_, i) => ({
    angle: (i / count) * 360,
    delay: i * STAGGER_MS,
  }));
}

const particles = buildParticles(PARTICLE_COUNT);
---

<div class="bloom-particles" aria-hidden="true">
  {particles.map((p) => (
    <span
      class="bloom-particle"
      style={`--angle:${p.angle}deg;--delay:${p.delay}ms`}
    />
  ))}
</div>
<span class="bloom-ring"  aria-hidden="true" />
<span class="bloom-flash" aria-hidden="true" />

<style>
  /* ── Origin: anchored to the KeepButton corner of .decay-card ───────── */
  .bloom-particles {
    position: absolute;
    bottom: 24px;
    right: 28px;
    width: 0;
    height: 0;
    pointer-events: none;
    z-index: var(--z-shimmer, 2);
  }

  /* ── Particles — invisible at rest ──────────────────────────────────── */
  /* transform-origin: 0 0 rotates around the bloom-particles origin.      */
  /* rotate(--angle) translateY(-48px) is polar → Cartesian via CSS.       */
  .bloom-particle {
    position: absolute;
    top: 0;
    left: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--atm-bloom-color, var(--keep-accent, oklch(80% 0.22 80)));
    opacity: 0;
    transform: rotate(var(--angle, 0deg)) translateY(0) scale(0);
    transform-origin: 0 0;
  }

  /* ── Bloom ring — centered on the particle origin ───────────────────── */
  .bloom-ring {
    position: absolute;
    bottom: 16px;
    right: 20px;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1.5px solid var(--atm-bloom-color, var(--keep-accent, oklch(80% 0.22 80)));
    opacity: 0;
    pointer-events: none;
    z-index: var(--z-shimmer, 2);
    transform: translate(50%, 50%) scale(0.2);
  }

  /* ── Bloom flash — warm exhale over the whole card ──────────────────── */
  .bloom-flash {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--keep-warm, oklch(85% 0.15 80));
    opacity: 0;
    pointer-events: none;
    z-index: var(--z-shimmer, 2);
  }

  /* ══════════════════════════════════════════════════════════════════════
   * BLOOMING STATE — fires when .decay-card receives .blooming class.
   * Added by wireKeepButtons() in KeepButton.astro for feed-card buttons.
   * ══════════════════════════════════════════════════════════════════════ */

  .decay-card.blooming .bloom-particle {
    animation:
      bloom-fly
      var(--motion-ceremony-duration, 600ms)
      var(--motion-spring-easing, cubic-bezier(0.34, 1.56, 0.64, 1))
      var(--delay, 0ms) forwards;
  }

  .decay-card.blooming .bloom-ring {
    animation:
      bloom-ring-expand
      var(--motion-spring-duration, 800ms)
      var(--motion-spring-easing, cubic-bezier(0.34, 1.56, 0.64, 1))
      forwards;
  }

  .decay-card.blooming .bloom-flash {
    animation:
      bloom-warm-breath
      var(--motion-ceremony-duration, 600ms)
      var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1))
      forwards;
  }

  /* ── Keyframes ──────────────────────────────────────────────────────── */

  /* Polar flight: rotate sets direction; translateY sets distance.
     transform-origin: 0 0 keeps the rotation center at the bloom origin. */
  @keyframes bloom-fly {
    0%   { opacity: 0.9; transform: rotate(var(--angle, 0deg)) translateY(0)     scale(1.0); }
    60%  { opacity: 0.6; transform: rotate(var(--angle, 0deg)) translateY(-32px) scale(0.6); }
    100% { opacity: 0;   transform: rotate(var(--angle, 0deg)) translateY(-48px) scale(0);   }
  }

  @keyframes bloom-ring-expand {
    0%   { opacity: 0.75; transform: translate(50%, 50%) scale(0.20); }
    55%  { opacity: 0.40; transform: translate(50%, 50%) scale(1.10); }
    100% { opacity: 0;    transform: translate(50%, 50%) scale(1.80); }
  }

  /* Warm amber card glow — 0.15 opacity peak, slow fade (Tanya §3 Phase 2) */
  @keyframes bloom-warm-breath {
    0%   { opacity: 0.15; }
    100% { opacity: 0;    }
  }

  /* Reduced-motion: hide all bloom elements entirely.
     No flashes, no particles, no rings — counter tick is the only feedback. */
  @media (prefers-reduced-motion: reduce) {
    .bloom-particles,
    .bloom-ring,
    .bloom-flash { display: none; }
  }
</style>
