---
// src/components/SealReceipt.astro
// Phase 4 ceremony artifact — styled as a notary document, not a debug log.
// Static shell only; ConvictionSeal.astro's script populates data slots:
//   [data-receipt-date]     — formatted seal date (e.g. "Apr 12, 2026")
//   [data-receipt-score]    — conviction score (e.g. "8")
//   [data-receipt-hash]     — full content hash (monospace, typewriter reveal)
//   [data-receipt-anchor]   — GitHub Gist anchor URL (hidden if null)
//   [data-receipt-download] — download button wired by JS (Blob URL)
//   [data-receipt-audit]    — href set by JS to /audit/${slug}
//
// Entry: @starting-style slide-up on display:block. CSS-native, no JS toggle.
// Download: JS creates Blob URL from the full API response JSON.
//
// Credits: Mike (§SealReceipt §receipt-as-artifact §JSON-download),
//          Tanya (§5 notary document feel, §6.5 radius contract)
---

<div
  class="seal-receipt sr-root"
  data-receipt
  aria-live="polite"
  aria-label="Conviction sealed — receipt"
  role="region"
>

  <!-- Eyebrow row: status + date -->
  <div class="sr-header">
    <div class="sr-eyebrow-row">
      <span class="sr-check-icon" aria-hidden="true">✦</span>
      <span class="sr-eyebrow">CONVICTION SEALED</span>
    </div>
    <time class="sr-date" data-receipt-date></time>
  </div>

  <!-- Notary rule: top border stripe signals "official document" -->
  <div class="sr-rule" aria-hidden="true"></div>

  <!-- Score row -->
  <div class="sr-score-row">
    <div class="sr-score-label">CONVICTION SCORE</div>
    <div class="sr-score-value">
      <span data-receipt-score class="sr-score-num"></span>
      <span class="sr-score-denom">/10</span>
    </div>
  </div>

  <!-- Content hash: full hash, typewriter reveal -->
  <div class="sr-hash-block">
    <div class="sr-field-label">CONTENT HASH</div>
    <p
      class="seal-receipt-hash sr-hash"
      data-receipt-hash
      aria-label="Content hash"
    ></p>
  </div>

  <!-- RFC 3161 notice -->
  <div class="sr-tst-row">
    <div class="sr-field-label">RFC 3161 TIMESTAMP</div>
    <p class="sr-tst-note" data-receipt-tst-note>Anchoring…</p>
  </div>

  <!-- Anchor row: hidden until anchorUrl is present -->
  <div class="sr-anchor-row" style="display:none" data-receipt-anchor-row>
    <div class="sr-field-label">CONVICTION ANCHOR</div>
    <a
      class="sr-anchor-link"
      data-receipt-anchor
      href="#"
      target="_blank"
      rel="noopener noreferrer"
    >View on GitHub ↗</a>
  </div>

  <!-- Action row: download + audit -->
  <div class="sr-actions">
    <button
      type="button"
      class="sr-download-btn"
      data-receipt-download
      aria-label="Download receipt as JSON"
    >
      <span aria-hidden="true">⬇</span> Download Receipt
    </button>

    <a
      class="sr-audit-link"
      data-receipt-audit
      href="#conviction-audit"
    >View Audit Record ↓</a>
  </div>

</div>

<style>
  /* ── Display control: driven by ancestor [data-seal-phase] ────────────── */
  /* Pattern mirrors NotarizeStamp.astro — display rules live in own scope.   */
  /* seal-ceremony.css cannot target this element (different Astro scope ID). */

  .sr-root { display: none; }

  [data-seal-phase="4"] .sr-root { display: block; }

  /* @starting-style entry: slide up from below on display:block ─────────── */

  .sr-root {
    opacity:   1;
    translate: 0 0;
    transition:
      opacity   var(--motion-duration-base) var(--motion-easing-standard),
      translate var(--motion-duration-base) var(--motion-easing-standard);
  }

  @starting-style {
    .sr-root { opacity: 0; translate: 0 8px; }
  }

  /* Staggered row entrances ───────────────────────────────────────────────── */

  .sr-root > * {
    transition:
      opacity  var(--motion-ceremony-duration) var(--motion-ceremony-easing),
      translate var(--motion-ceremony-duration) var(--motion-ceremony-easing);
    transition-delay: calc(var(--row-index, 0) * 80ms);
  }

  .sr-root > *:nth-child(1) { --row-index: 0; }
  .sr-root > *:nth-child(2) { --row-index: 1; }
  .sr-root > *:nth-child(3) { --row-index: 2; }
  .sr-root > *:nth-child(4) { --row-index: 3; }
  .sr-root > *:nth-child(5) { --row-index: 4; }

  @starting-style {
    .sr-root > * { opacity: 0; translate: 0 6px; }
  }

  /* ── Hash: clip-path typewriter ink-dry reveal ──────────────────────────── */
  /* Reuses same technique as seal-ceremony.css — ghost → gold etching.       */

  .sr-hash {
    clip-path: inset(0 0% 0 0);
    animation:
      reveal-hash   800ms linear               200ms forwards,
      hash-ink-dry    2s   ease-in-out         200ms forwards;
  }

  @keyframes reveal-hash {
    from { clip-path: inset(0 100% 0 0); }
    to   { clip-path: inset(0 0%   0 0); }
  }

  @keyframes hash-ink-dry {
    from { color: var(--text-ghost); }
    to   { color: var(--gold-dim);   }
  }

  /* ── Root: visual shell ──────────────────────────────────────────── */

  .sr-root {
    background:    var(--surface-raised);
    border:        1px solid var(--gold-border);
    border-left:   3px solid rgba(245, 166, 35, 0.55);
    border-radius: var(--radius-md);          /* receipt panel: md per contract */
    padding:       var(--space-5) var(--space-6);
    margin-top:    var(--space-4);
    font-variant-numeric: tabular-nums;       /* fixed-width digits on all numbers */
  }

  /* ── Header ─────────────────────────────────────────────────── */

  .sr-header {
    display:         flex;
    align-items:     flex-start;
    justify-content: space-between;
    gap:             var(--space-3);
    margin-bottom:   var(--space-3);
  }

  .sr-eyebrow-row {
    display:     flex;
    align-items: center;
    gap:         var(--space-2);
  }

  .sr-check-icon {
    color:     var(--verdict-true);
    font-size: var(--text-sm);
    line-height: 1;
  }

  .sr-eyebrow {
    font-size:      var(--text-2xs);
    font-weight:    var(--weight-bold);
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color:          var(--verdict-true);
  }

  .sr-date {
    font-size:   var(--text-xs);
    font-family: var(--font-mono);
    color:       var(--text-ghost);
    letter-spacing: -0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Document rule ──────────────────────────────────────────── */

  .sr-rule {
    height:        1px;
    background:    var(--gold-border);
    margin-bottom: var(--space-4);
  }

  /* ── Score row ──────────────────────────────────────────────── */

  .sr-score-row {
    display:       flex;
    align-items:   baseline;
    gap:           var(--space-4);
    margin-bottom: var(--space-4);
  }

  .sr-field-label {
    font-size:      var(--text-3xs);
    font-weight:    var(--weight-semibold);
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color:          var(--text-ghost);
    min-width: 9ch;        /* align right-column data */
    flex-shrink: 0;
  }

  .sr-score-value {
    display:     flex;
    align-items: baseline;
    gap:         0.1rem;
  }

  .sr-score-num {
    font-family:    var(--font-mono);
    font-size:      var(--text-xl);
    font-weight:    var(--weight-bold);
    color:          var(--gold);
    letter-spacing: -0.02em;
    line-height:    1;
  }

  .sr-score-denom {
    font-family: var(--font-mono);
    font-size:   var(--text-sm);
    color:       var(--gold-dim);
  }

  /* ── Hash block ──────────────────────────────────────────────── */

  .sr-hash-block {
    display:       flex;
    align-items:   baseline;
    gap:           var(--space-4);
    margin-bottom: var(--space-4);
  }

  .sr-hash {
    font-family:    var(--font-mono);
    font-size:      var(--text-2xs);
    color:          var(--text-ghost);
    letter-spacing: -0.02em;
    word-break:     break-all;
    margin:         0;
    flex:           1;
    /* typewriter animation applied via seal-ceremony.css .seal-receipt-hash */
  }

  /* ── RFC 3161 / anchor rows ─────────────────────────────────── */

  .sr-tst-row,
  .sr-anchor-row {
    display:       flex;
    align-items:   baseline;
    gap:           var(--space-4);
    margin-bottom: var(--space-3);
  }

  .sr-tst-note {
    font-size:   var(--text-xs);
    font-family: var(--font-mono);
    color:       var(--text-tertiary);
    margin:      0;
    letter-spacing: -0.02em;
  }

  .sr-anchor-link {
    font-size:   var(--text-xs);
    font-family: var(--font-mono);
    color:       var(--color-interactive);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition:  color var(--motion-snap-duration) var(--motion-snap-easing);
  }

  .sr-anchor-link:hover  { color: var(--color-interactive-hover); }
  .sr-anchor-link:focus-visible {
    outline:        2px solid var(--border-focus);
    outline-offset: 2px;
    border-radius:  2px;
  }

  /* ── Actions row ────────────────────────────────────────────── */

  .sr-actions {
    display:      flex;
    align-items:  center;
    gap:          var(--space-4);
    padding-top:  var(--space-4);
    border-top:   1px solid var(--border-subtle);
    margin-top:   var(--space-2);
    flex-wrap:    wrap;
  }

  .sr-download-btn {
    display:        flex;
    align-items:    center;
    gap:            var(--space-2);
    background:     var(--gold-bg);
    border:         1px solid var(--gold-border);
    border-radius:  var(--radius-md);       /* buttons: md per radius contract */
    color:          var(--gold);
    cursor:         pointer;
    font-size:      var(--text-xs);
    font-weight:    var(--weight-semibold);
    letter-spacing: 0.06em;
    padding:        var(--space-2) var(--space-4);
    transition:
      background    var(--motion-snap-duration) var(--motion-snap-easing),
      border-color  var(--motion-snap-duration) var(--motion-snap-easing);
  }

  .sr-download-btn:hover {
    background:   var(--gold-bg-strong);
    border-color: var(--gold-border-strong);
  }

  .sr-download-btn:focus-visible {
    outline:        2px solid var(--border-focus);
    outline-offset: 2px;
  }

  .sr-audit-link {
    font-size:   var(--text-xs);
    font-family: var(--font-mono);
    color:       var(--color-interactive);
    text-decoration: none;
    letter-spacing: -0.02em;
    margin-left: auto;
    transition:  color var(--motion-snap-duration) var(--motion-snap-easing);
  }

  .sr-audit-link:hover { color: var(--color-interactive-hover); }

  .sr-audit-link:focus-visible {
    outline:        2px solid var(--border-focus);
    outline-offset: 2px;
    border-radius:  2px;
  }

  /* ── Reduced motion ─────────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .sr-root,
    .sr-root > *,
    .sr-download-btn,
    .sr-anchor-link,
    .sr-audit-link       { transition: none; animation: none; }
    .sr-hash             { clip-path: none; color: var(--gold-dim); }
  }
</style>
