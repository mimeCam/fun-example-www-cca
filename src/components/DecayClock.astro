---
// src/components/DecayClock.astro
// Unified countdown — replaces DeathClock + DeadlineClock + DeathClockBanner.
// Three variants, one component, zero duplicated urgency logic.
//
//   variant="ring"   → SVG countdown ring (card footers, post headers)
//   variant="bar"    → horizontal deadline bar (post detail body)
//   variant="banner" → sticky bottom CTA band (endangered post detail pages)
//
// All timing, colors, and pulse speeds reference CSS tokens — no magic values.
// Pulse at "final" tier: only the ring strokes breathe. Numbers stay still.
// Accessible: role="img"/"progressbar", aria-label computed server-side.
//
// Client hydration bridge (variant="ring"):
//   data-computed-at     → ISO timestamp when server rendered (delta origin)
//   data-verdict-modifier → conviction multiplier (0.7–1.4, default 1.0)
//   data-stage           → DecayStage string (decay-clock.css picks up immediately)
//   --live-decay         → initial CSS var set server-side; updated 1Hz by orchestrator
//
// Credits: Mike (arch §Module-2, §DecayClock-rewrite "The Living Decay Clock"),
//          Tanya (UX §2 DecayClock spec, ring drain spec, banner spec)

import '../styles/decay-clock.css';
import type { ClockUrgency, ConvictionVerdict } from '../lib/decay-engine';
import {
  deathClockDayDisplay,
  deathClockUnitDisplay,
  deathClockA11yLabel,
  clockStyleString,
} from '../lib/death-clock';
import { getDeadlineStatus } from '../lib/deadline-enforcer';
import { buildDeadlineDisplay } from '../lib/deadline-clock';
import { HEARTBEAT_FRESH, HEARTBEAT_FADING, HEARTBEAT_CRITICAL } from '../lib/spring-easing';

type DecayVariant = 'ring' | 'bar' | 'banner';

// Tanya §4.3: five stages, two of which hide the clock entirely.
type DecayStage = 'fresh' | 'fading' | 'endangered' | 'ghost' | 'fossil';

interface Props {
  variant?:      DecayVariant;
  /** For variant="ring" / variant="banner" */
  daysRemaining?: number;
  urgency?:       ClockUrgency;
  compact?:       boolean;
  conviction?:    ConvictionVerdict | null;
  /** Decimal 0–1 decay factor. When provided, enables visibility rules + heartbeat. */
  decayFactor?:  number;
  /** ISO timestamp when server computed decayFactor — client reads delta from here. */
  computedAt?:   string;
  /** Conviction multiplier: 0.7 (still-true) / 0.9 (evolved) / 1.0 (base) / 1.4 (wrong). */
  verdictModifier?: number;
  /** For variant="bar" */
  slug?:        string;
  publishDate?: Date;
  deadline?:    Date;
}

const {
  variant         = 'ring',
  daysRemaining   = 0,
  urgency         = 'aging',
  compact         = false,
  conviction      = null,
  decayFactor,
  computedAt      = new Date().toISOString(),
  verdictModifier = 1.0,
  slug,
  publishDate,
  deadline,
} = Astro.props;

// ── Decay stage from factor (Tanya §4.3 visibility thresholds) ────────────────
function toDecayStage(f: number): DecayStage {
  if (f < 0.25) return 'fresh';
  if (f < 0.50) return 'fading';
  if (f < 0.75) return 'endangered';
  if (f < 0.95) return 'ghost';
  return 'fossil';
}

const decayStage = decayFactor !== undefined ? toDecayStage(decayFactor) : null;

// Tanya §4.3: no clock on fresh (post thriving) or fossil (no time left).
const hiddenByStage = variant === 'ring' && (decayStage === 'fresh' || decayStage === 'fossil');

// ── Heartbeat profile from stage ─────────────────────────────────────────────
function heartbeatForStage(stage: DecayStage | null) {
  if (stage === 'ghost')     return HEARTBEAT_CRITICAL;
  if (stage === 'endangered') return HEARTBEAT_CRITICAL;
  if (stage === 'fading')    return HEARTBEAT_FADING;
  return HEARTBEAT_FRESH;
}

const heartbeat = heartbeatForStage(decayStage);

// Fading stage: 30% opacity — ambient, not urgent (Tanya §4.3).
const ringOpacity = decayStage === 'fading' ? 0.30 : 1;

// ── ring/banner helpers ────────────────────────────────────────────────────────
const dayDisplay  = deathClockDayDisplay(daysRemaining, urgency);
const unitDisplay = deathClockUnitDisplay(daysRemaining);

// Richer aria-label when decay factor is available (Tanya §8 a11y checklist).
const a11yLabel = decayFactor !== undefined
  ? `Post is ${Math.round(decayFactor * 100)}% toward expiration — ${deathClockA11yLabel(daysRemaining)}`
  : deathClockA11yLabel(daysRemaining);

// Merge base clock style with heartbeat CSS vars for stage-driven animation.
const baseStyle   = clockStyleString(urgency, daysRemaining, conviction);
const heartbeatStyle = [
  `--heartbeat-duration:${heartbeat.duration}ms`,
  `--heartbeat-easing:${heartbeat.easing}`,
  `--heartbeat-delay:${heartbeat.delay}ms`,
  `--clock-ring-opacity:${ringOpacity}`,
].join(';');
// --live-decay seed: server snapshot drives the arc before JS loads (no FOUC).
const liveDecayInit = decayFactor !== undefined ? `--live-decay:${decayFactor.toFixed(4)}` : '';
const inlineStyle = [baseStyle, heartbeatStyle, liveDecayInit].filter(Boolean).join(';');

// Expose decayFactor as a data attribute so orchestrators can:
// 1. Read it on init, 2. Re-read after live-decay tick updates.
const dataDecayFactor    = decayFactor !== undefined ? decayFactor.toFixed(4) : undefined;
// dataVerdictModifier: only expose when non-default (saves bytes in the HTML)
const dataVerdictModifier = verdictModifier !== 1.0 ? verdictModifier.toFixed(2) : undefined;

// Urgency tier mapping (ring CSS data-attribute drives pulse token)
function urgencyTier(u: ClockUrgency): 'warning' | 'critical' | 'final' {
  if (u === 'dying')     return 'final';
  if (u === 'critical')  return 'critical';
  return 'warning';
}
const tier = urgencyTier(urgency);

// ── bar helpers ────────────────────────────────────────────────────────────────
const deadlineStatus = (variant === 'bar' && slug && publishDate && deadline)
  ? getDeadlineStatus(slug, deadline)
  : null;

const deadlineDisplay = (
  deadlineStatus &&
  deadlineStatus.status !== 'no-deadline' &&
  deadlineStatus.status !== 'auto-resolved' &&
  deadlineStatus.status !== 'expired-unsealed'
) ? buildDeadlineDisplay(publishDate!, deadline!) : null;

// Urgency band → token name mapping (avoids BAND_COLOR magic strings)
function bandTokenName(band: string): string {
  if (band === 'critical' || band === 'overdue') return 'urgency-critical-color';
  if (band === 'warning')  return 'urgency-warning-color';
  return 'text-ghost';
}
const bandToken   = deadlineDisplay ? bandTokenName(deadlineDisplay.urgencyBand) : 'text-ghost';
const isPulsing   = deadlineDisplay && (deadlineDisplay.urgencyBand === 'critical' || deadlineDisplay.urgencyBand === 'overdue');
const deadlineFmt = deadline
  ? deadline.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
  : '';
---

{variant === 'ring' && !hiddenByStage && (
  <div
    class:list={['decay-clock', 'hb-clock-glow', compact && 'decay-clock--compact']}
    data-urgency={urgency}
    data-tier={tier}
    data-stage={decayStage ?? undefined}
    data-decay-stage={decayStage ?? undefined}
    data-days-remaining={daysRemaining}
    data-conviction={conviction ?? undefined}
    data-decay-factor={dataDecayFactor}
    data-computed-at={decayFactor !== undefined ? computedAt : undefined}
    data-verdict-modifier={dataVerdictModifier}
    style={inlineStyle}
    aria-label={a11yLabel}
    title={a11yLabel}
    role="img"
  >
    {/* Ambient glow — sits behind SVG, animated by decay-clock.css */}
    <div class="decay-clock__glow" aria-hidden="true" />
    <svg class="decay-clock__ring-wrap hb-ring-wrap" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
      <circle class="decay-clock__track" cx="32" cy="32" r="28" />
      <circle class="decay-clock__ring hb-ring-stroke hb-ring-opacity" cx="32" cy="32" r="28" />
      {/* Inner pulse ring — heartbeat animation keyed to --pulse-interval */}
      <circle class="decay-clock__pulse-ring" cx="32" cy="32" r="20" />
    </svg>
    <div class="decay-clock__label" aria-hidden="true">
      <span class="decay-clock__days">{dayDisplay}</span>
      <span class="decay-clock__unit">{unitDisplay}</span>
    </div>
  </div>
)}

{variant === 'bar' && deadlineStatus?.status === 'auto-resolved' && (
  <div class="dc-bar dc-bar--resolved">
    <span class="dc-bar__label">verdict sealed</span>
    <time class="dc-bar__date">
      {new Date(deadlineStatus.sealedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
    </time>
  </div>
)}

{variant === 'bar' && deadlineStatus?.status === 'expired-unsealed' && (
  <div class="dc-bar dc-bar--overdue" style="--dc-color: var(--urgency-final-color)">
    <div class="dc-bar__header">
      <span class="dc-bar__icon" aria-hidden="true">◈</span>
      <span class="dc-bar__label dc-bar__label--pulse">OVERDUE — awaiting sweep</span>
      <time class="dc-bar__date" datetime={deadline?.toISOString()}>{deadlineFmt}</time>
    </div>
    <div class="dc-bar__track" role="progressbar" aria-valuenow={100} aria-valuemin={0} aria-valuemax={100}>
      <div class="dc-bar__fill" style="width:100%" />
    </div>
  </div>
)}

{variant === 'bar' && deadlineDisplay && (
  <div
    class:list={['dc-bar', isPulsing && 'dc-bar--pulse']}
    style={`--dc-color: var(--${bandToken})`}
    aria-label={`Resolution deadline: ${deadlineDisplay.label}`}
  >
    <div class="dc-bar__header">
      <span class="dc-bar__icon" aria-hidden="true">◈</span>
      <span class="dc-bar__label">{deadlineDisplay.label}</span>
      <time class="dc-bar__date" datetime={deadline?.toISOString()}>{deadlineFmt}</time>
    </div>
    <div
      class="dc-bar__track"
      role="progressbar"
      aria-valuenow={deadlineDisplay.percentConsumed}
      aria-valuemin={0}
      aria-valuemax={100}
      aria-label={`${deadlineDisplay.percentConsumed}% of deadline window consumed`}
    >
      <div class="dc-bar__fill" style={`width:${deadlineDisplay.percentConsumed}%`} />
    </div>
  </div>
)}

{variant === 'banner' && daysRemaining > 0 && (
  <div class="dc-banner" data-tier={tier} aria-live="polite">
    <span class="dc-banner__ring" aria-hidden="true">
      <!-- Inline micro-ring: 20px, urgency-colored stroke -->
      <svg viewBox="0 0 24 24" class="dc-banner__svg" focusable="false">
        <circle class="dc-banner__track" cx="12" cy="12" r="9" />
        <circle class="dc-banner__arc"   cx="12" cy="12" r="9" />
      </svg>
    </span>
    <span class="dc-banner__text">
      This post has <strong>{daysRemaining}</strong> day{daysRemaining === 1 ? '' : 's'} left
    </span>
    <span class="dc-banner__sep" aria-hidden="true">·</span>
    <span class="dc-banner__cta-label">Hold to keep it alive</span>
    <slot name="keep-button" />
  </div>
)}

<style>
  /* ═══════════════════════════════════════════════
     variant="ring"
  ═══════════════════════════════════════════════ */
  .decay-clock {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 3.75rem;
    height: 3.75rem;
    flex-shrink: 0;
  }
  .decay-clock--compact { width: 2.75rem; height: 2.75rem; }

  .decay-clock__ring-wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .decay-clock__track {
    fill: none;
    stroke: var(--border-light);
    stroke-width: 3;
  }
  .decay-clock__ring {
    fill: none;
    /* decay-clock.css sets stroke: var(--decay-ring-color) for staged color.
       Fallback hsl() applies when data-stage is absent (no decay data passed). */
    stroke: var(--decay-ring-color, hsl(var(--clock-urgency-hue, 220) 65% 60%));
    stroke-width: 3;
    stroke-linecap: round;
    /* decay-clock.css overrides dasharray/dashoffset for --live-decay arc.
       Fallback below applies when the new CSS is absent (edge case). */
    stroke-dasharray: 175.93;
    stroke-dashoffset: calc(175.93 * var(--live-decay, 0));
    transform-origin: 32px 32px;
    transform: rotate(-90deg);
    transition: stroke-dashoffset 1000ms ease;
    filter: drop-shadow(0 0 4px var(--clock-conviction-tint, transparent));
  }
  /* Ring opacity: driven by --hb-opacity from HeartbeatOrchestrator (0.45→1.0).
     Falls back to --clock-ring-opacity for pre-JS frames (FOUC guard).
     Note: hb-ring-opacity class on the circle applies the CSS var.           */

  /* Heartbeat: stage-driven keyframe for pre-orchestrator first frame.
     Once JS fires, the orchestrator drives opacity/scale/color via CSS vars.
     ghost/endangered = erratic slow; fading = hesitant; urgency tiers = fast. */
  .decay-clock[data-decay-stage] .decay-clock__ring:not(.hb-ring-opacity) {
    animation: dc-ring-pulse
      var(--heartbeat-duration, var(--motion-heartbeat-fresh-duration))
      var(--heartbeat-easing,   var(--motion-heartbeat-fresh-easing))
      var(--heartbeat-delay,    0ms) infinite;
  }

  /* Urgency-tier overrides: final/critical pulse faster than heartbeat rhythm */
  .decay-clock[data-tier="final"] .decay-clock__ring:not(.hb-ring-opacity) {
    animation: dc-ring-pulse var(--urgency-pulse-speed-final, 0.4s) ease-in-out infinite;
  }
  .decay-clock[data-tier="critical"] .decay-clock__ring:not(.hb-ring-opacity) {
    animation: dc-ring-pulse var(--urgency-pulse-speed-critical, 1s) ease-in-out infinite;
  }

  /* Fallback keyframe still used before JS fires — plain opacity fade. */
  @keyframes dc-ring-pulse {
    0%, 100% { opacity: 1;    }
    50%       { opacity: 0.45; }
  }

  .decay-clock__label {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.05rem;
    line-height: 1;
    pointer-events: none;
  }
  .decay-clock__days {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    font-family: var(--font-mono);
    color: var(--decay-ring-color, oklch(72% 0.08 220));
    line-height: 1;
  }
  .decay-clock__unit {
    font-size: var(--text-3xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    opacity: 0.55;
    color: var(--decay-ring-color, oklch(65% 0.05 220));
  }
  .decay-clock--compact .decay-clock__days { font-size: var(--text-xs);  }
  .decay-clock--compact .decay-clock__unit { font-size: var(--text-3xs); }

  /* ═══════════════════════════════════════════════
     variant="bar"
  ═══════════════════════════════════════════════ */
  .dc-bar {
    margin: 1.25rem 0;
    padding: 0.65rem 0.9rem;
    border: 1px solid color-mix(in oklch, var(--dc-color, var(--border-medium)) 30%, transparent);
    border-radius: var(--radius-sm);
    background: var(--surface-raised);
    font-size: var(--text-sm);
  }
  .dc-bar--resolved {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0.55;
    --dc-color: var(--border-medium);
  }
  .dc-bar__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.55rem;
  }
  .dc-bar__icon { font-size: 0.85em; color: var(--dc-color); }
  .dc-bar__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--dc-color, var(--text-tertiary));
    font-weight: var(--weight-semibold);
  }
  .dc-bar__label--pulse {
    animation: dc-label-pulse var(--urgency-pulse-speed-critical, 1.6s) ease-in-out infinite;
  }
  .dc-bar__date {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    color: var(--text-ghost);
    letter-spacing: 0.02em;
  }
  .dc-bar__track {
    height: 3px;
    background: var(--border-subtle);
    border-radius: var(--radius-full);
    overflow: hidden;
  }
  .dc-bar__fill {
    height: 100%;
    background: var(--dc-color, var(--text-ghost));
    border-radius: var(--radius-full);
    transition: width 300ms ease;
  }
  @keyframes dc-label-pulse {
    0%, 100% { opacity: 1;    }
    50%       { opacity: 0.45; }
  }

  /* ═══════════════════════════════════════════════
     variant="banner"
  ═══════════════════════════════════════════════ */
  .dc-banner {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0 var(--space-4);
    height: 40px;
    width: 100%;
    background: var(--surface-overlay);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-top: 1px solid var(--border-subtle);
    position: sticky;
    bottom: 0;
    z-index: var(--z-sticky);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    /* Slide-up entrance when page loads and post is endangered */
    animation: dc-banner-enter 300ms ease-out both;
  }
  @keyframes dc-banner-enter {
    from { transform: translateY(40px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .dc-banner__svg {
    width: 1.2rem;
    height: 1.2rem;
    flex-shrink: 0;
  }
  .dc-banner__track {
    fill: none;
    stroke: var(--border-medium);
    stroke-width: 2;
  }
  .dc-banner__arc {
    fill: none;
    stroke: var(--urgency-critical-color);
    stroke-width: 2;
    stroke-linecap: round;
    transform-origin: 12px 12px;
    transform: rotate(-90deg);
  }
  .dc-banner[data-tier="final"] .dc-banner__arc {
    stroke: var(--urgency-final-color);
    animation: dc-ring-pulse var(--urgency-pulse-speed-final, 0.4s) ease-in-out infinite;
  }

  .dc-banner__text { flex: 1; }
  .dc-banner__text strong { color: var(--text-primary); }
  .dc-banner__sep  { color: var(--text-ghost); }
  .dc-banner__cta-label { color: var(--text-tertiary); font-size: var(--text-2xs); }

  @media (prefers-reduced-motion: reduce) {
    .decay-clock__ring,
    .dc-banner__arc,
    .dc-label-pulse,
    .dc-banner { animation: none; }
  }
</style>

{/* Init orchestrators when the ring variant is present and has decay data.
     heartbeat-orchestrator: global BPM waveform physics (scale/opacity/color on :root).
     decay-heartbeat-orchestrator: per-clock decay delta + stage transitions.
     Both use frame-scheduler — one RAF to rule them all.                     */}
{variant === 'ring' && !hiddenByStage && decayFactor !== undefined && (
  <script>
    import { initHeartbeatOrchestrator } from '../lib/client/heartbeat-orchestrator';
    import { initDecayHeartbeat } from '../lib/client/decay-heartbeat-orchestrator';
    document.addEventListener('DOMContentLoaded', () => {
      initHeartbeatOrchestrator();
      initDecayHeartbeat();
    }, { once: true });
  </script>
)}
