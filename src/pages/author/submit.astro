---
// src/pages/author/submit.astro
// 301 redirect to /community/submit — the canonical URL (Tanya §9).
// Preserves existing links: anyone bookmarking /author/submit still arrives at the form.
// Credits: Michael Koch (arch spec §6.2 canonical URL inversion)
export const prerender = false;
return Astro.redirect('/community/submit', 301);
---
