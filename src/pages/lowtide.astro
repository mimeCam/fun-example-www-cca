---
// src/pages/lowtide.astro
// Low Tide — surfaces aged content on a 72-hour tidal rhythm.
// Old entries glow brighter here: decay inverted into bioluminescence.
// Reuses mood/decay CSS vars. Zero new ambient layers.

import BaseLayout from '../layouts/BaseLayout.astro';
import { resolveMood } from '../lib/mood';
import { decay as computeDecay } from '../lib/temporal';
import {
  tidalPhase, tidalState, tidalLabel,
  activeDotCount, fossilCandidates, surfacedIntensity,
  type TideCandidate,
} from '../lib/lowtide';
import rawWall from '../data/wall.json';
import rawEmbers from '../data/embers.json';

const now = new Date();
const phase = tidalPhase(now);
const state = tidalState(phase);
const label = tidalLabel(state);
const dots  = activeDotCount(phase);

const allEntries: TideCandidate[] = [
  ...rawWall.map(w => ({ ...w, source: 'wall' as const })),
  ...rawEmbers.map(e => ({ ...e, source: 'ember' as const })),
];
const candidates = fossilCandidates(allEntries, now);
---

<BaseLayout title="Low Tide — Surfaced Fossils">
  <main class="lowtide-page">
    <header class="lt-header">
      <h1 class="lt-heading">low tide</h1>
      <p class="lt-label">{label}</p>
      <div class="lt-dots" aria-label={`Tidal phase: ${dots} of 12`}>
        {Array.from({ length: 12 }, (_, i) => (
          <span class:list={['lt-dot', { active: i < dots }]} />
        ))}
      </div>
    </header>

    <section class="lt-fossils">
      {candidates.map(c => {
        const d = computeDecay(c.posted, 30, now);
        const intensity = surfacedIntensity(d, phase);
        const mood = resolveMood(c.mood);
        return (
          <article
            class="lt-fossil"
            style={`--surfaced: ${intensity.toFixed(4)}; --entry-accent-rgb: ${mood.accent_rgb};`}
          >
            <p class="lt-fossil-text">{c.text}</p>
            <footer class="lt-fossil-meta">
              <span class="lt-fossil-source">{c.source}</span>
              <span class="lt-fossil-mood">{mood.label}</span>
            </footer>
          </article>
        );
      })}
    </section>

    {candidates.length === 0 && (
      <p class="lt-empty">No fossils yet. The seafloor is bare — come back when the site has aged.</p>
    )}

    <footer class="lt-seafloor">
      The tide reveals what time has buried. It returns.
    </footer>
  </main>
</BaseLayout>

<style>
  .lowtide-page {
    max-width: 540px;
    margin: 0 auto;
    padding: 3rem 2rem 4rem;
  }

  /* --- Header --- */
  .lt-header { margin-bottom: 2.5rem; text-align: center; }
  .lt-heading {
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    opacity: 0.85;
    margin: 0 0 0.4rem;
  }
  .lt-label {
    font-size: 0.78rem;
    opacity: 0.5;
    margin: 0 0 1rem;
    font-style: italic;
  }

  /* --- Phase dots --- */
  .lt-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
  }
  .lt-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    transition: background 400ms ease, box-shadow 400ms ease;
  }
  .lt-dot.active {
    background: var(--mood-accent, #9CA3AF);
    box-shadow: 0 0 6px rgba(var(--mood-accent-rgb, 156,163,175), 0.4);
    animation: dot-pulse 4s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 0.7; }
    50%      { opacity: 1.0; }
  }

  /* --- Fossil cards --- */
  .lt-fossils {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .lt-fossil {
    padding: calc(0.75rem + 0.5rem * var(--surfaced));
    border-radius: calc(2px + 14px * var(--surfaced));
    border: 1px solid rgba(var(--entry-accent-rgb, 156,163,175), calc(0.04 + 0.21 * var(--surfaced)));
    background: rgba(var(--entry-accent-rgb, 156,163,175), calc(0.02 + 0.06 * var(--surfaced)));
    opacity: calc(0.35 + 0.6 * var(--surfaced));
    box-shadow:
      0 0 12px rgba(var(--entry-accent-rgb, 156,163,175), calc(0.15 * var(--surfaced))),
      0 4px 24px rgba(var(--entry-accent-rgb, 156,163,175), calc(0.10 * var(--surfaced))),
      0 8px 48px rgba(var(--entry-accent-rgb, 156,163,175), calc(0.06 * var(--surfaced)));
    transition: opacity 600ms ease, box-shadow 600ms ease;
  }

  .lt-fossil-text {
    font-size: 0.85rem;
    line-height: 1.55;
    margin: 0 0 0.5rem;
  }
  .lt-fossil-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.68rem;
    opacity: 0.4;
  }
  .lt-fossil-source { text-transform: lowercase; }
  .lt-fossil-mood   { font-style: italic; }

  /* --- Seafloor footer --- */
  .lt-seafloor {
    margin-top: 3rem;
    text-align: center;
    font-size: 0.72rem;
    opacity: 0.3;
    font-style: italic;
  }

  /* --- Empty state --- */
  .lt-empty {
    text-align: center;
    font-size: 0.8rem;
    opacity: 0.4;
    margin: 3rem 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .lt-dot.active { animation: none; }
  }
</style>
