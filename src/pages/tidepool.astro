---
// src/pages/tidepool.astro
// Full tidepool page — curated links that decay from foreign to native.
// Fresh links glow teal; old links blend into the site's mood palette.
//
// TODO: OG meta tags for sharing (title, description, image)
// TODO: TidepoolPreview widget for homepage (2-3 latest entries)

import BaseLayout from '../layouts/BaseLayout.astro';
import TidepoolEntry from '../components/TidepoolEntry.astro';
import { sortedTidepoolLinks } from '../lib/tidepool';
import rawLinks from '../data/tidepool.json';

const entries = sortedTidepoolLinks(rawLinks);
---

<BaseLayout title="Tidepool — Curated Links">
  <main class="tidepool-page">
    <header class="tp-header">
      <h1 class="tp-heading">tidepool</h1>
      <p class="tp-tagline">Things that washed ashore. Fresh links glow foreign; old ones settle in.</p>
    </header>
    <section class="tp-list">
      {entries.map(entry => <TidepoolEntry entry={entry} />)}
    </section>
  </main>
</BaseLayout>

<style>
  .tidepool-page {
    max-width: 40rem;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }
  .tp-header { margin-bottom: 2rem; }
  .tp-heading {
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    opacity: 0.85;
    margin: 0 0 0.4rem;
  }
  .tp-tagline {
    font-size: 0.75rem;
    opacity: 0.45;
    margin: 0;
    font-style: italic;
  }
  .tp-list {
    display: flex;
    flex-direction: column;
  }
</style>
