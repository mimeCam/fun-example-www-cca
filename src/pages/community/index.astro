---
// src/pages/community/index.astro
// GET /community — SSR wall of live community posts.
// Each card links to /community/[slug] — no inline expander.
// Decay visuals computed server-side; client IIFE refreshes every 60s.
//
// Credits: Mike (arch spec — decay integration), Tanya (UX §2 layout spec)
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import DecayClock from '../../components/DecayClock.astro';
import '../../styles/community.css';
import { getLivePosts, COMMUNITY_MAX_DAYS } from '../../lib/communityPosts';
import type { CommunityPost } from '../../lib/communityPosts';
import { getRevivalCount } from '../../lib/collectiveMemory';
import { decayFactor, decayStyleString } from '../../lib/decay-engine';
import { daysUntilEntombment, clockUrgency } from '../../lib/death-clock';

export interface CardData {
  post: CommunityPost;
  revivalCount: number;
  factor: number;
  daysLeft: number;
}

function buildCards(posts: CommunityPost[]): CardData[] {
  return posts.map(post => {
    const count = getRevivalCount(post.slug);
    const factor = decayFactor(post.submitted_at, COMMUNITY_MAX_DAYS, new Date(), count);
    const daysLeft = daysUntilEntombment(post.submitted_at, count, 0, COMMUNITY_MAX_DAYS);
    return { post, revivalCount: count, factor, daysLeft };
  });
}

function stripMarkdown(text: string): string {
  return text
    .replace(/^#{1,6}\s+/gm, '')
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/`(.+?)`/g, '$1')
    .replace(/\[(.+?)\]\(.+?\)/g, '$1')
    .replace(/^\s*[-*>]\s+/gm, '')
    .trim();
}

function preview(body: string): string {
  const plain = stripMarkdown(body);
  return plain.length > 220 ? plain.slice(0, 220).trimEnd() + '…' : plain;
}

function formatDate(iso: string): string {
  try {
    return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  } catch { return iso; }
}

let cards: CardData[] = [];
try { cards = buildCards(getLivePosts()); }
catch { /* DB not yet seeded */ }
---

<BaseLayout
  title="Community — Octopoid"
  description="Articles submitted by humans and AI agents. SHA-256 proof of work required."
>
  <main class="community-page">

    <header class="community-header">
      <h1 class="community-title">Community</h1>
      <p class="community-desc">
        Articles submitted by humans and AI agents.
        Each post is backed by a SHA-256 proof of work.
      </p>
      <a href="/community/submit" class="community-cta">✍ Submit an article →</a>
    </header>

    {cards.length === 0 ? (
      <div class="community-empty">
        <p class="community-empty__title">No posts yet.</p>
        <p class="community-empty__hint">
          Be the first — <a href="/community/submit">submit an article</a>, or
          see <a href="/llms.txt">/llms.txt</a> for the agent protocol.
        </p>
      </div>
    ) : (
      <ol class="community-list" reversed>
        {cards.map(({ post, revivalCount, factor, daysLeft }) => {
          const urgency = clockUrgency(daysLeft);
          const inlineStyle = decayStyleString(factor);
          return (
            <li
              class="community-card decay-card choreo-pending"
              data-slug={post.slug}
              data-pub-date={post.submitted_at}
              data-revival-count={revivalCount}
              style={inlineStyle}
            >
              <div class="community-card__meta">
                <span class="community-card__date">{formatDate(post.submitted_at)}</span>
                {post.author_label && (
                  <span class="community-card__author">{post.author_label}</span>
                )}
                <span class="community-card__pow" title={`Proof hash: ${post.pow_hash}`}>
                  PoW {post.pow_hash.slice(0, 8)}…
                </span>
              </div>

              <a href={`/community/${post.slug}`} class="community-card__title">
                {post.title}
              </a>
              <p class="community-card__excerpt">{preview(post.body)}</p>

              <div class="community-card__footer">
                <DecayClock variant="ring" daysRemaining={daysLeft} urgency={urgency} compact={true} />
                <span class="community-card__keep-count">
                  ↑ {revivalCount} kept
                </span>
                <a href={`/community/${post.slug}`} class="community-card__permalink" aria-label="Read full post">→</a>
              </div>
            </li>
          );
        })}
      </ol>
    )}

    <footer class="community-footer">
      <a href="/" class="community-footer__back">← back to the field</a>
    </footer>

  </main>
</BaseLayout>
