---
// src/pages/blog/[slug].astro
// Blog detail page — "The Sealed Bet" (Tanya §9).
// Above-fold: ConvictionHero (score + clock/grace state).
// Below fold: post content, KeepButton (single CTA), GhostEchoes, AuditTrail.
//
// ConvictionHero replaces ConvictionDeclaration above fold (Mike §Modules).
// ConvictionDeclaration stays in codebase — still used by ConvictionAuditTrail context.
// ConvictionPanel merged into ConvictionHero's wager display — removed from below fold.
// ReadingPulse removed (Tanya §16 — zero reader value).
//
// DONE: reading progress "erosion bar" — see SiteNav.astro + inline script below

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostBadge from '../../components/PostBadge.astro';
import PostNav from '../../components/PostNav.astro';
import ConvictionHero from '../../components/ConvictionHero.astro';
import ConvictionAuditTrail from '../../components/ConvictionAuditTrail.astro';
import GhostEchoes from '../../components/GhostEchoes.astro';
import RevivalMoment from '../../components/RevivalMoment.astro';
import KeepButton from '../../components/KeepButton.astro';
import StanceDrawer from '../../components/StanceDrawer.astro';
import DeadlineClock from '../../components/DeadlineClock.astro';
// TensionBadge is now rendered inside ConvictionHero (embedded in status row).
import { allPostDisplayData, extractMeta } from '../../lib/postMeta';
import { getPostNav } from '../../lib/postNav';
import { getReadingTime } from '../../lib/readingTime';
import { formatPubDate } from '../../lib/dates';
import { getRevivalCount, getReadingSeconds } from '../../lib/collectiveMemory';
import { daysUntilEntombment, clockUrgency, CLOCK_MAX_DAYS } from '../../lib/death-clock';
import { decayFactor, dominantConviction } from '../../lib/decay-engine';
import { getGraceState } from '../../lib/cold-start';
import { getStanceDistribution } from '../../lib/stance-ledger';
import { computeTension } from '../../lib/tension-score';
import { getSealEntry } from '../../lib/conviction-ledger';
import { canonicalUrl } from '../../config/seo.config';
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildConvictionState,
  serializeJsonLd,
} from '../../lib/json-ld';

export async function getStaticPaths() {
  const posts  = await getCollection('blog');
  const sorted = allPostDisplayData(posts);
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post, nav: getPostNav(post.slug, sorted) },
  }));
}

const { post, nav } = Astro.props;
const { Content }   = await post.render();
const readingTime   = getReadingTime(post.body);
const pubDate       = formatPubDate(post.data.pubDate);
const pubDateISO    = post.data.pubDate.toISOString();
const lifespan      = post.data.lifespan ?? 365;

const convictions      = post.data.convictions ?? [];
const convictionVerdicts = convictions.map((c: { verdict: string }) => c.verdict as Parameters<typeof dominantConviction>[0][number]);
const dominantVerdict  = dominantConviction(convictionVerdicts);

// Collective memory — safe reads (DB may not be seeded in fresh deploys)
const revivalCount   = safeRead(() => getRevivalCount(post.slug));
const readingSeconds = safeRead(() => getReadingSeconds(post.slug));

// Decay + clock state
const postDecay      = decayFactor(pubDateISO, lifespan, new Date(), revivalCount, readingSeconds, dominantVerdict);
const daysRemaining  = daysUntilEntombment(pubDateISO, revivalCount, readingSeconds, CLOCK_MAX_DAYS);
const postUrgency    = clockUrgency(daysRemaining);

// Grace state — discriminated union drives ConvictionHero's clock section
const graceState     = safeRead(() => getGraceState(post.slug, pubDateISO, postDecay, daysRemaining));

function safeRead<T>(fn: () => T, fallback?: T): T {
  try { return fn(); } catch { return fallback as T; }
}

// safeRead for graceState needs a typed fallback
const safeGraceState = graceState ?? { warming: false, decayFactor: postDecay, daysRemaining };

// Tension score — computed from accumulated stances for this post
const stanceDist    = safeRead(() => getStanceDistribution(post.slug));
const tensionResult = stanceDist ? computeTension(stanceDist) : null;

// JSON-LD: conviction + decay are already computed above — free rider, no new DB queries.
const sealEntry       = safeRead(() => getSealEntry(post.slug));
const postMeta        = extractMeta(post);
const convictionState = buildConvictionState(
  sealEntry?.conviction_score ?? null,
  dominantVerdict,
  sealEntry?.timestamp ?? null,
);
const decayState  = { lifecycle: postDecay >= 0.95 ? 'DEAD' as const : postDecay >= 0.8 ? 'ENDANGERED' as const : 'LIVING' as const, daysRemaining, decayFactor: postDecay };
const jsonLd      = [
  serializeJsonLd(buildArticleSchema(postMeta, convictionState, decayState)),
  serializeJsonLd(buildBreadcrumbSchema([
    { name: 'Home', url: canonicalUrl('/') },
    { name: post.data.title, url: postMeta.url },
  ])),
];
---

<BaseLayout title={post.data.title} description={post.data.description} type="article" publishedAt={pubDateISO} ogSlug={post.slug} jsonLd={jsonLd}>
  <main class="post-detail">
    <nav class="post-nav-row" aria-label="Post navigation">
      <a href="/" class="back-link">← back to field</a>
      <a href="#conviction-audit" class="audit-link" aria-label="View conviction audit trail">
        [audit ↓]
      </a>
      <a href={`/audit/${post.slug}`} class="audit-link audit-link--receipt" aria-label="View conviction receipt">
        [receipt ↗]
      </a>
    </nav>

    <header class="post-header">
      {post.data.coverImage
        ? <div class="post-cover-wrap"><img src={post.data.coverImage} alt="" class="post-cover-img" aria-hidden="true" loading="eager" decoding="async" /></div>
        : <div class="post-cover-gradient" aria-hidden="true" />
      }
      <time datetime={pubDateISO}>{pubDate}</time>
      <h1>{post.data.title}</h1>
      <PostBadge readingTime={readingTime} badge={post.data.badge} />
    </header>

    <!-- ConvictionHero: above-fold sealed wager. The first impression.
         tensionResult flows in so TensionBadge renders inside the status row
         (Mike §Key Design Decisions #2 — visual unification). -->
    <ConvictionHero
      slug={post.slug}
      graceState={safeGraceState}
      revivalCount={revivalCount}
      conviction={dominantVerdict}
      tensionResult={tensionResult}
    />

    <!-- DeadlineClock: renders only when author has set a resolution_deadline.
         Maps to DeadlineStatus discriminated union — no booleans, no nullable flags.
         Auto-seal via POST /api/deadline-sweep (Mike §deadline-enforcer). -->
    {post.data.resolution_deadline && (
      <DeadlineClock
        slug={post.slug}
        publishDate={post.data.pubDate}
        deadline={post.data.resolution_deadline}
      />
    )}

    <RevivalMoment slug={post.slug} pubDate={post.data.pubDate}>
      <article class="post-body">
        <Content />
      </article>
    </RevivalMoment>

    <!-- Single CTA: end-of-article is the natural moment to act -->
    <div class="revival-footer">
      <KeepButton
        slug={post.slug}
        count={revivalCount}
        urgency={postUrgency}
        conviction={dominantVerdict}
        decayFactor={postDecay}
        lifespan={lifespan}
      />
    </div>

    <!-- Sparkline: only when revival history exists -->
    <GhostEchoes slug={post.slug} />

    <!-- Audit receipt link: quiet pointer to /audit/[slug] (Mike's spec §Integration) -->
    <div class="audit-receipt-nudge" id="conviction-audit">
      <a href={`/audit/${post.slug}`} class="audit-receipt-link">
        View conviction receipt →
      </a>
    </div>

    <!-- Audit trail: collapsed by default, for power readers -->
    <ConvictionAuditTrail slug={post.slug} />

  </main>

  <PostNav nav={nav} />

  <!-- StanceDrawer: slides up 800ms after revival to capture reader stance (Mike's arch spec) -->
  <StanceDrawer slug={post.slug} />

  <!-- Erosion bar: scroll-driven progress as a CSS custom property -->
  <script>
    (function erosionScroll() {
      const bar = document.querySelector('.erosion-bar');
      if (!bar) return;
      let ticking = false;
      function update() {
        const scrollMax = document.documentElement.scrollHeight - window.innerHeight;
        const progress  = scrollMax > 0 ? 1 - Math.min(window.scrollY / scrollMax, 1) : 1;
        document.documentElement.style.setProperty('--erosion-progress', String(progress));
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { requestAnimationFrame(update); ticking = true; }
      }, { passive: true });
      update();
    })();
  </script>
</BaseLayout>

<style>
  .post-detail {
    max-width: 40rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  /* Nav row — back + audit link (Tanya §9: quiet nav, not prominent) */
  .post-nav-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .back-link,
  .audit-link {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 180ms ease;
  }

  .back-link:hover,
  .audit-link:hover { color: rgba(255, 255, 255, 0.7); }

  .audit-link { margin-left: auto; }
  .audit-link--receipt { margin-left: 0; }

  /* Quiet "View conviction receipt" pointer above the audit trail */
  .audit-receipt-nudge {
    margin: 1.5rem 0 0.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .audit-receipt-link {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.25);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 150ms ease;
  }

  .audit-receipt-link:hover { color: rgba(255, 255, 255, 0.55); }

  /* Post header: cover → date → title → badge (Tanya §9 — above-fold layout) */
  .post-header { margin-bottom: 2rem; }

  /* Cover image: full-bleed hero with decay filters — same physics as DecayCard */
  .post-cover-wrap {
    width: calc(100% + 3rem);          /* bleed past the 1.5rem padding on each side */
    margin-left: -1.5rem;
    margin-bottom: 1.75rem;
    aspect-ratio: 16 / 6;
    overflow: hidden;
    border-radius: 12px 12px 0 0;
  }

  .post-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Fallback gradient: mood-tinted band when no image provided */
  .post-cover-gradient {
    width: calc(100% + 3rem);
    margin-left: -1.5rem;
    margin-bottom: 1.75rem;
    aspect-ratio: 16 / 6;
    background: linear-gradient(
      180deg,
      rgba(var(--mood-accent-rgb, 120,120,120), 0.12) 0%,
      transparent 100%
    );
    border-radius: 12px 12px 0 0;
  }

  .post-header time {
    display: block;
    font-size: 0.8rem;
    opacity: 0.5;
    margin-bottom: 0.5rem;
    letter-spacing: 0.04em;
  }

  .post-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
    color: var(--mood-accent, inherit);
  }

  /* Article body */
  .post-body {
    font-size: 1.1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.88);
  }

  .post-body :global(p)  { margin-bottom: 1.4em; }

  .post-body :global(a) {
    color: var(--mood-accent, currentColor);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2.5em 0 0.75em;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.94);
  }

  .post-body :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 2em 0 0.5em;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.90);
  }

  .post-body :global(blockquote) {
    border-left: 2px solid rgba(var(--mood-accent-rgb, 120,120,120), 0.25);
    padding: 0.25em 1em;
    margin: 1.5em 0;
    color: rgba(255, 255, 255, 0.7);
    font-style: italic;
  }

  .post-body :global(pre) {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 1em 1.25em;
    margin: 1.5em 0;
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .post-body :global(code) {
    font-size: 0.88em;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .post-body :global(pre code) { background: none; padding: 0; }

  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius, 12px);
    margin: 1.5em 0;
  }

  /* Revival footer: centered single CTA (Tanya §9 — one primary action) */
  .revival-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 3rem 0 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
</style>
