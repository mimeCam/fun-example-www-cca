---
// src/pages/blog/[slug].astro
// Blog detail page — renders a single post with mood atmosphere.
// Uses Astro's getStaticPaths for SSG; zero client JS.
//
// DONE: reading progress "erosion bar" — see SiteNav.astro + inline script below
// DONE: share button (native Web Share API with clipboard fallback) — see ShareSheet.astro
// DONE: prev/next post navigation at bottom — see PostNav.astro + postNav.ts

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostBadge from '../../components/PostBadge.astro';
import Echo from '../../components/Echo.astro';
import PostNav from '../../components/PostNav.astro';
import { allPostDisplayData } from '../../lib/postMeta';
import { getPostNav } from '../../lib/postNav';
import { getReadingTime } from '../../lib/readingTime';
import { formatPubDate } from '../../lib/dates';
import { variantScript } from '../../lib/variants';
import { shareScript } from '../../lib/share';
import ShareSheet from '../../components/ShareSheet.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sorted = allPostDisplayData(posts);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post, nav: getPostNav(post.slug, sorted) },
  }));
}

const { post, nav } = Astro.props;
const { Content } = await post.render();
const readingTime = getReadingTime(post.body);
const pubDate = formatPubDate(post.data.pubDate);

const echo = post.data.echo;
const echoTitle = await resolveEchoTitle(echo?.from);
const hasVariants = post.data.variants === true;
const articleMood = post.data.mood;
const vScript = hasVariants ? variantScript() : '';
const sScript = shareScript();

async function resolveEchoTitle(slug?: string) {
  if (!slug) return undefined;
  const posts = await getCollection('blog');
  const match = posts.find(p => p.slug === slug);
  if (!match) console.warn(`[Echo] slug "${slug}" not found`);
  return match?.data.title;
}
---

<BaseLayout title={post.data.title} description={post.data.description} type="article" publishedAt={post.data.pubDate.toISOString()} articleMood={articleMood}>
  <main class="post-detail">
    <header class="post-header">
      <time datetime={post.data.pubDate.toISOString()}>{pubDate}</time>
      <h1>{post.data.title}</h1>
      <PostBadge readingTime={readingTime} badge={post.data.badge} />
    </header>

    <article
      class="post-body"
      data-pub-date={hasVariants ? post.data.pubDate.toISOString() : undefined}
    >
      <Content />
    </article>

    {hasVariants && <script set:html={vScript} />}

    <Echo text={echo?.text} fromSlug={echo?.from} fromTitle={echoTitle} />
  </main>

  <ShareSheet title={post.data.title} description={post.data.description} />
  <PostNav nav={nav} />
  <script set:html={sScript} />

  <!-- Erosion Bar: scroll-driven progress as a CSS custom property -->
  <script>
    (function erosionScroll() {
      const bar = document.querySelector('.erosion-bar');
      if (!bar) return;

      let ticking = false;

      function update() {
        const scrollTop = window.scrollY;
        const scrollMax = document.documentElement.scrollHeight - window.innerHeight;
        const progress = scrollMax > 0 ? 1 - Math.min(scrollTop / scrollMax, 1) : 1;
        document.documentElement.style.setProperty('--erosion-progress', String(progress));
        ticking = false;
      }

      window.addEventListener('scroll', function onScroll() {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      }, { passive: true });

      update();
    })();
  </script>
</BaseLayout>

<style>
  .post-detail {
    max-width: 40rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }
  .post-header {
    margin-bottom: 2.5rem;
  }
  .post-header time {
    display: block;
    font-size: 0.8rem;
    opacity: 0.5;
    margin-bottom: 0.5rem;
    letter-spacing: 0.04em;
  }
  .post-header h1 {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    color: var(--mood-accent, inherit);
  }
  .post-body {
    font-size: 1.1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.88);
  }
  /* TODO: add prose styling for h2/h3, blockquotes, code blocks, images */
  .post-body :global(p) {
    margin-bottom: 1.4em;
  }
  .post-body :global(a) {
    color: var(--mood-accent, currentColor);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  /* Variant blocks: hidden by default, revealed by inline script */
  .post-body :global(.variant) {
    display: none;
    opacity: 0;
    transition: opacity 0.6s ease-in;
  }
  .post-body :global(.variant[data-active="true"]) {
    display: block;
    opacity: 1;
  }
</style>
