---
// src/pages/blog/[slug].astro
// Blog detail page — "The Sealed Bet" (Tanya §9).
// Above-fold: cover → title → author → article content (Tanya §1, Mike §Module1).
// Below fold: ConvictionRecord, DecayClock, SealCeremony (post-read context).
// FloatingKeepButton: persistent gold circle, appears at 15% scroll depth.
//
// DONE: reading progress "erosion bar" — see SiteNav.astro + inline script below

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostBadge from '../../components/PostBadge.astro';
import BattingAverageChip from '../../components/BattingAverageChip.astro';
import PostNav from '../../components/PostNav.astro';
import SealCeremony from '../../components/SealCeremony.astro';
import ConvictionRecord from '../../components/ConvictionRecord.astro';
import RevivalMoment from '../../components/RevivalMoment.astro';
import StickyStanceBar from '../../components/StickyStanceBar.astro';
import FloatingKeepButton from '../../components/FloatingKeepButton.astro';
import DecayClock from '../../components/DecayClock.astro';
import PredictionCard from '../../components/PredictionCard.astro';
import { flattenPredictions } from '../../lib/prediction-engine';
// TensionBadge is rendered inside SealCeremony sealed branch (embedded in status row).
import { allPostDisplayData, extractMeta } from '../../lib/postMeta';
import { getPostNav } from '../../lib/postNav';
import { getReadingTime } from '../../lib/readingTime';
import { formatPubDate } from '../../lib/dates';
import { getRevivalCount, getReadingSeconds } from '../../lib/collectiveMemory';
import { daysUntilEntombment, clockUrgency, CLOCK_MAX_DAYS } from '../../lib/death-clock';
import { decayFactor, dominantConviction, stageFromFactor } from '../../lib/decay-engine';
import { getGraceState } from '../../lib/cold-start';
import { getStanceDistribution } from '../../lib/stance-ledger';
import { computeTension } from '../../lib/tension-score';
import { getSealEntry } from '../../lib/conviction-ledger';
import { getVerdictRecord } from '../../lib/verdict-resolver';
import { getTstForSeal } from '../../lib/timestamp-store';
import { getDisputeState } from '../../lib/verdict-dispute';
import { canonicalUrl } from '../../config/seo.config';
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildConvictionState,
  serializeJsonLd,
} from '../../lib/json-ld';

export async function getStaticPaths() {
  const posts  = await getCollection('blog');
  const sorted = allPostDisplayData(posts);
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post, nav: getPostNav(post.slug, sorted) },
  }));
}

const { post, nav } = Astro.props;
const { Content }   = await post.render();
const readingTime   = getReadingTime(post.body);
// Pre-fetch totalPublished once — passed to BattingAverageChip to avoid duplicate getCollection call
const totalPublished = (await getCollection('blog')).length;
const pubDate       = formatPubDate(post.data.pubDate);
const pubDateISO    = post.data.pubDate.toISOString();
const lifespan      = post.data.lifespan ?? 365;

const convictions      = post.data.convictions ?? [];
const convictionVerdicts = convictions.map((c: { verdict: string }) => c.verdict as Parameters<typeof dominantConviction>[0][number]);
const dominantVerdict  = dominantConviction(convictionVerdicts);

// Collective memory — safe reads (DB may not be seeded in fresh deploys)
const revivalCount   = safeRead(() => getRevivalCount(post.slug));
const readingSeconds = safeRead(() => getReadingSeconds(post.slug));

// Decay + clock state
const postDecay      = decayFactor(pubDateISO, lifespan, new Date(), revivalCount, readingSeconds, dominantVerdict);
const daysRemaining  = daysUntilEntombment(pubDateISO, revivalCount, readingSeconds, CLOCK_MAX_DAYS);
const postUrgency    = clockUrgency(daysRemaining);
const decayStage     = stageFromFactor(postDecay);

// Grace state — discriminated union drives SealCeremony's sealed display clock section
const graceState     = safeRead(() => getGraceState(post.slug, pubDateISO, postDecay, daysRemaining));

function safeRead<T>(fn: () => T, fallback?: T): T {
  try { return fn(); } catch { return fallback as T; }
}

// safeRead for graceState needs a typed fallback
const safeGraceState = graceState ?? { warming: false, decayFactor: postDecay, daysRemaining };

// Tension score — computed from accumulated stances for this post
const stanceDist    = safeRead(() => getStanceDistribution(post.slug));
const tensionResult = stanceDist ? computeTension(stanceDist) : null;

// JSON-LD: conviction + decay are already computed above — free rider, no new DB queries.
// Prediction Vault — derive statuses at render time (wall-clock)
const postPredictions = flattenPredictions([post], new Date());

const sealEntry         = safeRead(() => getSealEntry(post.slug));
const tstData           = safeRead(() => getTstForSeal(post.slug));
const disputeState      = safeRead(() => getDisputeState(post.slug), { status: 'no-verdict' as const });
const verdictSealed     = disputeState.status !== 'no-verdict';
const verdictRecord     = safeRead(() => getVerdictRecord(post.slug));
const showVerdictCTA    = !!sealEntry && !verdictRecord;
const postMeta        = extractMeta(post);
const convictionState = buildConvictionState(
  sealEntry?.conviction_score ?? null,
  dominantVerdict,
  sealEntry?.timestamp ?? null,
);
const decayState  = { lifecycle: postDecay >= 0.95 ? 'DEAD' as const : postDecay >= 0.8 ? 'ENDANGERED' as const : 'LIVING' as const, daysRemaining, decayFactor: postDecay };

// Atmosphere — derived from decay factor + dispute state.
// SSR-sets data-atmosphere on <body> for zero-FOUC first paint.
type AtmStage = 'fresh' | 'endangered' | 'entombed';
function postAtmosphere(decay: number): AtmStage {
  if (decay >= 0.95) return 'entombed';
  if (decay >= 0.65) return 'endangered';
  return 'fresh';
}
const atmosphere  = postAtmosphere(postDecay);
const isDisputed  = disputeState.status === 'open' || disputeState.status === 'contested';
const jsonLd      = [
  serializeJsonLd(buildArticleSchema(postMeta, convictionState, decayState)),
  serializeJsonLd(buildBreadcrumbSchema([
    { name: 'Home', url: canonicalUrl('/') },
    { name: post.data.title, url: postMeta.url },
  ])),
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedAt={pubDateISO}
  ogSlug={post.slug}
  jsonLd={jsonLd}
  atmosphere={atmosphere}
  disputed={isDisputed}
>
  <main class="post-detail">
    <!-- Nav row — simplified: back link only (Tanya §1: remove audit link duplication) -->
    <nav class="post-nav-row" aria-label="Post navigation">
      <a href="/" class="back-link">← back to field</a>
    </nav>

    <header class="post-header">
      {post.data.coverImage
        ? <div class="post-cover-wrap"><img src={post.data.coverImage} alt="" class="post-cover-img" aria-hidden="true" loading="eager" decoding="async" /></div>
        : <div class="post-cover-gradient" aria-hidden="true" />
      }
      <time datetime={pubDateISO}>{pubDate}</time>
      <h1>{post.data.title}</h1>
      {/* Author meta row: name + chip — Tanya §5.2: "never hide it; it's the trust connection" */}
      <div class="post-author-row">
        <a href={`/author/${post.data.authorSlug ?? 'host'}`} class="post-author-link">
          {post.data.authorSlug ?? 'host'}
        </a>
        <BattingAverageChip
          authorSlug={post.data.authorSlug ?? 'host'}
          size="inline"
          totalPublished={totalPublished}
        />
      </div>
      <PostBadge readingTime={readingTime} badge={post.data.badge} />
    </header>

    <!-- Article body — MOVED UP: content is king (Tanya §1, Mike §Module1).
         Above-fold now shows: cover → title → author → article begins.
         Readers see content decaying, not UI chrome. -->
    <RevivalMoment slug={post.slug} pubDate={post.data.pubDate}>
      <article class="post-body">
        <Content />
      </article>
    </RevivalMoment>

    <!-- Predictions — post-article aside (Tanya §1: content-adjacent, not content-blocking) -->
    {postPredictions.length > 0 && (
      <aside class="post-predictions" aria-label="Predictions in this post">
        <h2 class="post-predictions__heading">Predictions</h2>
        <ul class="post-predictions__list">
          {postPredictions.map(p => (
            <li><PredictionCard prediction={p} compact /></li>
          ))}
        </ul>
        <a href="/predictions" class="post-predictions__vault-link">
          View all predictions →
        </a>
      </aside>
    )}

    <!-- Conviction Record: single card consolidating all post-accountability evidence.
         Replaces 5 scattered zones: KeepButton, DisputeChallenge, GhostEchoes,
         audit-receipt-nudge + DisputeTally, and ConvictionAuditTrail.
         Mike §ConvictionRecord · Tanya §2 -->
    <ConvictionRecord
      slug={post.slug}
      revivalCount={revivalCount}
      urgency={postUrgency}
      conviction={dominantVerdict}
      decayFactor={postDecay}
      lifespan={lifespan}
      verdictSealed={verdictSealed}
      disputeState={disputeState}
      decayStage={decayStage}
    />

    <!-- DecayClock bar — post-read context, near conviction evidence (Tanya §1).
         Renders only when author has set a resolution_deadline.
         Auto-seal via POST /api/deadline-sweep (Mike §deadline-enforcer). -->
    {post.data.resolution_deadline && (
      <DecayClock
        variant="bar"
        slug={post.slug}
        publishDate={post.data.pubDate}
        deadline={post.data.resolution_deadline}
      />
    )}

    <!-- SealCeremony — MOVED DOWN: post-read context (Tanya §1).
         Readers encounter the conviction seal AFTER reading the content,
         when they have context for what was sealed.
         sealEntry != null → sealed display (zero JS, permanent record).
         sealEntry == null → self-seal ceremony (variant="self", 4-phase flow). -->
    <SealCeremony
      slug={post.slug}
      title={post.data.title}
      authorSlug={post.data.authorSlug ?? 'host'}
      variant="self"
      sealEntry={sealEntry ?? null}
      graceState={safeGraceState}
      revivalCount={revivalCount}
      conviction={dominantVerdict}
      tensionResult={tensionResult}
      tst={tstData}
    />

    {/* Verdict CTA — sealed conviction with no verdict yet (Mike §napkin §10) */}
    {showVerdictCTA && (
      <a href={`/verdict/${post.slug}/`} class="verdict-cta-link">
        Face your verdict &rarr;
      </a>
    )}

  </main>

  <PostNav nav={nav} />

  <!-- StickyStanceBar: fixed bottom bar, surfaces at 50% read depth.
       Shows live stance distribution; lets readers vote inline (desktop + mobile). -->
  <StickyStanceBar
    slug={post.slug}
    dist={stanceDist ?? { agree: 0, torn: 0, disagree: 0, total: 0 }}
  />

  <!-- FloatingKeepButton: fixed gold circle, surfaces at 15% read depth.
       THE one unmissable action — appears above StickyStanceBar.
       Tanya §2A · Mike §Module1: KeepButton promotion. -->
  <FloatingKeepButton
    slug={post.slug}
    count={revivalCount}
    urgency={postUrgency}
    decayStage={decayStage}
  />

  <!-- Erosion bar: scroll-driven progress as a CSS custom property -->
  <script>
    (function erosionScroll() {
      const bar = document.querySelector('.erosion-bar');
      if (!bar) return;
      let ticking = false;
      function update() {
        const scrollMax = document.documentElement.scrollHeight - window.innerHeight;
        const progress  = scrollMax > 0 ? 1 - Math.min(window.scrollY / scrollMax, 1) : 1;
        document.documentElement.style.setProperty('--erosion-progress', String(progress));
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { requestAnimationFrame(update); ticking = true; }
      }, { passive: true });
      update();
    })();
  </script>
</BaseLayout>

<style>
  .post-detail {
    max-width: 40rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  /* Nav row — single back link (Tanya §1: audit links live in ConvictionRecord) */
  .post-nav-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .back-link {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color var(--motion-flow-duration) ease;
  }

  .back-link:hover { color: var(--text-secondary); }

  /* Post header: cover → date → title → badge
     Tighter margin (Tanya §1: header-to-content coupling signals "this flows together") */
  .post-header { margin-bottom: 1.25rem; }

  /* Cover image: full-bleed hero with decay filters — same physics as DecayCard */
  .post-cover-wrap {
    width: calc(100% + 3rem);          /* bleed past the 1.5rem padding on each side */
    margin-left: -1.5rem;
    margin-bottom: 1.75rem;
    aspect-ratio: 16 / 6;
    overflow: hidden;
    border-radius: var(--radius-card) var(--radius-card) 0 0;
  }

  .post-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Fallback gradient: mood-tinted band when no image provided */
  .post-cover-gradient {
    width: calc(100% + 3rem);
    margin-left: -1.5rem;
    margin-bottom: 1.75rem;
    aspect-ratio: 16 / 6;
    background: linear-gradient(
      180deg,
      color-mix(in oklch, var(--mood-accent) 12%, transparent) 0%,
      transparent 100%
    );
    border-radius: var(--radius-card) var(--radius-card) 0 0;
  }

  .post-header time {
    display: block;
    font-size: var(--text-sm);
    opacity: 0.5;
    margin-bottom: 0.5rem;
    letter-spacing: 0.04em;
  }

  .post-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
    color: var(--mood-accent, inherit);
  }

  /* Author meta row — name + batting average chip (Tanya §5.2) */
  .post-author-row {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .post-author-link {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    transition: color var(--motion-snap-duration) var(--motion-snap-easing);
  }

  .post-author-link:hover { color: var(--text-secondary); }

  /* Article body */
  .post-body {
    font-size: var(--text-prose);
    line-height: var(--leading-prose);
    color: var(--text-primary);
  }

  .post-body :global(p)  { margin-bottom: 1.4em; }

  .post-body :global(a) {
    color: var(--mood-accent, currentColor);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-body :global(h2) {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    margin: 2.5em 0 0.75em;
    line-height: 1.3;
    color: var(--text-primary);
  }

  .post-body :global(h3) {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin: 2em 0 0.5em;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .post-body :global(blockquote) {
    border-left: 2px solid color-mix(in oklch, var(--mood-accent) 25%, transparent);
    padding: 0.25em 1em;
    margin: 1.5em 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-body :global(pre) {
    background: var(--surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-input);
    padding: 1em 1.25em;
    margin: 1.5em 0;
    overflow-x: auto;
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .post-body :global(code) {
    font-size: 0.88em;
    background: var(--surface-hover);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-xs);
  }

  .post-body :global(pre code) { background: none; padding: 0; }

  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius, 12px);
    margin: 1.5em 0;
  }

  /* Prediction inline section — between conviction strip and article body */
  .post-predictions {
    margin: 1.5rem 0 2rem;
    padding: 1.25rem;
    background: oklch(11% 0.008 270 / 0.6);
    border-radius: 12px;
    border: 1px solid var(--border-faint);
  }

  .post-predictions__heading {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 0 0 0.85rem;
  }

  .post-predictions__list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .post-predictions__vault-link {
    font-size: var(--text-xs);
    color: var(--text-ghost);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color var(--motion-snap-duration) var(--motion-snap-easing);
  }
  .post-predictions__vault-link:hover { color: var(--text-secondary); }

  /* Verdict CTA — subtle navigation prompt (Mike §napkin §10) */
  .verdict-cta-link {
    display: block;
    text-align: center;
    margin-top: var(--space-6);
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    color: var(--text-dim);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      color var(--motion-duration-fast) ease,
      border-color var(--motion-duration-fast) ease;
  }

  .verdict-cta-link:hover {
    color: var(--gold-dim);
    border-color: var(--gold-border);
  }

</style>
