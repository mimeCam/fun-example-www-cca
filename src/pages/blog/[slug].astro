---
// src/pages/blog/[slug].astro
// Blog detail page — "The Sealed Bet" (Tanya §9).
// Above-fold: ConvictionHero (score + clock/grace state).
// Below fold: post content, KeepButton (single CTA), GhostEchoes, AuditTrail.
//
// ConvictionHero replaces ConvictionDeclaration above fold (Mike §Modules).
// ConvictionDeclaration stays in codebase — still used by ConvictionAuditTrail context.
// ConvictionPanel merged into ConvictionHero's wager display — removed from below fold.
// ReadingPulse removed (Tanya §16 — zero reader value).
//
// DONE: reading progress "erosion bar" — see SiteNav.astro + inline script below

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostBadge from '../../components/PostBadge.astro';
import PostNav from '../../components/PostNav.astro';
import ConvictionHero from '../../components/ConvictionHero.astro';
import ConvictionAuditTrail from '../../components/ConvictionAuditTrail.astro';
import GhostEchoes from '../../components/GhostEchoes.astro';
import RevivalMoment from '../../components/RevivalMoment.astro';
import KeepButton from '../../components/KeepButton.astro';
import StanceDrawer from '../../components/StanceDrawer.astro';
import TensionBadge from '../../components/TensionBadge.astro';
import { allPostDisplayData } from '../../lib/postMeta';
import { getPostNav } from '../../lib/postNav';
import { getReadingTime } from '../../lib/readingTime';
import { formatPubDate } from '../../lib/dates';
import { getRevivalCount, getReadingSeconds } from '../../lib/collectiveMemory';
import { daysUntilEntombment, clockUrgency, CLOCK_MAX_DAYS } from '../../lib/death-clock';
import { decayFactor, dominantConviction } from '../../lib/decay-engine';
import { getGraceState } from '../../lib/cold-start';
import { getStanceDistribution } from '../../lib/stance-ledger';
import { computeTension } from '../../lib/tension-score';

export async function getStaticPaths() {
  const posts  = await getCollection('blog');
  const sorted = allPostDisplayData(posts);
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post, nav: getPostNav(post.slug, sorted) },
  }));
}

const { post, nav } = Astro.props;
const { Content }   = await post.render();
const readingTime   = getReadingTime(post.body);
const pubDate       = formatPubDate(post.data.pubDate);
const pubDateISO    = post.data.pubDate.toISOString();
const lifespan      = post.data.lifespan ?? 365;

const convictions      = post.data.convictions ?? [];
const convictionVerdicts = convictions.map((c: { verdict: string }) => c.verdict as Parameters<typeof dominantConviction>[0][number]);
const dominantVerdict  = dominantConviction(convictionVerdicts);

// Collective memory — safe reads (DB may not be seeded in fresh deploys)
const revivalCount   = safeRead(() => getRevivalCount(post.slug));
const readingSeconds = safeRead(() => getReadingSeconds(post.slug));

// Decay + clock state
const postDecay      = decayFactor(pubDateISO, lifespan, new Date(), revivalCount, readingSeconds, dominantVerdict);
const daysRemaining  = daysUntilEntombment(pubDateISO, revivalCount, readingSeconds, CLOCK_MAX_DAYS);
const postUrgency    = clockUrgency(daysRemaining);

// Grace state — discriminated union drives ConvictionHero's clock section
const graceState     = safeRead(() => getGraceState(post.slug, pubDateISO, postDecay, daysRemaining));

function safeRead<T>(fn: () => T, fallback?: T): T {
  try { return fn(); } catch { return fallback as T; }
}

// safeRead for graceState needs a typed fallback
const safeGraceState = graceState ?? { warming: false, decayFactor: postDecay, daysRemaining };

// Tension score — computed from accumulated stances for this post
const stanceDist    = safeRead(() => getStanceDistribution(post.slug));
const tensionResult = stanceDist ? computeTension(stanceDist) : null;
---

<BaseLayout title={post.data.title} description={post.data.description} type="article" publishedAt={pubDateISO} ogSlug={post.slug}>
  <main class="post-detail">
    <nav class="post-nav-row" aria-label="Post navigation">
      <a href="/" class="back-link">← back to field</a>
      <a href="#conviction-audit" class="audit-link" aria-label="View conviction audit trail">
        [audit ↓]
      </a>
    </nav>

    <header class="post-header">
      <time datetime={pubDateISO}>{pubDate}</time>
      <h1>{post.data.title}</h1>
      <PostBadge readingTime={readingTime} badge={post.data.badge} />
    </header>

    <!-- ConvictionHero: above-fold sealed wager. The first impression. -->
    <ConvictionHero
      slug={post.slug}
      graceState={safeGraceState}
      revivalCount={revivalCount}
      conviction={dominantVerdict}
    />

    <!-- TensionBadge: live stance signal alongside ConvictionHero (Tanya §5.1) -->
    {tensionResult && (
      <div class="tension-row">
        <TensionBadge
          tensionResult={tensionResult}
          revivalCount={revivalCount}
          slug={post.slug}
        />
      </div>
    )}

    <RevivalMoment slug={post.slug} pubDate={post.data.pubDate}>
      <article class="post-body">
        <Content />
      </article>
    </RevivalMoment>

    <!-- Single CTA: end-of-article is the natural moment to act -->
    <div class="revival-footer">
      <KeepButton
        slug={post.slug}
        count={revivalCount}
        urgency={postUrgency}
        conviction={dominantVerdict}
        decayFactor={postDecay}
        lifespan={lifespan}
      />
    </div>

    <!-- Sparkline: only when revival history exists -->
    <GhostEchoes slug={post.slug} />

    <!-- Audit trail: collapsed by default, for power readers -->
    <ConvictionAuditTrail slug={post.slug} />

  </main>

  <PostNav nav={nav} />

  <!-- StanceDrawer: slides up 800ms after revival to capture reader stance (Mike's arch spec) -->
  <StanceDrawer slug={post.slug} />

  <!-- Erosion bar: scroll-driven progress as a CSS custom property -->
  <script>
    (function erosionScroll() {
      const bar = document.querySelector('.erosion-bar');
      if (!bar) return;
      let ticking = false;
      function update() {
        const scrollMax = document.documentElement.scrollHeight - window.innerHeight;
        const progress  = scrollMax > 0 ? 1 - Math.min(window.scrollY / scrollMax, 1) : 1;
        document.documentElement.style.setProperty('--erosion-progress', String(progress));
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { requestAnimationFrame(update); ticking = true; }
      }, { passive: true });
      update();
    })();
  </script>
</BaseLayout>

<style>
  .post-detail {
    max-width: 40rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  /* Nav row — back + audit link (Tanya §9: quiet nav, not prominent) */
  .post-nav-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .back-link,
  .audit-link {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 180ms ease;
  }

  .back-link:hover,
  .audit-link:hover { color: rgba(255, 255, 255, 0.7); }

  .audit-link { margin-left: auto; }

  /* Post header: date → title → badge (Tanya §9 — above-fold layout) */
  .post-header { margin-bottom: 2rem; }

  .post-header time {
    display: block;
    font-size: 0.8rem;
    opacity: 0.5;
    margin-bottom: 0.5rem;
    letter-spacing: 0.04em;
  }

  .post-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
    color: var(--mood-accent, inherit);
  }

  /* Article body */
  .post-body {
    font-size: 1.1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.88);
  }

  .post-body :global(p)  { margin-bottom: 1.4em; }

  .post-body :global(a) {
    color: var(--mood-accent, currentColor);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2.5em 0 0.75em;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.94);
  }

  .post-body :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 2em 0 0.5em;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.90);
  }

  .post-body :global(blockquote) {
    border-left: 2px solid rgba(var(--mood-accent-rgb, 120,120,120), 0.25);
    padding: 0.25em 1em;
    margin: 1.5em 0;
    color: rgba(255, 255, 255, 0.7);
    font-style: italic;
  }

  .post-body :global(pre) {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 1em 1.25em;
    margin: 1.5em 0;
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .post-body :global(code) {
    font-size: 0.88em;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .post-body :global(pre code) { background: none; padding: 0; }

  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius, 12px);
    margin: 1.5em 0;
  }

  /* TensionBadge row — sits just below ConvictionHero (Tanya §5.1) */
  .tension-row {
    margin: 0.5rem 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 1.5rem; /* prevent layout shift when badge absent */
  }

  /* Revival footer: centered single CTA (Tanya §9 — one primary action) */
  .revival-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 3rem 0 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
</style>
