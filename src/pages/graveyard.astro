---
// src/pages/graveyard.astro
// The Graveyard — posts that reached full decay with zero recent revivals.
// Emotional climax of the product. Dark warm charcoal. Stats carved like epitaphs.
// No fog, no bloom, no spectacle — the absence IS the atmosphere.
//
// SSR: reads ?page= query param for pagination.
// graveyard.css imported here only — do not pollute global styles.
//
// Credits: Mike (architecture — pagination, napkin plan),
//          Tanya (UX spec §3 — epitaph stats, 2-col grid, dark charcoal)

export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TombstoneCard from '../components/TombstoneCard.astro';
import GraveyardEmptyState from '../components/GraveyardEmptyState.astro';
import { allPostDisplayData } from '../lib/postMeta';
import { getResurrectionRate, getTotalReadingSecondsEntombed } from '../lib/graveyardStats';
import '../styles/graveyard.css';

const PAGE_SIZE = 20;

const pageParam  = Astro.url.searchParams.get('page');
const currentPage = Math.max(1, parseInt(pageParam ?? '1', 10) || 1);

const posts       = await getCollection('blog');
const all         = allPostDisplayData(posts);
const entombed    = all.filter(p => p.entombed);
const livingCount = all.length - entombed.length;
const totalPages  = Math.max(1, Math.ceil(entombed.length / PAGE_SIZE));
const safePage    = Math.min(currentPage, totalPages);

const offset       = (safePage - 1) * PAGE_SIZE;
const pageEntombed = entombed.slice(offset, offset + PAGE_SIZE);

const resurrectionRate   = getResurrectionRate(all);
const totalReadingSeconds = getTotalReadingSecondsEntombed(all);
const totalReadingMins   = Math.round(totalReadingSeconds / 60);
const broughtBack        = Math.round(resurrectionRate * entombed.length);

const hasPrev = safePage > 1;
const hasNext = safePage < totalPages;
---

<BaseLayout title="Graveyard — Posts Lost to Time">
  <main class="graveyard graveyard-page">

    <!-- Epitaph stats: numbers carved in stone — Tanya §3.2 -->
    {entombed.length > 0 && (
      <header class="graveyard-epitaph" aria-label="Graveyard statistics">

        <div class="epitaph-stat">
          <span class="epitaph-number">{entombed.length}</span>
          <span class="epitaph-label">posts forgotten</span>
        </div>

        {totalReadingMins > 0 && (
          <div class="epitaph-stat">
            <span class="epitaph-number">{totalReadingMins.toLocaleString()}</span>
            <span class="epitaph-label">minutes unread</span>
          </div>
        )}

        {broughtBack > 0 && (
          <div class="epitaph-stat">
            <span class="epitaph-number">{broughtBack}</span>
            <span class="epitaph-label">brought back</span>
          </div>
        )}

      </header>
    )}

    <!-- Empty state: silence is the message — Mike §6 -->
    {entombed.length === 0 && <GraveyardEmptyState />}

    <!-- Tombstone grid — Tanya §3.3 (2-col desktop, 1-col mobile) -->
    {pageEntombed.length > 0 && (
      <section class="tombs" aria-label="Entombed posts">
        {pageEntombed.map(post => <TombstoneCard post={post} />)}
      </section>
    )}

    <!-- Pagination — text only, no chrome — Mike §7 -->
    {totalPages > 1 && (
      <nav class="graveyard-pages" aria-label="Graveyard pagination">
        {hasPrev && (
          <a href={`/graveyard?page=${safePage - 1}`} class="page-link">
            &larr; newer graves
          </a>
        )}
        <span class="page-count">{safePage} / {totalPages}</span>
        {hasNext && (
          <a href={`/graveyard?page=${safePage + 1}`} class="page-link">
            older graves &rarr;
          </a>
        )}
      </nav>
    )}

    <!-- Footer: candlelight ambient + back link — Mike §5 -->
    {entombed.length > 0 && (
      <footer class="graveyard-footer">
        <a href="/" class="back-link">
          ← {livingCount} {livingCount === 1 ? 'post' : 'posts'} still alive
        </a>
      </footer>
    )}

  </main>
</BaseLayout>

<style>
  .graveyard {
    padding: 4rem 1.25rem 6rem;
    max-width: 52rem;
    margin: 0 auto;
  }

  /* ── Epitaph stats: numbers floating on the dark page — Tanya §3.2 */
  .graveyard-epitaph {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    text-align: center;
    margin-bottom: 4rem;
    padding-top: 1.5rem;
  }

  .epitaph-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  /* Large thin numbers — weight 300, like chiselled stone — Tanya §3.2 */
  .epitaph-number {
    font-size: 3.5rem;
    font-weight: 300;
    line-height: 1;
    color: var(--color-grave-text);
    letter-spacing: -0.01em;
  }

  .epitaph-label {
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-grave-ghost);
  }

  .tombs {
    margin-bottom: 2.5rem;
  }

  /* ── Pagination — restrained prose — */
  .graveyard-pages {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin: 1.5rem 0 2.5rem;
  }

  .page-link {
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-grave-ghost);
    text-decoration: none;
    transition: color 200ms ease;
    padding: 10px 0;
  }

  .page-link:hover { color: var(--color-grave-text); }

  .page-count {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: var(--color-grave-ghost);
    opacity: 0.5;
  }

  /* ── Footer: candlelight is in graveyard.css via ::before — */
  .graveyard-footer {
    text-align: center;
    padding-top: 2rem;
  }

  .back-link {
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--color-grave-ghost);
    text-decoration: none;
    transition: color 200ms ease;
    padding: 10px 0;
    display: inline-block;
  }

  .back-link:hover { color: var(--color-grave-text); }
</style>
