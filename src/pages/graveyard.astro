---
// src/pages/graveyard.astro
// The Graveyard — posts that reached full decay with zero recent revivals.
// Visual inverse of the homepage: dark, monochrome, stripped bare.
// No fog overlay, no bloom, no spectacle — the absence IS the atmosphere.
// Resurrection requires deliberate action (click, not hover).
//
// SSR: reads ?page= query param for pagination (P1 fix).
// Mood: locked to GRAVEYARD_MOOD (jazz) — cool, respectful, unhurried (P2 fix).
//
// Credits: Mike (architecture — pagination + entombed_at migration),
//          Tanya (UX spec §4 — Graveyard layout, entombed_at display)

export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TombstoneCard from '../components/TombstoneCard.astro';
import { allPostDisplayData } from '../lib/postMeta';
import { getResurrectionRate, getTotalReadingSecondsEntombed } from '../lib/graveyardStats';

const PAGE_SIZE = 20;

const pageParam = Astro.url.searchParams.get('page');
const currentPage = Math.max(1, parseInt(pageParam ?? '1', 10) || 1);

const posts = await getCollection('blog');
const all = allPostDisplayData(posts);
const entombed = all.filter(p => p.entombed);
const livingCount = all.length - entombed.length;
const totalPages = Math.max(1, Math.ceil(entombed.length / PAGE_SIZE));
const safePage = Math.min(currentPage, totalPages);

const offset = (safePage - 1) * PAGE_SIZE;
const pageEntombed = entombed.slice(offset, offset + PAGE_SIZE);

const resurrectionRate = getResurrectionRate(all);
const totalReadingSeconds = getTotalReadingSecondsEntombed(all);
const totalReadingMins = Math.round(totalReadingSeconds / 60);
const ratePercent = Math.round(resurrectionRate * 100);
const hasPrev = safePage > 1;
const hasNext = safePage < totalPages;
---

<BaseLayout title="Graveyard — Posts Lost to Time">
  <!-- Resurrect handler now in revivalEngineScript (BaseLayout) -->
  <main class="graveyard">
    <header class="graveyard-header">
      <h1 class="graveyard-title">Graveyard</h1>
      <p class="graveyard-subtitle">
        {entombed.length === 0
          ? 'Nothing here yet. All posts are still alive.'
          : `${entombed.length} ${entombed.length === 1 ? 'post' : 'posts'} lost to time.`}
      </p>

      {entombed.length > 0 && (
        <dl class="graveyard-stats">
          <div class="graveyard-stat">
            <dt>posts entombed</dt>
            <dd>{entombed.length}</dd>
          </div>
          {totalReadingMins > 0 && (
            <div class="graveyard-stat">
              <dt>read but forgotten</dt>
              <dd>{totalReadingMins} min</dd>
            </div>
          )}
          {resurrectionRate > 0 && (
            <div class="graveyard-stat">
              <dt>resurrection rate</dt>
              <dd>{ratePercent}%</dd>
            </div>
          )}
        </dl>
      )}
    </header>

    {pageEntombed.length > 0 && (
      <section class="tombs" aria-label="Entombed posts">
        {pageEntombed.map(post => <TombstoneCard post={post} />)}
      </section>
    )}

    {totalPages > 1 && (
      <nav class="graveyard-pages" aria-label="Graveyard pagination">
        {hasPrev && (
          <a href={`/graveyard?page=${safePage - 1}`} class="page-link page-link--prev">
            &larr; newer graves
          </a>
        )}
        <span class="page-count">{safePage} / {totalPages}</span>
        {hasNext && (
          <a href={`/graveyard?page=${safePage + 1}`} class="page-link page-link--next">
            older graves &rarr;
          </a>
        )}
      </nav>
    )}

    {entombed.length > 0 && livingCount > 0 && (
      <footer class="graveyard-footer">
        <a href="/" class="back-link">
          &larr; {livingCount} {livingCount === 1 ? 'post' : 'posts'} still alive
        </a>
      </footer>
    )}

    {entombed.length === 0 && (
      <footer class="graveyard-footer">
        <a href="/" class="back-link">&larr; back to the living</a>
      </footer>
    )}
  </main>
</BaseLayout>

<style>
  .graveyard {
    padding: 3rem 1rem 4rem;
    max-width: 44rem;
    margin: 0 auto;
    min-height: 60vh;
  }

  .graveyard-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .graveyard-title {
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.4;
    margin: 0 0 0.5rem;
  }

  .graveyard-subtitle {
    font-size: 0.78rem;
    opacity: 0.3;
    font-style: italic;
    margin: 0;
  }

  /* Three-figure stats row — quiet data, not a dashboard */
  .graveyard-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin: 1.25rem auto 0;
    max-width: 32rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 0.85rem;
  }

  .graveyard-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
  }

  .graveyard-stat dt {
    text-transform: uppercase;
    opacity: 0.25;
    font-weight: 400;
  }

  .graveyard-stat dd {
    margin: 0;
    font-style: italic;
    opacity: 0.45;
    font-size: 0.9rem;
  }

  .tombs {
    margin-bottom: 2rem;
  }

  /* Pagination — restrained; page numbers are ceremony, not chrome */
  .graveyard-pages {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin: 1.5rem 0 2rem;
  }

  .page-link {
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.35;
    color: inherit;
    text-decoration: none;
    transition: opacity 200ms ease;
  }

  .page-link:hover { opacity: 0.65; }

  .page-count {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    opacity: 0.2;
    text-transform: uppercase;
  }

  .graveyard-footer {
    text-align: center;
    margin-top: 2rem;
  }

  .back-link {
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    opacity: 0.35;
    color: inherit;
    text-decoration: none;
    transition: opacity 200ms ease;
  }

  .back-link:hover { opacity: 0.6; }
</style>
