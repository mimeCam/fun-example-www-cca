---
// src/pages/admin.astro
// Protected conviction seal dashboard — author-only.
// ADMIN_SECRET env var guards access via HTTP-only cookie.
// Lists all posts with seal status; provides form per unsealed post.
//
// Auth flow:
//   GET  /admin — show login form (no cookie) OR dashboard (valid cookie)
//   POST /admin — validate secret → set cookie → redirect to dashboard
//
// Credits: Mike (architecture spec §The One Feature), Tanya (UX §9 seal layout)

export const prerender = false;

import { getCollection } from 'astro:content';
import { createHmac } from 'crypto';
import { getSealEntry } from '../lib/conviction-ledger';
import { getVerdictRecord } from '../lib/collectiveMemory';
import AdminSealForm from '../components/AdminSealForm.astro';
import VerdictResolutionPanel from '../components/VerdictResolutionPanel.astro';

// ---------------------------------------------------------------------------
// Auth helpers
// ---------------------------------------------------------------------------

function adminSecret(): string {
  return process.env.ADMIN_SECRET ?? '';
}

function expectedToken(secret: string): string {
  return createHmac('sha256', secret).update('admin-session').digest('hex');
}

function isAuthed(cookieHeader: string | null): boolean {
  if (!cookieHeader) return false;
  const match = cookieHeader.match(/(?:^|;\s*)admin_token=([^;]+)/);
  return match ? match[1] === expectedToken(adminSecret()) : false;
}

// ---------------------------------------------------------------------------
// Request handling
// ---------------------------------------------------------------------------

const secret = adminSecret();

if (!secret) {
  return new Response('ADMIN_SECRET not configured.', { status: 503 });
}

const cookie = Astro.request.headers.get('Cookie');
let authed = isAuthed(cookie);
let loginError = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const submitted = form.get('secret') as string | null;
  if (submitted && submitted === secret) {
    const token = expectedToken(secret);
    // 1-hour cookie; HTTP-only so client JS can't read it.
    return Astro.redirect('/admin', 302, {
      'Set-Cookie': `admin_token=${token}; Path=/; HttpOnly; SameSite=Lax; Max-Age=3600`,
    });
  }
  loginError = 'Wrong secret. Try again.';
}

// ---------------------------------------------------------------------------
// Dashboard data — only loaded when authed
// ---------------------------------------------------------------------------

type PostStatus = {
  slug: string; title: string; sealed: boolean; score: number | null; sealedAt: string | null;
  verdictSealed: boolean; verdict: string | null; verdictNote: string | null; verdictSealedAt: string | null;
};

async function buildPostStatuses(): Promise<PostStatus[]> {
  const posts = await getCollection('blog');
  return posts.map(p => {
    const entry   = getSealEntry(p.slug);
    const vRecord = entry ? getVerdictRecord(p.slug) : null;
    return {
      slug: p.slug,
      title: p.data.title as string,
      sealed: !!entry,
      score: entry?.conviction_score ?? null,
      sealedAt: entry
        ? new Date(entry.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
        : null,
      verdictSealed: !!vRecord,
      verdict: vRecord?.verdict ?? null,
      verdictNote: vRecord?.note ?? null,
      verdictSealedAt: vRecord
        ? new Date(vRecord.sealedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
        : null,
    };
  });
}

const posts = authed ? await buildPostStatuses() : [];
const sealedCount = posts.filter(p => p.sealed).length;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Conviction Seal</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0c0c0e;
      color: rgba(255, 255, 255, 0.88);
      min-height: 100vh;
      padding: 2rem 1.25rem;
    }

    .admin-wrap { max-width: 42rem; margin: 0 auto; }

    .admin-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 2.5rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      padding-bottom: 1rem;
    }

    .admin-title {
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.35);
    }

    .admin-stat {
      font-size: 0.72rem;
      color: rgba(245, 166, 35, 0.6);
      font-family: ui-monospace, monospace;
    }

    /* Login form */
    .login-form {
      margin-top: 4rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-width: 22rem;
    }

    .login-label {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.4);
      letter-spacing: 0.03em;
    }

    .login-input {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 0.65rem 0.9rem;
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.88);
      outline: none;
      width: 100%;
      transition: border-color 150ms ease;
    }

    .login-input:focus { border-color: rgba(245, 166, 35, 0.4); }

    .login-btn {
      background: rgba(245, 166, 35, 0.12);
      border: 1px solid rgba(245, 166, 35, 0.25);
      border-radius: 8px;
      padding: 0.65rem 1.25rem;
      font-size: 0.85rem;
      color: rgba(245, 166, 35, 0.9);
      cursor: pointer;
      align-self: flex-start;
      transition: background 150ms ease;
    }

    .login-btn:hover { background: rgba(245, 166, 35, 0.2); }

    .login-error {
      font-size: 0.75rem;
      color: rgba(220, 90, 90, 0.8);
    }

    /* Post list */
    .post-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    /* Conviction seal + verdict panel grouped per post */
    .admin-post-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      border-left: 2px solid rgba(255, 255, 255, 0.05);
      padding-left: 0.75rem;
    }
  </style>
</head>
<body>
  <div class="admin-wrap">
    <div class="admin-header">
      <span class="admin-title">Conviction Seal — Admin</span>
      {authed && (
        <span class="admin-stat">
          {sealedCount}/{posts.length} sealed ·{' '}
          {posts.filter(p => p.verdictSealed).length}/{posts.filter(p => p.sealed).length} verdicts
        </span>
      )}
    </div>

    {!authed && (
      <form class="login-form" method="POST">
        <label class="login-label" for="secret">Admin secret</label>
        <input
          id="secret"
          name="secret"
          type="password"
          class="login-input"
          autocomplete="current-password"
          autofocus
        />
        {loginError && <span class="login-error">{loginError}</span>}
        <button type="submit" class="login-btn">Enter</button>
      </form>
    )}

    {authed && (
      <div class="post-list">
        {posts.map(post => (
          <div class="admin-post-group">
            <AdminSealForm
              slug={post.slug}
              title={post.title}
              sealed={post.sealed}
              score={post.score}
              sealedAt={post.sealedAt}
            />
            <VerdictResolutionPanel
              slug={post.slug}
              title={post.title}
              convictionSealed={post.sealed}
              verdictSealed={post.verdictSealed}
              verdict={post.verdict as any}
              verdictNote={post.verdictNote}
              verdictSealedAt={post.verdictSealedAt}
            />
          </div>
        ))}
      </div>
    )}
  </div>
</body>
</html>
