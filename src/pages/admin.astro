---
// src/pages/admin.astro
// Protected conviction seal dashboard — author-only.
// ADMIN_SECRET env var guards access via HTTP-only cookie.
// Lists all posts with seal status; provides form per unsealed post.
//
// Auth flow:
//   GET  /admin — show login form (no cookie) OR dashboard (valid cookie)
//   POST /admin — validate secret → set cookie → redirect to dashboard
//
// Credits: Mike (architecture spec §The One Feature), Tanya (UX §9 seal layout)

export const prerender = false;

import { getCollection } from 'astro:content';
import { createHmac } from 'crypto';
import { getSealEntry, type LedgerEntry } from '../lib/conviction-ledger';
import { getDisputeResolution } from '../lib/verdict-dispute';
import { getVerdictRecord } from '../lib/collectiveMemory';
import { getDeadlineStatus } from '../lib/deadline-enforcer';
import SealCeremony from '../components/SealCeremony.astro';
import VerdictResolutionPanel from '../components/VerdictResolutionPanel.astro';
import type { ConvictionStage } from '../components/TrustBadge.astro';

// ---------------------------------------------------------------------------
// Auth helpers
// ---------------------------------------------------------------------------

function adminSecret(): string {
  return process.env.ADMIN_SECRET ?? '';
}

function expectedToken(secret: string): string {
  return createHmac('sha256', secret).update('admin-session').digest('hex');
}

function isAuthed(cookieHeader: string | null): boolean {
  if (!cookieHeader) return false;
  const match = cookieHeader.match(/(?:^|;\s*)admin_token=([^;]+)/);
  return match ? match[1] === expectedToken(adminSecret()) : false;
}

// ---------------------------------------------------------------------------
// Request handling
// ---------------------------------------------------------------------------

const secret = adminSecret();

if (!secret) {
  return new Response('ADMIN_SECRET not configured.', { status: 503 });
}

const cookie = Astro.request.headers.get('Cookie');
let authed = isAuthed(cookie);
let loginError = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const submitted = form.get('secret') as string | null;
  if (submitted && submitted === secret) {
    const token = expectedToken(secret);
    // 1-hour cookie; HTTP-only so client JS can't read it.
    return Astro.redirect('/admin', 302, {
      'Set-Cookie': `admin_token=${token}; Path=/; HttpOnly; SameSite=Lax; Max-Age=3600`,
    });
  }
  loginError = 'Wrong secret. Try again.';
}

// ---------------------------------------------------------------------------
// Dashboard data — only loaded when authed
// ---------------------------------------------------------------------------

type PostStatus = {
  slug: string; title: string; sealed: boolean; score: number | null; sealedAt: string | null;
  sealEntry: LedgerEntry | null; convictionStage: ConvictionStage;
  verdictSealed: boolean; verdict: string | null; verdictNote: string | null; verdictSealedAt: string | null;
};

type DeadlineRow = {
  slug: string; title: string;
  deadline: Date; daysRemaining: number; status: string;
};

function deriveConvictionStage(entry: LedgerEntry | null, slug: string): ConvictionStage {
  if (!entry) return 'unsealed';
  let resolution = null;
  try { resolution = getDisputeResolution(slug); } catch { /* DB not ready */ }
  if (!resolution) return 'sealed';
  return resolution.state as ConvictionStage;
}

async function buildPostStatuses(): Promise<PostStatus[]> {
  const posts = await getCollection('blog');
  return posts.map(p => {
    const entry   = getSealEntry(p.slug);
    const vRecord = entry ? getVerdictRecord(p.slug) : null;
    return {
      slug: p.slug,
      title: p.data.title as string,
      sealed: !!entry,
      sealEntry: entry ?? null,
      convictionStage: deriveConvictionStage(entry ?? null, p.slug),
      score: entry?.conviction_score ?? null,
      sealedAt: entry
        ? new Date(entry.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
        : null,
      verdictSealed: !!vRecord,
      verdict: vRecord?.verdict ?? null,
      verdictNote: vRecord?.note ?? null,
      verdictSealedAt: vRecord
        ? new Date(vRecord.sealedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
        : null,
    };
  });
}

function buildDeadlineRow(slug: string, title: string, deadline: Date): DeadlineRow | null {
  const ds = getDeadlineStatus(slug, deadline);
  if (ds.status === 'no-deadline' || ds.status === 'auto-resolved') return null;
  const days = 'daysRemaining' in ds ? ds.daysRemaining : -1;
  if (days > 30) return null; // only surface < 30 days
  return { slug, title, deadline, daysRemaining: days, status: ds.status };
}

async function buildDeadlineRows(): Promise<DeadlineRow[]> {
  const all = await getCollection('blog');
  const rows = all.flatMap(p => {
    const dl = p.data.resolution_deadline as Date | undefined;
    if (!dl) return [];
    const row = buildDeadlineRow(p.slug, p.data.title as string, dl);
    return row ? [row] : [];
  });
  return rows.sort((a, b) => a.daysRemaining - b.daysRemaining);
}

const posts = authed ? await buildPostStatuses() : [];
const deadlineRows = authed ? await buildDeadlineRows() : [];
const sealedCount = posts.filter(p => p.sealed).length;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Conviction Seal</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--surface-base);
      color: var(--text-primary);
      min-height: 100vh;
      padding: 2rem 1.25rem;
    }

    .admin-wrap { max-width: 42rem; margin: 0 auto; }

    .admin-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 2.5rem;
      border-bottom: 1px solid var(--border-subtle);
      padding-bottom: 1rem;
    }

    .admin-title {
      font-size: var(--text-sm);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }

    .admin-stat {
      font-size: var(--text-xs);
      color: var(--gold-dim);
      font-family: ui-monospace, monospace;
    }

    /* Login form */
    .login-form {
      margin-top: 4rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-width: 22rem;
    }

    .login-label {
      font-size: var(--text-xs);
      color: var(--text-tertiary);
      letter-spacing: 0.03em;
    }

    .login-input {
      background: var(--surface-raised);
      border: 1px solid var(--border-light);
      border-radius: 10px;
      padding: 0.65rem 0.9rem;
      font-size: var(--text-sm);
      color: var(--text-primary);
      outline: none;
      width: 100%;
      transition: border-color 150ms ease;
    }

    .login-input:focus { border-color: var(--gold-border-strong); }

    .login-btn {
      background: var(--gold-bg-strong);
      border: 1px solid var(--gold-border);
      border-radius: 10px;
      padding: 0.65rem 1.25rem;
      font-size: var(--text-sm);
      color: var(--gold);
      cursor: pointer;
      align-self: flex-start;
      transition: background 150ms ease;
    }

    .login-btn:hover { background: var(--gold-glow); }

    .login-error {
      font-size: var(--text-xs);
      color: color-mix(in oklch, var(--clr-red-500) 80%, transparent);
    }

    /* Post list */
    .post-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    /* Conviction seal + verdict panel grouped per post */
    .admin-post-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      border-left: 2px solid var(--surface-raised);
      padding-left: 0.75rem;
    }

    /* Upcoming deadlines panel */
    .deadlines-panel {
      margin-bottom: 2.5rem;
      border: 1px solid var(--gold-glow);
      border-radius: 10px;
      padding: 1rem 1.1rem;
      background: color-mix(in oklch, var(--gold) 3%, transparent);
    }

    .deadlines-heading {
      font-size: var(--text-xs);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold-dim);
      margin-bottom: 0.75rem;
    }

    .deadline-row {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
      padding: 0.4rem 0;
      border-bottom: 1px solid var(--border-faint);
      font-size: var(--text-sm);
    }

    .deadline-row:last-child { border-bottom: none; }

    .deadline-row-title {
      color: var(--text-secondary);
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .deadline-row-days {
      font-family: ui-monospace, monospace;
      font-size: var(--text-xs);
      color: var(--gold-mid);
      white-space: nowrap;
    }

    .deadline-row-days--overdue { color: var(--clr-red-500); }

    .deadline-row-status {
      font-size: var(--text-2xs);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--text-ghost);
    }

    .deadlines-empty {
      font-size: var(--text-sm);
      color: var(--text-ghost);
      font-style: italic;
    }
  </style>
</head>
<body>
  <div class="admin-wrap">
    <div class="admin-header">
      <span class="admin-title">Conviction Seal — Admin</span>
      {authed && (
        <span class="admin-stat">
          {sealedCount}/{posts.length} sealed ·{' '}
          {posts.filter(p => p.verdictSealed).length}/{posts.filter(p => p.sealed).length} verdicts
        </span>
      )}
    </div>

    {!authed && (
      <form class="login-form" method="POST">
        <label class="login-label" for="secret">Admin secret</label>
        <input
          id="secret"
          name="secret"
          type="password"
          class="login-input"
          autocomplete="current-password"
          autofocus
        />
        {loginError && <span class="login-error">{loginError}</span>}
        <button type="submit" class="login-btn">Enter</button>
      </form>
    )}

    {authed && deadlineRows.length >= 0 && (
      <div class="deadlines-panel">
        <p class="deadlines-heading">⏳ Resolution Deadlines — next 30 days</p>
        {deadlineRows.length === 0
          ? <p class="deadlines-empty">No active deadlines in the next 30 days.</p>
          : deadlineRows.map(row => (
              <div class="deadline-row">
                <a href={`/blog/${row.slug}`} class="deadline-row-title">{row.title}</a>
                <span class={`deadline-row-days${row.daysRemaining < 0 ? ' deadline-row-days--overdue' : ''}`}>
                  {row.daysRemaining < 0 ? `${Math.abs(row.daysRemaining)}d overdue` : `${row.daysRemaining}d left`}
                </span>
                <span class="deadline-row-status">{row.status}</span>
              </div>
            ))
        }
      </div>
    )}

    {authed && (
      <div class="post-list">
        {posts.map(post => (
          <div class="admin-post-group">
            <SealCeremony
              slug={post.slug}
              title={post.title}
              variant="conviction"
              context="admin"
              sealEntry={post.sealEntry}
              convictionStage={post.convictionStage}
            />
            <VerdictResolutionPanel
              slug={post.slug}
              title={post.title}
              convictionSealed={post.sealed}
              verdictSealed={post.verdictSealed}
              verdict={post.verdict as any}
              verdictNote={post.verdictNote}
              verdictSealedAt={post.verdictSealedAt}
            />
          </div>
        ))}
      </div>
    )}
  </div>
</body>
</html>
