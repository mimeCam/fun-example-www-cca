---
// src/pages/embers.astro
// Short-form micro-posts that glow and fade.
// Each ember gets the full decay/mood treatment via EmberEntry.
//
// TODO: add pagination or "load older" once ember count grows
// TODO: add RSS integration for embers feed

import BaseLayout from '../layouts/BaseLayout.astro';
import EmberEntry from '../components/EmberEntry.astro';
import { sortedEmbers } from '../lib/ember';
import type { Ember } from '../lib/ember';
import embersRaw from '../data/embers.json';

const computed = sortedEmbers(embersRaw as Ember[]);
---

<BaseLayout title="Embers">
  <main class="embers-page">
    <header class="embers-header">
      <h1>Embers</h1>
      <p class="embers-tagline">Short sparks — they glow, then cool.</p>
    </header>
    <section class="embers-list">
      {computed.map(c => <EmberEntry computed={c} />)}
    </section>
  </main>
</BaseLayout>

<style>
  .embers-page { max-width: 40rem; margin: 0 auto; padding: 2rem 1rem; }
  .embers-header { margin-bottom: 2rem; text-align: center; }
  .embers-header h1 { font-size: 1.4rem; font-weight: 600; margin: 0; }
  .embers-tagline { font-size: 0.78rem; opacity: 0.5; margin-top: 0.5rem; }
  .embers-list { display: flex; flex-direction: column; gap: 1rem; }
</style>
