---
// src/pages/audit/[slug].astro
// Public proof page for sealed convictions — "The author's past self is on record."
// SSR mandatory: ledger is live, static page would show stale event counts.
// Returns 404 if slug not found. Shows "NOT YET SEALED" if post exists but unsealed.
// No client JS required — pure server-rendered HTML.
//
// Credits: Mike (architecture spec — Conviction Audit Trail napkin plan)

export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuditReceipt  from '../../components/AuditReceipt.astro';
import TrustBadge    from '../../components/TrustBadge.astro';
import ConvictionTimeline from '../../components/ConvictionTimeline.astro';
import { assembleAuditPayload, derHexLines, checkChainIntegrity } from '../../lib/audit-verifier';
import { getVerdictDisplay }    from '../../lib/verdict-display';
import AuditVerdictPanel        from '../../components/AuditVerdictPanel.astro';
import { verifyAnchor }         from '../../lib/anchor-verifier';
import { getTstForSeal }        from '../../lib/timestamp-store';
import { getOtsProof, getSealEntry } from '../../lib/conviction-ledger';
import { getDisputeResolution } from '../../lib/verdict-dispute';
import { verify as otsVerify }  from '../../lib/ots-verifier';
import { hashContent }          from '../../lib/rfc3161-client';
import type { ConvictionStage } from '../../components/TrustBadge.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const posts = await getCollection('blog');
const post  = posts.find(p => p.slug === slug);
if (!post) return Astro.redirect('/404');

const payload = assembleAuditPayload(slug, post.data.title);

// Live Gist verification — runs only here, never in hot paths.
// Fail-safe: if GitHub is unreachable, status is 'unreachable' not an error.
const anchorVerification = payload.seal
  ? await verifyAnchor(slug).catch(() => null)
  : null;

// RFC 3161 TST data — null for pre-stamp posts (graceful degradation).
const tstData = payload.seal ? getTstForSeal(slug) : null;

// OTS Bitcoin anchor — verify if confirmed, pass status if pending.
async function resolveOtsData() {
  const otsProof = getOtsProof(slug);
  if (!otsProof) return null;
  if (otsProof.status !== 'confirmed') return { status: otsProof.status, calendarUrl: otsProof.calendarUrl ?? undefined };
  const seal = getSealEntry(slug);
  if (!seal) return { status: 'unverifiable' as const };
  const original = hashContent(`${slug}:${seal.conviction_score}:${seal.timestamp}`);
  return otsVerify(otsProof.proof, original).catch(() => ({ status: 'unverifiable' as const }));
}
const otsData = payload.seal ? await resolveOtsData() : null;

// DER hex lines for offline verification display (null if no TST available).
const tstDerHexLines = tstData ? derHexLines(tstData.tst_token) : null;

// Chain integrity — recompute hash from stored fields; advisory warning on mismatch.
const sealEntry      = payload.seal ? getSealEntry(slug) : null;
const chainOk        = sealEntry ? checkChainIntegrity(sealEntry) : null;

// Verdict display data — assembled from existing modules, no new DB queries.
const verdictDisplay = getVerdictDisplay(slug);

// Conviction stage for TrustBadge — derives public trust state from ledger data.
const auditResolution = sealEntry ? getDisputeResolution(slug) : null;
function deriveAuditStage(): ConvictionStage {
  if (!sealEntry)      return 'unsealed';
  if (!tstData)        return 'pending';
  if (!auditResolution) return 'sealed';
  return auditResolution.state as ConvictionStage;
}
const auditConvictionStage = deriveAuditStage();

// Atmosphere: vindicated if verdict correct, wrong tint if verdict wrong.
// Pending/unsealed pages stay fresh (default).
const auditAtmosphere = verdictDisplay.verdict === 'still-true' ? 'risen' as const
  : verdictDisplay.verdict === 'wrong' || verdictDisplay.verdict === 'abandoned' ? 'verdict' as const
  : 'fresh' as const;
const verdictOutcomeAtm = verdictDisplay.verdict === 'still-true' ? 'correct' as const
  : verdictDisplay.verdict === 'wrong' || verdictDisplay.verdict === 'abandoned' ? 'wrong' as const
  : undefined;

const pageTitle       = `Conviction Audit — ${post.data.title}`;
const pageDescription = payload.seal
  ? `Sealed conviction receipt for "${post.data.title}": score ${payload.seal.score}/10, locked at ${new Date(payload.seal.sealedAt).toLocaleDateString()}.`
  : `Conviction audit for "${post.data.title}" — not yet sealed.`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogSlug={`audit/${slug}`}
  atmosphere={auditAtmosphere}
  verdictOutcome={verdictOutcomeAtm}
>
  <main class="audit-page">

    <!-- Back navigation -->
    <nav class="audit-nav" aria-label="Page navigation">
      <a href={`/blog/${slug}`} class="audit-back">← back to post</a>
      <a href="/" class="audit-field">field ↗</a>
    </nav>

    <!-- Page heading -->
    <header class="audit-header">
      <p class="audit-eyebrow">Conviction Audit</p>
      <h1 class="audit-title">{post.data.title}</h1>
      <p class="audit-sub">
        {payload.seal
          ? 'The author sealed a conviction before this post was published. You are looking at the receipt.'
          : 'This post has not been sealed yet. The conviction score will appear here once the author locks it.'}
      </p>
    </header>

    <!-- RFC 3161 trust badge — shows conviction stage (pending → sealed → upheld/overturned) -->
    {tstData && <div class="audit-trust-row"><TrustBadge tst={tstData} slug={slug} convictionStage={auditConvictionStage} /></div>}

    <!-- The receipt — visual proof block -->
    <AuditReceipt
      seal={payload.seal}
      postTitle={payload.postTitle}
      anchorVerification={anchorVerification}
      tstData={tstData}
      otsData={otsData}
      derHexLines={tstDerHexLines}
      chainIntegrityOk={chainOk}
    />

    <!-- Verdict outcome — completes the conviction → verdict → score chain -->
    <AuditVerdictPanel verdictDisplay={verdictDisplay} />

    <!-- API footnote — power-user disclosure per Tanya §11 -->
    <p class="audit-api-note">
      Verify programmatically →
      <code class="audit-api-code">GET /api/trust-verify/{slug}</code>
      <span class="audit-api-sep">·</span>
      Re-walk the OTS proof yourself →
      <a class="audit-api-link" href={`/verify?slug=${slug}`}>/verify?slug={slug}</a>
    </p>

    <!-- Event timeline — chronological history -->
    <ConvictionTimeline timeline={payload.timeline} slug={slug} />

    <!-- Footer nudge back to the post -->
    <div class="audit-footer">
      <a href={`/blog/${slug}`} class="audit-post-link">
        Read "{post.data.title}" →
      </a>
    </div>

  </main>
</BaseLayout>

<style>
  .audit-page {
    max-width: 38rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  /* RFC 3161 trust badge row */
  .audit-trust-row { margin-bottom: 1rem; }

  /* Back nav */
  .audit-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .audit-back,
  .audit-field {
    font-size: var(--text-xs);
    color: var(--text-dim);
    text-decoration: none;
    letter-spacing: var(--tracking-relaxed);
    transition: color var(--motion-flow-duration) ease;
  }

  .audit-back:hover,
  .audit-field:hover { color: var(--text-secondary); }
  .audit-field        { margin-left: auto; }

  /* Page heading */
  .audit-header { margin-bottom: 2rem; }

  .audit-eyebrow {
    font-size: var(--text-2xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-spread);
    text-transform: uppercase;
    color: var(--gold-mid);
    margin: 0 0 0.4rem;
  }

  .audit-title {
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    font-weight: var(--weight-bold);
    line-height: 1.25;
    letter-spacing: var(--tracking-tighter);
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .audit-sub {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-tertiary);
    margin: 0;
    font-style: italic;
  }

  /* Footer */
  .audit-footer {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-subtle);
  }

  .audit-post-link {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    text-decoration: none;
    letter-spacing: var(--tracking-snug);
    transition: color var(--motion-flow-duration) ease;
  }

  .audit-post-link:hover { color: var(--text-secondary); }

  /* API footnote — text-2xs, muted, monospace; Tanya §11 */
  .audit-api-note {
    margin-top: 1.25rem;
    font-size: var(--text-2xs);
    color: var(--text-ghost);
    letter-spacing: var(--tracking-snug);
    line-height: 1.5;
  }

  .audit-api-code {
    font-family: var(--font-mono, monospace);
    font-size: inherit;
    color: var(--text-dim);
  }
  .audit-api-sep { color: var(--text-ghost); margin: 0 0.25rem; }
  .audit-api-link {
    font-family: var(--font-mono, monospace);
    font-size: inherit;
    color: var(--gold);
    text-decoration: none;
  }
  .audit-api-link:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .audit-page { padding: 2rem 1rem 4rem; }
  }
</style>
