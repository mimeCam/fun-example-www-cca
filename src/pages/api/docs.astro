---
// src/pages/api/docs.astro
// API reference — the single page that hosts the published `decayStage` vocabulary.
//
// One page. Three sections. Five words. Zero new components.
//
// The vocabulary itself (the five DecayStage literals) is sourced from
// decay-engine.ts via DECAY_STAGES — there is no hand-typed list here, so
// the page can never drift from the wire.
//
// v150d — the 35 grammar cells now also carry `data-heat` (Tanya §2), a
// telemetry-side attribute painted by the cited-cell ledger. Same classifier
// the JSON endpoint uses — the page is the proof on the page.
//
// Credits: Tanya Donska (UX spec §1 — page layout, lede, list, tone, footer;
//          §2 layer-collision, §4 heat vocabulary, §7 ARIA sentence),
//          Mike Koch (napkin §3 — endpoint scope, response shape; §classifier
//          as single producer), Paul Kim (immutability commitment,
//          self-selection paragraph, API-parity vow), Elon (cold-start
//          guardrail, window discipline), Krystle (response-layer derivation
//          pattern). AGENTS.md ("polish what we have — AAA").

// v150d — SSR on demand so each request sees current ledger data. The page
// remains cheap (sub-50ms): one GROUP BY + one MIN() on an indexed table.
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { DECAY_STAGES } from '../../lib/decay-engine';
import type { DecayStage } from '../../lib/decay-engine';
import { STAGE_TRANSITION_DURATION_MS } from '../../lib/stage-tokens.generated';
import {
  STAGE_AXES,
  cellAnchorId,
  rowAnchorId,
  stageAnchorId,
  cellCitationLabel,
} from '../../lib/stage-axes';
import type { Axis } from '../../lib/stage-axes';
import {
  baseline,
  lifetimeByCell,
  ledgerMaturity,
  ROUND_TRIP_WINDOW_DAYS,
} from '../../lib/cell-event-ledger';
import { heatedGrid, heatSentence } from '../../lib/cell-heat';
import type { HeatedCell } from '../../lib/cell-heat';

// NOTE: the clipboard payload is built CLIENT-SIDE from window.location.origin
// so prerendered HTML never bakes in a build-time host (Paul §non-negotiable —
// the string is the product). The human label is SSR-stable; the URL is
// resolved at copy time by cell-cite.ts using the same cellCitationPayload()
// pure helper — one source of truth, no host drift.

// v165: every stage now carries a literal ms value (no more snap aliases).
// The `var(…)` fallback is retained only as a defensive guard for any
// future stage that re-aliases — the check-stage-tempo-divergence prebuild
// guard will flag any such collapse via `duration-alias`, long before it
// reaches this function.
function motionValueLabel(stage: DecayStage): string {
  const value = STAGE_TRANSITION_DURATION_MS[stage];
  return value.startsWith('var(') ? 'aliased (check tokens)' : value;
}

// ── Vocabulary copy — kept in this file only, beside the live tuple ─────────
// One short clause per stage. Casing: lowercase, identical to the wire string.
// Tanya §2.2: capitalisation rewrites belong in microcopy, not in this list.
const STAGE_MEANING: Record<DecayStage, string> = {
  fresh:      'the post is new; people are reading it.',
  fading:     'interest is cooling.',
  endangered: 'the clock is loud now.',
  ghost:      'the post has aged out; revival is still possible.',
  fossil:     'the post is sealed into the record.',
};

const PAGE_TITLE = 'API — Octopoid';
const REVIEWED_ON = '2026-04-22';

// v150d — per-request SSR fetch. heated is the 7×5 grid (never partial);
// snap.byCell drives the subtitle sentence; dormant suppresses the sentence
// until the ledger earns the right to speak (Elon's cold-start rule).
const _heatNow = Date.now();
const heatedCells: HeatedCell[] = heatedGrid(lifetimeByCell(), ledgerMaturity(_heatNow), _heatNow);
const heatSnapshot = baseline(ROUND_TRIP_WINDOW_DAYS);
const heatByKey = indexHeat(heatedCells);

/** Index heated cells by `${axis}:${stage}` — pure lookup, no side-effects. */
function indexHeat(cells: HeatedCell[]): Map<string, HeatedCell> {
  const out = new Map<string, HeatedCell>();
  for (const c of cells) out.set(`${c.axis}:${c.stage}`, c);
  return out;
}

/** Resolve the heated record for one cell — always defined (full grid). */
function heatFor(axis: Axis, stage: DecayStage): HeatedCell {
  return heatByKey.get(`${axis}:${stage}`)!;
}

/** DOM id for the sr-only sentence that backs `aria-describedby`. */
function heatSrId(axis: Axis, stage: DecayStage): string {
  return `heat-${axis}-${stage}`;
}

/** Subtitle copy — single-window, single-source. Tanya §5 / Elon §window. */
function heatSubtitle(): string {
  if (!heatSnapshot.copies) {
    return 'Citations will light this up over the coming week.';
  }
  const noun = heatSnapshot.arrivals === 1 ? 'citation' : 'citations';
  return `${heatSnapshot.arrivals} of ${heatSnapshot.copies} ${noun} returned within ${ROUND_TRIP_WINDOW_DAYS} days.`;
}

// JSON sample shown in the code block — small enough to read in one breath,
// representative enough that a builder can predict the rest. The `decayStage`
// line is highlighted via `data-line-stage` and styled in the <style> block.
const SAMPLE_JSON_LINES: Array<{ text: string; stage?: boolean }> = [
  { text: '{' },
  { text: '  "slug":         "the-decay-theory",' },
  { text: '  "title":        "the decay theory",' },
  { text: '  "decay":        0.62,' },
  { text: '  "decayStage":   "endangered",', stage: true },
  { text: '  "daysLeft":     21,' },
  { text: '  "urgency":      "warning",' },
  { text: '  "revivalCount": 3,' },
  { text: '  "pubDate":      "2025-08-14T09:00:00.000Z"' },
  { text: '}' },
];
---

<BaseLayout title={PAGE_TITLE} description="The five-name vocabulary the JSON uses for every post.">
  <main class="api-docs">

    <header class="api-docs__head">
      <h1 class="api-docs__h1">What posts look like, in JSON.</h1>
      <p class="api-docs__lede">
        Every post on this site has a clock. The clock has five names. Here is
        how the JSON says them.
      </p>
    </header>

    <pre class="api-docs__code" aria-label="Sample post response shape" tabindex="0"><code>{SAMPLE_JSON_LINES.map((l) => (
  <span class="api-docs__code-line" data-line-stage={l.stage ? 'true' : undefined}>{l.text + '\n'}</span>
))}</code></pre>

    <section class="api-docs__section" aria-labelledby="stages-heading">
      <h2 id="stages-heading" class="api-docs__h2">The five stages.</h2>

      <dl class="api-docs__stages">
        {DECAY_STAGES.map((stage) => (
          <div class="api-docs__row" data-stage={stage} id={stageAnchorId(stage)}>
            <dt class="api-docs__word">{stage}</dt>
            <dd class="api-docs__def"><span class="api-docs__dash" aria-hidden="true">—</span>{STAGE_MEANING[stage]}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="api-docs__section" aria-labelledby="motion-heading">
      <h2 id="motion-heading" class="api-docs__h2">How the five stages feel.</h2>
      <p class="api-docs__lede">
        Each stage has its own interaction timing. The grammar is five rows,
        each a distinct ms literal — <code class="api-docs__inline">endangered</code>
        is the shortest on purpose, because it is the one stage where the
        reader can still act to revive the post. The same five words drive
        every surface the reader touches: typography, border, tempo,
        selection, drag-highlight, the keyboard focus ring (v148), and — as
        of v149 — the prose link underline.
      </p>

      <dl class="api-docs__stages api-docs__stages--motion">
        {DECAY_STAGES.map((stage) => (
          <div class="api-docs__row" data-stage={stage}>
            <dt class="api-docs__word">{stage}</dt>
            <dd class="api-docs__def"><span class="api-docs__dash" aria-hidden="true">—</span>{motionValueLabel(stage)}</dd>
          </div>
        ))}
      </dl>
    </section>

    {/* v150a — Mike napkin §1 / Tanya §3. Seven axes, five stages, rendered
       with the exact CSS each cell documents. Not a new page, not a new
       route, not a content-negotiated JSON contract: an appendix, anchored. */}
    <section class="api-docs__section api-docs__matrix-section" aria-labelledby="matrix-heading">
      <h2 id="matrix-heading" class="api-docs__h2">The grammar, whole.</h2>
      <p class="api-docs__lede">
        Seven axes, five stages. Each cell below is rendered with the exact
        CSS it documents — if a cell looks wrong, the axis is wrong, not the
        page.
      </p>
      {/* v150d — single-window subtitle (Tanya §5). 7-day window named
         explicitly so nobody silently widens to 30d later. Omitted on
         cold start, swapped to an onboarding line instead. */}
      <p class="api-docs__lede api-docs__lede--heat" data-heat-subtitle>
        {heatSubtitle()}
      </p>

      {/* v151c — teach all three cite keys (Mike napkin §6, Tanya §9a).
         `c` first for mnemonic primacy; Enter/Space trail after an em-dash
         as platform courtesies. All three chips share .ds-kbd —
         hierarchy comes from word order, not styling. The courtesy clause
         is wrapped in .api-docs__legend-nowrap so on narrow viewports it
         breaks *before* the em-dash, never mid-chip. Still hidden on
         hover:none (touch has no analogue). Zero new tokens.

         v151d — a second `<p data-nav-legend>` follows as the quiet
         sibling (Tanya UX spec §3, Mike napkin §4). Order = cite, then
         nav: cite is the verb; nav is the prerequisite courtesy. Both
         paragraphs live inside `.api-docs__legend-stack` — a flex
         column that gives them a tight var(--space-1) gap while the
         outer margin preserves the room above/below the whole band.
         Both legends inherit `.api-docs__legend`, so the touch-hide
         and forced-colors contract covers them together — one owner,
         one rule (Tanya §3.1, §6).

         v152 — `.ds-kbd` PROMOTE shipped (Mike napkin "Earn the PROMOTE",
         Tanya §1.1). The chip rule lives in src/styles/ds-kbd.css now.
         Second real consumer is FloatingKeepButton's `K` legend chip,
         enforced by scripts/check-ds-kbd.ts at prebuild. */}
      <div class="api-docs__legend-stack">
        <p class="api-docs__legend" data-cite-legend>
          <span class="api-docs__legend-ico" aria-hidden="true">⌨︎</span>
          Press <kbd class="ds-kbd">c</kbd> to cite the focused cell —
          <span class="api-docs__legend-nowrap">
            <kbd class="ds-kbd">Enter</kbd> and
            <kbd class="ds-kbd">Space</kbd> also work.
          </span>
        </p>
        <p class="api-docs__legend" data-nav-legend>
          <span class="api-docs__legend-ico" aria-hidden="true">↕</span>
          <span class="api-docs__legend-nowrap">
            <kbd class="ds-kbd">ArrowUp</kbd> / <kbd class="ds-kbd">ArrowDown</kbd> / <kbd class="ds-kbd">ArrowLeft</kbd> / <kbd class="ds-kbd">ArrowRight</kbd>
          </span>
          move focus;
          <span class="api-docs__legend-nowrap">
            <kbd class="ds-kbd">Home</kbd> / <kbd class="ds-kbd">End</kbd>
          </span>
          jump a row,
          <span class="api-docs__legend-nowrap">
            <kbd class="ds-kbd">PageUp</kbd> / <kbd class="ds-kbd">PageDown</kbd>
          </span>
          jump an axis.
        </p>
      </div>

      <div class="api-docs__matrix" role="table" aria-labelledby="matrix-heading">
        <div class="api-docs__matrix-row api-docs__matrix-row--head" role="row">
          <div class="api-docs__matrix-rowhead api-docs__matrix-corner" role="columnheader" aria-hidden="true"></div>
          {DECAY_STAGES.map((stage) => (
            <div class="api-docs__matrix-colhead" role="columnheader" data-stage={stage}>
              <span class="api-docs__word">{stage}</span>
            </div>
          ))}
        </div>

        {STAGE_AXES.map((axis) => (
          <div class="api-docs__matrix-row" role="row" id={rowAnchorId(axis)}>
            <div class="api-docs__matrix-rowhead" role="rowheader">{axis}</div>
            {DECAY_STAGES.map((stage) => (
              <div
                class="api-docs__matrix-cell"
                role="cell"
                id={cellAnchorId(axis, stage)}
                data-axis={axis}
                data-decay-stage={stage}
                data-heat={heatFor(axis, stage).heat}
                tabindex="-1"
                aria-label={`${axis} at ${stage}`}
                aria-describedby={heatSrId(axis, stage)}
              >
                {/* v150b — copy-cell-anchor. Top-right affordance revealed on
                   hover/focus-within; the clipboard payload + human label
                   come straight off the SSR literal, so non-JS readers see
                   nothing broken and the button works without JS hydration
                   other than the single delegated listener. */}
                <button
                  type="button"
                  class="cell-copy"
                  data-cell-copy
                  data-cell-axis={axis}
                  data-cell-stage={stage}
                  data-cell-citation={cellCitationLabel(axis, stage)}
                  data-analytics="copy-cell"
                  aria-label={`copy citation for ${axis} at ${stage}`}
                >
                  <span class="cell-copy__glyph cell-copy__glyph--rest" aria-hidden="true">⌗</span>
                  <span class="cell-copy__glyph cell-copy__glyph--done" aria-hidden="true">✓</span>
                </button>

                {axis === 'typography' && (
                  <span class="mx-demo mx-demo--typo" aria-hidden="true">Aa</span>
                )}
                {axis === 'border' && (
                  <div class="mx-demo mx-demo--border" aria-hidden="true"></div>
                )}
                {axis === 'tempo' && (
                  <span class="mx-demo mx-demo--tempo" aria-hidden="true"></span>
                )}
                {axis === 'selection' && (
                  <span class="mx-demo mx-demo--selection" aria-hidden="true">text</span>
                )}
                {axis === 'drag-highlight' && (
                  <div class="mx-demo mx-demo--drag" aria-hidden="true">drop</div>
                )}
                {axis === 'focus' && (
                  <button class="mx-demo mx-demo--focus" type="button">tab</button>
                )}
                {axis === 'underline' && (
                  <p class="mx-demo mx-demo--under"><a href={`#${rowAnchorId(axis)}`}>link</a></p>
                )}

                {/* v150d — sr-only sentence carrying the heat story in words.
                   Referenced by the cell's `aria-describedby`. Plain English,
                   no punctuation noise. Tanya §7. */}
                <span id={heatSrId(axis, stage)} class="mx-sr-only">
                  {heatSentence(heatFor(axis, stage), _heatNow)}
                </span>
              </div>
            ))}
          </div>
        ))}
      </div>

      {/* v150b — shared aria-live toast. One node per page; text replaced
         on each copy (Tanya §4b, §8). Lives outside the role="table" matrix
         so screen-reader table semantics stay clean. Client module hooks
         it via [data-cell-toast]. */}
      <div
        class="cell-toast"
        role="status"
        aria-live="polite"
        aria-atomic="true"
        data-cell-toast
      ></div>
    </section>

    {/* v150c — Mike napkin §1 (endpoint documentation).
       v156 — Three endpoints: the terminal/`curl` mouth of the citation
       trilogy joins the ingest beacon and the metrics snapshot. One
       paragraph each. API parity vow: every public verb appears in
       this appendix alongside the vocabulary it uses. */}
    <section class="api-docs__section" aria-labelledby="endpoints-heading">
      <h2 id="endpoints-heading" class="api-docs__h2">Three endpoints.</h2>
      <p class="api-docs__lede">
        The cell-citation ritual is a loop: a reader copies a cell, pastes
        a URL elsewhere, and — if the grammar worked — someone clicks back.
        Three endpoints close that loop without a login, a cookie wall, or
        any third party. The same bytes reach you by click, key, or
        <code class="api-docs__inline">curl</code>.
      </p>
      <dl class="api-docs__stages">
        <div class="api-docs__row">
          <dt class="api-docs__word">GET /api/docs/cite</dt>
          <dd class="api-docs__def">
            <span class="api-docs__dash" aria-hidden="true">—</span>
            terminal mouth. Query:
            <code class="api-docs__inline">?axis=&amp;stage=&amp;r=</code>.
            Returns the citation payload as
            <code class="api-docs__inline">text/plain</code> (default) or
            <code class="api-docs__inline">application/json</code> (via
            <code class="api-docs__inline">Accept</code>). Byte-identical to
            what the click and keystroke mouths place on the clipboard.
          </dd>
        </div>
        <div class="api-docs__row">
          <dt class="api-docs__word">POST /api/ingest/cell-event</dt>
          <dd class="api-docs__def">
            <span class="api-docs__dash" aria-hidden="true">—</span>
            fire-and-forget beacon. Body:
            <code class="api-docs__inline">{`{ event, axis, stage, ref, ts }`}</code>.
            Always 202. Telemetry never blocks the ritual.
          </dd>
        </div>
        <div class="api-docs__row">
          <dt class="api-docs__word">GET /api/metrics/cited-cells</dt>
          <dd class="api-docs__def">
            <span class="api-docs__dash" aria-hidden="true">—</span>
            read-only snapshot. Seven-day rolling window; override with
            <code class="api-docs__inline">?days=N</code> (1..30). Returns
            copies, matched arrivals, and the round-trip ratio.
          </dd>
        </div>
      </dl>
    </section>

    <section class="api-docs__section" aria-labelledby="tone-heading">
      <h2 id="tone-heading" class="api-docs__h2">Tone.</h2>
      <p class="api-docs__tone">
        This site commits to the grammar of mortality. The five words above
        don't move. If labelling a post <code class="api-docs__inline">fossil</code>
        strikes you as morbid — this API is not for you. If it strikes you as
        honest, build something.
      </p>
    </section>

    <p class="api-docs__footnote">
      <span>last reviewed: {REVIEWED_ON}</span>
      <span aria-hidden="true">·</span>
      <span>these five words don't change</span>
    </p>

  </main>
</BaseLayout>

{/* v150b — client-side citation ritual. One module, one delegated
   listener, one arrival handler. See src/lib/client/cell-cite.ts.
   v151 "Linkable Gaze" — sibling module owning keyboard grid + hash-seed.
   v151a "Edge of axis" — third closed module hooks into matrix-keynav's
   clamp signal (see setClampListener in matrix-keynav.ts) and paints the
   2px wall-nod + aria-live whisper. Zero overlap: cell-cite owns citation,
   matrix-keynav owns navigation, edge-bump owns clamp-feedback. The shared
   contract is the DOM. Order matters: edge-bump imports matrix-keynav and
   registers its listener before DOMContentLoaded fires. */}
<script>
  import '../../lib/client/cell-cite';
  import '../../lib/client/edge-bump';
</script>

<style>
  /* ── Reading column — same width as the post body ─────────────────────────
     One column, no card shell, no panel. Tanya §1.3 / §1.4.                  */
  .api-docs {
    max-width: var(--container-read);
    margin: 0 auto;
    padding: var(--space-8) var(--gutter) var(--space-16);
    color: var(--text-primary);
  }

  /* ── Header ───────────────────────────────────────────────────────────── */
  .api-docs__head { margin-bottom: var(--space-8); }

  .api-docs__h1 {
    margin: 0 0 var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    line-height: var(--leading-tight);
  }

  /* Lede: prose-size, secondary tone, generous breathing room before code.
     Tanya §1.5 type spec. */
  .api-docs__lede {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-prose);
    line-height: var(--leading-prose);
    color: var(--text-secondary);
    letter-spacing: var(--tracking-normal);
  }

  /* ── JSON code block ──────────────────────────────────────────────────── */
  .api-docs__code {
    margin: 0 0 var(--space-10);
    padding: var(--space-4) var(--space-5);
    background: var(--surface-inset-deep);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    tab-size: 2;
    color: var(--text-secondary);
    overflow-x: auto;       /* mobile: horizontal scroll inside the block */
  }

  .api-docs__code:focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }

  /* Each line is a span — the highlight uses both color (gold) AND a left
     border accent. Two cues for one signal — Tanya §1.7 (color alone violates
     principle §7). */
  .api-docs__code-line {
    display: block;
    padding-left: var(--space-3);
    border-left: 2px solid transparent;
  }
  .api-docs__code-line[data-line-stage='true'] {
    color: var(--gold);
    border-left-color: var(--gold-mid);
  }

  /* ── Sections ─────────────────────────────────────────────────────────── */
  .api-docs__section { margin-bottom: var(--space-10); }

  .api-docs__h2 {
    margin: 0 0 var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
  }

  /* ── Five-stage list ──────────────────────────────────────────────────── */
  .api-docs__stages { margin: 0; padding: 0; }

  /* Definition row: stage word right-aligned in a 12ch column, em-dash,
     description left-aligned. Spacing-only relationship cue. Tanya §1.6. */
  .api-docs__row {
    display: grid;
    grid-template-columns: 12ch 1fr;
    gap: var(--space-3);
    align-items: baseline;
    margin: 0 0 var(--space-4);
  }

  .api-docs__word {
    margin: 0;
    text-align: right;
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-normal);
  }

  /* The almost-imperceptible glow uses the existing decay color tokens —
     vocabulary + visual identity, single source. Tanya §1.6.                */
  [data-stage='fresh']      .api-docs__word { color: var(--color-decay-fresh);
    text-shadow: 0 0 8px color-mix(in oklch, var(--color-decay-fresh) 18%, transparent); }
  [data-stage='fading']     .api-docs__word { color: var(--color-decay-fading);
    text-shadow: 0 0 8px color-mix(in oklch, var(--color-decay-fading) 18%, transparent); }
  [data-stage='endangered'] .api-docs__word { color: var(--color-decay-endangered);
    text-shadow: 0 0 8px color-mix(in oklch, var(--color-decay-endangered) 18%, transparent); }
  [data-stage='ghost']      .api-docs__word { color: var(--color-decay-ghost);
    text-shadow: 0 0 8px color-mix(in oklch, var(--color-decay-ghost) 18%, transparent); }
  [data-stage='fossil']     .api-docs__word { color: var(--color-decay-fossil);
    text-shadow: 0 0 8px color-mix(in oklch, var(--color-decay-fossil) 18%, transparent); }

  .api-docs__def {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }

  .api-docs__dash {
    display: inline-block;
    margin-right: var(--space-2);
    color: var(--text-tertiary);
  }

  /* ── Tone paragraph (self-selection) ──────────────────────────────────── */
  .api-docs__tone {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-prose);
    line-height: var(--leading-prose);
    color: var(--text-secondary);
  }

  .api-docs__inline {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    padding: 0 var(--space-1);
    background: var(--surface-inset);
    border-radius: var(--radius-detail);
  }

  /* ── Footnote ─────────────────────────────────────────────────────────── */
  .api-docs__footnote {
    margin: var(--space-12) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
