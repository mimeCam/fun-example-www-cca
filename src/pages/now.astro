---
// src/pages/now.astro
// The Author Right Now — living signal extracted from homepage.
// Philosophically opposite to the post ledger: impermanent, present-tense,
// almost a sticky note on top of the library.
//
// No conviction gold. No decay mechanics. Lighter visual register by design.
// Murmurs and NowLine belong here — not competing with sealed bets on the field.
//
// Credits: Tanya (UX spec §3 — sitemap revision, §10 — /now visual treatment)

export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import NowLine from '../components/NowLine.astro';
import Murmurs from '../components/Murmurs.astro';
import { partitionNow, computeFreshness } from '../lib/now';
import type { NowTiered } from '../lib/now';
import nowData from '../data/now.json';
import { computeBattingAverage } from '../lib/batting-average';

const data  = nowData as NowTiered;
const { hero } = partitionNow(data);
const avg   = computeBattingAverage();

// Use the hero item's update date if available; fall back to rightNow.updated.
const lastUpdated = hero[0]?.item.updated ?? data.rightNow.updated;
const freshness   = computeFreshness(lastUpdated);
---

<BaseLayout title="Now — Octopoid">
  <main class="now-page">

    <header class="now-header">
      <h1 class="now-title">Now</h1>
      <span class="now-freshness" title={freshness.quip}>{freshness.label}</span>
    </header>

    <NowLine />

    <Murmurs />

    <footer class="now-footer">
      <a href="/" class="now-back">← back to the field</a>
      {avg.status === 'live' && avg.total > 0 && (
        <a href="/" class="now-record" aria-label={`Current conviction record: ${avg.pct}%`}>
          Current conviction record: {avg.pct}% — see the field →
        </a>
      )}
    </footer>

  </main>
</BaseLayout>

<style>
  /* Lighter background than the main site — this page is impermanent by nature */
  .now-page {
    max-width: 40rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .now-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-faint);
  }

  .now-title {
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--text-primary);
  }

  /* Freshness quip: secondary, ephemeral — matches the page's register */
  .now-freshness {
    font-size: var(--text-2xs);
    color: var(--text-dim);
    font-style: italic;
    letter-spacing: 0.03em;
    cursor: default;
  }

  .now-footer {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border-faint);
  }

  .now-back {
    font-size: var(--text-xs);
    color: var(--text-dim);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 200ms ease;
  }

  .now-back:hover { color: var(--text-secondary); }

  /* Conviction record whisper — Tanya §7: no amber, 0.68rem, 0.25 opacity */
  .now-record {
    display: block;
    margin-top: 0.6rem;
    font-size: var(--text-2xs);
    color: var(--text-ghost);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 200ms ease;
  }

  .now-record:hover { color: var(--text-secondary); }

  @media (max-width: 640px) {
    .now-page { padding: 1.5rem 1rem 3rem; }
  }
</style>
