---
// src/pages/now.astro
// The /now page — a single card that decays over time.
// Data comes from src/data/now.json (hand-edited).
// Zero client-side JS; decay is baked at build time.
//
// TODO: add last-updated relative time ("3 days ago") below the card

import BaseLayout from '../layouts/BaseLayout.astro';
import NowCard from '../components/NowCard.astro';
import { partitionNow, emptyHeroQuip } from '../lib/now';
import type { NowTiered } from '../lib/now';
import nowRaw from '../data/now.json';

const data = nowRaw as NowTiered;
const { hero, season, residue } = partitionNow(data);
const hasHero = hero.length > 0;
// TODO: replace NowCard with NowHero, NowLayer, NowResidue components
// For now, wire hero item through the existing NowCard as a bridge
const heroEntry = hasHero ? hero[0] : null;
---

<BaseLayout title="Now" description="What I'm doing right now.">
  <main class="now-page">
    <h1 class="now-title">Now</h1>

    {heroEntry ? (
      <NowCard
        data={{ mood: data.mood, updated: heroEntry.item.updated,
                doing: [{ emoji: heroEntry.item.emoji, text: heroEntry.item.text }],
                thinking: heroEntry.item.thinking ?? '',
                location: data.location }}
        freshness={heroEntry.freshness}
        decay={heroEntry.decay}
      />
    ) : (
      <p class="now-empty">{emptyHeroQuip()}</p>
    )}

    {/* TODO: NowLayer component for season items */}
    {season.length > 0 && (
      <ul class="now-season">
        {season.map(s => (
          <li style={`opacity: ${(1 - s.decay * 0.5).toFixed(2)};`}>
            <span aria-hidden="true">{s.item.emoji}</span> {s.item.text}
          </li>
        ))}
      </ul>
    )}

    {/* TODO: NowResidue component for ghost-tier items */}
    {residue.length > 0 && (
      <ul class="now-residue">
        {residue.map(r => (
          <li style={`opacity: ${(0.2 + 0.2 * (1 - r.decay)).toFixed(2)};`}>
            <span aria-hidden="true">{r.item.emoji}</span> {r.item.text}
          </li>
        ))}
      </ul>
    )}
  </main>
</BaseLayout>

<style>
  .now-page {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .now-title {
    font-size: 1.5rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    opacity: 0.6;
  }

  .now-empty {
    font-style: italic;
    opacity: 0.4;
    margin: 2rem 0;
  }

  .now-season {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    max-width: 36rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.95rem;
  }

  .now-residue {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    max-width: 36rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.82rem;
    filter: blur(0.3px);
  }
</style>
