---
// src/pages/pulse.astro
// Two-zone page: open loops (decaying questions) + contradictions.
// Cards use crystallization styling — denser as they age.
// Layout: single column, no feature bloat.
//
// TODO: empty-state illustration when pulse is quiet
// TODO: resolved-loop visual treatment (strikethrough + muted)

import BaseLayout from '../layouts/BaseLayout.astro';
import OpenLoopCard from '../components/OpenLoopCard.astro';
import ContradictionCard from '../components/ContradictionCard.astro';
import { getPulseData, isPulseQuiet } from '../lib/pulse';

const data = await getPulseData();
const quiet = isPulseQuiet(data);
const activeLoops = data.openLoops.filter(l => !l.resolved);
const resolvedLoops = data.openLoops.filter(l => l.resolved);
---

<BaseLayout title="Pulse">
  <main class="pulse-page">
    <header class="pulse-header">
      <h1>Pulse</h1>
      <p class="pulse-tagline">
        {quiet ? 'All quiet — every question settled or fossilized.' : 'Open questions crystallizing in real time.'}
      </p>
    </header>

    {activeLoops.length > 0 && (
      <section class="zone" aria-label="Open loops">
        <h2 class="zone-title">Open Loops</h2>
        <div class="card-stack">
          {activeLoops.map(l => <OpenLoopCard loop={l} />)}
        </div>
      </section>
    )}

    {data.contradictions.length > 0 && (
      <section class="zone" aria-label="Contradictions">
        <h2 class="zone-title">Contradictions</h2>
        <div class="card-stack">
          {data.contradictions.map(c => <ContradictionCard item={c} />)}
        </div>
      </section>
    )}

    {resolvedLoops.length > 0 && (
      <section class="zone zone-resolved" aria-label="Resolved">
        <h2 class="zone-title">Resolved</h2>
        <div class="card-stack">
          {resolvedLoops.map(l => <OpenLoopCard loop={l} />)}
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .pulse-page { max-width: 38rem; margin: 0 auto; padding: 2rem 1rem; }
  .pulse-header { margin-bottom: 2.5rem; text-align: center; }
  .pulse-header h1 { font-size: 1.4rem; font-weight: 600; margin: 0; }
  .pulse-tagline { font-size: 0.78rem; opacity: 0.45; margin-top: 0.5rem; }
  .zone { margin-bottom: 2.5rem; }
  .zone-title {
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em;
    opacity: 0.4; margin-bottom: 1rem;
  }
  .card-stack { display: flex; flex-direction: column; gap: 0.75rem; }
  .zone-resolved { opacity: 0.5; }
</style>
