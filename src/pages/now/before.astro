---
// src/pages/now/before.astro
// The "Before" page — archived Now items grouped by geological era.
// Subordinate design: smaller cards, lower alpha, quieter presence.
// TODO: permalink anchors for individual archive items

import BaseLayout from '../../layouts/BaseLayout.astro';
import { partitionArchive } from '../../lib/now';
import type { NowTiered } from '../../lib/now';
import nowRaw from '../../data/now.json';

const data = nowRaw as NowTiered;
const entries = partitionArchive(data.archive ?? []);
const hasEntries = entries.length > 0;
---

<BaseLayout title="Before" description="What I used to be doing.">
  <main class="before-page">
    <h1 class="before-title">Before</h1>
    <p class="before-subtitle">Things I was doing, once.</p>

    {hasEntries ? (
      <ul class="before-list">
        {entries.map(({ item, era, opacity }) => (
          <li class={`before-item era-${era}`} style={`opacity:${opacity};`}>
            <span class="before-emoji" aria-hidden="true">{item.emoji}</span>
            <div class="before-body">
              <span class="before-text">{item.text}</span>
              {item.changed_mind && (
                <span class="before-reflection">— {item.changed_mind}</span>
              )}
            </div>
            <span class="before-era">{era}</span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="before-empty">Nothing archived yet. The present is all there is.</p>
    )}

    <a class="before-back" href="/now">← back to now</a>
  </main>
</BaseLayout>

<style>
  .before-page {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1rem;
  }
  .before-title {
    font-size: 1.3rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.5;
  }
  .before-subtitle {
    font-size: 0.85rem;
    opacity: 0.35;
    margin: 0.5rem 0 2rem;
    font-style: italic;
  }
  .before-list {
    list-style: none;
    padding: 0;
    max-width: 32rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .before-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    padding: 1rem 1.25rem;
    border-radius: 12px;
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.06);
  }
  .before-emoji { font-size: 1.1rem; flex-shrink: 0; }
  .before-body { display: flex; flex-direction: column; gap: 0.3rem; }
  .before-text { font-size: 0.88rem; }
  .before-reflection {
    font-size: 0.78rem;
    font-style: italic;
    opacity: 0.65;
  }
  .before-era {
    margin-left: auto;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.3;
    align-self: center;
  }
  .before-empty {
    font-style: italic;
    opacity: 0.3;
    margin: 2rem 0;
  }
  .before-back {
    margin-top: 3rem;
    font-size: 0.8rem;
    opacity: 0.4;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .before-back:hover { opacity: 0.7; }
</style>
