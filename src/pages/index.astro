---
// src/pages/index.astro
// Unified Conviction River — one feed, three lifecycle stages.
// Stage driven by ?stage= URL param (default: 'live'). Zero client state.
//
// Zone 1: BattingAverageHero — conviction score above the fold.
// Zone 2: RiverFilter pills + stage-appropriate cards below the fold.
//
// Stage routing (card polymorphism at the template layer — Mike §Key Design):
//   live       → DecayCards  (living posts)
//   endangered → EndangeredCards (urgency ring, decay bar)
//   graveyard  → TombstoneCards in paginated 2-col grid, 20/page
//   all        → all card types grouped
//
// Graveyard pagination: ?page=N, server-side, 20 items/page.
// GraveyardLedger always receives ALL entombed posts (aggregate, not sliced).
// API: GET /api/graveyard-page?page=N&pageSize=20
//
// Credits: Mike (arch §Unified Feed, §4.1–4.4 napkin plan), Tanya (UX §1 sitemap + §2–3 river)

export const prerender = false;

import { getCollection }      from 'astro:content';
import BaseLayout             from '../layouts/BaseLayout.astro';
import DecayCard              from '../components/DecayCard.astro';
import EndangeredCard         from '../components/EndangeredCard.astro';
import TombstoneCard          from '../components/TombstoneCard.astro';
import EndangeredBand         from '../components/EndangeredBand.astro';
import RiverFilter            from '../components/RiverFilter.astro';
import Pagination             from '../components/Pagination.astro';
import { allPostDisplayData } from '../lib/postMeta';
import { endangeredClientScript } from '../lib/endangered';
import { buildWebSiteSchema, serializeJsonLd } from '../lib/json-ld';
import { getStageCounts, filterByStage } from '../lib/river-data';
import type { StageFilter } from '../lib/river-data';
import { paginate, parsePage } from '../lib/pagination';
import { decayFactor } from '../lib/decay-engine';
import LandingHero      from '../components/LandingHero.astro';
import ConvictionStrip  from '../components/ConvictionStrip.astro';
import '../styles/river-filter.css';

// ─── Stage param ──────────────────────────────────────────────────────────────

const VALID_STAGES: StageFilter[] = ['live', 'endangered', 'graveyard', 'all'];

function parseStage(raw: string | null): StageFilter {
  return VALID_STAGES.includes(raw as StageFilter) ? (raw as StageFilter) : 'live';
}

const currentStage = parseStage(Astro.url.searchParams.get('stage'));

// ─── Data assembly ────────────────────────────────────────────────────────────

const GRAVEYARD_PAGE_SIZE = 20;

const posts        = await getCollection('blog');
const displayPosts = allPostDisplayData(posts);
const stageCounts  = getStageCounts(displayPosts);

// Pre-partition for 'all' stage rendering — template stays declarative
const allLive       = displayPosts.filter(p => !p.endangered && !p.entombed);
const allEndangered = displayPosts.filter(p => p.endangered);
const allEntombed   = displayPosts.filter(p => p.entombed);  // ALL — for GraveyardLedger aggregate

// ─── Graveyard pagination (only graveyard stage is paginated — Mike §4 napkin) ──

const graveTotalPages = Math.max(1, Math.ceil(allEntombed.length / GRAVEYARD_PAGE_SIZE));
const gravePage       = parsePage(Astro.url.searchParams.get('page'), graveTotalPages);
const { items: gravePagePosts, pagination: gravePagination } =
  paginate(allEntombed, gravePage, GRAVEYARD_PAGE_SIZE);

// ─── Stage posts (non-graveyard stages — no pagination needed yet) ────────────

const stagePosts = filterByStage(displayPosts, currentStage);

// ─── Empty-state copy per stage (Tanya §2 — first-class empty states) ─────────

const EMPTY_MSG: Record<StageFilter, string> = {
  live:       'Nothing sealing convictions yet.',
  endangered: 'All posts are healthy.',
  graveyard:  'No posts have died yet.',
  all:        'Nothing here yet.',
};

const STAGE_LABEL: Record<StageFilter, string> = {
  live:       'living bets',
  endangered: 'fading ideas',
  graveyard:  'the graveyard',
  all:        'all posts',
};

// ─── Hero demo post — synthetic decay state for LandingHero (no DB) ─────────
// maxDays=100, age=45 days → logarithmic formula yields ~0.68 (endangered).
// Client module (landing-hero.ts) continues the decay live via RAF.

const HERO_MAX_DAYS = 100;
const HERO_AGE_DAYS = 45;

function heroStageFor(f: number): string {
  if (f < 0.25) return 'fresh';
  if (f < 0.50) return 'fading';
  if (f < 0.75) return 'endangered';
  if (f < 0.97) return 'ghost';
  return 'fossil';
}

const heroPubDate = new Date(Date.now() - HERO_AGE_DAYS * 86_400_000).toISOString();
const heroDecay   = decayFactor(heroPubDate, HERO_MAX_DAYS);
const heroStage   = heroStageFor(heroDecay);

// ─── JSON-LD ──────────────────────────────────────────────────────────────────

const jsonLd = [serializeJsonLd(buildWebSiteSchema())];

// ─── Atmosphere — SSR-set based on active stage filter ────────────────────────
// Client-side watchRiverFilter() in atmosphere.ts updates this on pill click.
const STAGE_TO_ATMOSPHERE = {
  live:      'fresh',
  endangered:'endangered',
  graveyard: 'entombed',
  all:       'fresh',
} as const;
const atmosphere = STAGE_TO_ATMOSPHERE[currentStage];
---

<BaseLayout
  title="Persona Blog"
  description="Public predictions, sealed before publication. Batting average updated live."
  ogSlug="batting-average"
  jsonLd={jsonLd}
  atmosphere={atmosphere}
>
  <script set:html={endangeredClientScript()} />

  {/* Zone 1 — Living Landing Hero: demo post breathes + decays in the first viewport */}
  {/* Visitor feels posts are alive before reading a single word (Paul Kim / Tanya §4) */}
  <LandingHero decayProgress={heroDecay} stage={heroStage} />

  {/* ConvictionStrip — Zone 2B (bottom-of-feed) and OnboardingOverlay Step 3.       */}
  {/* Above-fold removed per Tanya §2: LandingHero owns Zone 1 alone.               */}

  {/* Zone 2 — Unified River Feed */}
  <main class="feed" id="bets" data-stage={currentStage}>

    <h2 class="feed-label">{STAGE_LABEL[currentStage]}</h2>

    <RiverFilter currentStage={currentStage} counts={stageCounts} />

    {/* live: DecayCards */}
    {currentStage === 'live' && stagePosts.length === 0 && (
      <p class="stage-empty">{EMPTY_MSG.live}</p>
    )}
    {currentStage === 'live' && stagePosts.map(post => <DecayCard post={post} />)}

    {/* endangered: EndangeredCards */}
    {currentStage === 'endangered' && stagePosts.length === 0 && (
      <p class="stage-empty">{EMPTY_MSG.endangered}</p>
    )}
    {currentStage === 'endangered' && stagePosts.map(post => <EndangeredCard post={post} />)}

    {/* graveyard: paginated TombstoneCards (Mike §4.1 — GraveyardLedger sees ALL) */}
    {currentStage === 'graveyard' && allEntombed.length === 0 && (
      <p class="stage-empty">{EMPTY_MSG.graveyard}</p>
    )}
    {currentStage === 'graveyard' && allEntombed.length > 0 && (
      <section class="tombs" aria-label={`Entombed posts — page ${gravePage} of ${graveTotalPages}`}>
        {gravePagePosts.map(post => <TombstoneCard post={post} />)}
      </section>
    )}
    {currentStage === 'graveyard' && (
      <Pagination meta={gravePagination} baseURL={Astro.url} />
    )}

    {/* all: group by type — live first, endangered second, graveyard last (no pagination) */}
    {currentStage === 'all' && stagePosts.length === 0 && (
      <p class="stage-empty">{EMPTY_MSG.all}</p>
    )}
    {currentStage === 'all' && allLive.map(post => <DecayCard post={post} />)}
    {currentStage === 'all' && allEndangered.map(post => <EndangeredCard post={post} />)}
    {currentStage === 'all' && allEntombed.length > 0 && (
      <section class="tombs" aria-label="Entombed posts">
        {allEntombed.map(post => <TombstoneCard post={post} />)}
      </section>
    )}

    {/* EndangeredBand: below live feed only, when endangered posts exist */}
    {currentStage === 'live' && allEndangered.length > 0 && (
      <EndangeredBand posts={allEndangered} />
    )}

    {/* Zone 2B — ConvictionStrip: batting average anchor at feed bottom  */}
    {/* Reinforces killer feature after visitor has scrolled through posts. */}
    {/* Paul Kim §1: comprehension reinforcement; Mike arch §Zone 2B.       */}
    <div class="feed-strip-anchor">
      <ConvictionStrip />
    </div>

  </main>
</BaseLayout>

<style>
  /* ── Feed section — Zone 2, below the hero ── */
  .feed {
    padding: 0 1.5rem 4rem;
    max-width: 40rem;
    margin: 0 auto;
    border-top: 1px solid var(--border-subtle);
    padding-top: 2.5rem;
  }

  /* "living bets" — whispered label (Tanya §2) */
  .feed-label {
    font-size: var(--text-2xs);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-ghost);
    margin: 0 0 1.5rem;
  }

  /* Empty state — dignity over blank screen (Tanya §2 — first-class empty) */
  .stage-empty {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--text-tertiary);
    padding: var(--space-8) 0;
    margin: 0;
    text-align: center;
  }

  /* ── ConvictionStrip anchor — Zone 2B separator ── */
  .feed-strip-anchor {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-subtle);
  }

  @media (max-width: 640px) {
    .feed { padding: 0 1rem 3rem; padding-top: 2rem; }
  }
</style>
