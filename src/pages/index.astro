---
// src/pages/index.astro
// Homepage "The Field" — one job: show living posts with conviction scores
// and death clocks. Decay is felt. The sealed bet is present on every card.
//
// NowLine + Murmurs extracted to /now (Tanya §3 — sitemap revision).
// GraveyardTeaser removed — graveyard is a nav link, not a homepage section.
// Band labels removed — DeathClock communicates age, no label needed (Tanya §8).
// FirstVisitHint removed — decay visuals are self-explanatory (Tanya §remove list).
//
// TODO: add pagination once post count grows beyond ~20
//
// Credits: Tanya (UX spec §8 — The Field layout), Mike (consolidation plan)

export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DecayCard from '../components/DecayCard.astro';
import EndangeredBand from '../components/EndangeredBand.astro';
import ConvictionMeter from '../components/ConvictionMeter.astro';
import { allPostDisplayData } from '../lib/postMeta';
import { groupIntoBands } from '../lib/timeBands';
import { endangeredClientScript } from '../lib/endangered';
import { computeBattingAverage } from '../lib/batting-average';
import { buildWebSiteSchema, serializeJsonLd } from '../lib/json-ld';

const posts        = await getCollection('blog');
const displayPosts = allPostDisplayData(posts);
const avg          = computeBattingAverage();

// Endangered posts surface in EndangeredBand — absence from main feed is the drama.
const endangered  = displayPosts.filter(p => p.endangered);
const feedPosts   = displayPosts.filter(p => !p.endangered);
const bands       = groupIntoBands(feedPosts);
const allEntombed = displayPosts.every(p => p.entombed);

// JSON-LD: WebSite schema — site-wide rich results (Mike §diagram).
const jsonLd = [serializeJsonLd(buildWebSiteSchema())];
---

<BaseLayout title="Persona Blog" jsonLd={jsonLd}>
  <script set:html={endangeredClientScript()} />
  <main class="feed">
    <ConvictionMeter avg={avg} />

    {allEntombed && (
      <div class="empty-state">
        <p>Everything has faded.</p>
        <a href="/graveyard" class="graveyard-cta">
          Visit the graveyard to bring something back
        </a>
      </div>
    )}

    {bands.now.posts.length > 0 && (
      <section class="band" data-band="now" aria-label={bands.now.hint}>
        {bands.now.posts.map(post => <DecayCard post={post} />)}
      </section>
    )}

    {bands.recent.posts.length > 0 && (
      <section class="band band--recent" data-band="recent" aria-label={bands.recent.hint}>
        {bands.recent.posts.map(post => <DecayCard post={post} />)}
      </section>
    )}

    {bands.archive.posts.length > 0 && (
      <section class="band band--archive" data-band="archive" aria-label={bands.archive.hint}>
        {bands.archive.posts.map(post => <DecayCard post={post} />)}
        {bands.archive.overflow > 0 && (
          <p class="archive-hint">
            + {bands.archive.overflow} older bets, still alive
          </p>
        )}
      </section>
    )}

    {endangered.length > 0 && <EndangeredBand posts={endangered} />}
  </main>
</BaseLayout>

<style>
  .feed {
    padding: 1.5rem 1.5rem 3rem;
    max-width: 40rem;
    margin: 0 auto;
  }

  /* Spacing between bands — gap is the visual separator, not labels */
  .band { margin-bottom: 3rem; }
  .band + .band { margin-top: 4rem; }

  .band--archive { opacity: 0.6; }

  .time-traveling .band { transition: opacity 0.3s ease; }
  .time-traveling .decay-card { will-change: transform; }

  .archive-hint {
    text-align: center;
    font-size: 0.65rem;
    opacity: 0.3;
    margin-top: 0.5rem;
    font-style: italic;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    opacity: 0.4;
  }
  .empty-state p {
    font-size: 0.9rem;
    font-style: italic;
    margin: 0 0 1rem;
  }

  .graveyard-cta {
    font-size: 0.75rem;
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.7;
    transition: opacity 200ms ease;
  }
  .graveyard-cta:hover { opacity: 1; }

  @media (max-width: 640px) {
    .feed { padding: 1.25rem 1rem 3rem; }
  }
</style>
