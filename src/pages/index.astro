---
// src/pages/index.astro
// Blog listing with decay-aware cards — the signature feature.
// Posts visually age: opacity, blur, saturation fade over time. Hover revives.
// Shows freshest active loop as a teaser hook into /pulse.
//
// TODO: add pagination once post count grows beyond ~20

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DecayCard from '../components/DecayCard.astro';
import PulseTeaser from '../components/PulseTeaser.astro';
import { allPostDisplayData } from '../lib/postMeta';
import { getPulseData, activeLoops } from '../lib/pulse';

const posts = await getCollection('blog');
const displayPosts = allPostDisplayData(posts);

const pulseData = await getPulseData();
const freshestLoop = activeLoops(pulseData)[0] ?? null;
---

<BaseLayout title="Persona Blog">
  <main class="feed">
    {freshestLoop && <PulseTeaser loop={freshestLoop} />}
    {displayPosts.map(post => (
      <DecayCard post={post} />
    ))}
  </main>
</BaseLayout>

<style>
  .feed {
    padding: 2rem 1rem;
    max-width: 44rem;
    margin: 0 auto;
  }
</style>
