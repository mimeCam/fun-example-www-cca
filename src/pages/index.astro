---
// src/pages/index.astro
// Homepage "The Field" — the single screen. Everything lives here.
// NowLine (hero + season) → decay cards in time bands → murmurs (wall fold) → graveyard link.
// Shadow depth is the primary age signal. Hover revives any card.
//
// First-Visit Clarity Engine: strip visual noise, amplify decay contrast,
// deliver one onboarding microinteraction in under 5 seconds.
//
// TODO: add pagination once post count grows beyond ~20
//
// Credits: Tanya (UX spec §3 — The Field layout), Mike (consolidation plan)

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DecayCard from '../components/DecayCard.astro';
import EndangeredBand from '../components/EndangeredBand.astro';
import FirstVisitHint from '../components/FirstVisitHint.astro';
import NowLine from '../components/NowLine.astro';
import Murmurs from '../components/Murmurs.astro';
import { allPostDisplayData } from '../lib/postMeta';
import { groupIntoBands } from '../lib/timeBands';
import { endangeredClientScript } from '../lib/endangered';
import { timeTravelScript } from '../lib/timeTravel';
import { timeTravelBandsScript } from '../lib/timeTravelBands';

const posts = await getCollection('blog');
const displayPosts = allPostDisplayData(posts);
const bands = groupIntoBands(displayPosts);
const endangered = displayPosts.filter(p => p.endangered);
const entombedCount = displayPosts.filter(p => p.entombed).length;
const allEntombed = displayPosts.every(p => p.entombed);
---

<BaseLayout title="Persona Blog">
  <script set:html={timeTravelScript()} />
  <script set:html={timeTravelBandsScript()} />
  <script set:html={endangeredClientScript()} />
  <main class="feed">

    <NowLine />

    {allEntombed && (
      <div class="empty-state">
        <p>Everything has faded.</p>
        <a href="/graveyard" class="graveyard-cta">
          Visit the graveyard to bring something back
        </a>
      </div>
    )}

    {bands.now.posts.length > 0 && (
      <section class="band" data-band="now" aria-label={bands.now.hint}>
        {bands.now.posts.map(post => <DecayCard post={post} />)}
      </section>
    )}

    {bands.recent.posts.length > 0 && (
      <section class="band band--recent" data-band="recent" aria-label={bands.recent.hint}>
        <h2 class="band-label">{bands.recent.label}</h2>
        {bands.recent.posts.map(post => <DecayCard post={post} />)}
      </section>
    )}

    {bands.archive.posts.length > 0 && (
      <section class="band band--archive" data-band="archive" aria-label={bands.archive.hint}>
        <h2 class="band-label">{bands.archive.label}</h2>
        {bands.archive.posts.map(post => <DecayCard post={post} />)}
        {bands.archive.overflow > 0 && (
          <p class="archive-hint">
            + {bands.archive.overflow} more fading into memory
          </p>
        )}
      </section>
    )}

    {endangered.length > 0 && <EndangeredBand posts={endangered} />}

    <Murmurs />

    {entombedCount > 0 && !allEntombed && (
      <a href="/graveyard" class="graveyard-link">
        {entombedCount} {entombedCount === 1 ? 'post' : 'posts'} lost to time &rarr;
      </a>
    )}

    <FirstVisitHint />
  </main>
</BaseLayout>

<style>
  .feed {
    padding: 1.5rem 1.5rem 3rem;
    max-width: 40rem;
    margin: 0 auto;
  }

  /* Generous spacing between bands — spacing IS the label */
  .band { margin-bottom: 3rem; }
  .band + .band { margin-top: 4rem; }

  .band-label {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.35;
    margin: 0 0 0.75rem;
    font-weight: 400;
  }

  .band--archive { opacity: 0.6; }

  .time-traveling .band { transition: opacity 0.3s ease; }
  .time-traveling .decay-card { will-change: transform; }

  .archive-hint {
    text-align: center;
    font-size: 0.65rem;
    opacity: 0.3;
    margin-top: 0.5rem;
    font-style: italic;
  }

  /* Graveyard link — subtle footer, not a nav item (Tanya §2) */
  .graveyard-link {
    display: block;
    text-align: center;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    opacity: 0.3;
    color: rgba(255, 255, 255, 0.30);
    text-decoration: none;
    margin-top: 2rem;
    padding-top: 1rem;
    transition: opacity 200ms ease;
  }
  .graveyard-link:hover {
    opacity: 0.55;
    color: rgba(255, 255, 255, 0.55);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    opacity: 0.4;
  }
  .empty-state p {
    font-size: 0.9rem;
    font-style: italic;
    margin: 0 0 1rem;
  }

  .graveyard-cta {
    font-size: 0.75rem;
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.7;
    transition: opacity 200ms ease;
  }
  .graveyard-cta:hover { opacity: 1; }

  @media (max-width: 640px) {
    .feed { padding: 1.25rem 1rem 3rem; }
  }
</style>
