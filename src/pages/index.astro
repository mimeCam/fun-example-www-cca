---
// src/pages/index.astro
// Homepage "Decay Field" — posts grouped into time bands.
// Three bands: Now (≤30d, full glow), Recent (1–6mo, partially decayed),
// Archive (6+mo, ghost previews). Shadow depth is the primary age signal.
// Hover revives any card.
//
// TODO: add pagination once post count grows beyond ~20

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DecayCard from '../components/DecayCard.astro';
import PulseTeaser from '../components/PulseTeaser.astro';
import { allPostDisplayData } from '../lib/postMeta';
import { getPulseData, activeLoops } from '../lib/pulse';
import { groupIntoBands } from '../lib/timeBands';
import { decayChoreographyScript } from '../lib/decayChoreography';
import { timeTravelScript } from '../lib/timeTravel';
import { timeTravelBandsScript } from '../lib/timeTravelBands';
import TimeTravelSlider from '../components/TimeTravelSlider.astro';
import FogOverlay from '../components/FogOverlay.astro';
import FirstVisitSpectacle from '../components/FirstVisitSpectacle.astro';

const posts = await getCollection('blog');
const displayPosts = allPostDisplayData(posts);
const bands = groupIntoBands(displayPosts);
const entombedCount = displayPosts.filter(p => p.entombed).length;
const allEntombed = displayPosts.every(p => p.entombed);

const pulseData = await getPulseData();
const freshestLoop = activeLoops(pulseData)[0] ?? null;
---

<BaseLayout title="Persona Blog">
  <script set:html={decayChoreographyScript()} />
  <script set:html={timeTravelScript()} />
  <script set:html={timeTravelBandsScript()} />
  <FogOverlay />
  <FirstVisitSpectacle />
  <main class="feed">
    <TimeTravelSlider />
    {freshestLoop && <PulseTeaser loop={freshestLoop} />}

    {allEntombed && (
      <div class="empty-state">
        <p>Everything has faded.</p>
        <a href="/graveyard" class="graveyard-cta">Visit the graveyard to bring something back</a>
      </div>
    )}

    {bands.now.posts.length > 0 && (
      <section class="band" data-band="now" aria-label={bands.now.hint}>
        {bands.now.posts.map(post => <DecayCard post={post} />)}
      </section>
    )}

    {bands.recent.posts.length > 0 && (
      <section class="band band--recent" data-band="recent" aria-label={bands.recent.hint}>
        <h2 class="band-label">{bands.recent.label}</h2>
        {bands.recent.posts.map(post => <DecayCard post={post} />)}
      </section>
    )}

    {bands.archive.posts.length > 0 && (
      <section class="band band--archive" data-band="archive" aria-label={bands.archive.hint}>
        <h2 class="band-label">{bands.archive.label}</h2>
        {bands.archive.posts.map(post => <DecayCard post={post} />)}
        {bands.archive.overflow > 0 && (
          <p class="archive-hint">
            + {bands.archive.overflow} more fading into memory
          </p>
        )}
      </section>
    )}

    {entombedCount > 0 && !allEntombed && (
      <a href="/graveyard" class="graveyard-link">
        {entombedCount} {entombedCount === 1 ? 'post' : 'posts'} lost to time
      </a>
    )}
  </main>
</BaseLayout>

<style>
  .feed {
    padding: 2rem 1rem;
    max-width: 44rem;
    margin: 0 auto;
  }
  .band { margin-bottom: 2rem; }
  .band-label {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.35;
    margin: 0 0 0.75rem;
    font-weight: 400;
  }
  .band--archive { opacity: 0.6; }
  .time-traveling .band { transition: opacity 0.3s ease; }
  .time-traveling .decay-card { will-change: transform; }
  .archive-hint {
    text-align: center;
    font-size: 0.65rem;
    opacity: 0.3;
    margin-top: 0.5rem;
    font-style: italic;
  }

  .graveyard-link {
    display: block;
    text-align: center;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    font-style: italic;
    opacity: 0.3;
    color: inherit;
    text-decoration: none;
    margin-top: 1.5rem;
    transition: opacity 200ms ease;
  }
  .graveyard-link:hover { opacity: 0.55; }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    opacity: 0.4;
  }
  .empty-state p {
    font-size: 0.9rem;
    font-style: italic;
    margin: 0 0 1rem;
  }
  .graveyard-cta {
    font-size: 0.75rem;
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.7;
    transition: opacity 200ms ease;
  }
  .graveyard-cta:hover { opacity: 1; }

  /* ── Spectacle overrides ─────────────────────────── */
  :global([data-spectacle-active]) .feed {
    pointer-events: none;
  }
  :global([data-spectacle-active]) .tt-bar {
    pointer-events: none;
  }
</style>
