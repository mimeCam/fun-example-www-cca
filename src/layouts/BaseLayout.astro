---
// src/layouts/BaseLayout.astro
// Root HTML shell — injects mood CSS vars into :root, slots page content.
// All pages extend this layout. No client-side JS. No framework islands.
//
// TODO: add <MoodBadge /> once src/components/MoodBadge.astro is built
// DONE: OG meta tags + canonical URL via SEOMeta component

import { resolveMood, moodToCSSVars, moodToCSSString, activeMoodIds, moodSwitchCSS } from '../lib/mood';
import { timeAmbientScript } from '../lib/timeAmbient';
import { seasonalScript } from '../lib/seasonal';
import { liveDecayScript } from '../lib/temporal';
import { moodCycleScript } from '../lib/moodCycle';
import moodConfig from '../data/mood.config.json';
import SEOMeta from '../components/SEOMeta.astro';
import { canonicalUrl } from '../config/seo.config';
import AmbientLayer from '../components/AmbientLayer.astro';
import SiteNav from '../components/SiteNav.astro';
import MoodPills from '../components/MoodPills.astro';
import GhostDrawer from '../components/GhostDrawer.astro';
import CelestialWitness from '../components/CelestialWitness.astro';
import Hearth from '../components/Hearth.astro';
import DriftButton from '../components/DriftButton.astro';
import DriftCard from '../components/DriftCard.astro';
import { filterCandidates, pickCandidate } from '../lib/drift';
import type { DriftCandidate } from '../lib/drift';
import wallData from '../data/wall.json';
import embersData from '../data/embers.json';
import '../styles/global.css';

const pillMoods = activeMoodIds();
const switchCSS = moodSwitchCSS();
const timeScript = timeAmbientScript();
const seasonScript = seasonalScript();
const decayScript = liveDecayScript();
const cycleScript = moodCycleScript();

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  publishedAt?: string;
}

const { title, description, type, publishedAt } = Astro.props;
const pageUrl = canonicalUrl(Astro.url.pathname);
const cssVars = moodToCSSVars(resolveMood(moodConfig.current_mood));
const cssString = moodToCSSString(cssVars);

// Drift: collect aged entries from wall + embers, pick one per day
const driftPool: DriftCandidate[] = [
  ...wallData.map(e => ({ ...e, source: 'wall' as const })),
  ...embersData.map(e => ({ ...e, source: 'ember' as const })),
];
const driftCandidates = filterCandidates(driftPool, 0.5, 30);
const driftPick = pickCandidate(driftCandidates);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOMeta title={title} description={description} url={pageUrl} type={type} publishedAt={publishedAt} />
    <style set:html={`:root {\n${cssString}\n}`} />
    <style set:html={`.mood-input, .ghost-input { display: none; }\n${switchCSS}\n#ghost-toggle:checked ~ [data-ghost-drawer] { display: block; }\n#ghost-toggle:checked ~ [data-mood-bar] .ghost-pill { opacity: 1; box-shadow: 0 0 10px rgba(212, 149, 106, 0.3); }`} />
    <script set:html={timeScript} />
    <script set:html={seasonScript} />
    <script set:html={decayScript} />
    <script set:html={cycleScript} />
    <style>
      :root {
        transition: --mood-from 60s ease, --mood-to 60s ease,
                    --mood-opacity 60s ease, --mood-speed 60s ease,
                    --mood-accent 60s ease;
      }
    </style>
  </head>
  <body>
    {pillMoods.map(id => (
      <input
        type="radio" name="mood" id={`mood-${id}`}
        class="mood-input"
        checked={id === moodConfig.current_mood}
      />
    ))}
    <input type="checkbox" id="ghost-toggle" class="ghost-input" />
    <AmbientLayer />
    <SiteNav />
    <MoodPills />
    <GhostDrawer />
    <slot />
    <Hearth />
    <CelestialWitness />
    <DriftButton />
    <DriftCard candidate={driftPick} />
  </body>
</html>
