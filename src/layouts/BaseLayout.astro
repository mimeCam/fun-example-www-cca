---
// src/layouts/BaseLayout.astro
// Root HTML shell — injects mood CSS vars into :root, slots page content.
// All pages extend this layout. Three client-side engines: decay, revival, presence.

import { simpleMoodCSSString } from '../lib/mood-simple';
import { sessionTokenScript } from '../lib/sessionToken';
import { decayEngineClientScript } from '../lib/decay-engine';
import { revivalEngineScript } from '../lib/revival-engine';
import { presenceUnifiedScript } from '../lib/presence-unified';
import { verdictCeremonyScript } from '../lib/verdict-ceremony';
import moodConfig from '../data/mood.config.json';
import SEOMeta from '../components/SEOMeta.astro';
import { canonicalUrl } from '../config/seo.config';
import SiteNav from '../components/SiteNav.astro';
import FrameSchedulerProvider from '../components/FrameSchedulerProvider.astro';
// Design system: tokens → motion → atmosphere → feature CSS layers
import '../styles/global.css';
import '../styles/atmosphere.css';
import '../styles/decay.css';
// Stage Identity System: 5 distinct worlds layered over continuous decay (Mike Koch §napkin-plan)
import '../styles/decay-stage-identity.css';
import '../styles/revival.css';
import '../styles/ambient.css';
import '../styles/endangered.css';
import '../styles/conviction-live.css';
// Conviction Record: single card consolidating 5 post-accountability zones (Mike §ConvictionRecord)
import '../styles/conviction-record.css';
// Revival Experience Unification (Mike Koch arch spec 2026-04-11)
import '../styles/keep-button.css';
import '../styles/revival-moment.css';
// Decay Pulse Orchestrator — heartbeat keyframes + --hb-* CSS var consumers
import '../styles/heartbeat.css';
// Stage Transition Orchestrator — crossing keyframes + ambient pulse (Mike §Orchestrator)
import '../styles/stage-transitions.css';

const cssString = simpleMoodCSSString(moodConfig.current_mood);
const sessionScript = sessionTokenScript();
const decayScript = decayEngineClientScript();
const revivalScript = revivalEngineScript();
const presenceScript = presenceUnifiedScript();
const ceremonyScript = verdictCeremonyScript();

type AtmosphereStage = 'fresh' | 'endangered' | 'entombed' | 'risen' | 'verdict';
type VerdictOutcomeAtm = 'correct' | 'wrong' | 'evolved' | undefined;

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  publishedAt?: string;
  ogSlug?: string;
  /** Direct OG image URL — takes precedence over ogSlug when set. */
  image?: string;
  /** Pre-serialized JSON-LD strings — passed through to SEOMeta for <script> injection. */
  jsonLd?: string | string[];
  /** Stage atmosphere painted on <body> via data-atmosphere. Defaults to 'fresh'. */
  atmosphere?: AtmosphereStage;
  /** Outcome tint for verdict pages. Only used when atmosphere='verdict'. */
  verdictOutcome?: VerdictOutcomeAtm;
  /** Marks the page as disputed — composable modifier on any atmosphere stage. */
  disputed?: boolean;
}

const {
  title, description, type, publishedAt, ogSlug, image, jsonLd,
  atmosphere = 'fresh',
  verdictOutcome,
  disputed = false,
} = Astro.props;
const pageUrl = canonicalUrl(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- IBM Plex Mono: numeric gravitas for batting %, revival counts, hash displays. -->
    <!-- Tanya §1 triage item #2: load this font before any visual work ships. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <SEOMeta title={title} description={description} url={pageUrl} type={type} publishedAt={publishedAt} ogSlug={ogSlug} image={image} jsonLd={jsonLd} />
    <meta name="decay-max-days" content="365" />
    <link rel="alternate" type="application/rss+xml" title="Persona Blog" href="/feed.xml" />
    <!-- Master RAF scheduler — must precede any island that registers animation tasks -->
    <FrameSchedulerProvider />
    <style set:html={`:root {\n${cssString}\n}`} />
    <script set:html={sessionScript} />
    <script set:html={decayScript} />
    <script set:html={revivalScript} />
    <script set:html={presenceScript} />
    <script set:html={ceremonyScript} />
    <style>
      :root {
        transition: --mood-from 60s ease, --mood-to 60s ease,
                    --mood-opacity 60s ease, --mood-speed 60s ease,
                    --mood-accent 60s ease;
      }
      /* Simple mood-tinted gradient replaces AmbientLayer.
         One gradient. Warm center. Dark edges. Done. */
      /* background-color defers to atmosphere.css via --atm-bg-primary token. */
      body {
        background-color: var(--atm-bg-primary);
        color: rgba(255, 255, 255, 0.88);
      }
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background: radial-gradient(
          ellipse at 50% 30%,
          color-mix(in oklch, var(--mood-accent) 4%, transparent) 0%,
          transparent 70%
        );
      }
      .site-footer {
        text-align: center;
        padding: 1.5rem 1rem 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
        margin-top: 3rem;
      }
      .site-footer__links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.25rem 1.25rem;
      }
      .site-footer__link {
        font-size: 0.7rem;
        color: rgba(255, 255, 255, 0.20);
        text-decoration: none;
        letter-spacing: 0.04em;
        transition: color 200ms ease;
      }
      .site-footer__link:hover { color: rgba(255, 255, 255, 0.50); }
    </style>
  </head>
  <body
    data-atmosphere={atmosphere}
    data-disputed={String(disputed)}
    data-verdict-outcome={verdictOutcome}
  >
    <SiteNav />
    <slot />
    <footer class="site-footer">
      <nav class="site-footer__links" aria-label="Footer navigation">
        <a href="/submit"      class="site-footer__link">✍ write</a>
        <a href="/now"         class="site-footer__link">now</a>
        <a href="/community"   class="site-footer__link">community ↗</a>
        <a href="/feed.xml"    class="site-footer__link">RSS</a>
        <a href="/api/docs"    class="site-footer__link">API</a>
      </nav>
    </footer>
    <!-- Atmosphere controller: re-applies on View Transitions, watches river filter -->
    <script>
      import '../lib/atmosphere';
    </script>
  </body>
</html>
