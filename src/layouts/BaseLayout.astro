---
// src/layouts/BaseLayout.astro
// Root HTML shell — injects mood CSS vars into :root, slots page content.
// All pages extend this layout. Minimal client-side JS islands.
//
// DONE: OG meta tags + canonical URL via SEOMeta component
// DONE: Pruned 6 overlay elements (MoodPills, GhostDrawer, DriftButton,
//       DriftCard, DroneToggle, DriftNav) per UX audit.
// DONE: Wired simple 3-mood system, removed old mood radio machinery.

import { simpleMoodCSSString } from '../lib/mood-simple';
import { sessionTokenScript } from '../lib/sessionToken';
import { firstBreathScript } from '../lib/firstBreath';
import FirstBreath from '../components/FirstBreath.astro';
import { timeAmbientScript } from '../lib/timeAmbient';
import { seasonalScript } from '../lib/seasonal';
import { liveDecayScript } from '../lib/live-decay';
import { shimmerScript } from '../lib/shimmer';
import { snapshotScript } from '../lib/snapshot';
import { revivalControllerScript } from '../lib/revivalController';
// Legacy imports removed: longPressRevive + reviveClient → revivalController
import { keepAliveScript } from '../lib/keepAlive';
import { onboardHintScript } from '../lib/onboardHint';
import { onboardProbeScript } from '../lib/onboardProbe';
import { bloomOrchestratorScript } from '../lib/bloomOrchestrator';
import { revivalRewardScript } from '../lib/revivalReward';
import { heartbeatClientScript } from '../lib/heartbeatClient';
import { heartbeatFxScript } from '../lib/heartbeatFx';
import { heartbeatBridgeScript } from '../lib/heartbeatBridge';
import { heartbeatPulseScript } from '../lib/heartbeatPulse';
import { sympatheticBloomScript } from '../lib/sympatheticBloom';
import { bloomGuardrailsScript } from '../lib/bloomGuardrails';
import { bloomHapticsScript } from '../lib/bloomHaptics';
import { bloomA11yScript } from '../lib/bloomA11y';
import { cascadeMobileScript } from '../lib/cascadeMobile';
import { revivalToastScript } from '../lib/revivalToast';
import { bloomOnArrivalScript } from '../lib/bloomOnArrival';
import { radialRingScript } from '../lib/radialRing';
import { radialRingA11yScript } from '../lib/radialRingA11y';
import { getAdaptiveConfig } from '../lib/adaptiveDecay';
import moodConfig from '../data/mood.config.json';
import SEOMeta from '../components/SEOMeta.astro';
import { canonicalUrl } from '../config/seo.config';
import AmbientLayer from '../components/AmbientLayer.astro';
import SiteNav from '../components/SiteNav.astro';
import CelestialWitness from '../components/CelestialWitness.astro';
import Hearth from '../components/Hearth.astro';
import QuietFollow from '../components/QuietFollow.astro';
import RevivalReward from '../components/RevivalReward.astro';
import HeartbeatPulse from '../components/HeartbeatPulse.astro';
import RadialRing from '../components/RadialRing.astro';
import '../styles/global.css';
import '../styles/decay.css';
import '../styles/choreography.css';
import '../styles/shimmer.css';
import '../styles/revival.css';
import '../styles/bloom.css';
import '../styles/hint.css';
import '../styles/timetravel.css';
import '../styles/reward.css';
import '../styles/heartbeat.css';
import '../styles/revival-toast.css';
import '../styles/radial-ring.css';
import '../styles/ring.css';
import '../styles/first-breath.css';

const cssString = simpleMoodCSSString(moodConfig.current_mood);
const sessionScript = sessionTokenScript();
const breathScript = firstBreathScript();
const timeScript = timeAmbientScript();
const seasonScript = seasonalScript();
const decayScript = liveDecayScript();
const shimScript = shimmerScript();
const snapScript = snapshotScript();
const revivalScript = revivalControllerScript();
const keepScript = keepAliveScript();
const probeScript = onboardProbeScript();
const hintScript = onboardHintScript();
const bloomScript = bloomOrchestratorScript();
const rewardScript = revivalRewardScript();
const heartbeatScript = heartbeatClientScript();
const heartbeatFx = heartbeatFxScript();
const heartbeatBridge = heartbeatBridgeScript();
const heartbeatPulseJs = heartbeatPulseScript();
const guardrailsJs = bloomGuardrailsScript();
const hapticsJs = bloomHapticsScript();
const a11yJs = bloomA11yScript();
const cascadeMobileJs = cascadeMobileScript();
const sympatheticScript = sympatheticBloomScript();
const toastScript = revivalToastScript();
const arrivalScript = bloomOnArrivalScript();
const radialRingJs  = radialRingScript();
const radialA11yJs  = radialRingA11yScript();

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  publishedAt?: string;
  ogSlug?: string;
}

const { title, description, type, publishedAt, ogSlug } = Astro.props;
const pageUrl = canonicalUrl(Astro.url.pathname);
const adaptiveMaxDays = getAdaptiveConfig()?.maxDays ?? 365;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOMeta title={title} description={description} url={pageUrl} type={type} publishedAt={publishedAt} ogSlug={ogSlug} />
    <meta name="decay-max-days" content={String(adaptiveMaxDays)} />
    <link rel="alternate" type="application/rss+xml" title="Persona Blog" href="/feed.xml" />
    <style set:html={`:root {\n${cssString}\n}`} />
    <script set:html={sessionScript} />
    <script set:html={breathScript} />
    <script set:html={timeScript} />
    <script set:html={seasonScript} />
    <script set:html={decayScript} />
    <script set:html={snapScript} />
    <script set:html={shimScript} />
    <script set:html={revivalScript} />
    <script set:html={keepScript} />
    <script set:html={probeScript} />
    <script set:html={hintScript} />
    <script set:html={guardrailsJs} />
    <script set:html={hapticsJs} />
    <script set:html={a11yJs} />
    <script set:html={bloomScript} />
    <script set:html={rewardScript} />
    <script set:html={heartbeatScript} />
    <script set:html={heartbeatFx} />
    <script set:html={heartbeatBridge} />
    <script set:html={heartbeatPulseJs} />
    <script set:html={sympatheticScript} />
    <script set:html={cascadeMobileJs} />
    <script set:html={toastScript} />
    <script set:html={arrivalScript} />
    <script set:html={radialRingJs} />
    <script set:html={radialA11yJs} />
    <style>
      :root {
        transition: --mood-from 60s ease, --mood-to 60s ease,
                    --mood-opacity 60s ease, --mood-speed 60s ease,
                    --mood-accent 60s ease;
      }
    </style>
  </head>
  <body>
    <FirstBreath />
    <AmbientLayer />
    <SiteNav />
    <RadialRing />
    <slot />
    <Hearth />
    <CelestialWitness />
    <RevivalReward />
    <HeartbeatPulse />
    <QuietFollow />
  </body>
</html>
