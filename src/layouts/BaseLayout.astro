---
// src/layouts/BaseLayout.astro
// Root HTML shell — injects mood CSS vars into :root, slots page content.
// All pages extend this layout. No client-side JS. No framework islands.
//
// TODO: add <MoodBadge /> once src/components/MoodBadge.astro is built
// TODO: add OG meta tags (og:title, og:description, og:image)
// TODO: add canonical URL via Astro.url

import { resolveMood, moodToCSSVars, moodToCSSString, activeMoodIds, moodSwitchCSS } from '../lib/mood';
import { timeAmbientScript } from '../lib/timeAmbient';
import { liveDecayScript } from '../lib/temporal';
import moodConfig from '../data/mood.config.json';
import AmbientLayer from '../components/AmbientLayer.astro';
import SiteNav from '../components/SiteNav.astro';
import MoodPills from '../components/MoodPills.astro';
import CelestialWitness from '../components/CelestialWitness.astro';
import '../styles/global.css';

const pillMoods = activeMoodIds();
const switchCSS = moodSwitchCSS();
const timeScript = timeAmbientScript();
const decayScript = liveDecayScript();

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A persona blog.' } = Astro.props;
const cssVars = moodToCSSVars(resolveMood(moodConfig.current_mood));
const cssString = moodToCSSString(cssVars);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style set:html={`:root {\n${cssString}\n}`} />
    <style set:html={`.mood-input { display: none; }\n${switchCSS}`} />
    <script set:html={timeScript} />
    <script set:html={decayScript} />
  </head>
  <body>
    {pillMoods.map(id => (
      <input
        type="radio" name="mood" id={`mood-${id}`}
        class="mood-input"
        checked={id === moodConfig.current_mood}
      />
    ))}
    <AmbientLayer />
    <SiteNav />
    <MoodPills />
    <slot />
    <CelestialWitness />
  </body>
</html>
