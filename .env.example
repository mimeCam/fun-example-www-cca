# ── Required ─────────────────────────────────────────────────────────────────

# Admin secret — used to derive the HMAC conviction seal and the admin session
# cookie token. Generate with: openssl rand -base64 24
ADMIN_SECRET=your-secret-here

# ── Optional — Conviction Anchor (tamper-evident external record) ─────────────
#
# Without this var the site works normally; conviction seals are stored locally.
# With it, every new seal and verdict is posted to a public GitHub Gist so the
# record is independently verifiable and can't be quietly deleted.
#
# PAT scope required: gist only.
# Create at: https://github.com/settings/tokens (classic) → check "gist".
# Never grant more than gist scope for this token.
GITHUB_PAT=ghp_your_gist_scoped_token_here
